{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/no-verify-guard.sh\"",
            "statusMessage": "Blocking git hook bypasses"
          },
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/lingui-commit-guard.sh\"",
            "statusMessage": "Validating Lingui catalogs before commit"
          }
        ]
      }
    ]
  }
}
