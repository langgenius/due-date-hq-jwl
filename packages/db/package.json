{
  "name": "@duedatehq/db",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./scoped": "./src/scoped.ts",
    "./audit-writer": "./src/audit-writer.ts",
    "./evidence-writer": "./src/evidence-writer.ts",
    "./reminder-linkage": "./src/reminder-linkage.ts",
    "./types": "./src/types.ts",
    "./schema/*": "./src/schema/*.ts"
  },
  "scripts": {
    "demo:generate": "node --experimental-strip-types seed/generate-demo.ts",
    "seed:demo": "node --experimental-strip-types seed/demo.ts",
    "test": "vp test"
  },
  "dependencies": {
    "@duedatehq/core": "workspace:*",
    "@duedatehq/ports": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@duedatehq/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "//": "Drizzle schema + scoped repo factory. `./schema/*` entries are intentionally exposed ONLY for migrations / seed / writers. Procedures must use `scoped()` (enforced by `vp check`)."
}
