{
  "name": "duedatehq",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci": "vp check && vp run -r test && vp run build",
    "ready": "vp check && vp run -r test && vp run build",
    "dev": "vp run -r dev",
    "build": "vp run @duedatehq/app#build && vp run @duedatehq/server#build && vp run @duedatehq/marketing#build",
    "test": "vp run -r test",
    "test:e2e": "playwright test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "design:lint": "npx --yes @google/design.md lint DESIGN.md",
    "format": "vp fmt --check",
    "format:fix": "vp fmt --write",
    "prepare": "vp config",
    "secrets:scan": "gitleaks detect --source . --no-git --redact",
    "check:deps": "node scripts/check-dep-direction.mjs",
    "check:tokens": "node scripts/check-token-discipline.mjs",
    "rules:check-sources": "tsx scripts/check-rule-sources.ts",
    "rules:concrete-draft-yield": "tsx scripts/rule-concrete-draft-yield.ts",
    "cost:report": "tsx scripts/cost-report.ts",
    "pulse:eval-recall": "tsx scripts/eval-alert-recall.ts",
    "social:x": "tsx scripts/social-x.ts",
    "rules:backfill-concrete-draft-source-text": "tsx scripts/backfill-concrete-draft-citations.ts",
    "pulse:email:smoke": "node scripts/pulse-inbound-email-smoke.mjs",
    "db:migrate:local": "pnpm --dir apps/server exec wrangler d1 migrations apply DB --local --config wrangler.toml",
    "db:migrate:remote": "pnpm --dir apps/server exec wrangler d1 migrations apply DB --remote --config wrangler.toml",
    "db:seed:demo": "pnpm --filter @duedatehq/db seed:demo",
    "cf:ensure-queues": "node scripts/ensure-cloudflare-queues.mjs apps/server/wrangler.toml",
    "deploy": "vp run workspace-deploy",
    "deploy:ci": "vp run workspace-publish"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.10.0"
}
