# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  apps/server/.dev.vars  (copy from this file; gitignored)                ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║  Scope · This file is read by `wrangler dev` ONLY, and injected into     ║
# ║  the Worker's `env` object at runtime. Cloudflare bindings (D1, KV, R2,  ║
# ║  Vectorize, Queues, Assets) are declared in wrangler.toml, not here —    ║
# ║  this file is reserved for RUNTIME SECRETS and per-env config.           ║
# ║                                                                          ║
# ║  ⚠ NOT read in staging/production. Use `wrangler secret put <NAME>`      ║
# ║    (or Cloudflare Dashboard → Worker → Settings → Variables).            ║
# ║                                                                          ║
# ║  ⚠ NOT the place for CLI credentials (CLOUDFLARE_ACCOUNT_ID,             ║
# ║    CLOUDFLARE_API_TOKEN, NODE_ENV). Those live in root `.env`.           ║
# ║                                                                          ║
# ║  ⚠ NOT the place for browser-facing vars. Those go to                    ║
# ║    apps/app/.env.local with a `VITE_` prefix.                            ║
# ║                                                                          ║
# ║  Schema validated by apps/server/src/env.ts (`validateServerEnv`).       ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ═════════════════════════════════════════════════════════════════════════════
# [Required] App · environment + URLs
# ═════════════════════════════════════════════════════════════════════════════
# ENV       · development | staging | production
# AUTH_URL  · origin of THIS Worker (where /api/auth/* and public API feeds are served)
# APP_URL   · origin of the browser-facing SPA; used for
#              (a) Better Auth trustedOrigins whitelist
#              (b) absolute links inside outbound emails
#             In dev the SPA runs on Vite (5173); in prod it's the Worker itself.
ENV=development
AUTH_URL=http://localhost:8787
APP_URL=http://localhost:5173

# ═════════════════════════════════════════════════════════════════════════════
# [Required] Better Auth · session secret + Google OAuth provider
# ═════════════════════════════════════════════════════════════════════════════
# AUTH_SECRET · `openssl rand -base64 32`   (min 32 chars — validated by Zod)
# Google Console → Credentials → OAuth 2.0 Client IDs
#   Redirect URI must include: {AUTH_URL}/api/auth/callback/google
#   Authorized JavaScript origins must include APP_URL for Google One Tap.
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional Microsoft Entra ID OAuth for Outlook / Microsoft 365 firms.
# Azure Portal → App registrations → Authentication
# Redirect URI must include: {AUTH_URL}/api/auth/oauth2/callback/microsoft-entra-id
# MICROSOFT_TENANT_ID may be "common" for multi-tenant sign-in.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ═════════════════════════════════════════════════════════════════════════════
# [Optional until email send] Mail · Resend
# ═════════════════════════════════════════════════════════════════════════════
# RESEND_API_KEY may be blank for login + organization bootstrap. Auth email
# sending still requires it outside development; development prints to console.
# RESEND_WEBHOOK_SECRET is required only when enabling delivery callbacks at
# /api/webhook/resend. Staging sends from noreply@langgenius.app, so the
# langgenius.app sending domain must be verified in Resend before real sends.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=noreply@langgenius.app

# ═════════════════════════════════════════════════════════════════════════════
# [Optional] Pulse · Browserless fetcher for sources blocked from Cloudflare egress
# ═════════════════════════════════════════════════════════════════════════════
# Browserless hosted REST API:
#   PULSE_BROWSERLESS_URL=https://production-sfo.browserless.io/content
# PULSE_BROWSERLESS_TOKEN is local-only here. In staging/production use:
#   wrangler secret put PULSE_BROWSERLESS_TOKEN
# PULSE_BROWSERLESS_SOURCE_IDS can override source fetchers without code changes.
# The current code also marks fl.dor.tips, wa.dor.news, and wa.dor.whats_new as
# Browserless-backed by default when PULSE_BROWSERLESS_URL is configured.
PULSE_BROWSERLESS_URL=
PULSE_BROWSERLESS_TOKEN=
PULSE_BROWSERLESS_SOURCE_IDS=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional until billing test] Stripe · Better Auth subscription checkout
# ═════════════════════════════════════════════════════════════════════════════
# Local webhook test:
#   stripe listen --forward-to localhost:8787/api/auth/stripe/webhook
# Then copy the printed whsec_* value into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Required for self-serve checkout enablement.
# Yearly recurring prices should match the annual offers:
# Solo 37200 cents/year, Pro 75600 cents/year, Team 142800 cents/year.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Optional self-serve tiers. Checkout is available when the matching price exists.
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
# Optional for sales-assisted Enterprise subscriptions.
STRIPE_PRICE_FIRM_MONTHLY=
STRIPE_PRICE_FIRM_YEARLY=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional] AI SDK via Cloudflare AI Gateway
# ═════════════════════════════════════════════════════════════════════════════
# Default local/staging path uses Cloudflare AI Gateway Provider Native for
# OpenRouter:
#   DueDateHQ → Cloudflare AI Gateway ({account}/{slug}) → OpenRouter.
#
# Fill AI_GATEWAY_PROVIDER_API_KEY with your OpenRouter token. This is the only
# required secret for the OpenRouter path. Do not put an OpenAI key here.
#
# Single model across all tiers (plan-based routing retired). Reasoning effort is tiered:
# quality tasks (pulse/rule/brief/insights) run reasoning.effort=high for accuracy; fast tasks
# (CSV mapper/normalizer/readiness) run low to stay fast & cheap on the import path. Set an
# effort var empty to disable reasoning options (e.g. if AI_GATEWAY_PROVIDER is not openrouter).
# Example model: google/gemini-3.5-flash
#
# Leave AI_GATEWAY_API_KEY empty unless you explicitly enable Cloudflare
# Authenticated Gateway or switch AI_GATEWAY_PROVIDER away from openrouter.
AI_GATEWAY_ACCOUNT_ID=
AI_GATEWAY_SLUG=duedatehq
AI_GATEWAY_PROVIDER=openrouter
AI_GATEWAY_PROVIDER_API_KEY=
AI_GATEWAY_MODEL_FAST_JSON=google/gemini-3.5-flash
AI_GATEWAY_MODEL_QUALITY_JSON=google/gemini-3.5-flash
AI_GATEWAY_MODEL_REASONING=google/gemini-3.5-flash
AI_GATEWAY_QUALITY_REASONING_EFFORT=high
AI_GATEWAY_FAST_REASONING_EFFORT=low
AI_GATEWAY_API_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional · Phase 1+] Web Push
# ═════════════════════════════════════════════════════════════════════════════
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@duedatehq.com

# ═════════════════════════════════════════════════════════════════════════════
# [Optional · Local dev only] E2E seed + demo-account access
# ═════════════════════════════════════════════════════════════════════════════
# Gates the /api/e2e/* routes — demo-login, demo-accounts, seed/reset, etc.
# In staging/production these routes always return 404 regardless of this var.
# In local dev, set this to any string ≥ 16 chars to unlock:
#
#   GET /api/e2e/demo-login?account=brightline-owner&redirectTo=/
#     → drops a session for a `mock_user_*` user and returns a 200 handoff
#       page that sends the browser to /. JSON/API callers receive 200 JSON.
#       Once signed in, the sidebar user menu reveals a Switch-account submenu
#       listing every seeded demo identity (Brightline firm + plan-tier
#       singletons: solo, pro, team).
#
# The endpoint self-heals the minimum demo identity rows required to sign in.
# Seed the full product demo data with `pnpm db:seed:demo` (runs mock/demo.sql
# via packages/db/seed/demo.ts). The full demo-account list is the source-of-
# truth in apps/server/src/routes/e2e.ts → `DEMO_ACCOUNTS`.
E2E_SEED_TOKEN=

# ═════════════════════════════════════════════════════════════════════════════
# [Optional] Observability
# ═════════════════════════════════════════════════════════════════════════════
SENTRY_DSN=
POSTHOG_KEY=
