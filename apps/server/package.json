{
  "name": "@duedatehq/server",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "dev": "node -e \"require('node:fs').mkdirSync('../app/dist',{recursive:true})\" && wrangler dev --local",
    "dev:fullstack": "pnpm --filter @duedatehq/app run build && wrangler dev --local",
    "build": "wrangler deploy --dry-run --outdir=dist --env=\"\"",
    "deploy": "wrangler deploy --env=\"\" ${WRANGLER_SECRETS_FILE:+--secrets-file \"$WRANGLER_SECRETS_FILE\"}",
    "test": "vp test"
  },
  "dependencies": {
    "@duedatehq/ai": "workspace:*",
    "@duedatehq/auth": "workspace:*",
    "@duedatehq/contracts": "workspace:*",
    "@duedatehq/core": "workspace:*",
    "@duedatehq/db": "workspace:*",
    "@duedatehq/i18n": "workspace:*",
    "@duedatehq/ingest": "workspace:*",
    "@duedatehq/ports": "workspace:*",
    "@orpc/contract": "catalog:",
    "@orpc/server": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "fflate": "catalog:",
    "hono": "catalog:",
    "pdf-lib": "catalog:",
    "pdfjs-dist": "catalog:",
    "postal-mime": "catalog:",
    "resend": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@duedatehq/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "//": "Cloudflare Worker for the SaaS app domain. Wrangler drives dev/build/deploy; `vp test` runs Vitest in the workers pool."
}
