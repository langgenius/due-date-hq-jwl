# apps/marketing — Astro build-time env. PUBLIC_* is exposed to the client.
# Copy to .env.local for local dev, or set in the deploy/build environment.

# App entry URL for CTAs (defaults to https://app.duedatehq.com in prod).
PUBLIC_APP_URL=

# Amplitude Browser SDK key (project 827681). Shared with apps/app so the
# landing → signup → activation funnel is one funnel. PRODUCTION BUILDS ONLY —
# dev/preview never report. Unset → silent no-op.
PUBLIC_AMPLITUDE_API_KEY=

# Cloudflare Web Analytics is enabled via zone-level auto-injection in the
# Cloudflare dashboard — no beacon token or code needed here.
