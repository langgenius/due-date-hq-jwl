# Cloudflare Static Assets otherwise canonicalizes Astro's file-format HTML
# with temporary 307 responses. Historical .html URLs are permanently moved
# to the extensionless public URLs used by canonical tags and the sitemap.
/index.html / 301
/zh-CN/index.html /zh-CN 301
/:page.html /:page 301
/:section/:page.html /:section/:page 301
/:locale/:section/:page.html /:locale/:section/:page 301
