---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import GeoResourcePage from '../../components/GeoResourcePage.astro'
import Footer from '../../components/home/Footer.astro'
import en from '../../i18n/en'
import type { GuidePageCopy } from '../../i18n/types'
import { getCtaHref } from '../../lib/app-url'
import { getResourceCtaHrefs, getRuleReferencePages } from '../../lib/seo-content'
import { resourceStructuredData } from '../../lib/structured-data'

export function getStaticPaths() {
  return getRuleReferencePages('en').map((rule) => ({
    params: { rule: rule.slug },
    props: { page: rule },
  }))
}

interface Props {
  page: GuidePageCopy
}

const t = en
const { page } = Astro.props
const pathname = `/rules/${page.slug}`
const ctaHref = getCtaHref()
const { primaryHref, secondaryHref } = getResourceCtaHrefs(page.slug, 'en')
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  ogType="article"
  structuredData={resourceStructuredData(t, page, 'en', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} />
  <GeoResourcePage
    page={page}
    primaryHref={primaryHref}
    secondaryHref={secondaryHref}
    locale="en"
    back={{ href: '/rules', label: 'Rule library' }}
  />
  <Footer />
</BaseLayout>
