---
/**
 * Live homepage — the production-v2 redesign, built from components/home/* on the
 * --m-* marketing token tier. The previous homepage is preserved verbatim at
 * /legacy (apps/marketing/src/pages/legacy.astro), noindex.
 *
 * English inline copy for now; i18n (中文) wrapping + the remaining depth sections
 * (See-it-work, Surfaces, Trust, Security, FAQ) land in later phases.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import ScrollRail from '../components/home/ScrollRail.astro'
import Hero from '../components/home/Hero.astro'
import Villain from '../components/home/Villain.astro'
import Notice from '../components/home/Notice.astro'
import Sources from '../components/home/Sources.astro'
import Compare from '../components/home/Compare.astro'
import Surfaces from '../components/home/Surfaces.astro'
import Security from '../components/home/Security.astro'
import Faq from '../components/home/Faq.astro'
import Close from '../components/home/Close.astro'
import Footer from '../components/home/Footer.astro'
import ScrollMotion from '../components/home/ScrollMotion.astro'
import en from '../i18n/en'
import { getCtaHref, getAppHref } from '../lib/app-url'
import { homeStructuredData } from '../lib/structured-data'

const ctaHref = getCtaHref()
const signInHref = getAppHref('/login')
const t = en
---

<BaseLayout
  lang="en"
  pathname="/"
  title="DueDateHQ — a tax deadline just moved. Do you know who it hits?"
  description="DueDateHQ watches the IRS and all 50 states around the clock. The moment a deadline moves, you know exactly which of your clients it affects — with the official source on every date."
  ogImage={t.meta.ogImage}
  structuredData={homeStructuredData(t, 'en')}
>
  <TopNav ctaHref={ctaHref} signInHref={signInHref} />
  <ScrollRail />
  <main>
    <Hero ctaHref={ctaHref} workflowAnchor="/how-it-works" />
    <Villain />
    <Surfaces />
    <Notice />
    <Sources />
    <Compare />
    <Security />
    <Faq />
    <Close ctaHref={ctaHref} />
  </main>
  <Footer />
  <ScrollMotion />
</BaseLayout>
