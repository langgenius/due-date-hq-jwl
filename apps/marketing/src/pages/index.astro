---
/**
 * Live homepage — the production-v2 redesign, built from components/home/* on the
 * --m-* marketing token tier.
 *
 * All home sections ship in components/home/*; EN + zh-CN kept in parity.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import ScrollRail from '../components/home/ScrollRail.astro'
import Hero from '../components/home/Hero.astro'
import Villain from '../components/home/Villain.astro'
import Creed from '../components/home/Creed.astro'
import Notice from '../components/home/Notice.astro'
import Sources from '../components/home/Sources.astro'
import Gap from '../components/home/Gap.astro'
import Compare from '../components/home/Compare.astro'
import Surfaces from '../components/home/Surfaces.astro'
import Security from '../components/home/Security.astro'
import Faq from '../components/home/Faq.astro'
import Close from '../components/home/Close.astro'
import Footer from '../components/home/Footer.astro'
import ScrollMotion from '../components/home/ScrollMotion.astro'
import en from '../i18n/en'
import { getStartedHref, getAppHref, getConciergeHref } from '../lib/app-url'
import { homeStructuredData } from '../lib/structured-data'

const ctaHref = getStartedHref()
const conciergeHref = getConciergeHref()
const signInHref = getAppHref('/login')
const t = en
---

<BaseLayout
  lang="en"
  pathname="/"
  title="DueDateHQ — catching every rule change. Naming every affected client."
  description="DueDateHQ watches the IRS, all 50 states, and FEMA around the clock. When a rule changes, know exactly which clients are hit — official source on every date."
  ogImage={t.meta.ogImage}
  structuredData={homeStructuredData(t, 'en')}
>
  <TopNav ctaHref={ctaHref} signInHref={signInHref} current="home" />
  <ScrollRail />
  <main>
    <Hero ctaHref={ctaHref} conciergeHref={conciergeHref} workflowAnchor="/how-it-works" />
    <Villain />
    <Surfaces />
    <Creed />
    <Notice />
    <Sources />
    <Gap />
    <Compare />
    <Security />
    <Faq />
    <Close ctaHref={ctaHref} conciergeHref={conciergeHref} />
  </main>
  <Footer />
  <ScrollMotion />
</BaseLayout>
