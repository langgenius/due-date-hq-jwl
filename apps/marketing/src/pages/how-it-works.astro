---
/**
 * /how-it-works — the flagship product walkthrough. NOT a re-stack of the
 * landing's sections: a page-specific, in-depth tour. A bold display-serif hero
 * grounded by one live worked example, then THE LOOP expanded to four stages
 * (Watch · Match · Rank · Apply) in LoopDeep, then a per-surface deep dive
 * (Alerts · Coverage · Worklist · Apply & audit) in SurfaceDeep — each surface
 * its own section with a real product mini-UI and a CPA-facing rationale — and
 * the shared bold finale. Nav stays current="how"; #how/#work anchors preserved
 * for the landing's Surfaces "See it" links.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import LoopDeep from '../components/home/LoopDeep.astro'
import SurfaceDeep from '../components/home/SurfaceDeep.astro'
import Close from '../components/home/Close.astro'
import Footer from '../components/home/Footer.astro'
import ScrollMotion from '../components/home/ScrollMotion.astro'
import en from '../i18n/en'
import { getStartedHref } from '../lib/app-url'
import { howItWorksStructuredData } from '../lib/structured-data'

const t = en
const ctaHref = getStartedHref()
const pathname = '/how-it-works'
const title = 'How DueDateHQ works — from a deadline change to the clients it affects'
const description =
  'The full product walkthrough: DueDateHQ watches official IRS, state, and FEMA sources, matches each change to your clients, ranks your week by risk, and applies the fix with a source on every date.'
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={title}
  description={description}
  ogImage={t.meta.ogImage}
  structuredData={howItWorksStructuredData(t, 'en', title, description)}
>
  <TopNav pageMode ctaHref={ctaHref} current="how" />
  <main>
    <section class="m-section m-page-hero how-hero" id="hero">
      <p class="m-eyebrow">Product walkthrough</p>
      <h1 class="m-page-title how-hero__title">
        From a deadline change to the clients it <span class="ital">affects.</span>
      </h1>
      <p class="m-page-lead how-hero__lead">
        DueDateHQ runs one loop, around the clock: it watches the official sources, reads what a
        change actually moved, ranks your week by who's most at risk, and applies the new date with
        a source on every line. Here is the whole thing, surface by surface.
      </p>

      <!-- one live worked example — the loop run once, end to end. The hero's
           visual anchor: a four-stage flow, numbered, with the outcome lit. -->
      <div class="how-hero__ex" aria-label="One worked example, end to end">
        <div class="how-hero__ex-head">
          <span class="how-hero__ex-lead">One change, start to finish</span>
          <span class="how-hero__ex-meta">the loop, once</span>
        </div>
        <ol class="how-flow">
          <li class="fstage">
            <div class="fstage__top">
              <span class="fstage__n">01</span>
              <span class="fstage__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" /></svg>
              </span>
            </div>
            <span class="fstage__k">Watch</span>
            <span class="fstage__v">IRS posts a disaster postponement</span>
          </li>
          <li class="fstage__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </li>
          <li class="fstage">
            <div class="fstage__top">
              <span class="fstage__n">02</span>
              <span class="fstage__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8.5" /><circle cx="12" cy="12" r="3.4" /></svg>
              </span>
            </div>
            <span class="fstage__k">Match</span>
            <span class="fstage__v">8 of your clients hit</span>
          </li>
          <li class="fstage__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </li>
          <li class="fstage">
            <div class="fstage__top">
              <span class="fstage__n">03</span>
              <span class="fstage__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 7h14M7 12h10M10 17h4" /></svg>
              </span>
            </div>
            <span class="fstage__k">Rank</span>
            <span class="fstage__v">2 are already late</span>
          </li>
          <li class="fstage__arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </li>
          <li class="fstage fstage--apply">
            <div class="fstage__top">
              <span class="fstage__n">04</span>
              <span class="fstage__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4.5 13.5H11l-1 8.5 8.5-11.5H12z" /></svg>
              </span>
            </div>
            <span class="fstage__k">Apply</span>
            <span class="fstage__v"><s>Apr 15</s> → <b>Nov 3</b>, sourced &amp; logged</span>
          </li>
        </ol>
      </div>
    </section>

    <LoopDeep />
    <SurfaceDeep />
    <Close ctaHref={ctaHref} />
  </main>
  <Footer />
  <ScrollMotion />
</BaseLayout>

<style>
  /* page hero — display serif at the shared subpage title size (one tier below
     the home hero, consistent with /pricing + /state-coverage). Padding comes
     from the shared .m-page-hero on the section — no per-page override. */
  /* hero title + lead come from the shared kit (.m-page-title / .m-page-lead);
     only the italic accent span is page-specific */
  .how-hero__title .ital {
    font-style: italic;
    letter-spacing: 0.002em;
  }

  /* worked-example flow — the hero's visual anchor: four numbered stages, the
     outcome lit in accent + cyan, on a soft tinted panel */
  .how-hero__ex {
    margin-top: clamp(28px, 3vw, 40px);
    padding: clamp(18px, 2vw, 24px);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    background:
      radial-gradient(130% 150% at 0% 0%, var(--m-accent-tint), transparent 60%),
      var(--m-surface);
  }
  .how-hero__ex-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }
  .how-hero__ex-lead {
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .how-hero__ex-meta {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-accent);
  }
  .how-flow {
    display: flex;
    align-items: stretch;
    gap: 6px;
    list-style: none;
    padding: 0;
  }
  .fstage {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 14px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transition:
      transform var(--m-dur-fast) var(--m-ease),
      border-color var(--m-dur-fast) var(--m-ease);
  }
  .fstage:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--m-accent) 30%, transparent);
  }
  .fstage__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .fstage__n {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-lg);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    color: color-mix(in srgb, var(--m-accent) 38%, transparent);
  }
  .fstage__icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .fstage__icon svg {
    width: 16px;
    height: 16px;
  }
  .fstage__k {
    font-size: var(--m-text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .fstage__v {
    font-size: var(--m-text-xs);
    line-height: 1.4;
    color: var(--m-muted);
  }
  /* the lit outcome — accent frame + tint, cyan number, the loop's payoff */
  .fstage--apply {
    background: var(--m-accent-tint);
    border-color: color-mix(in srgb, var(--m-accent) 28%, transparent);
  }
  .fstage--apply .fstage__n {
    color: var(--m-accent);
  }
  .fstage--apply .fstage__icon {
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--m-accent),
      color-mix(in srgb, var(--m-accent) 45%, var(--m-cyan))
    );
  }
  .fstage--apply .fstage__v s {
    color: var(--m-faint);
  }
  .fstage--apply .fstage__v b {
    font-weight: 600;
    color: var(--m-accent);
  }
  .fstage__arrow {
    display: flex;
    align-items: center;
    flex: none;
    color: color-mix(in srgb, var(--m-accent) 45%, transparent);
  }
  .fstage__arrow svg {
    width: 18px;
    height: 18px;
  }
  @media (max-width: 760px) {
    .how-flow {
      flex-direction: column;
      gap: 8px;
    }
    .fstage__arrow {
      transform: rotate(90deg);
      align-self: center;
    }
  }
</style>
