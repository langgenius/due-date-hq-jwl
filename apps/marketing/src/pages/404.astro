---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/TopNav.astro'
import Footer from '../components/Footer.astro'
import en from '../i18n/en'
import { getCtaHref } from '../lib/app-url'

const ctaHref = getCtaHref()
const t = en
const nav = {
  ...t.nav,
  links: t.nav.links.map((link) =>
    Object.assign({}, link, {
      href: link.href.startsWith('#') ? `/${link.href}` : link.href,
    }),
  ),
}
const routes = t.notFound.routes.map((route) =>
  Object.assign({}, route, { href: route.href === 'app' ? ctaHref : route.href }),
)
---

<BaseLayout
  lang="en"
  pathname="/404"
  title={t.notFound.meta.title}
  description={t.notFound.meta.description}
  ogImage={t.notFound.meta.ogImage}
  noindex
>
  <TopNav t={nav} ctaHref={ctaHref} />
  <main class="bg-bg-canvas">
    <section
      class="mx-auto grid min-h-[calc(100vh-72px)] max-w-[1440px] grid-cols-12 items-center gap-12 px-6 py-20 sm:px-10 lg:px-20 lg:py-28"
    >
      <div class="col-span-12 lg:col-span-7">
        <p class="font-mono text-[12px] tracking-[0.18em] text-text-muted">
          {t.notFound.eyebrow}
        </p>
        <h1
          class="mt-5 max-w-[760px] text-[44px] leading-[0.98] font-semibold tracking-normal text-text-primary sm:text-[54px]"
        >
          {t.notFound.title}
        </h1>
        <p class="mt-6 max-w-[680px] text-[17px] leading-8 text-text-secondary">
          {t.notFound.body}
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a
            href="/"
            class="inline-flex h-10 items-center justify-center rounded-md bg-accent-default px-4 text-[13px] font-medium text-primary-foreground outline-none transition-colors hover:bg-accent-hover focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          >
            {t.notFound.primaryCta}
          </a>
          <a
            href="/pricing"
            class="inline-flex h-10 items-center justify-center rounded-md border border-border-default bg-bg-elevated px-4 text-[13px] font-medium text-text-primary outline-none transition-colors hover:bg-bg-subtle focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          >
            {t.notFound.secondaryCta}
          </a>
        </div>
      </div>

      <aside class="col-span-12 lg:col-span-5">
        <div class="border border-border-default bg-bg-panel p-6">
          <div class="flex items-center justify-between border-b border-border-subtle pb-5">
            <span class="font-mono text-[11px] tracking-[0.16em] text-text-muted">
              {t.notFound.statusLabel}
            </span>
            <span class="font-mono text-[12px] text-text-accent">404</span>
          </div>
          <div class="py-8">
            <p class="text-[20px] font-semibold text-text-primary">{t.notFound.statusValue}</p>
            <p class="mt-2 font-mono text-[12px] tracking-[0.12em] text-text-muted">
              {t.notFound.routesLabel}
            </p>
          </div>
          <ul class="grid gap-2">
            {
              routes.map((route) => (
                <li>
                  <a
                    href={route.href}
                    class="flex h-11 items-center justify-between border border-border-subtle bg-bg-canvas px-3 text-[13px] text-text-secondary outline-none transition-colors hover:border-border-default hover:text-text-primary focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
                  >
                    <span>{route.label}</span>
                    <span aria-hidden="true">→</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>
    </section>
  </main>
  <Footer t={t.footer} enHref="/" zhHref="/zh-CN" currentLocale="en" />
</BaseLayout>
