---
/**
 * Homepage redesign preview (noindex). New production-v2-style components live in
 * components/home/ and are assembled here; this route gets swapped into index.astro
 * only once the whole page is complete and approved. Keeps the live homepage intact.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import Hero from '../components/home/Hero.astro'
import Villain from '../components/home/Villain.astro'
import HowItWorks from '../components/home/HowItWorks.astro'
import Notice from '../components/home/Notice.astro'
import Sources from '../components/home/Sources.astro'
import Close from '../components/home/Close.astro'
import Footer from '../components/home/Footer.astro'
import { getCtaHref, getAppHref } from '../lib/app-url'

const ctaHref = getCtaHref()
const signInHref = getAppHref('/login')
---

<BaseLayout
  lang="en"
  pathname="/preview"
  title="DueDateHQ — homepage preview"
  description="Homepage redesign preview."
  ogImage="/og/home.en.png"
  noindex={true}
>
  <TopNav ctaHref={ctaHref} signInHref={signInHref} />
  <main>
    <Hero ctaHref={ctaHref} workflowAnchor="#how" />
    <Villain />
    <HowItWorks />
    <Notice />
    <Sources />
    <Close ctaHref={ctaHref} />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  /* the new homepage sits on a cold light gray, not the warm canvas */
  body {
    background: var(--m-canvas);
  }
</style>
