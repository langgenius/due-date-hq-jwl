---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import TrustPage from '../components/TrustPage.astro'
import Footer from '../components/home/Footer.astro'
import en from '../i18n/en'
import { getStartedHref } from '../lib/app-url'
import { trustPageStructuredData } from '../lib/structured-data'
import { trustPages, type TrustPageCopy } from '../lib/trust-pages'

export function getStaticPaths() {
  return trustPages.en.map((page) => ({
    params: { trustPage: page.slug },
    props: { page },
  }))
}

interface Props {
  page: TrustPageCopy
}

const t = en
const { page } = Astro.props
const pathname = `/${page.slug}`
const ctaHref = getStartedHref()
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={trustPageStructuredData(t, page, 'en', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} current={page.slug === 'security' ? 'security' : undefined} />
  <TrustPage page={page} locale="en" />
  <Footer />
</BaseLayout>
