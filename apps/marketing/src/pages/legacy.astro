---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/TopNav.astro'
import Hero from '../components/Hero.astro'
import SlaStrip from '../components/SlaStrip.astro'
import Problem from '../components/Problem.astro'
import Workflow from '../components/Workflow.astro'
import Proof from '../components/Proof.astro'
import Security from '../components/Security.astro'
import FinalCta from '../components/FinalCta.astro'
import Footer from '../components/Footer.astro'
import en from '../i18n/en'
import { getCtaHref } from '../lib/app-url'
import { homeStructuredData } from '../lib/structured-data'

const ctaHref = getCtaHref()
const t = en
---

<BaseLayout
  lang="en"
  pathname="/legacy"
  title={t.meta.title}
  description={t.meta.description}
  ogImage={t.meta.ogImage}
  noindex={true}
  structuredData={homeStructuredData(t, 'en')}
>
  <TopNav t={t.nav} ctaHref={ctaHref} />
  <main>
    <Hero t={t.hero} ctaHref={ctaHref} workflowAnchor="#workflow" />
    <SlaStrip t={t.sla} />
    <Problem t={t.problem} />
    <Workflow t={t.workflow} />
    <Proof t={t.proof} />
    <Security t={t.security} />
    <FinalCta t={t.finalCta} ctaHref={ctaHref} />
  </main>
  <Footer t={t.footer} enHref="/" zhHref="/zh-CN" currentLocale="en" />
</BaseLayout>
