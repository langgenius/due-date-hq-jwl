---
import BaseLayout from '../layouts/BaseLayout.astro'
import TopNav from '../components/home/TopNav.astro'
import Pricing from '../components/Pricing.astro'
import Footer from '../components/home/Footer.astro'
import en from '../i18n/en'
import { getAppHref, getStartedHref } from '../lib/app-url'
import { pricingStructuredData } from '../lib/structured-data'
import { PRICING_COMING_SOON } from '../lib/pricing-state'

const t = en
const ctaHref = getStartedHref()
const checkoutHrefs = {
  solo: {
    monthly: getAppHref('/billing/checkout?plan=solo&interval=monthly'),
    yearly: getAppHref('/billing/checkout?plan=solo&interval=yearly'),
  },
  pro: {
    monthly: getAppHref('/billing/checkout?plan=pro&interval=monthly'),
    yearly: getAppHref('/billing/checkout?plan=pro&interval=yearly'),
  },
  team: {
    monthly: getAppHref('/billing/checkout?plan=team&interval=monthly'),
    yearly: getAppHref('/billing/checkout?plan=team&interval=yearly'),
  },
}
const pathname = '/pricing'
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={t.pricing.meta.title}
  description={t.pricing.meta.description}
  ogImage={t.pricing.meta.ogImage}
  structuredData={pricingStructuredData(t, 'en', pathname, PRICING_COMING_SOON)}
>
  <TopNav pageMode ctaHref={ctaHref} current="pricing" />
  <main>
    <Pricing t={t.pricing} appHref={ctaHref} checkoutHrefs={checkoutHrefs} />
  </main>
  <Footer />
</BaseLayout>
