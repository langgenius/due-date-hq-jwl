---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import TopNav from '../../../components/home/TopNav.astro'
import StateDetailPage from '../../../components/StateDetailPage.astro'
import Footer from '../../../components/home/Footer.astro'
import zhCN from '../../../i18n/zh-CN'
import type { StatePageCopy } from '../../../i18n/types'
import { getStartedHref } from '../../../lib/app-url'
import { stateOfficialSources } from '../../../lib/content-metadata'
import { getStatePages } from '../../../lib/seo-content'
import { statePageStructuredData } from '../../../lib/structured-data'

export function getStaticPaths() {
  const allStates = getStatePages(zhCN, 'zh-CN')
  return allStates.map((state) => ({
    params: { state: state.slug },
    props: { page: state, allStates },
  }))
}

interface Props {
  page: StatePageCopy
  allStates: StatePageCopy[]
}

const t = zhCN
const { page, allStates } = Astro.props
const enPathname = `/states/${page.slug}`
const pathname = `/zh-CN${enPathname}`
const ctaHref = getStartedHref('zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={statePageStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} locale="zh-CN" current="coverage" />
  <StateDetailPage
    page={page}
    allStates={allStates}
    coverageHref="/zh-CN/state-coverage"
    locale="zh-CN"
    officialSources={stateOfficialSources[page.slug] ?? []}
  />
  <Footer locale="zh-CN" />
</BaseLayout>
