---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import TopNav from '../../../components/TopNav.astro'
import GeoResourcePage from '../../../components/GeoResourcePage.astro'
import Footer from '../../../components/Footer.astro'
import zhCN from '../../../i18n/zh-CN'
import type { GuidePageCopy } from '../../../i18n/types'
import { getCtaHref } from '../../../lib/app-url'
import { getComparisonPages, getResourceCtaHrefs } from '../../../lib/seo-content'
import { resourceStructuredData } from '../../../lib/structured-data'

export function getStaticPaths() {
  return getComparisonPages('zh-CN').map((comparison) => ({
    params: { comparison: comparison.slug },
    props: { page: comparison },
  }))
}

interface Props {
  page: GuidePageCopy
}

const t = zhCN
const { page } = Astro.props
const enPathname = `/compare/${page.slug}`
const pathname = `/zh-CN${enPathname}`
const ctaHref = getCtaHref('zh-CN')
const { primaryHref, secondaryHref } = getResourceCtaHrefs(page.slug, 'zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  ogType="article"
  structuredData={resourceStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav t={t.nav} ctaHref={ctaHref} />
  <GeoResourcePage
    page={page}
    primaryHref={primaryHref}
    secondaryHref={secondaryHref}
    locale="zh-CN"
  />
  <Footer t={t.footer} enHref={enPathname} zhHref={pathname} currentLocale="zh-CN" />
</BaseLayout>
