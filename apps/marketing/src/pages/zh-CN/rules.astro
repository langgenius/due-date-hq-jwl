---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import GeoResourcePage from '../../components/GeoResourcePage.astro'
import Footer from '../../components/home/Footer.astro'
import zhCN from '../../i18n/zh-CN'
import { getStartedHref } from '../../lib/app-url'
import { getRuleReferenceLinks } from '../../lib/seo-content'
import { resourceStructuredData } from '../../lib/structured-data'

const t = zhCN
const page = t.geo.rules
const pathname = '/zh-CN/rules'
const ctaHref = getStartedHref('zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={resourceStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} locale="zh-CN" />
  <GeoResourcePage
    page={page}
    primaryHref="/zh-CN/state-coverage"
    secondaryHref="/zh-CN/pricing"
    locale="zh-CN"
    related={getRuleReferenceLinks('zh-CN')}
    relatedTitle="带来源的规则参考"
  />
  <Footer locale="zh-CN" />
</BaseLayout>
