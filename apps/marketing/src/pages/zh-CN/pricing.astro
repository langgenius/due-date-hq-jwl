---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import Pricing from '../../components/Pricing.astro'
import Footer from '../../components/home/Footer.astro'
import zhCN from '../../i18n/zh-CN'
import { getAppHref, getStartedHref } from '../../lib/app-url'
import { pricingStructuredData } from '../../lib/structured-data'

const t = zhCN
const ctaHref = getStartedHref('zh-CN')
const checkoutHrefs = {
  solo: {
    monthly: getAppHref('/billing/checkout?plan=solo&interval=monthly', 'zh-CN'),
    yearly: getAppHref('/billing/checkout?plan=solo&interval=yearly', 'zh-CN'),
  },
  pro: {
    monthly: getAppHref('/billing/checkout?plan=pro&interval=monthly', 'zh-CN'),
    yearly: getAppHref('/billing/checkout?plan=pro&interval=yearly', 'zh-CN'),
  },
  team: {
    monthly: getAppHref('/billing/checkout?plan=team&interval=monthly', 'zh-CN'),
    yearly: getAppHref('/billing/checkout?plan=team&interval=yearly', 'zh-CN'),
  },
}
const pathname = '/zh-CN/pricing'
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={t.pricing.meta.title}
  description={t.pricing.meta.description}
  ogImage={t.pricing.meta.ogImage}
  structuredData={pricingStructuredData(t, 'zh-CN', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} locale="zh-CN" current="pricing" />
  <main>
    <Pricing t={t.pricing} appHref={ctaHref} checkoutHrefs={checkoutHrefs} />
  </main>
  <Footer locale="zh-CN" />
</BaseLayout>
