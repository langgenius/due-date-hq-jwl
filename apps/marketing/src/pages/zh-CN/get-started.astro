---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import GetStartedPage from '../../components/GetStartedPage.astro'
import Footer from '../../components/home/Footer.astro'
import { getStartedHref, getAppHref } from '../../lib/app-url'

const ctaHref = getStartedHref('zh-CN')
const signInHref = getAppHref('/login', 'zh-CN')
const formAction = import.meta.env.PUBLIC_QUESTIONNAIRE_ACTION ?? ''
---

<BaseLayout
  lang="zh-CN"
  pathname="/zh-CN/get-started"
  title="免费用 3 个月 Team 版 — DueDateHQ"
  description="花两分钟告诉我们一点你事务所的情况，前三个月的 DueDateHQ Team 版就由我们请客。无需信用卡。"
  ogImage="/og/home.zh-CN.png"
>
  <TopNav pageMode ctaHref={ctaHref} signInHref={signInHref} locale="zh-CN" />
  <GetStartedPage
    locale="zh-CN"
    formAction={formAction}
    securityHref="/zh-CN/security"
    pricingHref="/zh-CN/pricing"
  />
  <Footer locale="zh-CN" />
</BaseLayout>
