---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import StateCoveragePage from '../../components/StateCoveragePage.astro'
import Footer from '../../components/home/Footer.astro'
import zhCN from '../../i18n/zh-CN'
import { getCtaHref } from '../../lib/app-url'
import { getStateCoveragePage } from '../../lib/seo-content'
import { stateCoverageStructuredData } from '../../lib/structured-data'

const t = zhCN
const page = getStateCoveragePage(t, 'zh-CN')
const pathname = '/zh-CN/state-coverage'
const ctaHref = getCtaHref('zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={stateCoverageStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} locale="zh-CN" current="coverage" />
  <StateCoveragePage page={page} locale="zh-CN" />
  <Footer locale="zh-CN" />
</BaseLayout>
