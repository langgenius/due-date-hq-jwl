---
/**
 * zh-CN homepage — the production-v2 redesign in Simplified Chinese. Mirrors
 * index.astro, passing locale="zh-CN" to each home component (each component
 * holds its own EN/zh copy). Chinese is a first draft, pending refinement.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import ScrollRail from '../../components/home/ScrollRail.astro'
import Hero from '../../components/home/Hero.astro'
import Villain from '../../components/home/Villain.astro'
import HowItWorks from '../../components/home/HowItWorks.astro'
import Notice from '../../components/home/Notice.astro'
import Sources from '../../components/home/Sources.astro'
import Compare from '../../components/home/Compare.astro'
import Surfaces from '../../components/home/Surfaces.astro'
import Security from '../../components/home/Security.astro'
import Faq from '../../components/home/Faq.astro'
import Close from '../../components/home/Close.astro'
import Footer from '../../components/home/Footer.astro'
import ScrollMotion from '../../components/home/ScrollMotion.astro'
import zhCN from '../../i18n/zh-CN'
import { getCtaHref, getAppHref } from '../../lib/app-url'
import { homeStructuredData } from '../../lib/structured-data'

const ctaHref = getCtaHref('zh-CN')
const signInHref = getAppHref('/login', 'zh-CN')
const t = zhCN
---

<BaseLayout
  lang="zh-CN"
  pathname="/zh-CN"
  title="DueDateHQ — 捕捉每一次报税截止日变化，看清它影响到哪些客户"
  description="DueDateHQ 全天候监控 IRS、主要州税务机关和 FEMA 灾害救济。截止日一变动，你立刻知道影响到哪些客户——每个日期都附官方来源。"
  ogImage={t.meta.ogImage}
  structuredData={homeStructuredData(t, 'zh-CN')}
>
  <TopNav ctaHref={ctaHref} signInHref={signInHref} locale="zh-CN" />
  <ScrollRail locale="zh-CN" />
  <main>
    <Hero ctaHref={ctaHref} workflowAnchor="#how" locale="zh-CN" />
    <Villain locale="zh-CN" />
    <Surfaces locale="zh-CN" />
    <HowItWorks locale="zh-CN" />
    <Notice locale="zh-CN" />
    <Sources locale="zh-CN" />
    <Compare locale="zh-CN" />
    <Security locale="zh-CN" />
    <Faq locale="zh-CN" />
    <Close ctaHref={ctaHref} locale="zh-CN" />
  </main>
  <Footer locale="zh-CN" />
  <ScrollMotion />
</BaseLayout>

<style is:global>
  body {
    background: var(--m-canvas);
  }
</style>
