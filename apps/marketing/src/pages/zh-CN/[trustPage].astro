---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/TopNav.astro'
import TrustPage from '../../components/TrustPage.astro'
import Footer from '../../components/Footer.astro'
import zhCN from '../../i18n/zh-CN'
import { getCtaHref } from '../../lib/app-url'
import { trustPageStructuredData } from '../../lib/structured-data'
import { trustPages, type TrustPageCopy } from '../../lib/trust-pages'

export function getStaticPaths() {
  return trustPages['zh-CN'].map((page) => ({
    params: { trustPage: page.slug },
    props: { page },
  }))
}

interface Props {
  page: TrustPageCopy
}

const t = zhCN
const { page } = Astro.props
const enPathname = `/${page.slug}`
const pathname = `/zh-CN${enPathname}`
const ctaHref = getCtaHref('zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={trustPageStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav t={t.nav} ctaHref={ctaHref} />
  <TrustPage page={page} locale="zh-CN" />
  <Footer t={t.footer} enHref={enPathname} zhHref={pathname} currentLocale="zh-CN" />
</BaseLayout>
