---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import TopNav from '../../../components/home/TopNav.astro'
import GeoResourcePage from '../../../components/GeoResourcePage.astro'
import Footer from '../../../components/home/Footer.astro'
import zhCN from '../../../i18n/zh-CN'
import type { GuidePageCopy } from '../../../i18n/types'
import { getCtaHref } from '../../../lib/app-url'
import { getGuidePages, getResourceCtaHrefs } from '../../../lib/seo-content'
import { resourceStructuredData } from '../../../lib/structured-data'

export function getStaticPaths() {
  return getGuidePages(zhCN, 'zh-CN').map((guide) => ({
    params: { guide: guide.slug },
    props: { page: guide },
  }))
}

interface Props {
  page: GuidePageCopy
}

const t = zhCN
const { page } = Astro.props
const enPathname = `/guides/${page.slug}`
const pathname = `/zh-CN${enPathname}`
const ctaHref = getCtaHref('zh-CN')
const { primaryHref, secondaryHref } = getResourceCtaHrefs(page.slug, 'zh-CN')
---

<BaseLayout
  lang="zh-CN"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  ogType="article"
  structuredData={resourceStructuredData(t, page, 'zh-CN', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} locale="zh-CN" />
  <GeoResourcePage
    page={page}
    primaryHref={primaryHref}
    secondaryHref={secondaryHref}
    locale="zh-CN"
  />
  <Footer locale="zh-CN" />
</BaseLayout>
