---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/TopNav.astro'
import GeoResourcePage from '../../components/GeoResourcePage.astro'
import Footer from '../../components/Footer.astro'
import en from '../../i18n/en'
import type { GuidePageCopy } from '../../i18n/types'
import { getCtaHref } from '../../lib/app-url'
import { getGuidePages, getResourceCtaHrefs } from '../../lib/seo-content'
import { resourceStructuredData } from '../../lib/structured-data'

export function getStaticPaths() {
  return getGuidePages(en, 'en').map((guide) => ({
    params: { guide: guide.slug },
    props: { page: guide },
  }))
}

interface Props {
  page: GuidePageCopy
}

const t = en
const { page } = Astro.props
const pathname = `/guides/${page.slug}`
const ctaHref = getCtaHref()
const { primaryHref, secondaryHref } = getResourceCtaHrefs(page.slug, 'en')
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  structuredData={resourceStructuredData(t, page, 'en', pathname)}
>
  <TopNav t={t.nav} ctaHref={ctaHref} />
  <GeoResourcePage
    page={page}
    primaryHref={primaryHref}
    secondaryHref={secondaryHref}
    locale="en"
  />
  <Footer t={t.footer} enHref={pathname} zhHref={`/zh-CN${pathname}`} currentLocale="en" />
</BaseLayout>
