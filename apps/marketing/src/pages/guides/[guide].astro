---
import BaseLayout from '../../layouts/BaseLayout.astro'
import TopNav from '../../components/home/TopNav.astro'
import GeoResourcePage from '../../components/GeoResourcePage.astro'
import Footer from '../../components/home/Footer.astro'
import en from '../../i18n/en'
import type { GuidePageCopy } from '../../i18n/types'
import { getStartedHref } from '../../lib/app-url'
import { getGuidePages, getRelatedResources, getResourceCtaHrefs } from '../../lib/seo-content'
import { resourceStructuredData } from '../../lib/structured-data'

export function getStaticPaths() {
  return getGuidePages(en, 'en').map((guide) => ({
    params: { guide: guide.slug },
    props: { page: guide },
  }))
}

interface Props {
  page: GuidePageCopy
}

const t = en
const { page } = Astro.props
const pathname = `/guides/${page.slug}`
const ctaHref = getStartedHref()
const { primaryHref, secondaryHref } = getResourceCtaHrefs(page.slug, 'en')
---

<BaseLayout
  lang="en"
  pathname={pathname}
  title={page.meta.title}
  description={page.meta.description}
  ogImage="/og/guide.en.png"
  ogType="article"
  structuredData={resourceStructuredData(t, page, 'en', pathname)}
>
  <TopNav pageMode ctaHref={ctaHref} />
  <GeoResourcePage
    page={page}
    primaryHref={primaryHref}
    secondaryHref={secondaryHref}
    locale="en"
    back={{ href: '/how-it-works', label: 'How it works' }}
    related={getRelatedResources(pathname, 'en')}
  />
  <Footer />
</BaseLayout>
