---
import { ClientRouter } from 'astro:transitions'
import { THEME_INIT_SCRIPT } from '@duedatehq/ui/theme/no-flash-script'
import type { Locale } from '@duedatehq/i18n/locales'
import StructuredData from '../components/StructuredData.astro'
import FoundingBanner from '../components/FoundingBanner.astro'
import type { JsonLdDocument } from '../lib/structured-data'
import { MARKETING_SITE_URL, getMarketingUrl } from '../lib/site'
import '../styles/globals.css'

// Founding-user lead form endpoint (dedicated Formspree form). Hardcoded default
// so it works on deploy with no env; override with PUBLIC_FOUNDING_FORM_ACTION.
const FOUNDING_FORM_ACTION =
  import.meta.env.PUBLIC_FOUNDING_FORM_ACTION ?? 'https://formspree.io/f/mjgnrnpj'

interface Props {
  /** BCP-47 tag rendered into <html lang>. */
  lang: Locale
  /** Path on the marketing site (e.g. "/" or "/pricing") used for canonical + OG. */
  pathname: string
  title: string
  description: string
  /** Path of the locale-specific OG image under /public, e.g. "/og/home.en.png". */
  ogImage: string
  noindex?: boolean
  /** og:type — 'website' (default) or 'article' for guide/rule/compare pages. */
  ogType?: string
  structuredData?: JsonLdDocument | JsonLdDocument[]
}

const OG_LOCALE: Record<Locale, string> = {
  en: 'en_US',
  'zh-CN': 'zh_CN',
}
const ALTERNATE_OG_LOCALE: Record<Locale, readonly string[]> = {
  en: ['zh_CN'],
  'zh-CN': ['en_US'],
}

const { lang, pathname, title, description, ogImage, noindex = false, ogType = 'website', structuredData } =
  Astro.props
const canonical = getMarketingUrl(pathname)
const ogImageUrl = `${MARKETING_SITE_URL}${ogImage}`
const localeFreePath =
  pathname === '/zh-CN' ? '/' : pathname.startsWith('/zh-CN/') ? pathname.slice('/zh-CN'.length) : pathname
const enHref = getMarketingUrl(localeFreePath)
const zhHref = getMarketingUrl(localeFreePath === '/' ? '/zh-CN' : `/zh-CN${localeFreePath}`)

// Marketing display/body/mono faces. Loaded non-render-blocking (preload as
// style + media=print onload swap, <noscript> fallback) so the third-party CSS
// request never blocks first paint; `&display=swap` already prevents FOIT.
const FONT_CSS_HREF =
  'https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600&family=Instrument+Sans:ital,wght@0,400..700;1,400&family=Instrument+Serif:ital@0;1&display=swap'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1F315C" />

    {/* Progressive-enhancement flag: marks JS-on before first paint so the
        scroll-reveal pre-hidden state (.m-js [data-reveal]) never flashes for
        no-JS visitors. Paired with ScrollMotion.astro (GSAP). */}
    <script is:inline>document.documentElement.classList.add('m-js')</script>

    {/* Agentation visual-feedback devtool — DEV builds only, localhost only, so it
        never ships to production. The import map must precede any module script,
        so it lives at the top of <head>. Add ?noagent to any URL to disable. */}
    {
      import.meta.env.DEV && (
        <script
          type="importmap"
          is:inline
          set:html={`{
  "imports": {
    "react": "https://esm.sh/react@19.2.6",
    "react/jsx-runtime": "https://esm.sh/react@19.2.6/jsx-runtime",
    "react-dom": "https://esm.sh/react-dom@19.2.6",
    "react-dom/client": "https://esm.sh/react-dom@19.2.6/client"
  }
}`}
        />
      )
    }

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    {!noindex && <link rel="alternate" hreflang="en" href={enHref} />}
    {!noindex && <link rel="alternate" hreflang="zh-CN" href={zhHref} />}
    {!noindex && <link rel="alternate" hreflang="x-default" href={enHref} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="DueDateHQ" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    {ALTERNATE_OG_LOCALE[lang].map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Marketing display/body/mono faces (Instrument Serif hero, Instrument Sans,
        Geist Mono) — loaded async so the font CSS never render-blocks. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={FONT_CSS_HREF} />
    <link rel="stylesheet" href={FONT_CSS_HREF} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={FONT_CSS_HREF} /></noscript>

    {structuredData && <StructuredData data={structuredData} />}

    <script is:inline set:html={THEME_INIT_SCRIPT}></script>

    {/* Smooth cross-page navigation. Scripts that drive motion/nav re-init on
        astro:page-load (ScrollMotion, TopNav, Notice, ScrollRail) so nothing
        goes inert after a swap. Animation + reduced-motion live in marketing.css. */}
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-bg-canvas text-text-primary antialiased">
    <a class="m-skip" href="#main-content">{lang === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}</a>
    <FoundingBanner locale={lang} action={FOUNDING_FORM_ACTION} />
    <slot />
    <script>
      // Tag <main> as the skip-link target on first load AND after every
      // View-Transition swap (the swapped-in page brings a fresh <main>).
      const tagMain = () => {
        const m = document.querySelector('main')
        if (m && m.id !== 'main-content') {
          m.id = 'main-content'
          m.setAttribute('tabindex', '-1')
        }
      }
      document.addEventListener('astro:page-load', tagMain)
    </script>

    <script>
      import { initMarketingAnalytics, trackPageView } from '../lib/analytics'

      // One-time setup self-guards; the page-view fires on every astro:page-load
      // so views keep counting across view-transition navigations (not just the
      // session's first page).
      document.addEventListener('astro:page-load', () => {
        initMarketingAnalytics()
        trackPageView()
      })
    </script>

    {
      import.meta.env.DEV && (
        <script
          type="module"
          is:inline
          set:html={`
if ((location.hostname === 'localhost' || location.hostname === '127.0.0.1') && !location.search.includes('noagent')) {
  // ClientRouter swaps <body> on navigation, tearing the overlay's root out and
  // leaving it broken until a manual refresh. Cache the lib, unmount cleanly
  // before each swap, and re-mount after every page-load (initial + post-swap)
  // so the feedback tool survives tab switches. Dev-only; never ships to prod.
  let lib = null
  let root = null
  async function mountAgentation() {
    if (document.getElementById('agentation-root')) return
    try {
      if (!lib) {
        const React = (await import('react')).default
        const { createRoot } = await import('react-dom/client')
        const { Agentation } = await import('https://esm.sh/agentation@3.0.2?external=react,react-dom')
        lib = { React, createRoot, Agentation }
      }
      const el = document.createElement('div')
      el.id = 'agentation-root'
      document.body.appendChild(el)
      root = lib.createRoot(el)
      root.render(lib.React.createElement(lib.Agentation))
    } catch (e) {
      console.error('[Agentation] failed to load:', e)
    }
  }
  document.addEventListener('astro:before-swap', () => { if (root) { root.unmount(); root = null } })
  document.addEventListener('astro:page-load', mountAgentation)
}`}
        />
      )
    }
  </body>
</html>
