---
import type { HeroSurfaceCopy } from '../i18n/types'
import {
  marketingBadgeBase as badgeBase,
  marketingBadgeTone as badgeTone,
  marketingGhostButtonSm,
  marketingSeverityBadgeTone,
  marketingSeverityDot,
  marketingSeverityRow,
  marketingStatusDot as statusDot,
  marketingTable,
  marketingTableHeaderControl,
  marketingTableHeaderGroup,
  marketingTableSortButton,
} from '../lib/marketing-table-styles'
import KbdHint from './primitives/KbdHint.astro'

interface Props {
  t: HeroSurfaceCopy
}

const { t } = Astro.props
---

<div class="relative overflow-hidden rounded-xl border border-components-card-border bg-components-card-bg shadow-overlay">
  <div class="flex h-10 items-center justify-between border-b border-divider-subtle px-3">
    <div class="flex min-w-0 items-center gap-3">
      <div class="flex shrink-0 items-center gap-1.5">
        <span class="block h-2 w-2 rounded-full bg-severity-critical/70"></span>
        <span class="block h-2 w-2 rounded-full bg-severity-medium/70"></span>
        <span class="block h-2 w-2 rounded-full bg-status-done/70"></span>
      </div>
      <div class="flex min-w-0 items-center gap-1.5 truncate font-mono text-xs text-text-tertiary">
        <span class="block h-2.5 w-2.5 shrink-0 rounded-sm bg-background-subtle"></span>
        <span>{t.breadcrumb.workbench}</span>
        <span>/</span>
        <span>{t.breadcrumb.dashboard}</span>
        <span>/</span>
        <span class="text-text-secondary">{t.breadcrumb.week}</span>
      </div>
    </div>
    <KbdHint keys="⌘K" label={t.kbdCommand} />
  </div>

  <div class="flex items-center gap-3 border-b border-divider-subtle bg-components-badge-bg-warning-soft px-4 py-2.5">
    <span class:list={[badgeBase, 'rounded-md bg-components-badge-bg-warning-soft text-text-warning']}>
      <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot.warning]}></span>
      {t.pulse.tag}
    </span>
    <p class="min-w-0 flex-1 truncate text-xs text-text-primary">{t.pulse.text}</p>
    <span class="hidden rounded border border-divider-regular bg-background-default px-2 py-0.5 font-mono text-caption-xs text-text-secondary sm:inline-flex">
      {t.pulse.source}
    </span>
    <span class="font-mono text-xs text-text-accent">{t.pulse.cta} →</span>
  </div>

  <div class="grid gap-0 border-b border-divider-subtle lg:grid-cols-[1fr_0.82fr]">
    <div class="border-b border-divider-subtle px-4 py-4 lg:border-b-0 lg:border-r lg:border-divider-subtle">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2 font-mono text-xs tracking-eyebrow text-text-tertiary">
          <span class="block h-1.5 w-1.5 rounded-full bg-severity-critical"></span>
          <span>{t.metric.eyebrow}</span>
        </div>
        <span class:list={[badgeBase, 'border-divider-regular bg-background-section font-mono text-text-secondary']}>
          {t.metric.range}
        </span>
      </div>
      <div class="mt-3 flex items-end justify-between gap-4">
        <div>
          <div class="font-mono tabular text-[42px] font-bold leading-none text-text-primary">
            {t.metric.value}
          </div>
          <div class:list={[badgeBase, 'mt-2 bg-components-badge-bg-red-soft font-mono text-text-destructive']}>
            {t.metric.delta}
          </div>
        </div>
      </div>
    </div>

    <div class="grid content-start gap-3 px-4 py-4">
      <div class="flex items-center justify-between gap-3">
        <div>
          <div class="text-xs font-semibold text-text-primary">{t.brief.title}</div>
          <div class="mt-0.5 font-mono text-xs text-text-tertiary">{t.brief.citation}</div>
        </div>
        <span class:list={[badgeBase, 'bg-state-accent-active-alt font-mono text-text-accent']}>
          {t.brief.status}
        </span>
      </div>
      <p class="text-[12px] leading-relaxed text-text-secondary">{t.brief.text}</p>
    </div>
  </div>

  <div class="grid grid-cols-4 gap-0 border-b border-divider-subtle">
    {t.metric.stats.map((stat) => (
      <div class="border-r border-divider-subtle px-4 py-3 last:border-r-0">
        <div class="font-mono text-caption-xs tracking-wider text-text-tertiary">{stat.label}</div>
        <div class="mt-0.5 font-mono tabular text-[18px] font-semibold text-text-primary">{stat.value}</div>
      </div>
    ))}
  </div>

  <div class="flex items-center justify-between border-b border-divider-subtle px-4 py-2.5">
    <div class="flex rounded-md border border-divider-regular bg-background-section p-0.5 font-mono text-xs">
      {t.triageTabs.map((tab, idx) => (
        <span class:list={['px-2 py-1', idx === 0 ? 'rounded-sm bg-background-default text-text-primary' : 'text-text-secondary']}>
          {tab.label} · {tab.count}
        </span>
      ))}
    </div>
    <span class="font-mono text-xs text-text-tertiary">{t.liveLabel}</span>
  </div>

  <div class={marketingTable.container}>
    <table class:list={[marketingTable.table, 'min-w-[980px]']}>
      <thead class={marketingTable.header}>
        <tr class={marketingTable.row}>
          <th class:list={[marketingTable.head, 'w-[12%]']}>
            <span class:list={[marketingTableHeaderControl, 'max-w-32']}>
              {t.table.headers.priority}
              <span aria-hidden class="text-text-quaternary">↕</span>
            </span>
          </th>
          <th class:list={[marketingTable.head, 'w-[20%]']}>
            <span class={marketingTableHeaderControl}>
              {t.table.headers.client}
              <span aria-hidden class="text-text-quaternary">⌄</span>
            </span>
          </th>
          <th class:list={[marketingTable.head, 'w-[10%]']}>{t.table.headers.form}</th>
          <th class:list={[marketingTable.head, 'w-[17%]']}>
            <div class={marketingTableHeaderGroup}>
              <span class:list={[marketingTableHeaderControl, 'max-w-32']}>
                {t.table.headers.due}
                <span aria-hidden class="text-text-quaternary">⌄</span>
              </span>
              <span aria-hidden class={marketingTableSortButton}>↕</span>
            </div>
          </th>
          <th class:list={[marketingTable.head, 'w-[14%]']}>
            <span class:list={[marketingTableHeaderControl, 'max-w-36']}>
              {t.table.headers.status}
              <span aria-hidden class="text-text-quaternary">⌄</span>
            </span>
          </th>
          <th class:list={[marketingTable.head, 'w-[12%]']}>{t.table.headers.severity}</th>
          <th class:list={[marketingTable.head, 'w-[11%] text-right']}>
            <div class:list={[marketingTableHeaderGroup, 'justify-end']}>
              <span class:list={[marketingTableHeaderControl, 'max-w-36 justify-end text-right']}>
                {t.table.headers.exposure}
                <span aria-hidden class="text-text-quaternary">⌄</span>
              </span>
              <span aria-hidden class={marketingTableSortButton}>↕</span>
            </div>
          </th>
          <th class:list={[marketingTable.head, 'w-[14%]']}>{t.table.headers.evidence}</th>
        </tr>
      </thead>
      <tbody class={marketingTable.body}>
        {t.table.rows.slice(0, 4).map((row) => (
          <tr class:list={[marketingTable.row, marketingSeverityRow[row.severity]]}>
            <td class={marketingTable.cell}>
              <span class:list={[badgeBase, badgeTone[row.priorityTone], 'font-mono tabular-nums']}>
                {row.priorityScore}
                {row.priorityRank && <span>{row.priorityRank}</span>}
              </span>
            </td>
            <td class:list={[marketingTable.cell, 'font-medium']}>
              <div class="min-w-0 leading-tight">
                <div class="truncate text-xs text-text-primary">{row.client}</div>
                <div class="font-mono text-xs text-text-tertiary">{row.ein}</div>
              </div>
            </td>
            <td class:list={[marketingTable.cell, 'font-mono text-xs text-text-secondary']}>{row.form}</td>
            <td class={marketingTable.cell}>
              <div class="flex items-center gap-2 font-mono tabular-nums">
                <span class:list={[badgeBase, badgeTone[row.severity === 'medium' ? 'outline' : 'warning'], 'min-w-18 justify-start font-mono text-xs tabular-nums']}>
                  {row.daysLeft}
                </span>
                <span class="text-xs text-text-secondary">{row.due}</span>
              </div>
            </td>
            <td class={marketingTable.cell}>
              <span class:list={[badgeBase, badgeTone[row.statusTone], 'h-6 cursor-default text-xs']}>
                <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[row.statusDotTone]]}></span>
                {row.status}
              </span>
            </td>
            <td class={marketingTable.cell}>
              <span class:list={[badgeBase, badgeTone[marketingSeverityBadgeTone[row.severity]], 'h-7 px-2.5 text-xs uppercase tracking-wide']}>
                <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[marketingSeverityDot[row.severity]]]}></span>
                {row.severityLabel}
              </span>
            </td>
            <td class:list={[marketingTable.cell, 'text-right']}>
              <span class:list={[badgeBase, badgeTone[row.exposureTone], 'ml-auto font-mono tabular-nums']}>{row.exposure}</span>
            </td>
            <td class={marketingTable.cell}>
              <span class:list={[marketingGhostButtonSm, 'max-w-36 justify-start']}>
                <span class="truncate">{row.evidence}</span>
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="flex items-center gap-4 border-t border-divider-subtle px-4 py-2.5">
    {t.hints.slice(0, 3).map((hint) => (
      <KbdHint keys={hint.keys} label={hint.label} variant="inline" />
    ))}
  </div>
</div>
