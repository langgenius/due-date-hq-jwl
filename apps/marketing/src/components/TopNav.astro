---
import brandMarkDark from '@duedatehq/ui/assets/brand/brand-favicon-dark.svg?url'
import brandMarkLight from '@duedatehq/ui/assets/brand/brand-favicon.svg?url'

import type { NavCopy } from '../i18n/types'

interface Props {
  t: NavCopy
  ctaHref: string
}

const { t, ctaHref } = Astro.props
---

<header class="sticky top-0 z-30 border-b border-border-default bg-bg-canvas/90 backdrop-blur">
  <div class="mx-auto flex h-[72px] max-w-[1440px] items-center justify-between gap-4 px-6 sm:px-10 lg:px-20">
    <!-- Brand + nav cluster: 32px gap matches Figma NavLeft (Brand 238w + 32 gap + NavLinks 412w). -->
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2 text-[13px]">
        <img
          src={brandMarkLight}
          alt=""
          aria-hidden="true"
          width="16"
          height="16"
          class="size-4 shrink-0 dark:hidden"
        />
        <img
          src={brandMarkDark}
          alt=""
          aria-hidden="true"
          width="16"
          height="16"
          class="hidden size-4 shrink-0 dark:block"
        />
        <span class="font-semibold text-text-primary">{t.brand}</span>
        <span class="hidden text-text-muted sm:inline">/</span>
        <span class="hidden text-text-secondary sm:inline">{t.audience}</span>
      </a>
      <nav class="hidden items-center gap-6 text-[13px] text-text-secondary lg:flex">
        {t.links.map((link) => (
          <a href={link.href} class="rounded-sm outline-none transition-colors hover:text-text-primary focus-visible:ring-2 focus-visible:ring-state-accent-active-alt">{link.label}</a>
        ))}
      </nav>
    </div>
    <div class="flex items-center gap-4">
      <span class="hidden items-center gap-2 rounded-full border border-border-default bg-bg-elevated px-2.5 py-1 text-[12px] text-text-secondary xl:inline-flex">
        <span class="block h-1.5 w-1.5 rounded-full bg-status-done"></span>
        {t.statusPill}
      </span>
      <a
        href={ctaHref}
        class="inline-flex h-8 items-center gap-1.5 rounded-md bg-accent-default px-3 text-[13px] font-medium text-primary-foreground outline-none transition-colors hover:bg-accent-hover focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
        data-event="marketing.nav.cta"
      >
        <span>{t.cta}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>
