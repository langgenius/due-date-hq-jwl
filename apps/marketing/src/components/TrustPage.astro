---
/** TrustPage — about / security / privacy / terms / status.
 *  The in-depth, deeper-pushed counterpart to the landing's trust section.
 *  Reuses the shared long-tail kit (.m-page-* / .m-card / .m-btn) but lifts it:
 *  a display-serif hero that bookends the navy finale (the only two places the
 *  serif appears here), a calm meta rail, an optional signature statement, a
 *  numbered section rhythm with contained rules, and a bold navy CTA that closes
 *  the page — chroma in containers, never in text. */
import { getContentDates } from '../lib/content-metadata'
import type { TrustPageCopy } from '../lib/trust-pages'
import FaqList from './FaqList.astro'

interface Props {
  page: TrustPageCopy
  locale: 'en' | 'zh-CN'
}

const { page, locale } = Astro.props
const zh = locale === 'zh-CN'
const faqCopy = zh ? { eyebrow: '常见问题', title: '关于本页的常见问题。' } : { eyebrow: 'FAQ', title: 'Common questions.' }
const reviewedOn = getContentDates(page.slug).reviewedOn
const lastReviewedLabel = zh ? '最近复核' : 'Last reviewed'
const sectionsLabel = zh ? '本页内容' : 'On this page'

/** Security earns an evidence-first tone (display-serif hero, statement rail, an
 *  architecture diagram); the legal pages stay calm. */
const isSignature = page.slug === 'security'
const sectionCount = page.sections.length
const pad = (n: number) => String(n).padStart(2, '0')
---

<main class="trustpg" data-slug={page.slug}>
  <section class="m-section m-page-hero trustpg__hero" id="hero">
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class={`m-page-title trustpg__title${isSignature ? ' trustpg__title--display' : ''}`}>{page.hero.title}</h1>
    <p class="m-page-lead trustpg__lead">{page.hero.description}</p>

    <div class="trustpg__meta">
      <p class="trustpg__note">{page.hero.note}</p>
      <p class="trustpg__reviewed">
        <span class="trustpg__reviewed-k">{lastReviewedLabel}</span>
        <time datetime={reviewedOn}>{reviewedOn}</time>
      </p>
    </div>

    {
      page.slug === 'security' && (
        <div
          class="secdiag"
          role="img"
          aria-label="DueDateHQ architecture: a public marketing site kept fully separate from the authenticated app, which guards tenant data behind session, firm-access, tenant, and rate-limit middleware. Every change carries a source, a human approval, and an audit trail."
        >
          <div class="secdiag__access">
            <div class="secdiag__node">
              <span class="secdiag__k">Public site</span>
              <span class="secdiag__v">Marketing &amp; discovery</span>
              <span class="secdiag__chip secdiag__chip--muted">No client data</span>
            </div>
            <div class="secdiag__sep" aria-hidden="true">
              <span class="secdiag__sep-line" />
              <span class="secdiag__sep-label">No shared surface</span>
              <span class="secdiag__sep-line" />
            </div>
            <div class="secdiag__node secdiag__node--app">
              <span class="secdiag__k">Authenticated app</span>
              <span class="secdiag__v">Signed-in practice work</span>
              <ul class="secdiag__mw">
                <li>session</li>
                <li>firm access</li>
                <li>tenant</li>
                <li>rate limit</li>
              </ul>
              <span class="secdiag__data">Tenant data · isolated per firm</span>
            </div>
          </div>
          <div class="secdiag__evidence">
            <span class="secdiag__elabel">Every change carries</span>
            <ol class="secdiag__chain">
              <li>Source URL + excerpt</li>
              <li class="secdiag__arrow" aria-hidden="true">→</li>
              <li>Human approval</li>
              <li class="secdiag__arrow" aria-hidden="true">→</li>
              <li>Audit trail · reversible</li>
            </ol>
          </div>
        </div>
      )
    }
  </section>

  {
    page.statement && (
      <section class="m-section trustpg__statement-sec">
        <figure class="statement">
          <figcaption class="statement__label">{page.statement.label}</figcaption>
          <blockquote class="statement__text">{page.statement.text}</blockquote>
        </figure>
      </section>
    )
  }

  <section class="m-section trustpg__toc" aria-label={sectionsLabel}>
    <p class="trustpg__toc-label">{sectionsLabel}</p>
    <ol class="trustpg__toc-list">
      {
        page.sections.map((section, i) => (
          <li class="trustpg__toc-item">
            <span class="trustpg__toc-num">{pad(i + 1)}</span>
            <span class="trustpg__toc-txt">{section.title}</span>
          </li>
        ))
      }
    </ol>
  </section>

  {
    page.sections.map((section, i) => (
      <section class="m-section m-page-block trustpg__block">
        <div class="m-page-split">
          <div class="m-page-split__lead trustpg__lead-col">
            <div class="trustpg__index" aria-hidden="true">
              <span class="trustpg__index-n">{pad(i + 1)}</span>
              <span class="trustpg__index-of">/ {pad(sectionCount)}</span>
            </div>
            <p class="m-eyebrow trustpg__sec-eyebrow">{section.eyebrow}</p>
            <h2 class="m-page-h2 trustpg__h2">{section.title}</h2>
            <p class="m-page-body trustpg__body">{section.body}</p>
          </div>
          <div class="m-page-cards trustpg__cards">
            {section.items.map((item) => (
              <article class="m-card trustpg__card">
                <h3 class="m-card__t trustpg__card-t">{item.title}</h3>
                <p class="m-card__d trustpg__card-d">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  {
    page.faq && page.faq.length > 0 && (
      <section class="m-section m-page-block trustpg__block trustpg__faq">
        <FaqList eyebrow={faqCopy.eyebrow} title={faqCopy.title} items={page.faq} />
      </section>
    )
  }

  <section class="trustpg__close">
    <div class="trustpg__close-card">
      <div class="trustpg__close-inner">
        <p class="trustpg__close-eyebrow">{page.contact.label}</p>
        <h2 class="trustpg__close-title">{page.contact.title}</h2>
        <p class="trustpg__close-body">{page.contact.body}</p>
        <a class="trustpg__close-btn" href={page.contact.href}>
          {page.contact.label}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</main>

<style>
  /* ============================================================================
     Hero — calm by default; bold + display-serif on the signature pages.
     ============================================================================ */
  /* hero padding + eyebrow come from the shared kit (.m-page-hero on the section,
     plain .m-eyebrow) — aligned with every other subpage */
  /* Display serif hero — one voice with every other page (home, leaves, finale).
     Calm size on the legal pages; the signature pages step up below. */
  /* hero title comes from the shared .m-page-title; signature pages (security /
     about) only tighten the measure + tracking a hair for more presence. */
  .trustpg__title--display {
    max-width: 17ch;
    letter-spacing: -0.018em;
  }
  /* ============================================================================
     Security architecture diagram — a real picture of the two boundaries the
     page describes (replaces the placeholder figure). Public site | separation |
     authenticated app behind middleware → tenant data; then the evidence chain.
     ============================================================================ */
  .secdiag {
    margin-top: clamp(28px, 4vw, 44px);
    max-width: 900px;
    display: grid;
    gap: 14px;
  }
  .secdiag__access {
    display: grid;
    grid-template-columns: 1fr auto 1.35fr;
    align-items: stretch;
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--m-surface);
  }
  .secdiag__node {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: clamp(18px, 2vw, 24px);
  }
  .secdiag__node--app {
    background:
      radial-gradient(130% 140% at 100% 0%, var(--m-accent-tint), transparent 62%),
      var(--m-surface);
  }
  .secdiag__k {
    font-size: var(--m-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .secdiag__v {
    font-size: var(--m-text-sm);
    color: var(--m-muted);
  }
  .secdiag__chip {
    align-self: flex-start;
    margin-top: auto;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    padding: 3px 9px;
    border-radius: 999px;
  }
  .secdiag__chip--muted {
    color: var(--m-muted);
    background: var(--m-section);
    border: 1px solid var(--m-hairline-2);
  }
  /* the deliberate gap between the public site and the app */
  .secdiag__sep {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 16px 12px;
    background: var(--m-section);
    border-inline: 1px solid var(--m-hairline-2);
  }
  .secdiag__sep-line {
    flex: 1;
    width: 0;
    border-left: 1px dashed color-mix(in srgb, var(--m-accent) 35%, transparent);
  }
  .secdiag__sep-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--m-faint);
    white-space: nowrap;
  }
  .secdiag__mw {
    margin-top: 2px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
  }
  .secdiag__mw li {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border: 1px solid color-mix(in srgb, var(--m-accent) 18%, transparent);
    border-radius: 4px;
    padding: 3px 8px;
  }
  .secdiag__data {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    align-self: stretch;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: #fff;
    background: var(--m-accent);
    border-radius: 8px;
    padding: 9px 12px;
  }
  .secdiag__evidence {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 16px;
    padding: 14px clamp(16px, 2vw, 22px);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    background: var(--m-section);
  }
  .secdiag__elabel {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .secdiag__chain {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 12px;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--m-text-sm);
  }
  .secdiag__chain li {
    font-weight: 500;
    color: var(--m-ink);
  }
  .secdiag__arrow {
    color: var(--m-accent);
    font-weight: 400;
  }
  @media (max-width: 640px) {
    .secdiag__access {
      grid-template-columns: 1fr;
    }
    .secdiag__sep {
      flex-direction: row;
      padding: 10px 16px;
    }
    .secdiag__sep-line {
      flex: 1;
      width: auto;
      height: 0;
      border-left: 0;
      border-top: 1px dashed color-mix(in srgb, var(--m-accent) 35%, transparent);
    }
    .secdiag__sep-label {
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
  /* hero lead comes from the shared .m-page-lead (no per-page override) */
  /* meta rail — note + last-reviewed sit on one quiet, ruled line */
  .trustpg__meta {
    margin-top: clamp(28px, 3.4vw, 40px);
    padding-top: 18px;
    border-top: 1px solid var(--m-hairline);
    display: grid;
    gap: 14px 40px;
    align-items: start;
  }
  .trustpg__note {
    max-width: 64ch;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    line-height: 1.55;
    color: var(--m-muted);
  }
  .trustpg__reviewed {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: var(--m-faint);
  }
  .trustpg__reviewed-k {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: var(--m-text-2xs);
  }
  .trustpg__reviewed time {
    color: var(--m-ink-2);
  }
  @media (min-width: 720px) {
    .trustpg__meta {
      grid-template-columns: 1fr auto;
    }
  }

  /* ============================================================================
     Statement — a single page-defining line, set large, like a pull-quote.
     Only present on the signature pages.
     ============================================================================ */
  .trustpg__statement-sec {
    padding-block: clamp(8px, 1.6vw, 20px) clamp(28px, 3.6vw, 48px);
  }
  .statement {
    max-width: 940px;
    padding: clamp(26px, 3.2vw, 40px) clamp(26px, 3.4vw, 44px);
    background: var(--m-accent-tint);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
  }
  .statement__label {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--m-accent);
  }
  .statement__text {
    margin-top: 16px;
    font-family: var(--m-font-sans);
    font-weight: 600;
    font-size: clamp(20px, 2.2vw, 28px);
    line-height: 1.34;
    letter-spacing: -0.01em;
    color: var(--m-ink);
    text-wrap: pretty;
  }

  /* ============================================================================
     On-this-page — a compact, numbered contents rail. Gives the long legal
     pages structure + scent without a heavy nav.
     ============================================================================ */
  .trustpg__toc {
    padding-block: clamp(20px, 2.6vw, 32px) 0;
  }
  .trustpg__toc-label {
    padding-bottom: 14px;
    border-bottom: 1px solid var(--m-hairline);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    letter-spacing: 0.02em;
    color: var(--m-faint);
  }
  .trustpg__toc-list {
    margin-top: 6px;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 clamp(24px, 3vw, 48px);
  }
  .trustpg__toc-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: baseline;
    padding: 14px 0;
  }
  .trustpg__toc-num {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    font-weight: 500;
    color: var(--m-accent);
  }
  .trustpg__toc-txt {
    font-size: var(--m-text-md);
    line-height: 1.45;
    color: var(--m-ink);
  }
  @media (max-width: 640px) {
    .trustpg__toc-list {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================================
     Section blocks — a numbered editorial index in the lead column gives every
     block a confident anchor instead of a plain eyebrow-stack.
     ============================================================================ */
  .trustpg__block:first-of-type {
    border-top-width: 1px;
    border-top-color: var(--m-hairline);
  }
  .trustpg__index {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 18px;
  }
  .trustpg__index-n {
    font-family: var(--m-font-mono);
    font-weight: 600;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--m-ink);
  }
  .trustpg__index-of {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-sm);
    color: var(--m-faint);
  }
  .trustpg__sec-eyebrow {
    margin-bottom: 12px;
  }
  .trustpg__h2 {
    text-wrap: balance;
  }
  /* cards lift on hover via a border + a 1px translate — no drop shadow */
  .trustpg__card {
    transition:
      border-color 0.18s ease,
      transform 0.18s ease;
  }
  .trustpg__card:hover {
    border-color: var(--m-hairline);
    transform: translateY(-1px);
  }
  .trustpg__card-t {
    display: flex;
    align-items: baseline;
    gap: 9px;
  }
  /* a small accent tick before each card title — chroma in a container glyph */
  .trustpg__card-t::before {
    content: '';
    flex: none;
    width: 6px;
    height: 6px;
    margin-top: 1px;
    border-radius: 999px;
    background: var(--m-accent);
  }

  /* ============================================================================
     Close — bold navy CTA that ENDS the page, bookending the hero. Cyan top-edge
     + a faint corner light (chroma in the container, white text only), matching
     the home's Close. Serif title returns the page's display voice.
     ============================================================================ */
  .trustpg__close {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(40px, 6vw, 80px);
  }
  .trustpg__close-card {
    position: relative;
    background: var(--m-accent);
    border-radius: 12px;
    overflow: hidden;
    isolation: isolate;
  }
  .trustpg__close-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      120% 90% at 100% 0%,
      color-mix(in srgb, var(--m-cyan) 16%, transparent) 0%,
      transparent 55%
    );
    pointer-events: none;
  }
  .trustpg__close-card::after {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--m-cyan) 22%, var(--m-cyan) 78%, transparent);
    pointer-events: none;
  }
  .trustpg__close-inner {
    position: relative;
    padding: clamp(40px, 5.5vw, 68px) clamp(28px, 5vw, 60px);
    max-width: 60ch;
  }
  .trustpg__close-eyebrow {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }
  .trustpg__close-title {
    margin-top: 16px;
    font-family: var(--m-font-sans);
    font-weight: 600;
    font-size: clamp(32px, 4.4vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: #fff;
    text-wrap: balance;
  }
  .trustpg__close-body {
    margin-top: 18px;
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
  }
  .trustpg__close-btn {
    margin-top: 28px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 44px;
    padding-inline: 20px;
    border-radius: 8px;
    background: #fff;
    color: var(--m-accent);
    font-size: var(--m-text-base);
    font-weight: 500;
    transition:
      background 0.18s ease,
      transform 0.12s ease;
  }
  .trustpg__close-btn span {
    transition: transform 0.18s ease;
  }
  .trustpg__close-btn:hover {
    background: rgba(255, 255, 255, 0.9);
  }
  .trustpg__close-btn:hover span {
    transform: translateX(3px);
  }
  .trustpg__close-btn:active {
    transform: translateY(1px);
  }
</style>
