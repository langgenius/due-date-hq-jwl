---
/** TrustPage — about / security / privacy / terms / status. Uses the shared
 *  long-tail page kit (.m-page-* / .m-card / .m-btn) so it matches the home. */
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'
import type { TrustPageCopy } from '../lib/trust-pages'

interface Props {
  page: TrustPageCopy
  locale: 'en' | 'zh-CN'
}

const { page, locale } = Astro.props
const lastReviewedLabel = locale === 'zh-CN' ? '最近复核' : 'Last reviewed'
---

<main>
  <section class="m-section m-page-hero" id="hero">
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class="m-page-title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {lastReviewedLabel}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  {
    page.sections.map((section) => (
      <section class="m-section m-page-block">
        <div class="m-page-split">
          <div class="m-page-split__lead">
            <p class="m-eyebrow">{section.eyebrow}</p>
            <h2 class="m-page-h2">{section.title}</h2>
            <p class="m-page-body">{section.body}</p>
          </div>
          <div class="m-page-cards">
            {section.items.map((item) => (
              <article class="m-card">
                <h3 class="m-card__t">{item.title}</h3>
                <p class="m-card__d">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="m-section m-page-block">
    <div class="m-page-cta">
      <div>
        <h2 class="m-page-cta__title">{page.contact.title}</h2>
        <p class="m-page-cta__body">{page.contact.body}</p>
      </div>
      <div class="m-page-cta__btns">
        <a class="m-btn m-btn--primary" href={page.contact.href}>{page.contact.label}</a>
      </div>
    </div>
  </section>
</main>
