---
import type { GuidePageCopy, ResourcePageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'

interface Props {
  page: ResourcePageCopy | GuidePageCopy
  primaryHref: string
  secondaryHref: string
  locale: 'en' | 'zh-CN'
}

const { page, primaryHref, secondaryHref, locale } = Astro.props
const lastReviewedLabel = locale === 'zh-CN' ? '最近复核' : 'Last reviewed'
---

<main>
  <section id="hero" class="border-b border-border-default bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-16 md:px-12 lg:px-20 lg:py-20">
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {page.hero.eyebrow}
      </span>
      <h1
        class="mt-5 max-w-[900px] text-display-large font-semibold leading-[1.1] tracking-tight text-text-primary"
      >
        {page.hero.title}
      </h1>
      <p class="mt-5 max-w-[820px] text-[17px] leading-[1.65] text-text-secondary">
        {page.hero.description}
      </p>
      <p class="mt-6 max-w-[780px] font-mono text-[12px] leading-5 text-text-muted">
        {page.hero.note}
      </p>
      <p class="mt-4 font-mono text-[12px] text-text-muted">
        {lastReviewedLabel}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
      </p>
    </div>
  </section>

  {
    page.keyDates && (
      <section class="border-b border-border-default bg-bg-canvas">
        <div class="mx-auto max-w-[1440px] px-6 py-14 md:px-12 lg:px-20 lg:py-16">
          <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
            {page.keyDates.eyebrow}
          </span>
          <h2 class="mt-4 max-w-[720px] text-[24px] font-semibold leading-[1.25] tracking-tight text-text-primary">
            {page.keyDates.title}
          </h2>
          <dl class="mt-8 max-w-[840px] divide-y divide-border-default rounded-xl border border-border-default bg-bg-panel">
            {page.keyDates.rows.map((row) => (
              <div class="grid gap-2 px-6 py-4 sm:grid-cols-[210px_1fr] sm:gap-6">
                <dt class="font-mono text-[13px] font-medium text-text-primary">{row.label}</dt>
                <dd class="text-[14px] leading-[1.6] text-text-secondary">{row.value}</dd>
              </div>
            ))}
          </dl>
          <p class="mt-5 max-w-[840px] font-mono text-[12px] leading-5 text-text-muted">
            {page.keyDates.note}
          </p>
          <p class="mt-3 text-[13px]">
            <a
              href={page.keyDates.sourceHref}
              class="text-text-accent underline underline-offset-2"
              rel="nofollow noopener"
              target="_blank"
            >
              {page.keyDates.sourceLabel}
            </a>
          </p>
        </div>
      </section>
    )
  }

  {
    page.sections.map((section) => (
      <section class="border-b border-border-default bg-bg-canvas">
        <div class="mx-auto grid max-w-[1440px] gap-10 px-6 py-14 md:px-12 lg:grid-cols-12 lg:px-20 lg:py-16">
          <div class="lg:col-span-5">
            <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
              {section.eyebrow}
            </span>
            <h2 class="mt-4 max-w-[620px] text-[28px] font-semibold leading-[1.2] tracking-tight text-text-primary">
              {section.title}
            </h2>
            <p class="mt-5 max-w-[640px] text-[15px] leading-[1.7] text-text-secondary">
              {section.body}
            </p>
          </div>
          <div class="grid gap-4 lg:col-span-7 lg:grid-cols-3">
            {section.items.map((item) => (
              <article class="rounded-xl border border-border-default bg-bg-panel p-6">
                <h3 class="text-[15px] font-semibold leading-[1.4] text-text-primary">
                  {item.title}
                </h3>
                <p class="mt-3 text-[13px] leading-[1.65] text-text-secondary">
                  {item.body}
                </p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="border-b border-border-default bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-14 md:px-12 lg:px-20 lg:py-16">
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {page.faqHeader.eyebrow}
      </span>
      <h2 class="mt-4 text-[24px] font-semibold leading-[1.25] tracking-tight text-text-primary">
        {page.faqHeader.title}
      </h2>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {
          page.faq.map((item) => (
            <section class="rounded-xl border border-border-default bg-bg-panel p-6">
              <h3 class="text-[15px] font-semibold leading-[1.4] text-text-primary">
                {item.question}
              </h3>
              <p class="mt-3 text-[13px] leading-[1.65] text-text-secondary">
                {item.answer}
              </p>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-14 md:px-12 lg:px-20 lg:py-16">
      <div class="rounded-xl border border-border-default bg-bg-panel p-8 lg:flex lg:items-center lg:justify-between lg:gap-10">
        <div>
          <h2 class="max-w-[720px] text-[26px] font-semibold leading-[1.25] tracking-tight text-text-primary">
            {page.cta.title}
          </h2>
          <p class="mt-4 max-w-[760px] text-[14px] leading-[1.7] text-text-secondary">
            {page.cta.body}
          </p>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row lg:mt-0 lg:shrink-0">
          <a
            href={primaryHref}
            class="inline-flex h-11 items-center justify-center rounded-md bg-accent-default px-4 text-[13px] font-medium text-primary-foreground outline-none transition-colors hover:bg-accent-hover focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          >
            {page.cta.primary}
          </a>
          <a
            href={secondaryHref}
            class="inline-flex h-11 items-center justify-center rounded-md border border-border-strong bg-bg-elevated px-4 text-[13px] font-medium text-text-primary outline-none transition-colors hover:border-text-muted hover:bg-bg-canvas focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          >
            {page.cta.secondary}
          </a>
        </div>
      </div>
    </div>
  </section>
</main>
