---
/** GeoResourcePage — shared template for the long-tail SEO/AEO/GEO pages:
 *  rule references, comparisons, and guides (hubs + leaves). Uses the shared
 *  long-tail page kit (.m-page-* / .m-card / .m-btn in marketing.css) so it
 *  matches the home's design language; content + SEO are unchanged. */
import type { GuidePageCopy, ResourcePageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'

interface Props {
  page: ResourcePageCopy | GuidePageCopy
  primaryHref: string
  secondaryHref: string
  locale: 'en' | 'zh-CN'
}

const { page, primaryHref, secondaryHref, locale } = Astro.props
const lastReviewedLabel = locale === 'zh-CN' ? '最近复核' : 'Last reviewed'
---

<main>
  <section class="m-section m-page-hero" id="hero">
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class="m-page-title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {lastReviewedLabel}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  {
    page.keyDates && (
      <section class="m-section m-page-block">
        <p class="m-eyebrow">{page.keyDates.eyebrow}</p>
        <h2 class="m-page-h2">{page.keyDates.title}</h2>
        <dl class="m-page-dl">
          {page.keyDates.rows.map((row) => (
            <div class="m-page-dl__row">
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))}
        </dl>
        <p class="m-page-note">{page.keyDates.note}</p>
        <p class="m-page-source">
          <a class="m-link" href={page.keyDates.sourceHref} rel="nofollow noopener" target="_blank">
            {page.keyDates.sourceLabel}
          </a>
        </p>
      </section>
    )
  }

  {
    page.sections.map((section) => (
      <section class="m-section m-page-block">
        <div class="m-page-split">
          <div class="m-page-split__lead">
            <p class="m-eyebrow">{section.eyebrow}</p>
            <h2 class="m-page-h2">{section.title}</h2>
            <p class="m-page-body">{section.body}</p>
          </div>
          <div class="m-page-cards">
            {section.items.map((item) => (
              <article class="m-card">
                <h3 class="m-card__t">{item.title}</h3>
                <p class="m-card__d">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{page.faqHeader.eyebrow}</p>
    <h2 class="m-page-h2">{page.faqHeader.title}</h2>
    <div class="m-page-grid-3">
      {
        page.faq.map((item) => (
          <section class="m-card">
            <h3 class="m-card__t">{item.question}</h3>
            <p class="m-card__d">{item.answer}</p>
          </section>
        ))
      }
    </div>
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-cta">
      <div>
        <h2 class="m-page-cta__title">{page.cta.title}</h2>
        <p class="m-page-cta__body">{page.cta.body}</p>
      </div>
      <div class="m-page-cta__btns">
        <a class="m-btn m-btn--primary" href={primaryHref}>{page.cta.primary}</a>
        <a class="m-btn m-btn--secondary" href={secondaryHref}>{page.cta.secondary}</a>
      </div>
    </div>
  </section>
</main>

<style>
  .m-page-source {
    margin-top: 14px;
  }
  .m-link {
    font-size: 13px;
    color: var(--m-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .m-link:hover {
    color: var(--m-accent-strong);
  }
</style>
