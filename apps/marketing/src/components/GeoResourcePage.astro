---
/** GeoResourcePage — shared template for the long-tail SEO/AEO/GEO pages:
 *  rule references, comparisons, and guides (hubs + leaves). Uses the shared
 *  long-tail page kit (.m-page-* / .m-card / .m-btn in marketing.css) so it
 *  matches the home's design language; content + SEO are unchanged.
 *
 *  Design intent: these are proof / answer pages — restrained but deliberate.
 *  A stronger, anchored page-hero; the key-dates list reads as a sourced fact
 *  table (the page's core trust artifact); sections carry a numbered editorial
 *  rhythm so a stack of them feels intentional; FAQ blocks read as Q→A pairs
 *  for AEO; and a confident "next step" block links back into the funnel above
 *  the CTA. Content slots, headings, ids and the source link are untouched. */
import type { GuidePageCopy, ResourcePageCopy } from '../i18n/types'
import { getContentDates } from '../lib/content-metadata'
import type { ResourceLink } from '../lib/seo-content'
import FaqList from './FaqList.astro'

interface Props {
  page: ResourcePageCopy | GuidePageCopy
  primaryHref: string
  secondaryHref: string
  locale: 'en' | 'zh-CN'
  /** Optional parent for the in-hero "back up a level" link (leaf pages only). */
  back?: { href: string; label: string }
  /** Optional cross-links rendered in a "Keep exploring" block above the CTA. */
  related?: ResourceLink[]
  /** Heading for the related block; defaults to a localized "Keep exploring". */
  relatedTitle?: string
}

const { page, primaryHref, secondaryHref, locale, back, related, relatedTitle } = Astro.props
const zh = locale === 'zh-CN'

// Visible "Last reviewed" date — per-slug when an override exists (guides carry a
// slug; bare ResourcePageCopy hubs fall back to the site-wide reviewed date).
const reviewedOn = getContentDates('slug' in page ? page.slug : undefined).reviewedOn

// The hero's product peek is built from the page's OWN first sourced date — real
// data, no fabrication. Pages without key dates (some guides) fall back to a
// labelled placeholder figure so the hero still carries a visual.
const peekDate = page.keyDates?.rows?.[0]

// Optional DueDateHQ-vs-product table (comparison pages only).
const cmp = 'comparisonTable' in page ? page.comparisonTable : undefined

const t = zh
  ? {
      lastReviewed: '最近复核',
      sourced: '每个日期都附官方来源',
      nextEyebrow: '下一步',
      relatedTitle: '继续了解',
      nextTitle: '把这条规则接到你真实的客户名单上',
      nextBody: '阅读是一回事。真正的价值，是当这条日期变动时，你立刻知道它影响到你的哪些客户。',
      nextPrimary: '开始监控我的客户',
      nextSecondary: '看它如何运作',
      watchedIn: 'DueDateHQ 持续监控',
      previewTag: '预览',
      nextDeadline: '下一个截止日',
      peekCaption: '这个日期一变动，你当天就能看清它影响到哪些客户。',
      figureAlt: '产品预览',
    }
  : {
      lastReviewed: 'Last reviewed',
      sourced: 'A source on every date',
      nextEyebrow: 'Next step',
      relatedTitle: 'Keep exploring',
      nextTitle: 'Put this rule against your actual client list',
      nextBody:
        'Reading it is one thing. The point is knowing — the moment this date moves — exactly which of your clients it affects.',
      nextPrimary: 'Start watching my clients',
      nextSecondary: 'See how it works',
      watchedIn: 'Watched in DueDateHQ',
      previewTag: 'Preview',
      nextDeadline: 'Next deadline',
      peekCaption: 'If this date moves, you see exactly which clients it hits — the same day.',
      figureAlt: 'Product preview',
    }
---

<main class="geo">
  <section class="m-section m-page-hero geo-hero" id="hero">
    <div class="geo-hero__text">
    {
      back && (
        <a class="m-page-back" href={back.href}>
          <span class="m-page-back__arrow" aria-hidden="true">←</span>
          {zh ? `返回${back.label}` : `Back to ${back.label}`}
        </a>
      )
    }
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class="m-page-title geo-hero__title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note geo-hero__note">{page.hero.note}</p>
    <div class="geo-trust">
      <span class="geo-trust__item">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 3l7 3v5c0 4.2-2.9 7.4-7 8.8C7.9 18.4 5 15.2 5 11V6l7-3z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
          ></path>
          <path
            d="M9.2 11.8l2 2 3.6-3.8"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
        {t.lastReviewed}
        <time class="geo-trust__date" datetime={reviewedOn}>{reviewedOn}</time>
      </span>
      <span class="geo-trust__sep" aria-hidden="true"></span>
      <span class="geo-trust__item geo-trust__item--muted">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M10 14a5 5 0 007.5.5l3-3a5 5 0 00-7-7l-1.7 1.7M14 10a5 5 0 00-7.5-.5l-3 3a5 5 0 007 7l1.7-1.7"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
        {t.sourced}
      </span>
    </div>
    </div>

    <aside class="geo-hero__aside">
      {
        peekDate ? (
          <div class="geo-peek" role="img" aria-label={`${t.watchedIn} · ${t.previewTag}`}>
            <div class="geo-peek__bar">
              <span class="geo-peek__live" aria-hidden="true" />
              <span class="geo-peek__app">{t.watchedIn}</span>
              <span class="geo-peek__tag">{t.previewTag}</span>
            </div>
            <div class="geo-peek__card">
              <p class="geo-peek__eyebrow">{page.hero.eyebrow}</p>
              <p class="geo-peek__dl-label">{t.nextDeadline}</p>
              <p class="geo-peek__dl">{peekDate.value}</p>
              <span class="geo-peek__src">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {page.keyDates?.sourceLabel}
              </span>
            </div>
            <p class="geo-peek__cap">{t.peekCaption}</p>
          </div>
        ) : (
          <figure class="m-figure geo-hero__figure" aria-label={t.figureAlt}>
            <span class="m-figure__mark">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.6" />
                <circle cx="8.5" cy="9.5" r="1.5" fill="currentColor" />
                <path
                  d="M21 15l-5-4-5 4-3-2-5 4"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              {t.figureAlt}
            </span>
          </figure>
        )
      }
    </aside>
  </section>

  {
    page.keyDates && (
      <section class="m-section m-page-block geo-block" id="key-dates">
        <p class="m-eyebrow">{page.keyDates.eyebrow}</p>
        <h2 class="m-page-h2">{page.keyDates.title}</h2>
        <div class="geo-facts">
          <div class="geo-facts__head" aria-hidden="true">
            <span>{page.keyDates.eyebrow}</span>
            <span class="geo-facts__head-src">
              <span class="geo-facts__src-dot" />
              {t.sourced}
            </span>
          </div>
          <dl class="geo-facts__dl">
            {page.keyDates.rows.map((row) => (
              <div class="geo-facts__row">
                <dt>{row.label}</dt>
                <dd>{row.value}</dd>
              </div>
            ))}
          </dl>
          <div class="geo-facts__foot">
            <p class="geo-facts__note">{page.keyDates.note}</p>
            <a
              class="geo-source"
              href={page.keyDates.sourceHref}
              rel="nofollow noopener"
              target="_blank"
            >
              {page.keyDates.sourceLabel}
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M7 17L17 7M9 7h8v8"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        </div>
      </section>
    )
  }

  {
    cmp && (
      <section class="m-section m-page-block geo-block" id="at-a-glance">
        <p class="m-eyebrow">{cmp.eyebrow}</p>
        <h2 class="m-page-h2">{cmp.title}</h2>
        <div class="geo-cmp">
          <div class="geo-cmp__head" aria-hidden="true">
            <span class="geo-cmp__dim" />
            <span class="geo-cmp__mine">{cmp.mineLabel}</span>
            <span class="geo-cmp__theirs">{cmp.theirsLabel}</span>
          </div>
          {cmp.rows.map((row) => (
            <div class="geo-cmp__row">
              <span class="geo-cmp__dim">{row.dimension}</span>
              <span class="geo-cmp__mine">
                <span class="geo-cmp__k">{cmp.mineLabel}</span>
                {row.mine}
              </span>
              <span class="geo-cmp__theirs">
                <span class="geo-cmp__k">{cmp.theirsLabel}</span>
                {row.theirs}
              </span>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    page.sections.map((section, i) => (
      <section class="m-section m-page-block geo-block geo-sec">
        <div class="m-page-split">
          <div class="m-page-split__lead geo-sec__lead">
            <span class="geo-sec__num" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <p class="m-eyebrow">{section.eyebrow}</p>
            <h2 class="m-page-h2">{section.title}</h2>
            <p class="m-page-body">{section.body}</p>
          </div>
          <div class="m-page-cards geo-cards">
            {section.items.map((item) => (
              <article class="m-card geo-card">
                <h3 class="m-card__t">{item.title}</h3>
                <p class="m-card__d">{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="m-section m-page-block geo-block geo-faq" id="faq">
    <FaqList eyebrow={page.faqHeader.eyebrow} title={page.faqHeader.title} items={page.faq} />
  </section>

  {
    related && related.length > 0 && (
      <section class="m-section m-page-block geo-block geo-related" aria-labelledby="geo-related-h">
        <h2 class="m-page-h2 geo-related__title" id="geo-related-h">
          {relatedTitle ?? t.relatedTitle}
        </h2>
        <ul class="geo-related__list">
          {related.map((link) => (
            <li>
              <a class="geo-related__link" href={link.href}>
                <span>{link.label}</span>
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M5 12h14M13 6l6 6-6 6"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="m-section m-page-block geo-block">
    <div class="geo-next">
      <p class="m-eyebrow geo-next__eyebrow">{t.nextEyebrow}</p>
      <div class="geo-next__row">
        <div class="geo-next__copy">
          <h2 class="m-page-h2 geo-next__title">{page.cta.title || t.nextTitle}</h2>
          <p class="geo-next__body">{page.cta.body || t.nextBody}</p>
        </div>
        <div class="geo-next__btns">
          <a class="m-btn m-btn--primary geo-next__primary" href={primaryHref}>
            {page.cta.primary}
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </a>
          <a class="m-btn m-btn--secondary" href={secondaryHref}>{page.cta.secondary}</a>
        </div>
      </div>
    </div>
  </section>
</main>

<style>
  /* ====================================================================
     Long-tail proof / answer page — restrained but deliberate.
     Reuses the .m-page-* / .m-card / .m-btn kit; these scoped rules add
     hierarchy, rhythm and trust treatment on top of it.
     ==================================================================== */

  /* ---- hero ---- */
  /* 2-column hero: serif text + a product peek built from the page's OWN sourced
     date — every leaf shows the product, the way the home hero does. */
  .geo-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }
  .geo-hero__aside {
    width: 100%;
  }
  @media (max-width: 880px) {
    .geo-hero {
      grid-template-columns: 1fr;
      gap: clamp(24px, 5vw, 36px);
    }
    .geo-hero__aside {
      max-width: 460px;
    }
  }
  .geo-hero__title {
    max-width: 20ch;
  }
  .geo-hero__note {
    max-width: 64ch;
  }
  /* product peek — a compact in-product card echoing the home alert feed */
  .geo-peek {
    border-radius: 12px;
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    overflow: hidden;
  }
  .geo-peek__bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--m-hairline);
    background: var(--m-section);
    font-size: var(--m-text-xs);
  }
  .geo-peek__live {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--m-ok);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-ok) 18%, transparent);
  }
  .geo-peek__app {
    font-weight: 600;
    color: var(--m-ink);
  }
  .geo-peek__tag {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--m-faint);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .geo-peek__card {
    padding: 16px 18px;
  }
  .geo-peek__eyebrow {
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .geo-peek__dl-label {
    margin-top: 12px;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }
  .geo-peek__dl {
    margin-top: 3px;
    font-family: var(--m-font-mono);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .geo-peek__src {
    margin-top: 13px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--m-text-xs);
    color: var(--m-accent);
  }
  .geo-peek__src svg {
    width: 13px;
    height: 13px;
    flex: none;
  }
  .geo-peek__cap {
    padding: 13px 18px;
    border-top: 1px solid var(--m-hairline-2);
    background: var(--m-accent-tint);
    font-size: var(--m-text-sm);
    line-height: 1.5;
    color: var(--m-ink-2);
  }
  .geo-hero__figure {
    --m-figure-ratio: 4 / 3;
  }
  /* trust row — the reviewed date + "sourced on every date" are real signals
     for an answer page; present them as a calm, confident bar, not afterthought */
  .geo-trust {
    margin-top: 22px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 16px;
  }
  .geo-trust__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-ink-2);
  }
  .geo-trust__item--muted {
    color: var(--m-muted);
    font-weight: 400;
  }
  .geo-trust__item svg {
    width: 15px;
    height: 15px;
    flex: none;
    color: var(--m-accent);
  }
  .geo-trust__item--muted svg {
    color: var(--m-muted);
  }
  .geo-trust__date {
    font-family: var(--m-font-mono);
    color: var(--m-ink);
  }
  .geo-trust__sep {
    width: 1px;
    height: 14px;
    background: var(--m-hairline);
  }

  /* ---- shared block rhythm ---- */
  /* tighten the first block's top rule into the hero so the page reads as one
     intentional column, not loose stacked panels */
  .geo-block > .m-eyebrow {
    margin-bottom: 12px;
  }

  /* ---- key-dates → sourced fact table ---- */
  .geo-facts {
    margin-top: 26px;
    max-width: 880px;
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--m-surface);
  }
  .geo-facts__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 11px 22px;
    background: var(--m-section);
    border-bottom: 1px solid var(--m-hairline);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-muted);
  }
  .geo-facts__head-src {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    letter-spacing: 0.04em;
    color: var(--m-faint);
  }
  .geo-facts__src-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    flex: none;
    background: var(--m-ok);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-ok) 16%, transparent);
  }
  .geo-facts__dl {
    margin: 0;
  }
  .geo-facts__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: 16px 28px;
    padding: 15px 22px;
  }
  .geo-facts__row + .geo-facts__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .geo-facts__row dt {
    font-size: var(--m-text-base);
    font-weight: 500;
    color: var(--m-ink);
    line-height: 1.45;
  }
  /* dates align to the right rail in mono — scannable as a real fact table */
  .geo-facts__row dd {
    margin: 0;
    text-align: right;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-base);
    line-height: 1.5;
    color: var(--m-ink-2);
    white-space: nowrap;
  }
  .geo-facts__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px 28px;
    flex-wrap: wrap;
    padding: 14px 22px;
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline);
  }
  .geo-facts__note {
    margin: 0;
    max-width: 58ch;
    font-size: var(--m-text-sm);
    line-height: 1.55;
    color: var(--m-muted);
  }
  /* official source — the page's trust artifact, treated as a confident link */
  .geo-source {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex: none;
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--m-accent) 40%, transparent);
    transition:
      color 0.16s ease,
      text-decoration-color 0.16s ease;
  }
  .geo-source svg {
    width: 13px;
    height: 13px;
    flex: none;
  }
  .geo-source:hover {
    color: var(--m-accent-strong);
    text-decoration-color: currentColor;
  }

  /* ---- comparison "at a glance" — DueDateHQ vs a product, side by side ---- */
  .geo-cmp {
    margin-top: 26px;
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--m-surface);
  }
  .geo-cmp__head,
  .geo-cmp__row {
    display: grid;
    grid-template-columns: minmax(110px, 0.7fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px 26px;
    padding: 15px 22px;
  }
  .geo-cmp__head {
    background: var(--m-section);
    border-bottom: 1px solid var(--m-hairline);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-muted);
  }
  .geo-cmp__head .geo-cmp__mine {
    color: var(--m-accent);
  }
  .geo-cmp__row + .geo-cmp__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .geo-cmp__row {
    font-size: var(--m-text-sm);
    line-height: 1.55;
  }
  .geo-cmp__dim {
    font-weight: 600;
    color: var(--m-ink);
  }
  /* DueDateHQ column reads slightly stronger than the product column */
  .geo-cmp__mine {
    color: var(--m-ink-2);
  }
  .geo-cmp__theirs {
    color: var(--m-muted);
  }
  /* per-cell label — hidden on desktop (the header carries it), shown when stacked */
  .geo-cmp__k {
    display: none;
  }
  @media (max-width: 720px) {
    .geo-cmp__head {
      display: none;
    }
    .geo-cmp__row {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px 18px;
    }
    .geo-cmp__dim {
      font-size: var(--m-text-base);
    }
    .geo-cmp__k {
      display: block;
      font-family: var(--m-font-mono);
      font-size: var(--m-text-3xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--m-faint);
