---
import type { ProblemCopy } from '../i18n/types'
import {
  marketingBadgeBase as badgeBase,
  marketingBadgeTone as badgeTone,
  marketingSeverityBadgeTone,
  marketingSeverityDot,
  marketingSeverityRow,
  marketingStatusDot as statusDot,
  marketingTable,
} from '../lib/marketing-table-styles'
import SectionEyebrow from './primitives/SectionEyebrow.astro'

interface Props {
  t: ProblemCopy
}

const { t } = Astro.props
---

<section class="border-b border-border-default bg-bg-canvas">
  <div class="mx-auto max-w-[1440px] px-6 py-20 sm:px-10 lg:px-20">
    <!-- Section header -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <SectionEyebrow index={t.index} label={t.eyebrow} />
        <h2 class="mt-6 max-w-[640px] text-display-large font-semibold tracking-tight text-text-primary">
          {t.title}
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-[15px] leading-relaxed text-text-secondary">{t.paragraph}</p>
        <p class="mt-6 font-mono text-sm text-text-muted">{t.footnote}</p>
      </div>
    </div>

    <!-- Cards grid -->
    <div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-3">
      {t.cards.map((card) => (
        <article class="rounded-xl border border-components-card-border bg-components-card-bg p-4">
          <div class="flex items-center justify-between">
            <span class:list={[badgeBase, badgeTone[marketingSeverityBadgeTone[card.severity]], 'font-mono tracking-eyebrow']}>
              <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[marketingSeverityDot[card.severity]]]}></span>
              {card.tag}
            </span>
            <span class="font-mono text-xs text-text-tertiary">{card.cadence}</span>
          </div>
          <h3 class="mt-7 text-[20px] font-semibold leading-snug text-text-primary">{card.headline}</h3>
          <p class="mt-6 text-description leading-relaxed text-text-secondary">{card.body}</p>
          <div class="mt-8 overflow-hidden rounded-lg border border-divider-regular bg-background-section">
            <div class="flex h-9 items-center justify-between border-b border-divider-regular px-3 text-xs">
              <span class="font-medium text-text-primary">{card.listTitle}</span>
              <span class="font-mono text-xs text-text-tertiary">{card.listSummary}</span>
            </div>
            <table class:list={[marketingTable.table, 'table-fixed']}>
              <tbody class={marketingTable.body}>
                {card.rows.map((row) => (
                  <tr class:list={[marketingTable.row, row.severity && marketingSeverityRow[row.severity]]}>
                    <td class:list={[marketingTable.compactCell, 'w-[36%]']}>
                      <span class:list={[badgeBase, badgeTone[row.pillTone ?? 'outline'], 'max-w-[112px] font-mono']}>
                        <span class:list={['inline-block size-2 shrink-0 rounded-full', statusDot[row.dotTone ?? (row.severity ? marketingSeverityDot[row.severity] : 'normal')]]}></span>
                        <span class="truncate">{row.pill}</span>
                      </span>
                    </td>
                    <td class:list={[marketingTable.compactCell, 'min-w-0 text-text-secondary']}>
                      <span class="block truncate">{row.text}</span>
                    </td>
                    <td class:list={[marketingTable.compactCell, 'w-[28%] text-right']}>
                      <span class:list={[badgeBase, badgeTone[row.severity ? marketingSeverityBadgeTone[row.severity] : 'outline'], 'ml-auto font-mono']}>{row.date}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
