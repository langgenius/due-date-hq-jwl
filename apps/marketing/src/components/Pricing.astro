<script>
  type PricingInterval = 'monthly' | 'yearly'

  function setPricingInterval(root: HTMLElement, interval: PricingInterval) {
    root.dataset.billingInterval = interval

    // active styling is driven by aria-pressed in CSS — only set the state here
    root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
      button.setAttribute('aria-pressed', String(button.dataset.pricingBillingToggle === interval))
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-price]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-cadence]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-savings]').forEach((node) => {
      node.classList.toggle('is-hidden', interval !== 'yearly')
    })

    root.querySelectorAll<HTMLAnchorElement>('[data-pricing-cta]').forEach((link) => {
      const next = interval === 'yearly' ? link.dataset.hrefYearly : link.dataset.hrefMonthly
      if (next) link.setAttribute('href', next)
    })
  }

  function initPricingBillingToggles() {
    document.querySelectorAll<HTMLElement>('[data-pricing-root]').forEach((root) => {
      root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
          const interval = button.dataset.pricingBillingToggle
          if (interval === 'monthly' || interval === 'yearly') {
            setPricingInterval(root, interval)
          }
        })
      })
    })
  }

  // re-init on first load + every View-Transition navigation (DOMContentLoaded
  // does not fire on a client-side swap)
  document.addEventListener('astro:page-load', initPricingBillingToggles)
</script>
