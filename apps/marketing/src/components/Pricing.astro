---
import type {
  PricingBillingInterval,
  PricingCheckoutPlan,
  PricingCopy,
  PricingPlanCopy,
} from '../i18n/types'

interface Props {
  t: PricingCopy
  appHref: string
  checkoutHrefs: Record<PricingCheckoutPlan, Record<PricingBillingInterval, string>>
}

const { t, appHref, checkoutHrefs } = Astro.props

function hrefFor(plan: PricingPlanCopy, interval: PricingBillingInterval): string {
  if (plan.hrefKind === 'checkout') return checkoutHrefs[plan.checkoutPlan ?? 'pro'][interval]
  if (plan.hrefKind === 'app') return appHref
  return 'mailto:sales@duedatehq.com?subject=DueDateHQ%20Enterprise'
}
---

<section class="bg-bg-canvas" data-pricing-root data-billing-interval="monthly">
  <div class="mx-auto max-w-[1440px] px-20 py-20">
    <!-- Hero — Figma: pad 80/80/56/80, gap 20 -->
    <div>
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {t.hero.eyebrow}
      </span>
      <h1
        class="mt-5 max-w-[840px] text-display-large font-semibold leading-[1.1] tracking-tight text-text-primary"
      >
        {t.hero.title}
      </h1>
      <p class="mt-5 max-w-[760px] text-[17px] leading-[1.6] text-text-secondary">
        {t.hero.description}
      </p>
      <p class="mt-5 font-mono text-[11px] text-text-muted">{t.hero.note}</p>
    </div>

    <!-- Plans — Figma: pad 0/80/56/80 -->
    <section class="mt-14">
      <header class="flex flex-wrap items-end justify-between gap-4 pt-2 pb-6">
        <div class="flex flex-col gap-1.5">
          <span
            class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent"
          >
            {t.plansHeader.eyebrow}
          </span>
          <h2
            class="text-[22px] font-semibold leading-[1.3] tracking-tight text-text-primary"
          >
            {t.plansHeader.title}
          </h2>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-3">
          <span
            class="font-mono text-[11px] font-medium tracking-[0.13em] text-text-secondary"
          >
            {t.plansHeader.note}
          </span>
          <div
            role="group"
            aria-label={t.billingToggle.ariaLabel}
            class="inline-flex h-11 max-w-full items-center rounded-lg border border-border-default bg-bg-elevated p-1"
          >
            <button
              type="button"
              data-pricing-billing-toggle="monthly"
              aria-pressed="true"
              class="inline-flex h-9 min-w-24 items-center justify-center rounded-md bg-accent-default px-3 text-[13px] font-medium text-primary-foreground shadow-sm transition-colors"
            >
              {t.billingToggle.monthly}
            </button>
            <button
              type="button"
              data-pricing-billing-toggle="yearly"
              aria-pressed="false"
              class="inline-flex h-9 min-w-40 items-center justify-center gap-2 rounded-md px-3 text-[13px] font-medium text-text-secondary outline-none transition-colors hover:bg-bg-panel hover:text-text-primary focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
            >
              <span>{t.billingToggle.yearly}</span>
              <span
                data-pricing-billing-badge
                class="rounded-sm bg-accent-tint px-2 py-0.5 font-mono text-[10px] font-medium text-text-accent"
              >
                {t.billingToggle.yearlyBadge}
              </span>
            </button>
          </div>
        </div>
      </header>

      <div class="grid items-stretch gap-4 md:grid-cols-2 xl:grid-cols-4">
        {
          t.plans.map((plan) => {
            const isRecommended = Boolean(plan.badge)
            const monthlyHref = hrefFor(plan, 'monthly')
            const yearlyHref = hrefFor(plan, 'yearly')
            return (
              <article
                class:list={[
                  'flex flex-col rounded-xl bg-bg-panel p-8',
                  isRecommended
                    ? 'border-[1.5px] border-accent-default bg-bg-elevated'
                    : 'border border-border-default',
                ]}
              >
                <div class="flex flex-1 flex-col gap-7">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="text-[18px] font-semibold leading-[1.4] tracking-tight text-text-primary">
                      {plan.name}
                    </h3>
                    {plan.badge ? (
                      <span class="rounded-sm bg-accent-tint px-2 py-1 text-[11px] font-medium tracking-eyebrow-tight text-text-accent">
                        {plan.badge}
                      </span>
                    ) : null}
                  </div>

                  <p class="text-[13px] leading-[1.6] text-text-secondary">
                    {plan.description}
                  </p>

                  <div class="flex flex-col gap-1.5 pt-1">
                    <div class="flex items-baseline gap-2">
                      <span
                        class:list={[
                          'text-[40px] font-semibold leading-none tracking-tight text-text-primary',
                          plan.priceKind === 'text' ? 'font-sans' : 'font-mono font-bold',
                        ]}
                      >
                        <span
                          data-pricing-price
                          data-monthly={plan.price}
                          data-yearly={plan.yearlyPrice ?? plan.price}
                        >
                          {plan.price}
                        </span>
                      </span>
                      <span
                        data-pricing-cadence
                        data-monthly={plan.cadence}
                        data-yearly={plan.yearlyCadence ?? plan.cadence}
                        class="text-[13px] leading-[1.4] text-text-secondary"
                      >
                        {plan.cadence}
                      </span>
                    </div>
                    {plan.yearlySavings ? (
                      <p
                        data-pricing-savings
                        class="hidden font-mono text-[11px] font-medium tracking-eyebrow-tight text-text-accent"
                      >
                        {plan.yearlySavings}
                      </p>
                    ) : null}
                    <p class="font-mono text-[11px] font-medium tracking-eyebrow-tight text-text-muted">
                      {plan.seats}
                    </p>
                  </div>

                  <div class="flex flex-col gap-2 rounded-lg border border-border-subtle bg-bg-canvas p-3">
                    <p class="w-fit rounded-sm border border-border-default bg-bg-panel px-2 py-1 font-mono text-[11px] font-medium tracking-eyebrow-tight text-text-primary">
                      {plan.aiLabel}
                    </p>
                    <p class="text-[13px] leading-[1.5] text-text-secondary">
                      {plan.aiDescription}
                    </p>
                    <ul class="flex flex-col gap-1.5 text-[12px] leading-[1.4] text-text-muted">
                      {plan.aiFeatures.map((feature) => (
                        <li class="flex items-start gap-2">
                          <span aria-hidden="true" class="mt-0.5 text-text-accent">
                            ✓
                          </span>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="h-px w-full bg-border-subtle" aria-hidden="true" />

                  <ul class="flex flex-col gap-3 text-[13px] leading-[1.5] text-text-primary">
                    {plan.features.map((feature) => (
                      <li class="flex items-center gap-2.5">
                        <span
                          aria-hidden="true"
                          class="grid size-4 shrink-0 place-items-center rounded-sm bg-accent-tint text-[10px] font-semibold leading-none text-text-accent"
                        >
                          ✓
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <a
                  href={monthlyHref}
                  data-pricing-cta
                  data-href-monthly={monthlyHref}
                  data-href-yearly={yearlyHref}
                  class:list={[
                    'mt-10 inline-flex h-11 items-center justify-center gap-1.5 rounded-md px-3.5 text-[13px] font-medium transition-colors',
                    isRecommended
                      ? 'bg-accent-default text-primary-foreground hover:bg-accent-hover'
                      : 'border border-border-strong bg-bg-elevated text-text-primary hover:border-text-muted hover:bg-bg-canvas',
                  ]}
                  data-event={`marketing.pricing.${plan.hrefKind}`}
                >
                  <span>{plan.cta}</span>
                  {isRecommended ? <span aria-hidden="true">→</span> : null}
                </a>
              </article>
            )
          })
        }
      </div>
    </section>

    <!-- FAQ — Figma: pad 24/80/96/80, gap 32 -->
    <section class="mt-6 pt-6 pb-12">
      <header class="mb-8 flex flex-col gap-2">
        <span
          class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent"
        >
          {t.faqHeader.eyebrow}
        </span>
        <h2
          class="text-[24px] font-semibold leading-[1.3] tracking-tight text-text-primary"
        >
          {t.faqHeader.title}
        </h2>
      </header>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          t.faq.map((item) => (
            <section class="flex flex-col gap-3 rounded-xl border border-border-default bg-bg-panel p-6">
              <h3 class="text-[15px] font-semibold leading-[1.4] tracking-tight text-text-primary">
                {item.question}
              </h3>
              <p class="text-[13px] leading-[1.65] text-text-secondary">
                {item.answer}
              </p>
            </section>
          ))
        }
      </div>
    </section>
  </div>
</section>

<script>
  type PricingInterval = 'monthly' | 'yearly'

  function setPricingInterval(root: HTMLElement, interval: PricingInterval) {
    root.dataset.billingInterval = interval

    root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
      const pressed = button.dataset.pricingBillingToggle === interval
      button.setAttribute('aria-pressed', String(pressed))
      button.classList.toggle('bg-accent-default', pressed)
      button.classList.toggle('text-primary-foreground', pressed)
      button.classList.toggle('shadow-sm', pressed)
      button.classList.toggle('text-text-secondary', !pressed)
      button.classList.toggle('hover:bg-bg-panel', !pressed)
      button.classList.toggle('hover:text-text-primary', !pressed)

      const badge = button.querySelector<HTMLElement>('[data-pricing-billing-badge]')
      badge?.classList.toggle('bg-white/20', pressed)
      badge?.classList.toggle('text-primary-foreground', pressed)
      badge?.classList.toggle('bg-accent-tint', !pressed)
      badge?.classList.toggle('text-text-accent', !pressed)
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-price]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-cadence]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-savings]').forEach((node) => {
      node.classList.toggle('hidden', interval !== 'yearly')
    })

    root.querySelectorAll<HTMLAnchorElement>('[data-pricing-cta]').forEach((link) => {
      const next = interval === 'yearly' ? link.dataset.hrefYearly : link.dataset.hrefMonthly
      if (next) link.setAttribute('href', next)
    })
  }

  function initPricingBillingToggles() {
    document.querySelectorAll<HTMLElement>('[data-pricing-root]').forEach((root) => {
      root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
          const interval = button.dataset.pricingBillingToggle
          if (interval === 'monthly' || interval === 'yearly') {
            setPricingInterval(root, interval)
          }
        })
      })
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricingBillingToggles, { once: true })
  } else {
    initPricingBillingToggles()
  }
</script>
