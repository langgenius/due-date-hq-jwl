---
/** Pricing — restyled to the marketing --m-* tier and pushed bolder. The four
 *  tiers, billing toggle, checkout hrefs, and data-* hooks are the team's live
 *  billing wiring and are preserved exactly; this pass strengthens the hierarchy
 *  (display-serif hero, a clearly-dominant recommended plan), adds a derived
 *  feature-comparison matrix and an "every plan includes" recap, and keeps the
 *  beta posture: pricing is real but DueDateHQ is free during the beta.
 *
 *  The comparison matrix is DERIVED from the same plan data rendered in the cards
 *  (allowances + the `Label: value` feature lines) — no new copy keys, no
 *  fabricated facts, one source of truth. */
import type {
  PricingBillingInterval,
  PricingCheckoutPlan,
  PricingCopy,
  PricingPlanCopy,
} from '../i18n/types'
import FaqList from './FaqList.astro'
import { getStartedHref } from '../lib/app-url'

interface Props {
  t: PricingCopy
  appHref: string
  checkoutHrefs: Record<PricingCheckoutPlan, Record<PricingBillingInterval, string>>
}

const { t, appHref, checkoutHrefs } = Astro.props
// locale is derived from the i18n payload (no extra prop the page wrappers must
// pass): the zh catalog routes pricing under /zh-CN/pricing.
const zh = t.navPricingHref.startsWith('/zh-CN')
const startHref = getStartedHref(zh ? 'zh-CN' : undefined)

function hrefFor(plan: PricingPlanCopy, interval: PricingBillingInterval): string {
  if (plan.hrefKind === 'checkout') return checkoutHrefs[plan.checkoutPlan ?? 'pro'][interval]
  return appHref
}

// ---- Derived comparison matrix --------------------------------------------
// Each feature line is authored as "Label: value". We split on the first colon
// so the matrix rows are the labels and the cells are the per-plan values —
// every datum already lives in the cards above, just transposed for scanning.
function splitFeature(feature: string): { label: string; value: string } {
  const idx = feature.indexOf(':')
  if (idx === -1) return { label: feature.trim(), value: '' }
  return { label: feature.slice(0, idx).trim(), value: feature.slice(idx + 1).trim() }
}

// allowance rows come first (clients / workspace / seats), then the labelled
// feature rows in author order. Labels are taken from the first plan so they
// stay in sync with whatever the copy authors name them.
const allowanceRows = [
  { label: zh ? '客户上限' : 'Clients', get: (p: PricingPlanCopy) => p.clients },
  { label: zh ? '工作区' : 'Workspace', get: (p: PricingPlanCopy) => p.firms },
  { label: zh ? '席位' : 'Seats', get: (p: PricingPlanCopy) => p.seats },
]

const featureLabels = t.plans[0].features.map((f) => splitFeature(f).label)
const featureRows = featureLabels.map((label, rowIdx) => ({
  label,
  values: t.plans.map((p) => splitFeature(p.features[rowIdx] ?? '').value),
}))

// ---- Page-specific copy (template-owned, not in the shared i18n object) ----
const ui = zh
  ? {
      betaTag: '上线活动',
      betaText:
        '定价是真实的——但现在，花两分钟告诉我们一点你的情况，前 3 个月的 Team 版免费。开始无需信用卡。',
      betaStrong: '免费',
      betaCta: '免费领 3 个月',
      matrixEyebrow: '逐项对比',
      matrixTitle: '四个套餐，并排看清。',
      matrixNote: '所有价格为月费；切换年付即按 8 折计费。',
      recapEyebrow: '每个套餐都包含',
      recapTitle: '无论选哪个套餐，核心保障都一样。',
      recap: [
        { icon: 'watch', t: '7×24 监控', d: 'IRS、全部 50 个州和 FEMA 一有变化就提醒。' },
        { icon: 'source', t: '每个日期都有来源', d: '官方原文链接随每条变更附上，可逐条点开核验。' },
        { icon: 'client', t: '精确到客户', d: '每次变化都标出影响到你的哪些客户。' },
        { icon: 'undo', t: '24 小时可撤销', d: '任何应用都能干净撤回，每一步都留审计记录。' },
      ],
      yes: '包含',
    }
  : {
      betaTag: 'Launch offer',
      betaText:
        "Pricing is real — but right now, tell us a little about your practice and your first 3 months on the Team plan are free. No card to start.",
      betaStrong: 'free',
      betaCta: 'Get 3 months free',
      matrixEyebrow: 'Side by side',
      matrixTitle: 'All four plans, line by line.',
      matrixNote: 'Prices shown monthly; switch to yearly to bill at 20% off.',
      recapEyebrow: 'In every plan',
      recapTitle: 'The core promise is the same on every plan.',
      recap: [
        { icon: 'watch', t: 'Watches 24/7', d: 'IRS, all 50 states, and FEMA — the moment a deadline moves.' },
        { icon: 'source', t: 'A source on every date', d: 'The official text is linked to every change, ready to verify.' },
        { icon: 'client', t: 'Down to the client', d: 'Every change flags exactly which of your clients it hits.' },
        { icon: 'undo', t: 'Reversible for 24h', d: 'Any apply undoes cleanly, with every action on the audit trail.' },
      ],
      yes: 'Included',
    }
---

<section class="m-section m-page-hero pr" data-pricing-root data-billing-interval="monthly">
  <div class="pr__hero">
    <p class="m-eyebrow">{t.hero.eyebrow}</p>
    <h1 class="m-page-title pr__title">{t.hero.title}</h1>
    <p class="m-page-lead pr__lead">{t.hero.description}</p>

    <div class="pr__beta" role="note">
      <span class="pr__beta-tag">{ui.betaTag}</span>
      <p class="pr__beta-text">{ui.betaText}</p>
      <a class="m-cta m-cta--primary pr__beta-cta" href={startHref}>
        {ui.betaCta} <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <p class="m-page-note pr__note">{t.hero.note}</p>
  </div>

  <section class="pr__plans">
    <header class="pr__planshead">
      <div>
        <p class="m-eyebrow">{t.plansHeader.eyebrow}</p>
        <h2 class="m-page-h2">{t.plansHeader.title}</h2>
      </div>
      <div class="pr__toggleblock">
        <div role="group" aria-label={t.billingToggle.ariaLabel} class="pr__toggle">
          <button type="button" data-pricing-billing-toggle="monthly" aria-pressed="true" class="pr__toggle-btn">
            {t.billingToggle.monthly}
          </button>
          <button type="button" data-pricing-billing-toggle="yearly" aria-pressed="false" class="pr__toggle-btn">
            <span>{t.billingToggle.yearly}</span>
            <span data-pricing-billing-badge class="pr__toggle-badge">{t.billingToggle.yearlyBadge}</span>
          </button>
        </div>
      </div>
    </header>

    <div class="pr__grid">
      {
        t.plans.map((plan) => {
          const isRecommended = Boolean(plan.badge)
          const monthlyHref = hrefFor(plan, 'monthly')
          const yearlyHref = hrefFor(plan, 'yearly')
          return (
            <article class:list={['pr__card', isRecommended && 'pr__card--rec']}>
              {plan.badge ? <p class="pr__ribbon">{plan.badge}</p> : null}
              <div class="pr__cardbody">
                <div class="pr__cardtop">
                  <h3 class="pr__name">{plan.name}</h3>
                  <p class="pr__desc">{plan.description}</p>
                </div>

                <div class="pr__priceblock">
                  <div class="pr__pricerow">
                    <span class:list={['pr__price', plan.priceKind === 'text' && 'pr__price--text']}>
                      <span data-pricing-price data-monthly={plan.price} data-yearly={plan.yearlyPrice ?? plan.price}>
                        {plan.price}
                      </span>
                    </span>
                    <span
                      data-pricing-cadence
                      data-monthly={plan.cadence}
                      data-yearly={plan.yearlyCadence ?? plan.cadence}
                      class="pr__cadence"
                    >
                      {plan.cadence}
                    </span>
                  </div>
                  {plan.yearlySavings ? (
                    <p data-pricing-savings class="pr__savings is-hidden">
                      {plan.yearlySavings}
                    </p>
                  ) : (
                    <p class="pr__savings-spacer" aria-hidden="true" />
                  )}
                </div>

                <a
                  href={monthlyHref}
                  data-pricing-cta
                  data-href-monthly={monthlyHref}
                  data-href-yearly={yearlyHref}
                  class:list={['pr__cta', isRecommended ? 'pr__cta--rec' : 'pr__cta--plain']}
                  data-event={`marketing.pricing.${plan.hrefKind}`}
                >
                  <span>{plan.cta}</span>
                  <span aria-hidden="true">→</span>
                </a>

                <dl class="pr__meta">
                  <div class="pr__metarow">
                    <dt>{zh ? '客户' : 'Clients'}</dt>
                    <dd class="pr__metastrong">{plan.clients}</dd>
                  </div>
                  <div class="pr__metarow">
                    <dt>{zh ? '工作区' : 'Workspace'}</dt>
                    <dd>{plan.firms}</dd>
                  </div>
                  <div class="pr__metarow">
                    <dt>{zh ? '席位' : 'Seats'}</dt>
                    <dd>{plan.seats}</dd>
                  </div>
                </dl>

                <div class="pr__divider" aria-hidden="true" />

                <ul class="pr__features">
                  {plan.features.map((feature) => (
                    <li class="pr__feat">
                      <span aria-hidden="true" class="pr__check">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="m3.5 8.5 3 3 6-7" />
                        </svg>
                      </span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          )
        })
      }
    </div>
  </section>

  <section class="pr__matrix-sec" aria-labelledby="pr-matrix-h">
    <p class="m-eyebrow">{ui.matrixEyebrow}</p>
    <h2 class="m-page-h2" id="pr-matrix-h">{ui.matrixTitle}</h2>

    <div class="pr__matrix-scroll">
      <div class="pr__matrix" role="table" aria-label={ui.matrixTitle}>
        <div class="pr__mr pr__mr--head" role="row">
          <div class="pr__mc pr__mc--head pr__mc--corner" role="columnheader" />
          {
            t.plans.map((plan) => (
              <div
                class:list={['pr__mc', 'pr__mc--head', Boolean(plan.badge) && 'pr__mc--rec pr__mhead--rec']}
                role="columnheader"
              >
                <span class="pr__mname">{plan.name}</span>
                <span class="pr__mprice">
                  <span data-pricing-price data-monthly={plan.price} data-yearly={plan.yearlyPrice ?? plan.price}>
                    {plan.price}
                  </span>
                  <span
                    class="pr__mcadence"
                    data-pricing-cadence
                    data-monthly={plan.cadence}
                    data-yearly={plan.yearlyCadence ?? plan.cadence}
                  >
                    {plan.cadence}
                  </span>
                </span>
              </div>
            ))
          }
        </div>

        <div class="pr__mr pr__mr--group" role="row">
          <div class="pr__mc pr__mc--group" role="cell" aria-colspan="5">{zh ? '容量' : 'Capacity'}</div>
        </div>
        {
          allowanceRows.map((row) => (
            <div class="pr__mr" role="row">
              <div class="pr__mc pr__mc--row" role="rowheader">{row.label}</div>
              {t.plans.map((plan) => (
                <div class:list={['pr__mc', 'pr__mc--cell', Boolean(plan.badge) && 'pr__mc--rec']} role="cell">
                  {row.get(plan)}
                </div>
              ))}
            </div>
          ))
        }

        <div class="pr__mr pr__mr--group" role="row">
          <div class="pr__mc pr__mc--group" role="cell" aria-colspan="5">{zh ? '能力' : 'What you get'}</div>
        </div>
        {
          featureRows.map((row) => (
            <div class="pr__mr" role="row">
              <div class="pr__mc pr__mc--row" role="rowheader">{row.label}</div>
              {row.values.map((value, i) => (
                <div
                  class:list={['pr__mc', 'pr__mc--cell', Boolean(t.plans[i].badge) && 'pr__mc--rec']}
                  role="cell"
                  aria-label={value ? undefined : zh ? '未包含' : 'Not included'}
                >
                  {value ? value : <span class="pr__mdash" aria-hidden="true" />}
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pr__recap">
    <div class="pr__recap-head">
      <p class="m-eyebrow">{ui.recapEyebrow}</p>
      <h2 class="m-page-h2">{ui.recapTitle}</h2>
    </div>
    <div class="pr__recap-panel">
      {
        ui.recap.map((r) => (
          <div class="pr__recap-item">
            <span class="pr__recap-ic" aria-hidden="true">
              {r.icon === 'watch' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="3" />
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                </svg>
              )}
              {r.icon === 'source' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12a3 3 0 0 1 3-3h4a3 3 0 0 1 0 6h-1" />
                  <path d="M15 12a3 3 0 0 1-3 3H8a3 3 0 0 1 0-6h1" />
                </svg>
              )}
              {r.icon === 'client' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="8.5" />
                  <circle cx="12" cy="12" r="3.2" />
                </svg>
              )}
              {r.icon === 'undo' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8h10a5 5 0 0 1 0 10H7" />
                  <path d="m3 8 4-4M3 8l4 4" />
                </svg>
              )}
            </span>
            <div class="pr__recap-text">
              <p class="pr__recap-t">{r.t}</p>
              <p class="pr__recap-d">{r.d}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="pr__faq">
    <FaqList eyebrow={t.faqHeader.eyebrow} title={t.faqHeader.title} items={t.faq} />
  </section>
</section>

<style>
  /* ---- hero: display-serif headline, beta posture front and centre ---- */
  /* hero padding comes from the shared .m-page-hero on the section (eyebrow lands
     at the same Y as every subpage); this only restores the hero → plans gap the
     inner wrapper used to carry */
  .pr__hero {
    margin-bottom: clamp(20px, 3vw, 36px);
  }
  /* font comes from the shared .m-page-title; only these overrides are page-specific */
  .pr__title {
    max-width: 18ch;
    line-height: 1;
  }
  .pr__lead {
    max-width: 62ch;
  }
  .pr__beta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 16px;
    margin-top: 28px;
    padding: 14px 16px 14px 18px;
    background: var(--m-accent-tint);
    border: 1px solid color-mix(in srgb, var(--m-accent) 18%, transparent);
    border-radius: 12px;
    max-width: 820px;
  }
  .pr__beta-text {
    flex: 1 1 320px;
  }
  .pr__beta-cta {
    flex: none;
    margin-left: auto;
  }
  .pr__beta-tag {
    flex: none;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    color: #fff;
    background: var(--m-accent);
  }
  .pr__beta-text {
    font-size: var(--m-text-base);
    line-height: 1.5;
    color: var(--m-ink-2);
  }
  .pr__note {
    margin-top: 16px;
  }

  /* ---- plans header + billing toggle ---- */
  .pr__plans {
    margin-top: 8px;
  }
  .pr__planshead {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px 24px;
    margin-bottom: 28px;
  }
  .pr__toggle {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 4px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
  }
  .pr__toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 36px;
    padding-inline: 14px;
    border-radius: 8px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-muted);
    cursor: pointer;
    transition:
      background 0.18s ease,
      color 0.18s ease;
  }
  .pr__toggle-btn:hover {
    color: var(--m-ink);
  }
  .pr__toggle-btn[aria-pressed='true'] {
    color: #fff;
    background: var(--m-accent);
  }
  .pr__toggle-badge {
    padding: 1px 6px;
    border-radius: 4px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .pr__toggle-btn[aria-pressed='true'] .pr__toggle-badge {
    color: #fff;
    background: color-mix(in srgb, #fff 24%, transparent);
  }

  /* ---- plan grid + cards ---- */
  /* Four equal columns: every tier reads on the same rhythm, so the price, CTA
     and feature rows line up across all four. Emphasis on the recommended plan
     comes from an accent frame + a straddling badge, never from a wider column —
     that keeps the CTAs on one line. */
  .pr__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 1.3vw, 16px);
    align-items: stretch;
    /* headroom for the recommended badge straddling the top edge */
    margin-top: 18px;
  }
  .pr__card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: clamp(22px, 2.1vw, 26px);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
  }
  /* the recommended plan is unmistakable: accent frame, a faint tinted body, a
     soft lift, and a badge straddling the top edge. The page's single shot of
     brand cyan lives here — the winner gets the highlight, nothing else does. */
  .pr__card--rec {
    border: 1.5px solid var(--m-accent);
    background: color-mix(in srgb, var(--m-accent) 4%, var(--m-surface));
  }
  .pr__ribbon {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    height: 26px;
    padding-inline: 14px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: linear-gradient(
      96deg,
      var(--m-accent),
      color-mix(in srgb, var(--m-accent) 42%, var(--m-cyan))
    );
  }
  .pr__cardbody {
    display: flex;
    flex: 1;
    flex-direction: column;
  }
  /* fixed header height keeps the price + CTA rows aligned across all four
     cards regardless of how many lines each description wraps to */
  .pr__cardtop {
    min-height: 78px;
  }
  .pr__name {
    font-size: var(--m-text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .pr__card--rec .pr__name {
    color: var(--m-accent);
  }
  .pr__desc {
    margin-top: 8px;
    font-size: var(--m-text-sm);
    line-height: 1.55;
    color: var(--m-muted);
  }
  .pr__priceblock {
    margin-top: 18px;
  }
  /* price big, cadence on its own line beneath it. Stacking keeps every card's
     price block the same height (the yearly "/ mo, billed yearly" string never
     has to share a line with the number), so the CTAs stay on one row. */
  .pr__pricerow {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
  }
  /* The price out-SCALES the plan name unmistakably — dominance comes from size
     + tighter tracking, not extra weight (one 400/500/600 system). Mono reads
     optically lighter at display size, so it takes the larger jump (~52px) and
     negative tracking to clearly dominate the card at the shared 600. */
  .pr__price {
    font-family: var(--m-font-mono);
    font-weight: 600;
    font-size: clamp(42px, 4.8vw, 52px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: var(--m-ink);
  }
  /* word-priced tiers ("Free"/"Let's talk") keep sans + a calmer tracking */
  .pr__price--text {
    font-family: var(--m-font-sans);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .pr__cadence {
    font-size: var(--m-text-sm);
    color: var(--m-muted);
    white-space: nowrap;
  }
  .pr__savings {
    margin-top: 8px;
    height: 14px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    line-height: 14px;
    color: var(--m-accent);
  }
  /* hidden, not removed — keeps the savings line's space reserved so every
     card's CTA stays on one row in monthly mode too (not just yearly) */
  .pr__savings.is-hidden {
    visibility: hidden;
  }
  /* same reserved height for plans that never show a savings line (Free) */
  .pr__savings-spacer {
    margin-top: 8px;
    height: 14px;
  }
  .pr__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 44px;
    margin-top: 20px;
    padding-inline: 16px;
    border-radius: 8px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    transition:
      background 0.18s ease,
      border-color 0.18s ease,
      gap 0.15s ease;
  }
  .pr__cta span[aria-hidden] {
    transition: transform 0.18s ease;
  }
  .pr__cta:hover span[aria-hidden] {
    transform: translateX(3px);
  }
  .pr__cta--rec {
    color: #fff;
    background: var(--m-accent);
  }
  .pr__cta--rec:hover {
    background: var(--m-accent-strong);
  }
  .pr__cta--plain {
    color: var(--m-ink);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .pr__cta--plain:hover {
    border-color: var(--m-muted);
  }
  /* allowances as a tight definition list under the CTA */
  .pr__meta {
    margin-top: 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pr__metarow {
    display: flex;
