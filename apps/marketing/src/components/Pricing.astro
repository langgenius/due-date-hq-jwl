---
/** Pricing — restyled to the marketing --m-* tier. The four tiers, billing
 *  toggle, checkout hrefs, and data-* hooks are the team's live billing wiring
 *  and are preserved exactly; only the styling changes, plus a beta banner:
 *  pricing is real but DueDateHQ is free during the beta. */
import type {
  PricingBillingInterval,
  PricingCheckoutPlan,
  PricingCopy,
  PricingPlanCopy,
} from '../i18n/types'

interface Props {
  t: PricingCopy
  appHref: string
  checkoutHrefs: Record<PricingCheckoutPlan, Record<PricingBillingInterval, string>>
}

const { t, appHref, checkoutHrefs } = Astro.props

function hrefFor(plan: PricingPlanCopy, interval: PricingBillingInterval): string {
  if (plan.hrefKind === 'checkout') return checkoutHrefs[plan.checkoutPlan ?? 'pro'][interval]
  return appHref
}
---

<section class="m-section pr" data-pricing-root data-billing-interval="monthly">
  <div class="pr__beta" role="note">
    <span class="pr__beta-tag">Beta</span>
    <p class="pr__beta-text">
      Every plan is <b>free while we're in beta</b> — nothing to pay today. Here's how pricing will
      work once we launch.
    </p>
  </div>

  <div class="m-page-hero pr__hero">
    <p class="m-eyebrow">{t.hero.eyebrow}</p>
    <h1 class="m-page-title">{t.hero.title}</h1>
    <p class="m-page-lead">{t.hero.description}</p>
    <p class="m-page-note">{t.hero.note}</p>
  </div>

  <section class="pr__plans">
    <header class="pr__planshead">
      <div>
        <p class="m-eyebrow">{t.plansHeader.eyebrow}</p>
        <h2 class="m-page-h2">{t.plansHeader.title}</h2>
      </div>
      <div class="pr__toggleblock">
        <span class="pr__togglenote">{t.plansHeader.note}</span>
        <div role="group" aria-label={t.billingToggle.ariaLabel} class="pr__toggle">
          <button type="button" data-pricing-billing-toggle="monthly" aria-pressed="true" class="pr__toggle-btn">
            {t.billingToggle.monthly}
          </button>
          <button type="button" data-pricing-billing-toggle="yearly" aria-pressed="false" class="pr__toggle-btn">
            <span>{t.billingToggle.yearly}</span>
            <span data-pricing-billing-badge class="pr__toggle-badge">{t.billingToggle.yearlyBadge}</span>
          </button>
        </div>
      </div>
    </header>

    <div class="pr__grid">
      {
        t.plans.map((plan) => {
          const isRecommended = Boolean(plan.badge)
          const monthlyHref = hrefFor(plan, 'monthly')
          const yearlyHref = hrefFor(plan, 'yearly')
          return (
            <article class:list={['pr__card', isRecommended && 'pr__card--rec']}>
              <div class="pr__cardbody">
                <div class="pr__cardtop">
                  <h3 class="pr__name">{plan.name}</h3>
                  {plan.badge ? <span class="pr__badge">{plan.badge}</span> : null}
                </div>

                <p class="pr__desc">{plan.description}</p>

                <div class="pr__priceblock">
                  <div class="pr__pricerow">
                    <span class:list={['pr__price', plan.priceKind === 'text' && 'pr__price--text']}>
                      <span data-pricing-price data-monthly={plan.price} data-yearly={plan.yearlyPrice ?? plan.price}>
                        {plan.price}
                      </span>
                    </span>
                    <span
                      data-pricing-cadence
                      data-monthly={plan.cadence}
                      data-yearly={plan.yearlyCadence ?? plan.cadence}
                      class="pr__cadence"
                    >
                      {plan.cadence}
                    </span>
                  </div>
                  {plan.yearlySavings ? (
                    <p data-pricing-savings class="pr__savings is-hidden">
                      {plan.yearlySavings}
                    </p>
                  ) : null}
                  <div class="pr__meta">
                    <span class="pr__metastrong">{plan.clients}</span>
                    <span>{plan.firms}</span>
                    <span class="pr__seats">
                      <span aria-hidden="true" class="pr__dot" />
                      <span class="pr__seatstxt">{plan.seats}</span>
                    </span>
                  </div>
                </div>

                <div class="pr__divider" aria-hidden="true" />

                <ul class="pr__features">
                  {plan.features.map((feature) => (
                    <li class="pr__feat">
                      <span aria-hidden="true" class="pr__check">✓</span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <a
                href={monthlyHref}
                data-pricing-cta
                data-href-monthly={monthlyHref}
                data-href-yearly={yearlyHref}
                class:list={['pr__cta', isRecommended ? 'pr__cta--rec' : 'pr__cta--plain']}
                data-event={`marketing.pricing.${plan.hrefKind}`}
              >
                <span>{plan.cta}</span>
                {isRecommended ? <span aria-hidden="true">→</span> : null}
              </a>
            </article>
          )
        })
      }
    </div>
  </section>

  <section class="pr__faq">
    <p class="m-eyebrow">{t.faqHeader.eyebrow}</p>
    <h2 class="m-page-h2">{t.faqHeader.title}</h2>
    <div class="m-page-grid-3">
      {
        t.faq.map((item) => (
          <section class="m-card">
            <h3 class="m-card__t">{item.question}</h3>
            <p class="m-card__d">{item.answer}</p>
          </section>
        ))
      }
    </div>
  </section>
</section>

<style>
  /* beta banner */
  .pr__beta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: clamp(8px, 2vw, 20px);
    padding: 14px 18px;
    background: var(--m-accent-tint);
    border: 1px solid color-mix(in srgb, var(--m-accent) 18%, transparent);
    border-radius: 12px;
  }
  .pr__beta-tag {
    flex: none;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    color: #fff;
    background: var(--m-accent);
  }
  .pr__beta-text {
    font-size: 14px;
    line-height: 1.5;
    color: var(--m-ink-2);
  }
  .pr__beta-text b {
    color: var(--m-ink);
    font-weight: 600;
  }
  .pr__hero {
    padding-block: clamp(28px, 4vw, 48px) clamp(28px, 4vw, 44px);
  }

  /* plans header + billing toggle */
  .pr__plans {
    margin-top: 8px;
  }
  .pr__planshead {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }
  .pr__togglenote {
    font-family: var(--m-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--m-muted);
  }
  .pr__toggleblock {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }
  .pr__toggle {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 4px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 10px;
  }
  .pr__toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 36px;
    padding-inline: 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--m-muted);
    cursor: pointer;
    transition:
      background 0.18s ease,
      color 0.18s ease;
  }
  .pr__toggle-btn:hover {
    color: var(--m-ink);
  }
  .pr__toggle-btn[aria-pressed='true'] {
    color: #fff;
    background: var(--m-accent);
  }
  .pr__toggle-badge {
    padding: 1px 6px;
    border-radius: 4px;
    font-family: var(--m-font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .pr__toggle-btn[aria-pressed='true'] .pr__toggle-badge {
    color: #fff;
    background: color-mix(in srgb, #fff 24%, transparent);
  }

  /* plan grid + cards */
  .pr__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.6vw, 18px);
    align-items: stretch;
  }
  .pr__card {
    display: flex;
    flex-direction: column;
    padding: clamp(22px, 2.4vw, 30px);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
  }
  .pr__card--rec {
    border: 1.5px solid var(--m-accent);
    background: color-mix(in srgb, var(--m-accent) 4%, var(--m-surface));
  }
  .pr__cardbody {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 24px;
  }
  .pr__cardtop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .pr__name {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .pr__badge {
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .pr__desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--m-muted);
  }
  .pr__pricerow {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .pr__price {
    font-family: var(--m-font-mono);
    font-weight: 700;
    font-size: clamp(34px, 4vw, 40px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--m-ink);
  }
  .pr__price--text {
    font-family: var(--m-font-sans);
    font-weight: 600;
  }
  .pr__cadence {
    font-size: 13px;
    color: var(--m-muted);
  }
  .pr__savings {
    margin-top: 6px;
    font-family: var(--m-font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--m-accent);
  }
  .pr__savings.is-hidden {
    display: none;
  }
  .pr__meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--m-ink-2);
  }
  .pr__metastrong {
    font-weight: 500;
    color: var(--m-ink);
  }
  .pr__seats {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .pr__dot {
    width: 6px;
    height: 6px;
    flex: none;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .pr__seatstxt {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pr__divider {
    height: 1px;
    width: 100%;
    background: var(--m-hairline-2);
  }
  .pr__features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--m-ink);
  }
  .pr__feat {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pr__check {
    display: grid;
    place-items: center;
    width: 16px;
    height: 16px;
    flex: none;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .pr__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 44px;
    margin-top: 28px;
    padding-inline: 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    transition:
      background 0.18s ease,
      border-color 0.18s ease;
  }
  .pr__cta--rec {
    color: #fff;
    background: var(--m-accent);
  }
  .pr__cta--rec:hover {
    background: var(--m-accent-strong);
  }
  .pr__cta--plain {
    color: var(--m-ink);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .pr__cta--plain:hover {
    border-color: var(--m-muted);
  }

  /* faq */
  .pr__faq {
    margin-top: clamp(40px, 5vw, 64px);
    padding-top: clamp(32px, 4vw, 48px);
    border-top: 1px solid var(--m-hairline-2);
  }

  @media (max-width: 1100px) {
    .pr__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .pr__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  type PricingInterval = 'monthly' | 'yearly'

  function setPricingInterval(root: HTMLElement, interval: PricingInterval) {
    root.dataset.billingInterval = interval

    // active styling is driven by aria-pressed in CSS — only set the state here
    root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
      button.setAttribute('aria-pressed', String(button.dataset.pricingBillingToggle === interval))
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-price]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-cadence]').forEach((node) => {
      const next = interval === 'yearly' ? node.dataset.yearly : node.dataset.monthly
      if (next) node.textContent = next
    })

    root.querySelectorAll<HTMLElement>('[data-pricing-savings]').forEach((node) => {
      node.classList.toggle('is-hidden', interval !== 'yearly')
    })

    root.querySelectorAll<HTMLAnchorElement>('[data-pricing-cta]').forEach((link) => {
      const next = interval === 'yearly' ? link.dataset.hrefYearly : link.dataset.hrefMonthly
      if (next) link.setAttribute('href', next)
    })
  }

  function initPricingBillingToggles() {
    document.querySelectorAll<HTMLElement>('[data-pricing-root]').forEach((root) => {
      root.querySelectorAll<HTMLElement>('[data-pricing-billing-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
          const interval = button.dataset.pricingBillingToggle
          if (interval === 'monthly' || interval === 'yearly') {
            setPricingInterval(root, interval)
          }
        })
      })
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricingBillingToggles, { once: true })
  } else {
    initPricingBillingToggles()
  }
</script>
