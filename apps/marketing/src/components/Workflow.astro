---
import type { WorkflowCopy } from '../i18n/types'
import SectionEyebrow from './primitives/SectionEyebrow.astro'
import WorkflowStep from './WorkflowStep.astro'

interface Props {
  t: WorkflowCopy
}

const { t } = Astro.props
---

<section id="workflow" class="border-b border-border-default bg-bg-panel">
  <div class="mx-auto max-w-[1440px] px-6 py-20 sm:px-10 lg:px-20">
    <!-- Section header -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <SectionEyebrow index={t.index} label={t.eyebrow} />
        <h2 class="mt-6 max-w-[700px] text-display-large font-semibold tracking-tight text-text-primary">
          {t.title}
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-[15px] leading-relaxed text-text-secondary">{t.paragraph}</p>
      </div>
    </div>

    <!-- Steps -->
    <div class="mt-16 flex flex-col gap-20">
      {t.steps.map((step) => (
        <WorkflowStep t={step} />
      ))}
    </div>
  </div>
</section>

<script is:inline define:vars={{ id: 'marketing.workflow_section.viewed' }}>
  // Lightweight viewport tracker for the workflow event contract.
  // No analytics SDK wired — emit a CustomEvent that downstream tooling can pick up.
  if (typeof IntersectionObserver !== 'undefined') {
    const target = document.getElementById('workflow')
    if (target) {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            window.dispatchEvent(new CustomEvent(id))
            io.disconnect()
            break
          }
        }
      }, { threshold: 0.25 })
      io.observe(target)
    }
  }
</script>
