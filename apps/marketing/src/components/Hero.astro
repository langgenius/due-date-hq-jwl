---
import type { HeroCopy } from '../i18n/types'
import HeroSurface from './HeroSurface.astro'

interface Props {
  t: HeroCopy
  ctaHref: string
  workflowAnchor: string
}

const { t, ctaHref, workflowAnchor } = Astro.props
---

<section id="hero" class="border-b border-border-default bg-bg-canvas">
  <!-- Section pt 108 = Hero/RightSurface y in Figma; pb 108 mirrors bottom inset. -->
  <!-- Flex (not 12-col grid) so left copy = 560 and right surface = 640 match Figma exactly; -->
  <!-- the 80px slack at 1440 viewport falls naturally between them via justify-between. -->
  <div class="mx-auto flex max-w-[1440px] flex-col gap-12 px-6 pb-20 pt-20 sm:px-10 lg:flex-row lg:items-start lg:justify-between lg:px-20 lg:pb-[108px] lg:pt-[108px]">
    <!-- Left: copy. Sits ~21px below surface top (matches Figma Hero/Left vs Hero/RightSurface offset). -->
    <div class="lg:w-[560px] lg:shrink-0 lg:pt-[21px]">
      <span class="inline-flex items-center gap-2 rounded-full bg-accent-tint px-3 py-1 font-mono text-[12px] tracking-[0.16em] text-accent-text">
        <span class="block h-1.5 w-1.5 rounded-full bg-accent-default"></span>
        {t.eyebrow}
      </span>
      <h1 class="mt-6 max-w-[560px] text-display-hero font-semibold tracking-tight text-text-primary">
        {t.title}
      </h1>
      <p class="mt-6 max-w-[560px] text-[16px] leading-relaxed text-text-secondary">
        {t.description}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href={ctaHref}
          class="inline-flex h-10 items-center gap-2 rounded-md bg-accent-default px-4 text-base font-medium text-primary-foreground outline-none transition-colors hover:bg-accent-hover focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          data-event="marketing.hero_cta.clicked"
        >
          <span>{t.primaryCta}</span>
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={workflowAnchor}
          class="inline-flex h-10 items-center gap-2 rounded-md border border-border-default bg-bg-elevated px-4 text-base font-medium text-text-primary outline-none transition-colors hover:border-border-strong focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
          data-event="marketing.secondary_cta.clicked"
        >
          <span>{t.secondaryCta}</span>
          <span aria-hidden="true">↓</span>
        </a>
      </div>
      <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[12px] text-text-muted">
        {t.trust.map((item, idx) => (
          <>
            {idx > 0 && <span aria-hidden="true">·</span>}
            <span>{item.label}</span>
          </>
        ))}
      </div>
    </div>

    <!-- Right: surface — Figma Hero/RightSurface fixed width = 640. -->
    <div class="min-w-0 max-w-full lg:w-[640px] lg:shrink-0">
      <HeroSurface t={t.surface} />
    </div>
  </div>
</section>
