---
import brandMarkDark from '@duedatehq/ui/assets/brand/brand-favicon-dark.svg?url'
import brandMarkLight from '@duedatehq/ui/assets/brand/brand-favicon.svg?url'

import type { FooterCopy } from '../i18n/types'
import PreferenceSwitcher from './PreferenceSwitcher.astro'

interface Props {
  t: FooterCopy
  enHref: string
  zhHref: string
  currentLocale: 'en' | 'zh-CN'
}

const { t, enHref, zhHref, currentLocale } = Astro.props
---

<footer class="border-t border-border-default bg-bg-panel">
  <div class="mx-auto max-w-[1440px] px-6 py-16 sm:px-10 lg:px-20">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Brand block -->
      <div class="lg:col-span-4">
        <div class="flex items-center gap-2">
          <img
            src={brandMarkLight}
            alt=""
            aria-hidden="true"
            width="16"
            height="16"
            class="size-4 shrink-0 dark:hidden"
          />
          <img
            src={brandMarkDark}
            alt=""
            aria-hidden="true"
            width="16"
            height="16"
            class="hidden size-4 shrink-0 dark:block"
          />
          <span class="text-[15px] font-semibold text-text-primary">{t.brand}</span>
        </div>
        <p class="mt-7 text-[14px] text-text-secondary">{t.tagline}</p>
        <p class="mt-3 font-mono text-[12px] text-text-muted">{t.audience}</p>
      </div>
      <!-- Columns -->
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-3 lg:col-span-8">
        {
          t.columns.map((column) => (
            <div>
              <div class="font-mono text-[12px] tracking-[0.16em] text-text-muted">
                {column.title}
              </div>
              <ul class="mt-6 flex flex-col gap-3 text-[14px]">
                {column.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="rounded-sm text-text-secondary outline-none transition-colors hover:text-text-primary focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-border-subtle pt-8 text-[13px] lg:flex-row lg:items-center"
    >
      <span class="font-mono text-text-muted">{t.copyright}</span>
      <PreferenceSwitcher
        theme={t.theme}
        language={t.language}
        status={t.status}
        enHref={enHref}
        zhHref={zhHref}
        currentLocale={currentLocale}
      />
    </div>
  </div>
</footer>
