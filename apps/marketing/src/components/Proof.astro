---
import type { ProofCopy } from '../i18n/types'
import SectionEyebrow from './primitives/SectionEyebrow.astro'

interface Props {
  t: ProofCopy
}

const { t } = Astro.props
---

<section id="proof" class="border-b border-border-default bg-bg-canvas">
  <div class="mx-auto max-w-[1440px] px-6 py-20 sm:px-10 lg:px-20">
    <!-- Section header -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <SectionEyebrow index={t.index} label={t.eyebrow} />
        <h2 class="mt-6 max-w-[700px] text-display-large font-semibold tracking-tight text-text-primary">
          {t.title}
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-[15px] leading-relaxed text-text-secondary">{t.paragraph}</p>
        <p class="mt-6 font-mono text-sm text-text-muted">{t.footnote}</p>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-1 divide-y divide-border-default border border-border-default sm:grid-cols-2 sm:divide-x lg:grid-cols-4 lg:divide-y-0">
      {t.stats.map((stat) => (
        <div class="p-8">
          <div class="font-mono text-sm tracking-[0.16em] text-text-muted">{stat.label}</div>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="font-mono tabular text-[44px] font-semibold leading-none text-text-primary">{stat.value}</span>
            {stat.unit && <span class="font-mono text-[20px] text-text-secondary">{stat.unit}</span>}
          </div>
          <p class="mt-6 text-description leading-relaxed text-text-secondary">{stat.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
