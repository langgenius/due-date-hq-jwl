---
/**
 * FoundingBanner — site-wide top bar recruiting founding users + a modal lead
 * form. Rendered once in BaseLayout (above the sticky nav, so it scrolls away
 * while the nav pins below). The modal can be opened from the bar OR any element
 * with `data-founding-open` (e.g. the works-with-your-stack contact block).
 *
 * Submissions POST to Formspree via AJAX (inline success, no redirect). The
 * endpoint is the dedicated founding-user form (f/mjgnrnpj), overridable with
 * PUBLIC_FOUNDING_FORM_ACTION. Dismissal persists in localStorage. Bilingual.
 */
interface Props {
  locale?: 'en' | 'zh-CN'
  action: string
}
const { locale = 'en', action } = Astro.props
const zh = locale === 'zh-CN'

const c = zh
  ? {
      barText: '招募 founding users —— 首批美国 CPA 事务所,和我们一起打磨 DueDateHQ。',
      barCta: '申请加入',
      dismiss: '关闭',
      title: '成为 founding user',
      lead: '简单说说你的事务所,我们会亲自与你联系 —— 通常在 2 个工作日内。',
      name: '姓名',
      email: '工作邮箱',
      firm: '事务所名称',
      clients: '客户数量',
      clientsOpt: '(选填)',
      msg: '你最想让 DueDateHQ 解决什么?',
      msgOpt: '(选填)',
      submit: '申请加入',
      submitting: '提交中…',
      fine: '我们只会用它就 founding 使用权与你联系。也可邮件:',
      close: '关闭',
      successTitle: '已收到,谢谢!',
      successBody: '我们会通过你留下的邮箱与你联系。',
      errGeneric: '出了点问题 —— 也可直接邮件 hello@duedatehq.com',
      errNetwork: '网络错误 —— 也可直接邮件 hello@duedatehq.com',
    }
  : {
      barText: 'Founding users wanted — a first group of US CPA firms to shape DueDateHQ with us.',
      barCta: 'Apply',
      dismiss: 'Dismiss',
      title: 'Become a founding user',
      lead: "Tell us about your practice and we'll get back to you personally — usually within 2 business days.",
      name: 'Name',
      email: 'Work email',
      firm: 'Firm name',
      clients: 'Number of clients',
      clientsOpt: '(optional)',
      msg: 'What would you want DueDateHQ to solve?',
      msgOpt: '(optional)',
      submit: 'Request access',
      submitting: 'Sending…',
      fine: "We'll only use this to reach out about founding access. Prefer email? ",
      close: 'Close',
      successTitle: "Thanks — we've got it.",
      successBody: "We'll reach out at the email you gave us.",
      errGeneric: 'Something went wrong — you can also email hello@duedatehq.com',
      errNetwork: 'Network error — you can also email hello@duedatehq.com',
    }
---

<div class="fb-bar" data-founding-bar hidden>
  <p class="fb-bar__text">{c.barText}</p>
  <button
    class="fb-bar__cta"
    type="button"
    data-founding-open
    data-event="marketing.founding-banner.apply">{c.barCta} →</button
  >
  <button
    class="fb-bar__x"
    type="button"
    data-founding-dismiss
    data-event="marketing.founding-banner.dismiss"
    aria-label={c.dismiss}
  >
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="16" height="16">
      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
      ></path>
    </svg>
  </button>
</div>

<div class="fb-modal" data-founding-modal hidden>
  <div class="fb-modal__backdrop" data-founding-close></div>
  <div class="fb-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="fb-title">
    <button class="fb-modal__x" type="button" data-founding-close aria-label={c.close}>
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="18" height="18">
        <path
          d="M6 6l12 12M18 6L6 18"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"></path>
      </svg>
    </button>

    <form class="fb-form" data-founding-form action={action} method="POST">
      <h2 class="fb-form__title" id="fb-title">{c.title}</h2>
      <p class="fb-form__lead">{c.lead}</p>

      <input type="hidden" name="_subject" value="New DueDateHQ founding-user request" />
      <input type="hidden" name="source" value="founding-user" />
      {/* honeypot — real users never fill this; bots do */}
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="fb-hp" aria-hidden="true" />

      <div class="fb-form__grid">
        <label class="fb-field">
          <span class="fb-field__label">{c.name}</span>
          <input class="fb-input" type="text" name="name" required autocomplete="name" />
        </label>
        <label class="fb-field">
          <span class="fb-field__label">{c.email}</span>
          <input
            class="fb-input"
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@yourfirm.com"
          />
        </label>
        <label class="fb-field">
          <span class="fb-field__label">{c.firm}</span>
          <input class="fb-input" type="text" name="firm" required autocomplete="organization" />
        </label>
        <label class="fb-field">
          <span class="fb-field__label">{c.clients} <em class="fb-opt">{c.clientsOpt}</em></span>
          <input class="fb-input" type="text" name="clients" inputmode="numeric" />
        </label>
      </div>
      <label class="fb-field">
        <span class="fb-field__label">{c.msg} <em class="fb-opt">{c.msgOpt}</em></span>
        <textarea class="fb-input fb-textarea" name="message" rows="3"></textarea>
      </label>

      <button class="m-btn m-btn--primary fb-submit" type="submit" data-event="marketing.founding.submit">
        {c.submit}
      </button>
      <p class="fb-status" data-founding-status role="alert"></p>
      <p class="fb-fine">
        {c.fine}<a href="mailto:hello@duedatehq.com">hello@duedatehq.com</a>
      </p>
    </form>

    <div class="fb-success" data-founding-success hidden>
      <div class="fb-success__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" width="26" height="26">
          <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round"></path>
        </svg>
      </div>
      <h2 class="fb-success__title">{c.successTitle}</h2>
      <p class="fb-success__body">{c.successBody}</p>
      <button class="m-btn m-btn--secondary" type="button" data-founding-close>{c.close}</button>
    </div>
  </div>
</div>

<style>
  [hidden] {
    display: none !important;
  }
  /* ---- top bar (scrolls away above the sticky nav) ---- */
  .fb-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 16px;
    padding: 9px 44px 9px 20px;
    position: relative;
    /* brand cyan — the loud, eye-catching accent (navy text pairs with it) */
    background: var(--m-cyan);
    color: var(--m-brand);
    text-align: center;
  }
  .fb-bar__text {
    font-size: var(--m-text-sm);
    font-weight: 600;
    line-height: 1.35;
    color: var(--m-brand);
  }
  /* text link, not a pill — the bar colour already carries the affordance */
  .fb-bar__cta {
    flex: none;
    color: var(--m-brand);
    font-size: var(--m-text-sm);
    font-weight: 700;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--m-brand) 45%, transparent);
    transition: text-decoration-color var(--m-dur-fast) var(--m-ease);
  }
  .fb-bar__cta:hover {
    text-decoration-color: var(--m-brand);
  }
  .fb-bar__x {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: var(--m-radius-pill);
    color: color-mix(in srgb, var(--m-brand) 60%, transparent);
    cursor: pointer;
  }
  .fb-bar__x:hover {
    color: var(--m-brand);
    background: color-mix(in srgb, var(--m-brand) 12%, transparent);
  }

  /* ---- modal ---- */
  .fb-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 20px;
  }
  .fb-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(16, 24, 40, 0.55);
    backdrop-filter: blur(2px);
  }
  .fb-modal__dialog {
    position: relative;
    width: 100%;
    max-width: 540px;
    max-height: calc(100dvh - 40px);
    overflow-y: auto;
    background: var(--m-surface);
    border-radius: var(--m-radius-lg);
    padding: clamp(24px, 4vw, 36px);
    box-shadow: 0 24px 60px -12px rgba(16, 24, 40, 0.35);
  }
  .fb-modal__x {
    position: absolute;
    top: 14px;
    right: 14px;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: var(--m-radius-pill);
    color: var(--m-muted);
    cursor: pointer;
    transition:
      background var(--m-dur-fast) var(--m-ease),
      color var(--m-dur-fast) var(--m-ease);
  }
  .fb-modal__x:hover {
    background: var(--m-section);
    color: var(--m-ink);
  }

  .fb-form__title {
    font-family: var(--m-font-sans);
    font-weight: 600;
    font-size: clamp(24px, 3vw, 30px);
    letter-spacing: -0.02em;
    color: var(--m-ink);
    padding-right: 32px;
  }
  .fb-form__lead {
    margin-top: 8px;
    font-size: var(--m-text-md);
    line-height: 1.55;
    color: var(--m-ink-2);
  }
  .fb-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .fb-form__grid {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 480px) {
    .fb-form__grid {
      grid-template-columns: 1fr;
    }
  }
  .fb-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 14px;
  }
  .fb-form__grid .fb-field {
    margin-top: 0;
  }
  .fb-field__label {
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-ink-2);
  }
  .fb-opt {
    font-style: normal;
    font-weight: 400;
    color: var(--m-faint);
  }
  .fb-input {
    font: inherit;
    font-size: var(--m-text-md);
    padding: 10px 12px;
    border-radius: var(--m-radius-md);
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    color: var(--m-ink);
  }
  .fb-input::placeholder {
    color: var(--m-faint);
  }
  .fb-input:focus-visible {
    outline: 2px solid var(--m-accent);
    outline-offset: 1px;
    border-color: var(--m-accent);
  }
  .fb-textarea {
    resize: vertical;
    min-height: 68px;
  }
  .fb-submit {
    margin-top: 20px;
    width: 100%;
  }
  .fb-status {
    margin-top: 10px;
    font-size: var(--m-text-sm);
    color: var(--m-danger);
  }
  .fb-status:empty {
    display: none;
  }
  .fb-fine {
    margin-top: 14px;
    font-size: var(--m-text-xs);
    line-height: 1.5;
    color: var(--m-muted);
  }
  .fb-fine a {
    color: var(--m-accent);
    font-weight: 500;
  }

  .fb-success {
    text-align: center;
    padding: 12px 0 4px;
  }
  .fb-success__mark {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    margin: 0 auto 16px;
    border-radius: var(--m-radius-pill);
    background: color-mix(in srgb, var(--m-ok) 16%, transparent);
    color: var(--m-ok-ink);
  }
  .fb-success__title {
    font-family: var(--m-font-sans);
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 28px);
    letter-spacing: -0.02em;
    color: var(--m-ink);
  }
  .fb-success__body {
    margin: 8px 0 22px;
    font-size: var(--m-text-md);
    color: var(--m-ink-2);
  }
</style>

<script is:inline define:vars={{ errGeneric: c.errGeneric, errNetwork: c.errNetwork, sending: c.submitting }}>
  ;(() => {
    const DISMISS_STORE = 'ddhq_founding_dismissed_v1'

    function applyDismiss() {
      const bar = document.querySelector('[data-founding-bar]')
      if (!bar) return
      if (localStorage.getItem(DISMISS_STORE) === '1') bar.setAttribute('hidden', '')
      else bar.removeAttribute('hidden')
    }
    function openModal() {
      const m = document.querySelector('[data-founding-modal]')
      if (!m) return
      m.removeAttribute('hidden')
      document.documentElement.style.overflow = 'hidden'
      const first = m.querySelector('input:not([type=hidden]):not(.fb-hp), textarea')
      if (first) first.focus()
    }
    function closeModal() {
      const m = document.querySelector('[data-founding-modal]')
      if (!m) return
      m.setAttribute('hidden', '')
      document.documentElement.style.overflow = ''
    }

    if (!window.ddhqFoundingBound) {
      window.ddhqFoundingBound = true

      document.addEventListener('click', (e) => {
        const t = e.target.closest(
          '[data-founding-open],[data-founding-dismiss],[data-founding-close]',
        )
        if (!t) return
        if (t.hasAttribute('data-founding-open')) {
          e.preventDefault()
          openModal()
        } else if (t.hasAttribute('data-founding-dismiss')) {
          localStorage.setItem(DISMISS_STORE, '1')
          applyDismiss()
        } else {
          e.preventDefault()
          closeModal()
        }
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal()
      })

      document.addEventListener('submit', async (e) => {
        const form = e.target.closest('[data-founding-form]')
        if (!form) return
        e.preventDefault()
        const status = form.querySelector('[data-founding-status]')
        const btn = form.querySelector('button[type=submit]')
        const label = btn ? btn.textContent : ''
        if (status) status.textContent = ''
        if (btn) {
          btn.disabled = true
          btn.textContent = sending
        }
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          })
          if (res.ok) {
            form.setAttribute('hidden', '')
            const ok = document.querySelector('[data-founding-success]')
            if (ok) ok.removeAttribute('hidden')
          } else {
            const data = await res.json().catch(() => ({}))
            if (status)
              status.textContent =
                (data.errors && data.errors[0] && data.errors[0].message) || errGeneric
          }
        } catch (_) {
          if (status) status.textContent = errNetwork
        } finally {
          if (btn) {
            btn.disabled = false
            btn.textContent = label
          }
        }
      })
    }

    document.addEventListener('astro:page-load', applyDismiss)
    applyDismiss()
  })()
</script>
