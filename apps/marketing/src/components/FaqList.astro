---
/** FaqList — the shared FAQ block for every subpage: eyebrow + heading + the
 *  shared FaqAccordion (no <section> wrapper; each page slots it into its own
 *  rhythm). The accordion item treatment lives in FaqAccordion so /pricing,
 *  /state-coverage, the geo pages, the per-state pages, and the landing's home
 *  FAQ all render one identical accordion. */
import FaqAccordion from './FaqAccordion.astro'
interface Props {
  eyebrow: string
  title: string
  items: { question: string; answer: string }[]
}
const { eyebrow, title, items } = Astro.props
---

<p class="m-eyebrow">{eyebrow}</p>
<h2 class="m-page-h2">{title}</h2>
<div class="faqlist">
  <FaqAccordion items={items} />
</div>

<style>
  .faqlist {
    margin-top: clamp(24px, 3vw, 36px);
    max-width: 820px;
  }
</style>
