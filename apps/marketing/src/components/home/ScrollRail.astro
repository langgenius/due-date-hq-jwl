---
/** Left scroll-spy rail — an editorial "section index" in the left margin: a
 *  continuous spine line with a dot per section, mono uppercase labels, a glowing
 *  active dot, and an "NN / TT" progress counter. Shown on wide screens only. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? {
      items: [
        { label: '问题', href: '#villain-h' },
        { label: '产品', href: '#surfaces' },
        { label: '循环', href: '#how' },
        { label: '那份公告', href: '#notice' },
        { label: '来源', href: '#sources' },
        { label: '为什么可信', href: '#security' },
        { label: '常见问题', href: '#faq' },
      ],
    }
  : {
      items: [
        { label: 'The problem', href: '#villain-h' },
        { label: 'Surfaces', href: '#surfaces' },
        { label: 'The loop', href: '#how' },
        { label: 'The document', href: '#notice' },
        { label: 'Sources', href: '#sources' },
        { label: 'Why trust it', href: '#security' },
        { label: 'Questions', href: '#faq' },
      ],
    }
const items = t.items
const total = String(items.length).padStart(2, '0')
---

<nav class="spyrail" id="spyrail" aria-label="Section navigation">
  <div class="spyrail__track">
    <span class="spyrail__line" aria-hidden="true"></span>
    {
      items.map((it) => (
        <a class="spyrail__item" href={it.href}>
          <span class="spyrail__dot" aria-hidden="true" />
          <span class="spyrail__label">{it.label}</span>
        </a>
      ))
    }
  </div>
  <p class="spyrail__count" aria-hidden="true"><b id="spyrail-cur">01</b> / {total}</p>
</nav>

<style>
  .spyrail {
    position: fixed;
    left: clamp(20px, 3vw, 52px);
    top: 50%;
    z-index: 40;
    display: none;
    flex-direction: column;
    gap: 16px;
    /* hidden at the hero; revealed once scrolled into the page (toggled by JS) */
    opacity: 0;
    visibility: hidden;
    transform: translate(-8px, -50%);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s ease;
  }
  .spyrail.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translate(0, -50%);
  }
  @media (min-width: 1500px) {
    .spyrail {
      display: flex;
    }
  }

  /* the spine: a continuous line, overhanging the first/last dot like the ref */
  .spyrail__track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-block: 18px;
  }
  .spyrail__line {
    position: absolute;
    left: 3px; /* dot centre */
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--m-hairline);
  }

  .spyrail__item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .spyrail__dot {
    position: relative;
    z-index: 1;
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--m-muted) 42%, transparent);
    transition:
      background 0.25s ease,
      box-shadow 0.25s var(--m-ease),
      transform 0.25s var(--m-ease);
  }
  .spyrail__label {
    font-family: var(--m-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--m-faint);
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .spyrail__item:hover .spyrail__label {
    color: var(--m-muted);
  }
  .spyrail__item:hover .spyrail__dot {
    background: var(--m-muted);
  }

  /* active — a glowing filled dot + bright label, the one lit stop on the spine */
  .spyrail__item.is-active .spyrail__label {
    color: var(--m-ink);
  }
  .spyrail__item.is-active .spyrail__dot {
    background: var(--m-accent);
    transform: scale(1.2);
    box-shadow:
      0 0 0 1px var(--m-accent),
      0 0 10px 2px color-mix(in srgb, var(--m-accent) 55%, transparent);
  }

  .spyrail__count {
    margin: 4px 0 0;
    padding-left: 21px; /* under the labels (dot 7 + gap 14) */
    font-family: var(--m-font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--m-faint);
  }
  .spyrail__count b {
    font-weight: 600;
    color: var(--m-muted);
  }

  /* ===== over a dark band (the villain) — white spine + glow ===== */
  .spyrail.is-on-dark .spyrail__line {
    background: rgba(255, 255, 255, 0.18);
  }
  .spyrail.is-on-dark .spyrail__dot {
    background: rgba(255, 255, 255, 0.4);
  }
  .spyrail.is-on-dark .spyrail__label {
    color: rgba(255, 255, 255, 0.5);
  }
  .spyrail.is-on-dark .spyrail__item:hover .spyrail__label {
    color: rgba(255, 255, 255, 0.85);
  }
  .spyrail.is-on-dark .spyrail__item:hover .spyrail__dot {
    background: rgba(255, 255, 255, 0.7);
  }
  .spyrail.is-on-dark .spyrail__item.is-active .spyrail__label {
    color: #fff;
  }
  .spyrail.is-on-dark .spyrail__item.is-active .spyrail__dot {
    background: #fff;
    box-shadow:
      0 0 0 1px #fff,
      0 0 11px 2px rgba(255, 255, 255, 0.5);
  }
  .spyrail.is-on-dark .spyrail__count {
    color: rgba(255, 255, 255, 0.4);
  }
  .spyrail.is-on-dark .spyrail__count b {
    color: rgba(255, 255, 255, 0.72);
  }

  /* zh — CJK has no uppercase and the mono face lacks Chinese glyphs */
  html[lang='zh-CN'] .spyrail__label {
    text-transform: none;
    letter-spacing: 0.05em;
    font-family: var(--m-font-sans);
  }

  @media (prefers-reduced-motion: reduce) {
    .spyrail,
    .spyrail__item,
    .spyrail__dot,
    .spyrail__label {
      transition: none;
    }
    .spyrail__item.is-active .spyrail__dot {
      transform: none;
    }
  }
</style>

<script>
  const rail = document.getElementById('spyrail')
  if (rail) {
    const items = Array.from(rail.querySelectorAll('.spyrail__item'))
    const cur = document.getElementById('spyrail-cur')
    const secs = items.map((it) => document.getElementById(it.getAttribute('href').slice(1)))
    const darkSections = Array.from(document.querySelectorAll('[data-nav-dark]'))
    let ticking = false
    const update = () => {
      ticking = false
      // the section whose top has most recently passed a line ~40% down the viewport
      const line = window.innerHeight * 0.4
      let idx = -1
      for (let i = 0; i < secs.length; i++) {
        if (secs[i] && secs[i].getBoundingClientRect().top <= line) idx = i
      }
      items.forEach((it, i) => it.classList.toggle('is-active', i === idx))
      if (cur) cur.textContent = String(Math.max(0, idx) + 1).padStart(2, '0')
      // reveal only once scrolled past the hero
      rail.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.55)
      // white-out when the rail sits over a dark band (the villain)
      const railMid = window.innerHeight * 0.5
      let onDark = false
      for (const s of darkSections) {
        const r = s.getBoundingClientRect()
        if (r.top <= railMid && r.bottom >= railMid) {
          onDark = true
          break
        }
      }
      rail.classList.toggle('is-on-dark', onDark)
    }
    const onScroll = () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(update)
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    window.addEventListener('resize', onScroll, { passive: true })
    update()
  }
</script>
