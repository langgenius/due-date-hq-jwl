---
/** Left scroll-spy rail — a quiet "section index" in the left margin. At rest it
 *  reads as a column of short dashes; the active section grows its dash and shows
 *  its label. Hovering the rail reveals every label (inactive ones in gray), so
 *  the whole index is one hover away. Labels echo the real on-page section names.
 *  Wide screens only. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? {
      items: [
        { label: '问题', href: '#villain-h' },
        { label: '工作台', href: '#surfaces' },
        { label: '那份公告', href: '#notice' },
        { label: '来源', href: '#sources' },
        { label: '对比', href: '#cmp-h' },
        { label: '为什么可信', href: '#security' },
        { label: '常见问题', href: '#faq' },
      ],
    }
  : {
      items: [
        { label: 'The problem', href: '#villain-h' },
        { label: 'The workbench', href: '#surfaces' },
        { label: 'The notice', href: '#notice' },
        { label: 'Sources', href: '#sources' },
        { label: 'Compare', href: '#cmp-h' },
        { label: 'Why trust it', href: '#security' },
        { label: 'Questions', href: '#faq' },
      ],
    }
const items = t.items
---

<nav class="spyrail" id="spyrail" aria-label="Section navigation">
  {
    items.map((it) => (
      <a class="spyrail__item" href={it.href}>
        <span class="spyrail__dash" aria-hidden="true" />
        <span class="spyrail__label">{it.label}</span>
      </a>
    ))
  }
</nav>

<style>
  .spyrail {
    position: fixed;
    left: clamp(20px, 3vw, 52px);
    top: 50%;
    z-index: 40;
    display: none;
    flex-direction: column;
    gap: 4px;
    /* hidden at the hero; revealed once scrolled into the page (toggled by JS) */
    opacity: 0;
    visibility: hidden;
    transform: translate(-8px, -50%);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s ease;
  }
  .spyrail.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translate(0, -50%);
  }
  @media (min-width: 1500px) {
    .spyrail {
      display: flex;
    }
  }

  .spyrail__item {
    display: flex;
    align-items: center;
  }
  /* the marker — a small dash at rest, grown + accented when active (kept short
     and quiet so the rail reads as a hint, not a ruler) */
  .spyrail__dash {
    width: 6px;
    height: 1.5px;
    flex: none;
    border-radius: 999px;
    background: var(--m-faint);
    transition:
      width 0.28s cubic-bezier(0.32, 0.72, 0, 1),
      background 0.2s ease;
  }
  /* labels are collapsed by default; the active one (and any on rail-hover) opens */
  .spyrail__label {
    max-width: 0;
    margin-left: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    font-size: var(--m-text-xs);
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--m-faint);
    transition:
      max-width 0.3s cubic-bezier(0.32, 0.72, 0, 1),
      margin-left 0.3s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.22s ease,
      color 0.2s ease;
  }

  /* active — dash grows a little + turns accent, label opens in ink */
  .spyrail__item.is-active .spyrail__dash {
    width: 13px;
    background: var(--m-accent);
  }
  .spyrail__item.is-active .spyrail__label,
  .spyrail:hover .spyrail__label {
    max-width: 200px;
    margin-left: 12px;
    opacity: 1;
  }
  .spyrail__item.is-active .spyrail__label {
    color: var(--m-ink);
    font-weight: 500;
  }
  /* on hover the whole list shows; inactive labels read gray */
  .spyrail:hover .spyrail__item:not(.is-active) .spyrail__label {
    color: var(--m-muted);
  }
  .spyrail:hover .spyrail__item:not(.is-active):hover .spyrail__dash {
    background: var(--m-muted);
  }

  /* ===== over a dark band (the villain) — white-out ===== */
  .spyrail.is-on-dark .spyrail__dash {
    background: rgba(255, 255, 255, 0.4);
  }
  .spyrail.is-on-dark .spyrail__item.is-active .spyrail__dash {
    background: #fff;
  }
  .spyrail.is-on-dark .spyrail__label {
    color: rgba(255, 255, 255, 0.45);
  }
  .spyrail.is-on-dark .spyrail__item.is-active .spyrail__label {
    color: #fff;
  }
  .spyrail.is-on-dark:hover .spyrail__item:not(.is-active) .spyrail__label {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .spyrail,
    .spyrail__item,
    .spyrail__dash,
    .spyrail__label {
      transition: none;
    }
  }
</style>

<script>
  // Section-index spy-rail. Re-inits per View-Transition navigation; window
  // listeners drop on the next swap.
  function initSpyRail(signal: AbortSignal) {
    const rail = document.getElementById('spyrail')
    if (!rail) return
    const items = Array.from(rail.querySelectorAll('.spyrail__item'))
    const secs = items.map((it) => document.getElementById(it.getAttribute('href')!.slice(1)))
    const darkSections = Array.from(document.querySelectorAll('[data-nav-dark]'))
    let ticking = false
    const update = () => {
      ticking = false
      // the section whose top has most recently passed a line ~40% down the viewport
      const line = window.innerHeight * 0.4
      let idx = -1
      for (let i = 0; i < secs.length; i++) {
        const s = secs[i]
        if (s && s.getBoundingClientRect().top <= line) idx = i
      }
      items.forEach((it, i) => it.classList.toggle('is-active', i === idx))
      // reveal only once scrolled past the hero
      rail.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.55)
      // white-out when the rail sits over a dark band (the villain)
      const railMid = window.innerHeight * 0.5
      let onDark = false
      for (const s of darkSections) {
        const r = s.getBoundingClientRect()
        if (r.top <= railMid && r.bottom >= railMid) {
          onDark = true
          break
        }
      }
      rail.classList.toggle('is-on-dark', onDark)
    }
    const onScroll = () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(update)
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true, signal })
    window.addEventListener('resize', onScroll, { passive: true, signal })
    update()
  }
  let spyCtl: AbortController | undefined
  document.addEventListener('astro:page-load', () => {
    spyCtl = new AbortController()
    initSpyRail(spyCtl.signal)
  })
  document.addEventListener('astro:before-swap', () => spyCtl?.abort())
</script>
