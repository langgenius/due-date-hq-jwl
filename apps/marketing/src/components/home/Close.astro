---
/** Close — the finale CTA. A bold navy card (different from the white sections),
 *  made distinct as the page's end by bookending the Hero: the headline returns
 *  to the display serif that opens the page, with a quiet cyan top-edge and a
 *  faint corner light — chroma in containers, never in text. The card is a split:
 *  the decision on the left, a white "audit receipt" on the right (#31) — the
 *  honest proof of one applied change, sitting like paper on the desk. */
interface Props {
  ctaHref: string
  locale?: 'en' | 'zh-CN'
}
const { ctaHref, locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? {
      pill: '在报税旺季到来前做好准备',
      bodyLead:
        '把客户名单粘贴进来，约 30 分钟就能备好一年带来源的截止日。从此我们替你盯着每一处官方来源——日期一变动，你立刻看清它影响到谁。',
      bodyStrong: '再也不会是最后一个知道的。',
      ctaPrimary: '免费领 3 个月',
      ctaGhost: '预约演示',
      trust: ['免费用 3 个月 Team 版', '开始无需信用卡', '数据留在你的事务所'],
      receiptEyebrow: '审计凭据',
      receiptId: '#DDH-2240',
      receiptCount: '已应用到 8 位客户',
      receiptRows: [
        { glyph: 'link', text: '来源 irs.gov · 已核验' },
        { glyph: 'undo', text: '24 小时内可撤销' },
        { glyph: 'shield', text: '已记入审计记录' },
      ],
    }
  : {
      pill: 'Be ready before busy season',
      bodyLead:
        'Paste your clients once — a sourced year of deadlines is ready in about 30 minutes. From there we watch every official source for you, so the moment a date moves you see exactly who it hits. ',
      bodyStrong: 'Never the last to know.',
      ctaPrimary: 'Get 3 months free',
      ctaGhost: 'Book a demo call',
      trust: ['3 months of Team, free', 'No card to start', 'Data stays in your practice'],
      receiptEyebrow: 'Audit receipt',
      receiptId: '#DDH-2240',
      receiptCount: 'Applied to 8 clients',
      receiptRows: [
        { glyph: 'link', text: 'Sourced to irs.gov · verified' },
        { glyph: 'undo', text: 'Reversible for 24 hours' },
        { glyph: 'shield', text: 'Recorded to the audit trail' },
      ],
    }
const trust = t.trust
const receiptRows = t.receiptRows
---

<section class="close" id="close" aria-labelledby="close-h" data-reveal>
  <div class="close__card">
    <div class="close__body-wrap">
      <span class="close__pill"><span class="close__dot" aria-hidden="true"></span>{t.pill}</span>
      <h2 class="m-h2 close__h" id="close-h">
        {
          zh ? (
            <>
              下次截止日变动，你<span class="ital">早就知道是谁了。</span>
            </>
          ) : (
            <>
              Next time a deadline moves, you'll <span class="ital">know exactly who.</span>
            </>
          )
        }
      </h2>
      <p class="close__body">
        {t.bodyLead}<strong>{t.bodyStrong}</strong>
      </p>

      <div class="close__cta m-cta-dark">
        <a class="m-cta m-cta--primary" href={ctaHref} data-event="marketing.close.cta">
          {t.ctaPrimary} <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="m-cta m-cta--ghost" href={ctaHref}>{t.ctaGhost}</a>
      </div>

      <div class="close__trust">
        {
          trust.map((item) => (
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {item}
            </span>
          ))
        }
      </div>
    </div>

    <!-- the proof, on the right: a white paper receipt for one applied change -->
    <aside class="close__receipt" aria-label="Sample audit receipt for one applied change">
      <div class="rcpt">
        <div class="rcpt__top">
          <span class="rcpt__eyebrow">{t.receiptEyebrow}</span>
          <span class="rcpt__id">{t.receiptId}</span>
        </div>
        <div class="rcpt__change">
          <s>Apr 15</s>
          <span class="rcpt__arrow" aria-hidden="true">→</span>
          <b>Nov 3, 2026</b>
        </div>
        <div class="rcpt__count">{t.receiptCount}</div>
        <ul class="rcpt__rows">
          {
            receiptRows.map((r) => (
              <li class="rcpt__row">
                <span class="rcpt__ico" aria-hidden="true">
                  {r.glyph === 'link' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8" />
                    </svg>
                  )}
                  {r.glyph === 'undo' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 14 4 9l5-5" />
                      <path d="M4 9h11a5 5 0 0 1 0 10h-1" />
                    </svg>
                  )}
                  {r.glyph === 'shield' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                      <path d="M9 12l2 2 4-4" />
                    </svg>
                  )}
                </span>
                {r.text}
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </div>
</section>

<style>
  .close {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(48px, 7vw, 96px);
  }
  /* Bold navy finale — distinct as the page's END: a cyan top-edge + a faint
     corner light give the flat navy a crafted lift (chroma in containers, not
     text), and the headline returns to the page's display serif to bookend the
     Hero. A split: the decision left, the audit receipt right. */
  .close__card {
    position: relative;
    background: var(--m-accent);
    border-radius: 16px;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    grid-template-columns: 1.25fr 0.85fr;
    align-items: center;
  }
  .close__card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      130% 100% at 100% 0%,
      color-mix(in srgb, var(--m-cyan) 24%, transparent) 0%,
      transparent 58%
    );
    pointer-events: none;
  }
  .close__card::after {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--m-cyan) 14%,
      var(--m-cyan) 86%,
      transparent
    );
    box-shadow: 0 0 18px 1px color-mix(in srgb, var(--m-cyan) 45%, transparent);
    pointer-events: none;
  }
  .close__body-wrap {
    position: relative;
    padding: clamp(44px, 6vw, 76px) clamp(28px, 4vw, 56px) clamp(40px, 5vw, 60px);
  }
  .close__pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: var(--m-text-2xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 6px 14px;
    margin-bottom: 28px;
  }
  .close__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-cyan);
  }
  .close__h {
    font-family: var(--m-font-display);
    font-weight: 400;
    font-size: clamp(36px, 4.6vw, 60px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: #fff;
    max-width: 16ch;
    text-wrap: balance;
  }
  .close__h .ital {
    font-style: italic;
    letter-spacing: 0.002em;
  }
  .close__body {
    margin-top: 22px;
    max-width: 52ch;
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
  }
  .close__body strong {
    color: #fff;
    font-weight: 600;
  }
  .close__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 24px;
    align-items: center;
  }
  /* finale CTAs use the shared .m-cta pill in its .m-cta-dark (on-navy) context
     — defined in marketing.css; no local button styles */
  .close__trust {
    margin-top: 26px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px 22px;
  }
  .close__trust span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--m-text-sm);
    color: rgba(255, 255, 255, 0.78);
  }
  .close__trust svg {
    width: 15px;
    height: 15px;
    color: var(--m-cyan);
    flex: none;
  }

  /* ---- the receipt, right side of the navy card (#31) ---- */
  .close__receipt {
    position: relative;
    align-self: stretch;
    display: flex;
    align-items: center;
    padding: clamp(28px, 3.5vw, 48px) clamp(28px, 4vw, 56px) clamp(28px, 3.5vw, 48px) 0;
  }
  .rcpt {
    position: relative;
    width: 100%;
    background: var(--m-surface);
    border-radius: 12px;
    padding: 22px 24px 20px;
  }
  /* a faint perforated "tear" along the top — reads as a torn-off receipt */
  .rcpt::before {
    content: '';
    position: absolute;
    inset: 0 14px auto 14px;
    top: 0;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      color-mix(in srgb, var(--m-accent) 34%, transparent) 0 5px,
      transparent 5px 10px
    );
  }
  .rcpt__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .rcpt__eyebrow {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .rcpt__id {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-accent);
  }
  .rcpt__change {
    margin-top: 14px;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-lg);
    color: var(--m-ink);
  }
  .rcpt__change s {
    color: var(--m-faint);
  }
  .rcpt__arrow {
    color: var(--m-muted);
  }
  .rcpt__count {
    margin-top: 6px;
    font-size: var(--m-text-xs);
    font-weight: 500;
    color: var(--m-accent);
  }
  .rcpt__rows {
    list-style: none;
    margin: 16px 0 0;
    padding: 14px 0 0;
    border-top: 1px solid var(--m-hairline);
    display: grid;
    gap: 10px;
  }
  .rcpt__row {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: var(--m-text-xs);
    color: var(--m-ink-2);
  }
  .rcpt__ico {
    display: inline-flex;
    flex: none;
    color: var(--m-accent);
  }
  .rcpt__ico svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 860px) {
    .close__card {
      grid-template-columns: 1fr;
    }
    .close__receipt {
      padding: 0 clamp(28px, 5vw, 40px) clamp(36px, 6vw, 48px);
    }
    .rcpt {
      max-width: 420px;
    }
  }
</style>
