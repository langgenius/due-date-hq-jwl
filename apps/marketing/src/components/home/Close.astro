---
/** Close — the finale CTA. A bold navy card (different from the white sections,
 *  cohesive via the brand accent) with a full-width light audit "receipt" strip.
 *  White only on the navy; the accent lives in the inverted white CTA. */
interface Props {
  ctaHref: string
  locale?: 'en' | 'zh-CN'
}
const { ctaHref, locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? {
      pill: '在报税旺季到来前做好准备',
      bodyLead:
        '把你的客户名单粘贴进来，约 30 分钟内就能备好一年带来源的截止日。从此之后，我们替你盯着每一处变化——下次某个州调整截止日时，你早已知道它影响到谁。',
      bodyStrong: '我们会一直盯着。',
      ctaPrimary: '免费开始',
      ctaGhost: '要人带着上手',
      trust: ['测试期免费', '无需信用卡', '数据留在你的事务所'],
      receiptEyebrow: '审计凭据',
      receiptApply: 'Apply #DDH-2240',
      receiptChangeTail: '· 8 位客户',
      receiptRows: [
        { glyph: 'link', text: '来源 irs.gov · 已核验' },
        { glyph: 'undo', text: '24 小时内可撤销' },
        { glyph: 'shield', text: '已记入审计记录' },
      ],
    }
  : {
      pill: 'Be ready before busy season',
      bodyLead:
        "Paste your clients, and a sourced year of deadlines is ready in about 30 minutes. From there, we watch every change for you — so the next time a state moves a deadline, you'll already know who it affects. ",
      bodyStrong: "We'll be watching the whole time.",
      ctaPrimary: 'Start free',
      ctaGhost: 'Get a guided setup',
      trust: ['Free during the beta', 'No card required', 'Data stays in your practice'],
      receiptEyebrow: 'Audit receipt',
      receiptApply: 'Apply #DDH-2240',
      receiptChangeTail: '· 8 clients',
      receiptRows: [
        { glyph: 'link', text: 'Sourced to irs.gov · verified' },
        { glyph: 'undo', text: 'Reversible for 24 hours' },
        { glyph: 'shield', text: 'Recorded to the audit trail' },
      ],
    }
const trust = t.trust
const receiptRows = t.receiptRows
---

<section class="close" id="close" aria-labelledby="close-h">
  <div class="close__card">
    <div class="close__body-wrap">
      <span class="close__pill"><span class="close__dot" aria-hidden="true"></span>{t.pill}</span>
      <h2 class="m-h2 close__h" id="close-h">
        {
          zh ? (
            <>
              走进下一个报税旺季，已经<span class="ital">领先一步。</span>
            </>
          ) : (
            <>
              Walk into next busy season already <span class="ital">ahead.</span>
            </>
          )
        }
      </h2>
      <p class="close__body">
        {t.bodyLead}<strong>{t.bodyStrong}</strong>
      </p>

      <div class="close__cta">
        <a class="btn btn--primary" href={ctaHref} data-event="marketing.close.cta">
          {t.ctaPrimary} <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href={ctaHref}>{t.ctaGhost}</a>
      </div>

      <div class="close__trust">
        {
          trust.map((item) => (
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {item}
            </span>
          ))
        }
      </div>
    </div>

    <div class="receipt" aria-label="Sample audit receipt for one applied change">
      <div class="receipt__head">
        <span class="receipt__eyebrow">{t.receiptEyebrow} · {t.receiptApply}</span>
        <p class="receipt__change"><s>Apr 15</s> → Nov 3, 2026 {t.receiptChangeTail}</p>
      </div>
      <div class="receipt__facts">
        {
          receiptRows.map((r) => (
            <span class="receipt__fact">
              {r.glyph === 'link' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8" />
                </svg>
              )}
              {r.glyph === 'undo' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 14 4 9l5-5" />
                  <path d="M4 9h11a5 5 0 0 1 0 10h-1" />
                </svg>
              )}
              {r.glyph === 'shield' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                </svg>
              )}
              {r.text}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .close {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(48px, 7vw, 96px);
  }
  /* bold navy finale — different from the white sections, cohesive via the brand */
  .close__card {
    background: var(--m-accent);
    border-radius: 16px;
    overflow: hidden;
  }
  .close__body-wrap {
    padding: clamp(40px, 6vw, 72px) clamp(28px, 5vw, 64px) clamp(32px, 4vw, 44px);
  }
  .close__pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 6px 14px;
    margin-bottom: 28px;
  }
  .close__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-cyan);
  }
  .close__h {
    font-size: clamp(34px, 5vw, 60px);
    color: #fff;
  }
  .close__h .ital {
    font-style: italic;
  }
  .close__body {
    margin-top: 22px;
    max-width: 56ch;
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);
  }
  .close__body strong {
    color: #fff;
    font-weight: 600;
  }
  .close__cta {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 24px;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 8px;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.12s ease;
  }
  /* inverted on the navy */
  .btn--primary {
    background: #fff;
    color: var(--m-accent);
    padding: 12px 20px;
  }
  .btn--primary:hover {
    background: rgba(255, 255, 255, 0.9);
  }
  .btn--primary:active {
    transform: translateY(1px);
  }
  .btn--primary .arrow {
    transition: transform 0.18s ease;
  }
  .btn--primary:hover .arrow {
    transform: translateX(3px);
  }
  .btn--ghost {
    color: #fff;
    padding: 12px 4px;
  }
  .btn--ghost:hover {
    box-shadow: inset 0 -1.5px 0 rgba(255, 255, 255, 0.7);
  }
  .close__trust {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px 22px;
  }
  .close__trust span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.78);
  }
  .close__trust svg {
    width: 15px;
    height: 15px;
    color: var(--m-cyan);
    flex: none;
  }
  /* full-width light receipt strip at the bottom of the navy card */
  .receipt {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 28px;
    padding: 18px clamp(28px, 5vw, 64px);
    background: var(--m-surface);
    border-top: 1px dashed color-mix(in srgb, var(--m-accent) 30%, transparent);
  }
  .receipt__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 14px;
  }
  .receipt__eyebrow {
    font-family: var(--m-font-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .receipt__change {
    font-family: var(--m-font-mono);
    font-size: 12px;
    color: var(--m-ink);
  }
  .receipt__change s {
    color: var(--m-faint);
  }
  .receipt__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
  }
  .receipt__fact {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--m-ink-2);
  }
  .receipt__fact svg {
    width: 13px;
    height: 13px;
    color: var(--m-accent);
    flex: none;
  }
</style>
