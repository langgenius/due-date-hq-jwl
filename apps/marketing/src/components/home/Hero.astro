---
/**
 * Homepage hero (production-v2 design, ported to Astro on the --m-* token tier).
 * Copy is welcoming-but-restrained ("a calm expert who's got your back").
 * English inline for now; i18n wrapping happens in the localization pass.
 * The Alerts panel is the signature surface — static markup here; the
 * filter/expand/apply micro-interactions layer on in a follow-up.
 */
interface Props {
  locale?: 'en' | 'zh-CN'
  ctaHref: string
  workflowAnchor?: string
}
const { locale = 'en', ctaHref, workflowAnchor = '#how' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      headBefore: '截止日刚刚变了。你知道它影响到',
      headItal: '谁',
      headAfter: '吗？',
      subLead: 'DueDateHQ 全天候监控 IRS、全部 50 个州和 FEMA 灾害延期 ——',
      subEm: '申报日期一变动，',
      subRest: '你立刻看到它影响到哪些客户，以及背后的官方公告。',
      subStrong: '粘贴你的客户名单，约 10 分钟后第一条带来源的截止日就会出现。',
      points: [
        { strong: '我们全天候盯着 IRS、主要州税务机关和 FEMA', rest: '' },
        { strong: '你能看到', rest: '每次变化具体影响到哪些客户' },
        { strong: '每个日期都可追溯', rest: '回它的官方来源' },
        { strong: 'beta 期间免费', rest: '—— 无需信用卡' },
      ],
      ctaStart: '免费开始',
      ctaHow: '看它如何运作',
      panelAria: '本周示例提醒',
      panelTitleAlerts: '提醒',
      panelTitleWhen: '本周',
      panelCount: '6 项变化 · 31 个客户',
      panelCap: '实时预览 · 非你的真实数据',
      filterAria: '按辖区筛选',
      filters: ['全部', '联邦', 'CA', 'TX', 'NY'],
      sevUrgent: '紧急',
      sevInfo: '信息',
      affectsLabel: '影响',
      alerts: [
        {
          sev: 'urgent',
          juris: 'FED',
          source: 'irs.gov',
          title: 'IRS 在灾害声明后推迟申报与缴税截止日',
          from: 'Apr 15',
          to: 'Nov 3, 2026',
          delta: '推迟 202 天',
          affects: '8 个客户',
          status: '6 项就绪 · 2 项待复核',
        },
        {
          sev: 'info',
          juris: 'CA',
          source: 'ftb.ca.gov',
          title: '加州 FTB 在山火声明后延长第三季度预估税截止日',
          from: 'Sep 15',
          to: 'Sep 29, 2026',
          delta: '推迟 14 天',
          affects: '12 个客户',
          status: '9 项就绪 · 3 项待复核',
        },
        {
          sev: 'info',
          juris: 'TX',
          source: 'comptroller.texas.gov',
          title: '德州对远程卖家新增特许经营税申报要求',
          effective: '2026 年 1 月 1 日起生效',
          badge: '新义务',
          affects: '5 个客户',
          status: '5 项就绪',
        },
      ],
    }
  : {
      headBefore: 'A deadline just moved. Do you know',
      headItal: 'who',
      headAfter: 'it hits?',
      subLead: 'DueDateHQ monitors the IRS, all 50 states, and FEMA disaster postponements around the clock —',
      subEm: 'the moment a filing date moves,',
      subRest: 'you see which clients it affects and the official notice behind it.',
      subStrong:
        'Paste your client list and your first sourced deadline shows up in about 10 minutes.',
      points: [
        { strong: 'We watch the IRS, major state agencies & FEMA', rest: '— around the clock' },
        { strong: 'You see the exact clients', rest: 'each change touches' },
        { strong: 'Every date links back', rest: 'to its official source' },
        { strong: 'Free during the beta', rest: '— no card required' },
      ],
      ctaStart: 'Start free',
      ctaHow: 'See how it works',
      panelAria: 'Sample alerts for this week',
      panelTitleAlerts: 'Alerts',
      panelTitleWhen: 'this week',
      panelCount: '6 changes · 31 clients',
      panelCap: 'live preview · not your data',
      filterAria: 'Filter by jurisdiction',
      filters: ['All', 'Federal', 'CA', 'TX', 'NY'],
      sevUrgent: 'URGENT',
      sevInfo: 'INFO',
      affectsLabel: 'Affects',
      alerts: [
        {
          sev: 'urgent',
          juris: 'FED',
          source: 'irs.gov',
          title: 'IRS postpones filing & payment deadlines after disaster declaration',
          from: 'Apr 15',
          to: 'Nov 3, 2026',
          delta: '202 days later',
          affects: '8 clients',
          status: '6 ready · 2 review',
        },
        {
          sev: 'info',
          juris: 'CA',
          source: 'ftb.ca.gov',
          title: 'California FTB extends the Q3 estimated-tax deadline after wildfire declaration',
          from: 'Sep 15',
          to: 'Sep 29, 2026',
          delta: '14 days later',
          affects: '12 clients',
          status: '9 ready · 3 review',
        },
        {
          sev: 'info',
          juris: 'TX',
          source: 'comptroller.texas.gov',
          title: 'Texas adds a franchise-tax filing requirement for remote sellers',
          effective: 'Effective Jan 1, 2026',
          badge: 'new obligation',
          affects: '5 clients',
          status: '5 ready',
        },
      ],
    }
const points = t.points
const alerts = t.alerts
---

<section class="hero" aria-labelledby="hero-h" data-zh={zh ? '' : undefined}>
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 class="hero__head" id="hero-h">
        {t.headBefore} <span class="ital">{t.headItal}</span> {t.headAfter}
      </h1>
      <p class="hero__sub">
        {t.subLead} <em>{t.subEm}</em> {t.subRest}
      </p>

      <ul class="hero__points">
        {
          points.map((p, i) => (
            <li>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {/* each glyph is matched to its promise: watch · clients · source · free */}
                {i === 0 && (
                  <>
                    <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                    <circle cx="12" cy="12" r="2.7" />
                  </>
                )}
                {i === 1 && (
                  <>
                    <path d="M16 19v-1.2a3.6 3.6 0 0 0-3.6-3.6H6.6A3.6 3.6 0 0 0 3 17.8V19" />
                    <circle cx="9.5" cy="8" r="3.2" />
                    <path d="M21 19v-1.2a3.6 3.6 0 0 0-2.7-3.5M15.6 5a3.2 3.2 0 0 1 0 6" />
                  </>
                )}
                {i === 2 && (
                  <>
                    <path d="M10 13a4.5 4.5 0 0 0 6.7.5l2.5-2.5a4.5 4.5 0 0 0-6.4-6.4l-1.4 1.4" />
                    <path d="M14 11a4.5 4.5 0 0 0-6.7-.5L4.8 13a4.5 4.5 0 0 0 6.4 6.4l1.4-1.4" />
                  </>
                )}
                {i === 3 && (
                  <>
                    <path d="M20 12v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8" />
                    <rect x="2.5" y="7.5" width="19" height="4.5" rx="1" />
                    <path d="M12 7.5V21" />
                    <path d="M12 7.5H8.2a2.1 2.1 0 1 1 0-4.2C11 3.3 12 7.5 12 7.5Z" />
                    <path d="M12 7.5h3.8a2.1 2.1 0 1 0 0-4.2C13 3.3 12 7.5 12 7.5Z" />
                  </>
                )}
              </svg>
              <span>
                <b>{p.strong}</b> {p.rest}
              </span>
            </li>
          ))
        }
      </ul>

      <div class="hero__cta">
        <a class="m-cta m-cta--primary" href={ctaHref} data-event="marketing.hero.cta">
          {t.ctaStart} <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="m-cta m-cta--ghost" href={workflowAnchor}>
          <svg
            class="m-cta__ico"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 6.5V20" />
            <path d="M12 6.5S10.4 4.5 7 4.5 3 6 3 6v12.4s1.4-1.4 4-1.4 5 1.5 5 1.5" />
            <path d="M12 6.5S13.6 4.5 17 4.5 21 6 21 6v12.4s-1.4-1.4-4-1.4-5 1.5-5 1.5" />
          </svg>
          {t.ctaHow}
        </a>
      </div>
      <p class="hero__reassure">{t.subStrong}</p>
    </div>

    <!-- signature surface: this week's alerts (live preview · not your data) -->
    <div class="panel" aria-label={t.panelAria}>
      <div class="panel__head">
        <span class="panel__title">
          <span class="panel__live" aria-hidden="true"></span>{t.panelTitleAlerts}<span
            class="panel__dot">·</span
          >{t.panelTitleWhen}
        </span>
        <span class="panel__count">{t.panelCount}</span>
        <span class="panel__cap">{t.panelCap}</span>
      </div>

      <div class="panel__filter" aria-hidden="true">
        {
          t.filters.map((j, i) => (
            <span class={`chip${i === 0 ? ' chip--on' : ''}`}>{j}</span>
          ))
        }
      </div>

      <div class="panel__rows">
        {
          alerts.map((a) => (
            <article class={`row${a.sev === 'urgent' ? ' row--anchor' : ' row--secondary'}`}>
              <div class="row__top">
                <span class={`sev sev--${a.sev}`}>{a.sev === 'urgent' ? t.sevUrgent : t.sevInfo}</span>
                <span class="juris">{a.juris}</span>
                <span class="src">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M10 14a5 5 0 007.5.5l3-3a5 5 0 00-7-7l-1.7 1.7M14 10a5 5 0 00-7.5-.5l-3 3a5 5 0 007 7l1.7-1.7"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {a.source}
                </span>
              </div>
              <p class="row__title">{a.title}</p>
              {a.delta ? (
                <p class="row__change">
                  <s>{a.from}</s> <span class="arrow">→</span> <b>{a.to}</b>
                  <span class="row__delta row__delta--later">
                    {a.delta}
                  </span>
                </p>
              ) : (
                <p class="row__change">
                  <b>{a.effective}</b>
                  <span class="row__badge">{a.badge}</span>
                </p>
              )}
              <p class="row__affect">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M17 20v-1a4 4 0 00-4-4H7a4 4 0 00-4 4v1M10 11a3.5 3.5 0 100-7 3.5 3.5 0 000 7M21 20v-1a4 4 0 00-3-3.9"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {t.affectsLabel} <b>{a.affects}</b>
                {a.sev === 'urgent' ? <span class="row__status">{a.status}</span> : null}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-top: clamp(56px, 6.5vw, 108px);
    padding-bottom: clamp(80px, 10vw, 132px);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(36px, 4.5vw, 76px);
    gap: clamp(40px, 5vw, 64px);
    align-items: center;
  }
  .hero__copy {
    grid-column: span 6;
    align-self: center;
    /* reorder for a stronger top: hook → value → action → proof. The CTA rises
       above the proof bullets (which carry no focusable elements, so visual and
       tab order stay aligned). */
    display: flex;
    flex-direction: column;
  }
  .hero__head {
    order: 1;
  }
  .hero__sub {
    order: 2;
  }
  .hero__cta {
    order: 3;
  }
  .hero__reassure {
    order: 4;
  }
  .hero__points {
    order: 5;
  }
  .panel {
    grid-column: span 6;
  }

  /* ---- copy ---- */
  .hero__head {
    font-family: var(--m-font-display);
    font-weight: 400;
    /* The focal point — pushed bigger + tighter so it dominates the fold. */
    font-size: clamp(43px, 5.9vw, 84px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--m-ink);
    max-width: 14ch;
    text-wrap: balance;
  }
  .hero__head .ital {
    font-style: italic;
    /* Italic display cut reads tighter — pull a hair of optical spacing back. */
    letter-spacing: 0.002em;
  }
  /* CJK glyphs are full-width and heavier — the Latin ceiling overwhelms the column.
     Cap the size, widen the measure for a clean 2–3 lines, and drop the tight tracking. */
  .hero[data-zh] .hero__head {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.18;
    letter-spacing: 0;
    max-width: 18ch;
  }
  .hero__sub {
    margin-top: clamp(22px, 1.7vw, 28px);
    max-width: 53ch;
    font-size: clamp(15px, 1.05vw, 16.5px);
    line-height: 1.6;
    color: var(--m-ink-2);
  }
  .hero__sub em {
    font-style: italic;
    color: var(--m-ink);
  }
  /* zh: CJK has no italic — the synthesized oblique reads broken, so keep the
     emphasis as colour/weight only (mirrors the .ital faux-italic guard). */
  html[lang='zh-CN'] .hero__sub em {
    font-style: normal;
    font-weight: 500;
  }
  .hero__sub strong {
    color: var(--m-ink);
    font-weight: 500;
  }
  .hero__reassure {
    margin-top: 14px;
    max-width: 46ch;
    font-size: var(--m-text-base);
    line-height: 1.55;
    color: var(--m-ink-2);
  }
  /* demoted to a quiet proof strip beneath the CTA — smaller, set off by a
     hairline so it reads as supporting evidence, not a competing list */
  .hero__points {
    margin-top: clamp(24px, 2.4vw, 32px);
    padding-top: clamp(20px, 2vw, 26px);
    border-top: 1px solid var(--m-hairline);
    display: grid;
    gap: 9px;
    list-style: none;
    padding-left: 0;
    padding-right: 0;
  }
  .hero__points li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: var(--m-text-sm);
    line-height: 1.4;
    color: var(--m-muted);
  }
  .hero__points svg {
    width: 15px;
    height: 15px;
    flex: none;
    margin-top: 2px;
    color: var(--m-accent);
  }
  .hero__points b {
    color: var(--m-ink);
    font-weight: 600;
  }

  .hero__cta {
    margin-top: clamp(30px, 3vw, 40px);
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    align-items: center;
  }
  /* hero CTAs use the shared .m-cta / .m-cta--primary / .m-cta--ghost pill
     (defined in marketing.css) — no local button styles */
  /* ---- alerts panel ---- */
  .panel {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px -44px rgba(16, 24, 40, 0.4);
  }
  .panel__head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    border-bottom: 1px solid var(--m-hairline);
  }
  .panel__title {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--m-text-xs);
    font-weight: 600;
    color: var(--m-ink-2);
  }
  .panel__dot {
    color: var(--m-faint);
  }
  .panel__live {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--m-ok);
    flex: none;
    position: relative;
  }
  .panel__live::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 1px solid var(--m-ok);
    opacity: 0;
    animation: ripple 2.6s ease-out infinite;
  }
  @keyframes ripple {
    0% {
      opacity: 0.5;
      transform: scale(0.6);
    }
    70%,
    100% {
      opacity: 0;
      transform: scale(1.6);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .panel__live::after {
      animation: none;
    }
  }
  .panel__count {
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
    font-family: var(--m-font-mono);
  }
  .panel__cap {
    margin-left: auto;
    font-size: var(--m-text-3xs);
    letter-spacing: 0.04em;
    color: var(--m-faint);
    font-family: var(--m-font-mono);
    white-space: nowrap;
  }

  .panel__filter {
    display: flex;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--m-hairline-2);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .panel__filter::-webkit-scrollbar {
    display: none;
  }
  .chip {
    flex: none;
    font-size: var(--m-text-2xs);
    font-weight: 500;
    color: var(--m-muted);
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    white-space: nowrap;
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }
  .chip:hover {
    color: var(--m-ink);
    border-color: var(--m-faint);
  }
  .chip--on {
    color: #fff;
    background: var(--m-accent);
    border-color: var(--m-accent);
  }

  .row {
    padding: 14px 16px;
  }
  .row + .row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .row__top {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sev {
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 2px 7px;
    border-radius: 6px;
  }
  .sev--urgent {
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 9%, transparent);
  }
  .sev--info {
    color: var(--m-ink-2);
    background: var(--m-section);
  }
  .juris {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
    border-radius: 6px;
    padding: 1px 7px;
  }
  .src {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
  }
  .src svg {
    width: 12px;
    height: 12px;
  }
  .row__title {
    margin-top: 9px;
    font-size: var(--m-text-base);
    font-weight: 500;
    color: var(--m-ink);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  /* Secondary rows recede so the anchor (urgent) row reads first. */
  .row--secondary .row__title {
    font-weight: 400;
    color: var(--m-ink-2);
  }
  .row__change {
    margin-top: 9px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: var(--m-ink);
  }
  .row__change s {
    color: var(--m-muted);
  }
  .row__change .arrow {
    color: var(--m-muted);
  }
  .row__delta {
    font-family: var(--m-font-sans);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    padding: 1px 7px;
    border-radius: 999px;
  }
  .row__delta--later {
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
  }
  .row__badge {
    font-family: var(--m-font-sans);
    font-size: var(--m-text-2xs);
    font-weight: 500;
    color: var(--m-muted);
    background: var(--m-section);
    border-radius: 999px;
    padding: 1px 8px;
  }
  .row__affect {
    margin-top: 11px;
    padding-top: 10px;
    border-top: 1px solid var(--m-hairline-2);
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: var(--m-text-xs);
    color: var(--m-ink-2);
  }
  .row__affect svg {
    width: 14px;
    height: 14px;
    flex: none;
    color: var(--m-muted);
  }
  .row__affect b {
    color: var(--m-accent);
    font-weight: 600;
  }
  .row__status {
    margin-left: auto;
    font-size: var(--m-text-2xs);
    color: var(--m-faint);
    font-family: var(--m-font-mono);
  }

  @media (max-width: 1000px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__copy,
    .panel {
      grid-column: auto;
    }
  }
  @media (max-width: 540px) {
    .panel__head {
      flex-wrap: wrap;
    }
    .panel__cap {
      display: none;
    }
  }
</style>
