---
/**
 * Homepage hero (production-v2 design, ported to Astro on the --m-* token tier).
 * Copy is welcoming-but-restrained ("a calm expert who's got your back").
 * English inline for now; i18n wrapping happens in the localization pass.
 * The Alerts panel is the signature surface — static markup here; the
 * filter/expand/apply micro-interactions layer on in a follow-up.
 */
interface Props {
  locale?: 'en' | 'zh-CN'
  ctaHref: string
  conciergeHref: string
  workflowAnchor?: string
}
const { locale = 'en', ctaHref, conciergeHref, workflowAnchor = '#how' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      headBefore: '抓住每一次',
      headItal: '规则变动。',
      headAfter: '点名每一个受影响的客户。',
      headCoverage: 'IRS · 50 个州 · DC · FEMA',
      subLead: '',
      subEm: 'IRS、各州或 FEMA 一发布变动，',
      subRest: 'DueDateHQ 立刻告诉你哪些客户受影响 —— 并一键应用新日期。',
      subStrong: '自己来：粘贴客户名单，约 10 分钟出第一条带来源的截止日。',
      points: [
        { strong: '规则变动侦测', rest: '—— 主动，发布那一刻就抓到' },
        { strong: '客户影响匹配', rest: '—— 精准，点名到每一个客户' },
        { strong: '一键应用', rest: '—— 可追溯，每个日期都带官方来源' },
      ],
      ctaStart: '免费领 3 个月',
      ctaConcierge: '把名单交给我们，帮你设置好',
      reassureHow: '或',
      ctaHow: '看它如何运作',
      panelAria: '本周示例提醒',
      panelTitleAlerts: '提醒',
      panelTitleWhen: '本周',
      panelCount: '6 项变化 · 31 个客户',
      panelCap: '实时预览 · 非你的真实数据',
      filterAria: '按辖区筛选',
      filters: ['全部', '联邦', 'CA', 'TX', 'NY'],
      sevUrgent: '紧急',
      sevInfo: '信息',
      affectsLabel: '影响',
      alerts: [
        {
          sev: 'urgent',
          juris: 'FED',
          source: 'irs.gov',
          title: 'IRS 在灾害声明后推迟申报与缴税截止日',
          from: 'Apr 15',
          to: 'Nov 3, 2026',
          delta: '推迟 202 天',
          affects: '8 个客户',
          status: '6 项就绪 · 2 项待复核',
        },
        {
          sev: 'info',
          juris: 'CA',
          source: 'ftb.ca.gov',
          title: '加州 FTB 在山火声明后延长第三季度预估税截止日',
          from: 'Sep 15',
          to: 'Sep 29, 2026',
          delta: '推迟 14 天',
          affects: '12 个客户',
          status: '9 项就绪 · 3 项待复核',
        },
        {
          sev: 'info',
          juris: 'TX',
          source: 'comptroller.texas.gov',
          title: '德州对远程卖家新增特许经营税申报要求',
          effective: '2026 年 1 月 1 日起生效',
          badge: '新义务',
          affects: '5 个客户',
          status: '5 项就绪',
        },
      ],
    }
  : {
      headBefore: 'Catching every',
      headItal: 'rule change.',
      headAfter: 'Naming every affected client.',
      headCoverage: 'IRS · 50 states · DC · FEMA',
      subLead: '',
      subEm: 'The moment the IRS, a state, or FEMA publishes a change,',
      subRest:
        'DueDateHQ tells you exactly which clients are hit — and applies the new dates in one click.',
      subStrong:
        'Do it yourself: paste your client list, first sourced deadline in ~10 minutes.',
      points: [
        { strong: 'Rule-change detection', rest: '— proactive, the moment it publishes' },
        { strong: 'Client impact matching', rest: '— precise, down to the client' },
        { strong: 'One-click apply', rest: '— traceable, source on every date' },
      ],
      ctaStart: 'Get 3 months free',
      ctaConcierge: "We'll set it up with your list",
      reassureHow: 'Or',
      ctaHow: 'see how it works',
      panelAria: 'Sample alerts for this week',
      panelTitleAlerts: 'Alerts',
      panelTitleWhen: 'this week',
      panelCount: '6 changes · 31 clients',
      panelCap: 'live preview · not your data',
      filterAria: 'Filter by jurisdiction',
      filters: ['All', 'Federal', 'CA', 'TX', 'NY'],
      sevUrgent: 'URGENT',
      sevInfo: 'INFO',
      affectsLabel: 'Affects',
      alerts: [
        {
          sev: 'urgent',
          juris: 'FED',
          source: 'irs.gov',
          title: 'IRS postpones filing & payment deadlines after disaster declaration',
          from: 'Apr 15',
          to: 'Nov 3, 2026',
          delta: '202 days later',
          affects: '8 clients',
          status: '6 ready · 2 review',
        },
        {
          sev: 'info',
          juris: 'CA',
          source: 'ftb.ca.gov',
          title: 'California FTB extends the Q3 estimated-tax deadline after wildfire declaration',
          from: 'Sep 15',
          to: 'Sep 29, 2026',
          delta: '14 days later',
          affects: '12 clients',
          status: '9 ready · 3 review',
        },
        {
          sev: 'info',
          juris: 'TX',
          source: 'comptroller.texas.gov',
          title: 'Texas adds a franchise-tax filing requirement for remote sellers',
          effective: 'Effective Jan 1, 2026',
          badge: 'new obligation',
          affects: '5 clients',
          status: '5 ready',
        },
      ],
    }
const alerts = t.alerts
---

<section class="hero" aria-labelledby="hero-h" data-zh={zh ? '' : undefined}>
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 class="hero__head" id="hero-h">
        {t.headBefore} <span class="ital">{t.headItal}</span> {t.headAfter}
        <span class="hero__head-cov">{t.headCoverage}</span>
      </h1>
      <p class="hero__sub">
        {t.subLead} <em>{t.subEm}</em> {t.subRest}
      </p>

      <div class="hero__cta">
        <a class="m-cta m-cta--primary" href={ctaHref} data-event="marketing.hero.cta">
          {t.ctaStart} <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="m-cta m-cta--ghost" href={conciergeHref} data-event="marketing.hero.concierge">
          <svg
            class="m-cta__ico"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            {/* concierge service bell — the "done for you" path */}
            <path d="M3 19.5h18" />
            <path d="M5 19.5a7 7 0 0 1 14 0" />
            <path d="M12 7.5v-2" />
            <path d="M10 5.5h4" />
          </svg>
          {t.ctaConcierge}
        </a>
      </div>
      <p class="hero__reassure">
        {t.subStrong} {t.reassureHow}
        <a class="hero__howlink" href={workflowAnchor}>{t.ctaHow} <span aria-hidden="true">→</span></a>
      </p>
    </div>

    <!-- signature surface: this week's alerts (live preview · not your data) -->
    <div class="panel" aria-label={t.panelAria}>
      <div class="panel__head">
        <span class="panel__title">
          <span class="panel__live" aria-hidden="true"></span>{t.panelTitleAlerts}<span
            class="panel__dot">·</span
          >{t.panelTitleWhen}
        </span>
        <span class="panel__count">{t.panelCount}</span>
        <span class="panel__cap">{t.panelCap}</span>
      </div>

      <div class="panel__rows">
        {
          alerts.slice(0, 2).map((a) => (
            <article class={`row${a.sev === 'urgent' ? ' row--anchor' : ' row--secondary'}`}>
              <div class="row__top">
                <span class={`sev sev--${a.sev}`}>{a.sev === 'urgent' ? t.sevUrgent : t.sevInfo}</span>
                <span class="juris">{a.juris}</span>
                <span class="src">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M10 14a5 5 0 007.5.5l3-3a5 5 0 00-7-7l-1.7 1.7M14 10a5 5 0 00-7.5-.5l-3 3a5 5 0 007 7l1.7-1.7"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {a.source}
                </span>
              </div>
              <p class="row__title">{a.title}</p>
              {a.delta ? (
                <p class="row__change">
                  <s>{a.from}</s> <span class="arrow">→</span> <b>{a.to}</b>
                  <span class="row__delta row__delta--later">
                    {a.delta}
                  </span>
                </p>
              ) : (
                <p class="row__change">
                  <b>{a.effective}</b>
                  <span class="row__badge">{a.badge}</span>
                </p>
              )}
              <p class="row__affect">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M17 20v-1a4 4 0 00-4-4H7a4 4 0 00-4 4v1M10 11a3.5 3.5 0 100-7 3.5 3.5 0 000 7M21 20v-1a4 4 0 00-3-3.9"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {t.affectsLabel} <b>{a.affects}</b>
                {a.sev === 'urgent' ? <span class="row__status">{a.status}</span> : null}
              </p>
            </article>
          ))
        }
      </div>
    </div>

    <!-- keyword strip: the three-step chain (detection → matching → apply), one keyword
         per column — each pairs a feature noun with its product adjective -->
    <ul class="hero__points">
      {
        t.points.map((p) => (
          <li>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6L9 17l-4-4" />
            </svg>
            <b>{p.strong}</b> {p.rest}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-top: clamp(56px, 6.5vw, 108px);
    padding-bottom: clamp(80px, 10vw, 132px);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(36px, 4.5vw, 76px);
    gap: clamp(40px, 5vw, 64px);
    align-items: center;
  }
  .hero__copy {
    grid-column: span 6;
    align-self: center;
    /* reorder for a stronger top: hook → value → action → proof. The CTA rises
       above the proof bullets (which carry no focusable elements, so visual and
       tab order stay aligned). */
    display: flex;
    flex-direction: column;
  }
  .hero__head {
    order: 1;
  }
  .hero__sub {
    order: 2;
  }
  .hero__cta {
    order: 3;
  }
  .hero__reassure {
    order: 4;
  }
  .hero__points {
    order: 5;
  }
  .panel {
    grid-column: span 6;
  }

  /* ---- copy ---- */
  .hero__head {
    font-family: var(--m-font-display);
    font-weight: 400;
    /* The focal point — a positioning statement now (audience + scope), so it's a
       hair smaller and on a wider measure than the old one-line hook, reading as a
       confident two-liner that still dominates the fold. */
    font-size: clamp(40px, 5.2vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--m-ink);
    max-width: 20ch;
    text-wrap: balance;
  }
  .hero__head .ital {
    font-style: italic;
    /* Italic display cut reads tighter — pull a hair of optical spacing back. */
    letter-spacing: 0.002em;
  }
  /* coverage spec under the positioning line — set in mono + accent so it reads as
     a precise jurisdiction stamp (echoing the panel's mono jurisdiction chips),
     distinct from the serif statement above it. */
  .hero__head-cov {
    display: block;
    margin-top: clamp(10px, 1vw, 16px);
    font-family: var(--m-font-mono);
    font-size: clamp(14px, 1.45vw, 21px);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.2;
    color: var(--m-accent);
  }
  /* zh: mono stack carries no CJK glyphs, so inherit the head's CJK serif and keep
     the accent emphasis (mirrors the .ital colour-not-italic guard). */
  .hero[data-zh] .hero__head-cov {
    font-family: inherit;
    letter-spacing: 0;
  }
  /* CJK glyphs are full-width and heavier — the Latin ceiling overwhelms the column.
     Cap the size, widen the measure for a clean 2–3 lines, and drop the tight tracking. */
  .hero[data-zh] .hero__head {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.18;
    letter-spacing: 0;
    max-width: 18ch;
    /* keep CJK words whole — break only at the spaces between segments so the
       accent phrase 美国 CPA 事务所 never splits mid-word (事 / 务所). */
    word-break: keep-all;
  }
  .hero__sub {
    margin-top: clamp(22px, 1.7vw, 28px);
    max-width: 53ch;
    font-size: clamp(15px, 1.05vw, 16.5px);
    line-height: 1.6;
    color: var(--m-ink-2);
  }
  .hero__sub em {
    font-style: italic;
    color: var(--m-ink);
  }
  /* zh: CJK has no italic — the synthesized oblique reads broken, so keep the
     emphasis as colour/weight only (mirrors the .ital faux-italic guard). */
  html[lang='zh-CN'] .hero__sub em {
    font-style: normal;
    font-weight: 500;
  }
  .hero__sub strong {
    color: var(--m-ink);
    font-weight: 500;
  }
  .hero__reassure {
    margin-top: 14px;
    max-width: 50ch;
    font-size: var(--m-text-sm);
    line-height: 1.5;
    color: var(--m-muted);
  }
  /* tertiary "see how it works" — a quiet inline link, not a third button */
  .hero__howlink {
    color: var(--m-accent);
    font-weight: 500;
    white-space: nowrap;
    text-decoration: none;
  }
  .hero__howlink:hover {
    text-decoration: underline;
  }
  .hero__howlink span {
    display: inline-block;
    transition: transform var(--m-dur-fast) ease;
  }
  .hero__howlink:hover span {
    transform: translateX(2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__howlink span {
      transition: none;
    }
  }
  /* demoted to a quiet proof strip beneath the CTA — smaller, set off by a
     hairline so it reads as supporting evidence, not a competing list */
  /* a compact 2-up proof grid (1-up when the column gets narrow) — tighter than
     the old 4-row stack so it reads as a quiet footnote, not a second pitch */
  .hero__points {
    grid-column: 1 / -1;
    margin-top: clamp(22px, 2.2vw, 28px);
    padding-top: clamp(18px, 1.8vw, 22px);
    border-top: 1px solid var(--m-hairline);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px 22px;
    list-style: none;
    padding-left: 0;
    padding-right: 0;
  }
  .hero__points li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--m-text-sm);
    line-height: 1.35;
    color: var(--m-muted);
  }
  .hero__points svg {
    width: 15px;
    height: 15px;
    flex: none;
    color: var(--m-accent);
  }
  .hero__points b {
    color: var(--m-ink);
    font-weight: 500;
    white-space: nowrap; /* keyword nouns stay on one line so the 3 columns align */
  }
  /* entrance — the four proof ticks assemble one after another, each icon popping
     a beat behind its row (reads like the checklist confirming itself). Pure CSS so
     it survives no-JS; `both` holds each tick hidden until its delay (no flash); the
     whole thing is gated behind `no-preference` so reduced-motion shows it at rest. */
  @media (prefers-reduced-motion: no-preference) {
    .hero__points li {
      opacity: 0;
      animation: heroTickIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .hero__points li:nth-child(1) { animation-delay: 0.14s; }
    .hero__points li:nth-child(2) { animation-delay: 0.22s; }
    .hero__points li:nth-child(3) { animation-delay: 0.3s; }
    .hero__points li:nth-child(4) { animation-delay: 0.38s; }
    .hero__points svg {
      transform-origin: center;
      animation: heroTickIcon 0.42s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .hero__points li:nth-child(1) svg { animation-delay: 0.22s; }
    .hero__points li:nth-child(2) svg { animation-delay: 0.3s; }
    .hero__points li:nth-child(3) svg { animation-delay: 0.38s; }
    .hero__points li:nth-child(4) svg { animation-delay: 0.46s; }
  }
  @keyframes heroTickIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes heroTickIcon {
    from { transform: scale(0.62); }
    to { transform: scale(1); }
  }

  .hero__cta {
    margin-top: clamp(30px, 3vw, 40px);
    display: flex;
    flex-wrap: wrap;
    gap: 10px 8px;
    align-items: center;
  }
  /* hero CTAs use the shared .m-cta / .m-cta--primary / .m-cta--ghost pill
     (defined in marketing.css) — no local button styles */
  /* ---- alerts panel ---- */
  .panel {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .panel__head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    border-bottom: 1px solid var(--m-hairline);
  }
  .panel__title {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--m-text-xs);
    font-weight: 600;
    color: var(--m-ink-2);
  }
  .panel__dot {
    color: var(--m-faint);
  }
  .panel__live {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--m-ok);
    flex: none;
    position: relative;
  }
  .panel__live::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    border: 1px solid var(--m-ok);
    opacity: 0;
    animation: ripple 2.6s ease-out infinite;
  }
  @keyframes ripple {
    0% {
      opacity: 0.5;
      transform: scale(0.6);
    }
    70%,
    100% {
      opacity: 0;
      transform: scale(1.6);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .panel__live::after {
      animation: none;
    }
  }
  .panel__count {
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
    font-family: var(--m-font-mono);
  }
  .panel__cap {
    margin-left: auto;
    font-size: var(--m-text-3xs);
    letter-spacing: 0.04em;
    color: var(--m-faint);
    font-family: var(--m-font-mono);
    white-space: nowrap;
  }

  .panel__filter {
    display: flex;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--m-hairline-2);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .panel__filter::-webkit-scrollbar {
    display: none;
  }
  .chip {
    flex: none;
    font-size: var(--m-text-2xs);
    font-weight: 500;
    color: var(--m-muted);
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    white-space: nowrap;
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }
  .chip:hover {
    color: var(--m-ink);
    border-color: var(--m-faint);
  }
  .chip--on {
    color: #fff;
    background: var(--m-accent);
    border-color: var(--m-accent);
  }

  .row {
    padding: 14px 16px;
  }
  .row + .row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .row__top {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sev {
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 2px 7px;
    border-radius: var(--m-radius-md);
  }
  .sev--urgent {
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 9%, transparent);
  }
  .sev--info {
    color: var(--m-ink-2);
    background: var(--m-section);
  }
  .juris {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
    border-radius: var(--m-radius-md);
    padding: 1px 7px;
  }
  .src {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
  }
  .src svg {
    width: 12px;
    height: 12px;
  }
  .row__title {
    margin-top: 9px;
    font-size: var(--m-text-base);
    font-weight: 500;
    color: var(--m-ink);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  /* Secondary rows recede so the anchor (urgent) row reads first. */
  .row--secondary .row__title {
    font-weight: 400;
    color: var(--m-ink-2);
  }
  .row__change {
    margin-top: 9px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: var(--m-ink);
  }
  .row__change s {
    color: var(--m-muted);
  }
  .row__change .arrow {
    color: var(--m-muted);
  }
  .row__delta {
    font-family: var(--m-font-sans);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    padding: 1px 7px;
