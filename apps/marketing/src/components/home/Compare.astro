---
/** How it compares — an honest matrix. We own the monitoring rows; we openly
 *  concede practice-management breadth (we're narrow by design). The point is
 *  the positioning: we're the layer the all-in-ones are missing, not a rival.
 *
 *  The table is grouped so the honesty is structural, not a footnote: a
 *  "What we watch for you" block where DueDateHQ is the only yes, and a
 *  "Runs your whole practice (by design, not us)" block where the all-in-ones
 *  win and we deliberately say so. Columns span the status quo (Excel + Outlook)
 *  and a deadline tool (File In Time) through to an all-in-one suite (TaxDome). */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

// columns: status quo · deadline tracker · all-in-one suite · us
const products = [
  { name: 'Excel + Outlook', kind: zh ? '现状' : 'Status quo' },
  { name: 'File In Time', kind: zh ? '截止日工具' : 'Deadline tool' },
  { name: 'TaxDome', kind: zh ? '全能套件' : 'All-in-one' },
  { name: 'DueDateHQ', kind: zh ? '监测层' : 'The layer' },
]

// mark vocabulary, per product:
//   yes · no · partial (technically, but…) · manual · narrow (by design — not us)
type Mark = 'yes' | 'no' | 'partial' | 'manual' | 'narrow'

// Two honest groups. Group 1: the change-monitoring job — our ground.
// Group 2: full practice management — their ground, narrow by design for us.
const groups: { label: string; rows: { feature: string; marks: Mark[] }[] }[] = zh
  ? [
      {
        label: '我们替你盯着的事',
        rows: [
          { feature: '记录你已经知道的截止日', marks: ['manual', 'yes', 'yes', 'yes'] },
          { feature: '7×24 盯着 IRS、各州、FEMA 看变化', marks: ['no', 'no', 'no', 'yes'] },
          { feature: 'AI 读懂这条变化到底改了什么', marks: ['no', 'no', 'no', 'yes'] },
          { feature: '精确标出这次影响到你的哪些客户', marks: ['no', 'no', 'no', 'yes'] },
          { feature: '一键把新日期应用到所有受影响客户', marks: ['no', 'no', 'no', 'yes'] },
          { feature: '每个日期都附上官方来源链接', marks: ['no', 'no', 'no', 'yes'] },
          { feature: '不用录入就跟上中途改掉的规则', marks: ['no', 'no', 'partial', 'yes'] },
        ],
      },
      {
        label: '管理整个事务所（我们刻意不做）',
        rows: [
          { feature: '完整的事务所与工作流管理', marks: ['no', 'partial', 'yes', 'narrow'] },
          { feature: '开票与收款', marks: ['no', 'no', 'yes', 'narrow'] },
          { feature: '文档存储与客户门户', marks: ['no', 'no', 'yes', 'narrow'] },
          { feature: '装在你已有的工具之上，不替换它', marks: ['no', 'no', 'no', 'yes'] },
        ],
      },
    ]
  : [
      {
        label: 'What we watch for you',
        rows: [
          { feature: 'Tracks the deadlines you already know', marks: ['manual', 'yes', 'yes', 'yes'] },
          { feature: 'Watches IRS, every state & FEMA 24/7 for changes', marks: ['no', 'no', 'no', 'yes'] },
          { feature: 'AI reads what a change actually moved', marks: ['no', 'no', 'no', 'yes'] },
          { feature: "Flags exactly which of your clients it hits", marks: ['no', 'no', 'no', 'yes'] },
          { feature: 'One-click apply the new date across clients', marks: ['no', 'no', 'no', 'yes'] },
          { feature: 'Official source link on every date', marks: ['no', 'no', 'no', 'yes'] },
          { feature: 'Catches mid-season rule changes without re-entry', marks: ['no', 'no', 'partial', 'yes'] },
        ],
      },
      {
        label: 'Runs your whole practice (by design, not us)',
        rows: [
          { feature: 'Full practice & workflow management', marks: ['no', 'partial', 'yes', 'narrow'] },
          { feature: 'Billing & invoicing', marks: ['no', 'no', 'yes', 'narrow'] },
          { feature: 'Document storage & client portal', marks: ['no', 'no', 'yes', 'narrow'] },
          { feature: 'Layers on what you already use — no rip-and-replace', marks: ['no', 'no', 'no', 'yes'] },
        ],
      },
    ]

const t = zh
  ? {
      eyebrow: '横向对比',
      headingPre: '不是又一个全能套件。而是它们都缺的那一',
      headingItal: '层。',
      leadHtml:
        'TaxDome、Canopy、Karbon 已经在帮你管事务所——开票、文档、工作流。它们都做得很好，但都默认有人会盯着<b>截止日什么时候变</b>。没人盯。我们就做这一件事：<b>盯着官方来源、读懂变化、精确告诉你影响到谁</b>，然后装在你已有的工具之上。',
      partial: '勉强',
      manual: '手动',
      narrow: '刻意不做',
      legendYes: '内建',
      legendPartial: '技术上能，但不监测变化',
      legendNarrow: '它们的强项——我们刻意不碰',
      footnote:
        '诚实地说：要管整个事务所，留着你的套件。要在截止日变化第一时间知道、并知道影响到谁——那是我们。两者并不冲突。',
      ariaSummary:
        '对比 Excel + Outlook、File In Time、TaxDome 与 DueDateHQ。只有 DueDateHQ 7×24 盯着官方来源看变化、用 AI 读懂变化、精确标出受影响客户、一键应用并为每个日期保留来源；而完整的事务所管理、开票、文档存储是套件的强项，我们刻意不做，只装在它们之上。',
    }
  : {
      eyebrow: 'How it compares',
      headingPre: "We're not building another all-in-one. We're the layer they're all ",
      headingItal: 'missing.',
      leadHtml:
        'TaxDome, Canopy and Karbon already run your practice — billing, documents, workflow — and they do it well. But every one of them assumes someone is watching <b>when the deadlines themselves move</b>. No one is. That’s the one thing we do: <b>watch official sources, read the change, and tell you exactly who it hits</b> — sitting on top of the tools you already use.',
      partial: 'partial',
      manual: 'manual',
      narrow: 'By design',
      legendYes: 'Built in',
      legendPartial: 'Technically, but no change monitoring',
      legendNarrow: 'Their strength — we stay out of it',
      footnote:
        'Honestly: to run the whole practice, keep your suite. To know the moment a deadline moves — and who it affects — that’s us. The two aren’t in competition.',
      ariaSummary:
        'Comparison of Excel + Outlook, File In Time, TaxDome and DueDateHQ. Only DueDateHQ watches official sources 24/7 for changes, has AI read what changed, flags exactly who is affected, applies in one click, and keeps a source on every date. Full practice management, billing and document storage are the suites’ strength; DueDateHQ deliberately stays out of those and instead layers on top of them.',
    }
const ariaSummary = t.ariaSummary
---

<section class="m-section compare" aria-labelledby="cmp-h" data-reveal>
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2 compare__h" id="cmp-h">{t.headingPre}<span class="ital">{t.headingItal}</span></h2>
  <p class="m-lead compare__lead" set:html={t.leadHtml} />

  <div class="cmp-scroll">
    <div class="cmp" role="img" aria-label={ariaSummary}>
      <div class="cmp__c cmp__c--head cmp__c--corner"></div>
      {
        products.map((p, i) => (
          <div class:list={['cmp__c', 'cmp__c--head', i === 3 && 'cmp__c--ddhq cmp__head--ddhq']}>
            <span class="cmp__pname">{p.name}</span>
            <span class="cmp__pkind">{p.kind}</span>
          </div>
        ))
      }
      {
        groups.map((g) => (
          <>
            <div class="cmp__c cmp__c--group">{g.label}</div>
            {g.rows.map((r) => (
              <>
                <div class="cmp__c cmp__c--row">{r.feature}</div>
                {r.marks.map((m, i) => (
                  <div class:list={['cmp__c', 'cmp__c--mark', i === 3 && 'cmp__c--ddhq']}>
                    {m === 'yes' && (
                      <span class="yes" title={t.legendYes}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M20 6 9 17l-5-5" />
                        </svg>
                      </span>
                    )}
                    {m === 'no' && <span class="no" aria-hidden="true" />}
                    {m === 'partial' && (
                      <span class="cmp__partial" title={t.legendPartial}>
                        {t.partial}
                      </span>
                    )}
                    {m === 'manual' && <span class="cmp__manual">{t.manual}</span>}
                    {m === 'narrow' && (
                      <span class="cmp__narrow" title={t.legendNarrow}>
                        {t.narrow}
                      </span>
                    )}
                  </div>
                ))}
              </>
            ))}
          </>
        ))
      }
    </div>
  </div>

  <p class="compare__foot">{t.footnote}</p>
</section>

<style>
  .compare__h {
    max-width: 24ch;
  }
  .compare__lead {
    margin-top: 16px;
    max-width: 68ch;
  }
  .compare__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }
  .cmp-scroll {
    margin-top: clamp(28px, 3.5vw, 44px);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp {
    width: 100%;
    min-width: 720px;
    display: grid;
    grid-template-columns: 2fr repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--m-ink);
  }
  .cmp__c {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--m-hairline-2);
    font-size: 14px;
  }
  /* column heads — product name + what kind of tool it is */
  .cmp__c--head {
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 3px;
    min-height: 0;
    padding-block: 16px 14px;
    border-bottom: 1px solid var(--m-hairline);
    text-align: center;
  }
  .cmp__c--corner {
    border-bottom: 1px solid var(--m-hairline);
  }
  .cmp__pname {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink);
    white-space: nowrap;
  }
  .cmp__c--ddhq .cmp__pname,
  .cmp__head--ddhq .cmp__pname {
    color: var(--m-accent);
  }
  .cmp__pkind {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-faint);
    white-space: nowrap;
  }
  .cmp__head--ddhq .cmp__pkind {
    color: var(--m-accent);
    opacity: 0.72;
  }
  /* group divider rows span all columns */
  .cmp__c--group {
    grid-column: 1 / -1;
    min-height: 0;
    padding-block: 22px 10px;
    border-bottom: 1px solid var(--m-hairline);
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-muted);
  }
  .cmp__c--row {
    color: var(--m-ink);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }
  .cmp__c--mark {
    justify-content: center;
  }
  .cmp__c--ddhq {
    background: var(--m-accent-tint);
  }
  .cmp__head--ddhq {
    background: var(--m-accent-tint);
  }
  .yes {
    display: inline-flex;
    color: var(--m-muted);
  }
  .yes svg {
    width: 17px;
    height: 17px;
  }
  .cmp__c--ddhq .yes {
    color: var(--m-accent);
  }
  .no {
    width: 14px;
    height: 1.5px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .cmp__manual,
  .cmp__partial {
    font-size: 12px;
    color: var(--m-muted);
  }
  /* "By design" — our deliberate no. Calm, not a failure: a quiet pill, not red. */
  .cmp__narrow {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--m-hairline);
    font-size: 11px;
    font-weight: 500;
    color: var(--m-muted);
    white-space: nowrap;
  }
  .compare__foot {
    margin-top: clamp(20px, 2.4vw, 28px);
    max-width: 72ch;
    font-size: 14px;
    line-height: 1.6;
    color: var(--m-muted);
  }
</style>
