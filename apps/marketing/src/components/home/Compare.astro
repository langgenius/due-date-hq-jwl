---
/** How it compares — an honest matrix. We own the monitoring rows; we openly
 *  concede practice-management breadth (we're narrow by design). The point is
 *  the positioning: we're the layer the all-in-ones are missing, not a rival. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const products = ['Excel + Outlook', 'File In Time', 'TaxDome', 'DueDateHQ']
// per row, per product: yes · no · manual · narrow (deliberately not us)
const marksRows = [
  ['manual', 'yes', 'yes', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'manual', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'yes', 'narrow'],
]
const t = zh
  ? {
      eyebrow: '横向对比',
      headingPre: '不是又一个全能套件。而是它们都缺的那一',
      headingItal: '层。',
      leadHtml:
        'TaxDome、Canopy、Karbon 已经在帮你管事务所。我们是它们都没有的那一层——<b>盯着 IRS 和每个州看变化，精确告诉你影响到谁。</b>它装在你已有的工具之上，而不是替代它。',
      features: [
        '记录截止日',
        '盯着官方来源看变化',
        'AI 读懂变化内容',
        '精确标出影响到谁',
        '一键应用到所有受影响客户',
        '每个日期都有来源',
        '完整的事务所管理',
      ],
      manual: '手动',
      narrow: '刻意不做',
      ariaSummary:
        '对比 Excel + Outlook、File In Time、TaxDome 与 DueDateHQ。只有 DueDateHQ 盯着官方来源看变化、用 AI 读懂变化、精确标出受影响客户、一键应用并为每个日期保留来源；完整的事务所管理我们刻意不做。',
    }
  : {
      eyebrow: 'How it compares',
      headingPre: "Not another all-in-one. The layer they're all ",
      headingItal: 'missing.',
      leadHtml:
        'TaxDome, Canopy and Karbon already run your practice. We’re the narrow layer none of them have — <b>we watch the IRS and every state for changes, and tell you exactly who’s affected.</b> It sits on top of what you already use; it doesn’t replace it.',
      features: [
        'Tracks deadlines',
        'Watches official sources for changes',
        'AI reads what changed',
        "Flags exactly who's affected",
        'One-click apply across clients',
        'Source on every date',
        'Full practice management',
      ],
      manual: 'manual',
      narrow: 'By design',
      ariaSummary:
        'Comparison of Excel + Outlook, File In Time, TaxDome and DueDateHQ. Only DueDateHQ watches official sources for changes, has AI read what changed, flags exactly who is affected, applies in one click, and keeps a source on every date; full practice management is something DueDateHQ deliberately does not do.',
    }
const rows = marksRows.map((marks, i) => ({ feature: t.features[i], marks }))
const ariaSummary = t.ariaSummary
---

<section class="m-section compare" aria-labelledby="cmp-h">
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2 compare__h" id="cmp-h">{t.headingPre}<span class="ital">{t.headingItal}</span></h2>
  <p class="m-lead compare__lead" set:html={t.leadHtml} />

  <div class="cmp-scroll">
    <div class="cmp" role="img" aria-label={ariaSummary}>
      <div class="cmp__c cmp__c--head"></div>
      {
        products.map((p, i) => (
          <div class:list={['cmp__c', 'cmp__c--head', i === 3 && 'cmp__c--ddhq cmp__head--ddhq']}>
            {p}
          </div>
        ))
      }
      {
        rows.map((r) => (
          <>
            <div class="cmp__c cmp__c--row">{r.feature}</div>
            {r.marks.map((m, i) => (
              <div class:list={['cmp__c', 'cmp__c--mark', i === 3 && 'cmp__c--ddhq']}>
                {m === 'yes' && (
                  <span class="yes">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                )}
                {m === 'no' && <span class="no" aria-hidden="true" />}
                {m === 'manual' && <span class="cmp__manual">{t.manual}</span>}
                {m === 'narrow' && <span class="cmp__narrow">{t.narrow}</span>}
              </div>
            ))}
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .compare__h {
    max-width: 22ch;
  }
  .compare__lead {
    margin-top: 16px;
    max-width: 64ch;
  }
  .compare__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }
  .cmp-scroll {
    margin-top: clamp(28px, 3.5vw, 44px);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp {
    min-width: 640px;
    display: grid;
    grid-template-columns: 1.7fr repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--m-ink);
  }
  .cmp__c {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--m-hairline-2);
    font-size: 14px;
  }
  .cmp__c--head {
    min-height: 0;
    padding-block: 14px;
    justify-content: center;
    border-bottom: 1px solid var(--m-hairline);
    font-size: 12px;
    font-weight: 600;
    color: var(--m-muted);
    text-align: center;
    white-space: nowrap;
  }
  .cmp__c--row {
    color: var(--m-ink);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .cmp__c--mark {
    justify-content: center;
  }
  .cmp__c--ddhq {
    background: var(--m-accent-tint);
  }
  .cmp__head--ddhq {
    color: var(--m-accent);
  }
  .yes {
    display: inline-flex;
    color: var(--m-muted);
  }
  .yes svg {
    width: 17px;
    height: 17px;
  }
  .cmp__c--ddhq .yes {
    color: var(--m-accent);
  }
  .no {
    width: 14px;
    height: 1.5px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .cmp__manual {
    font-size: 12px;
    color: var(--m-muted);
  }
  .cmp__narrow {
    font-size: 11px;
    font-style: italic;
    color: var(--m-faint);
  }
</style>
