---
/** How it compares — a restrained 4-column matrix. The point isn't feature
 *  parity, it's the one row only DueDateHQ owns: watching the sources. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const products = ['Excel + Outlook', 'File In Time', 'TaxDome', 'DueDateHQ']
const marksRows = [
  ['manual', 'yes', 'yes', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'no', 'yes'],
  ['no', 'no', 'no', 'yes'],
]
const t = zh
  ? {
      eyebrow: '横向对比',
      headingPre: '别人替你记日期，我们替你盯它',
      headingItal: '变。',
      features: ['记录截止日', '盯着来源看变化', '标出影响到谁', '每个日期都有来源'],
      manual: '手动',
      ariaSummary:
        '对比。Excel 和 Outlook 手动记录你录入的截止日；File In Time 和 TaxDome 也只是记录。只有 DueDateHQ 盯着官方来源看变化、标出受影响的客户，并为每个日期保留来源。',
      footPre: 'Excel 和 File In Time 只记录你录入的日期。',
      footBold: '只有 DueDateHQ 盯着来源——还告诉你影响到谁。',
    }
  : {
      eyebrow: 'How it compares',
      headingPre: 'They store your dates. We watch them ',
      headingItal: 'change.',
      features: ['Tracks deadlines', 'Watches sources for changes', "Flags who's affected", 'Source on every date'],
      manual: 'manual',
      ariaSummary:
        'Comparison. Excel and Outlook track the deadlines you enter, manually; File In Time and ' +
        'TaxDome track them too. Only DueDateHQ watches the official sources for changes, flags which ' +
        'clients are affected, and keeps a source on every date.',
      footPre: 'Excel and File In Time track the dates you enter.',
      footBold: "Only DueDateHQ watches the sources — and tells you who's affected.",
    }
const rows = marksRows.map((marks, i) => ({ feature: t.features[i], marks }))
const ariaSummary = t.ariaSummary
---

<section class="m-section compare" aria-labelledby="cmp-h">
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2 compare__h" id="cmp-h">{t.headingPre}<span class="ital">{t.headingItal}</span></h2>

  <div class="cmp-scroll">
    <div class="cmp" role="img" aria-label={ariaSummary}>
      <div class="cmp__c cmp__c--head"></div>
      {
        products.map((p, i) => (
          <div class:list={['cmp__c', 'cmp__c--head', i === 3 && 'cmp__c--ddhq cmp__head--ddhq']}>
            {p}
          </div>
        ))
      }
      {
        rows.map((r) => (
          <>
            <div class="cmp__c cmp__c--row">{r.feature}</div>
            {r.marks.map((m, i) => (
              <div class:list={['cmp__c', 'cmp__c--mark', i === 3 && 'cmp__c--ddhq']}>
                {m === 'yes' && (
                  <span class="yes">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                )}
                {m === 'no' && <span class="no" aria-hidden="true" />}
                {m === 'manual' && <span class="cmp__manual">{t.manual}</span>}
              </div>
            ))}
          </>
        ))
      }
    </div>
  </div>

  <p class="compare__foot">
    {t.footPre}
    <b>{t.footBold}</b>
  </p>
</section>

<style>
  .compare__h {
    max-width: 20ch;
  }
  .cmp-scroll {
    margin-top: clamp(28px, 3.5vw, 44px);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp {
    min-width: 600px;
    max-width: 940px;
    display: grid;
    grid-template-columns: 1.7fr repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--m-ink);
  }
  .cmp__c {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 15px 16px;
    border-bottom: 1px solid var(--m-hairline-2);
    font-size: 14px;
  }
  .cmp__c--head {
    min-height: 0;
    padding-block: 13px;
    justify-content: center;
    border-bottom: 1px solid var(--m-hairline);
    font-size: 12px;
    font-weight: 600;
    color: var(--m-muted);
    text-align: center;
    white-space: nowrap;
  }
  .cmp__c--row {
    color: var(--m-ink);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .cmp__c--mark {
    justify-content: center;
  }
  .cmp__c--ddhq {
    background: var(--m-accent-tint);
  }
  .cmp__head--ddhq {
    color: var(--m-accent);
  }
  .yes {
    display: inline-flex;
    color: var(--m-muted);
  }
  .yes svg {
    width: 17px;
    height: 17px;
  }
  .cmp__c--ddhq .yes {
    color: var(--m-accent);
  }
  .no {
    width: 14px;
    height: 1.5px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .cmp__manual {
    font-size: 12px;
    color: var(--m-muted);
  }
  .compare__foot {
    margin-top: 20px;
    max-width: 62ch;
    font-size: 13px;
    line-height: 1.5;
    color: var(--m-muted);
  }
  .compare__foot b {
    color: var(--m-ink);
    font-weight: 600;
  }
</style>
