---
/** How it compares — an honest matrix. We own the monitoring rows; we openly
 *  concede practice-management breadth (we're narrow by design). The point is
 *  the positioning: we're the layer the all-in-ones are missing, not a rival.
 *
 *  The table is grouped so the honesty is structural, not a footnote: a
 *  "What we watch for you" block where DueDateHQ is the only yes, and a
 *  "Runs your whole practice (by design, not us)" block where the all-in-ones
 *  win and we deliberately say so. Columns span the status quo (Excel + Outlook)
 *  and a deadline tool (File In Time) through to an all-in-one suite (TaxDome). */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const base = zh ? '/zh-CN' : ''

// columns: status quo · deadline tracker · all-in-one suite · us
const products = [
  { name: 'Excel + Outlook', kind: zh ? '现状' : 'Status quo' },
  { name: 'File In Time', kind: zh ? '截止日工具' : 'Deadline tool' },
  { name: 'TaxDome', kind: zh ? '全能套件' : 'All-in-one' },
  { name: 'DueDateHQ', kind: zh ? '监测层' : 'The layer' },
]

// mark vocabulary, per product:
//   yes · no · partial (technically, but…) · manual · na (not advertised)
// `na` is used for NAMED third-party products on a capability their own public
// materials don't mention — we render the same neutral dash but the accessible
// label says "Not advertised", never a bare "No". This keeps us out of unsourced-
// negative / trade-libel territory (see the dated disclaimer under the table).
type Mark = 'yes' | 'no' | 'partial' | 'manual' | 'na'

// Two honest groups. Group 1: the change-monitoring job — our ground.
// Group 2: full practice management — their ground, narrow by design for us.
const groups: { label: string; rows: { feature: string; marks: Mark[] }[] }[] = zh
  ? [
      {
        label: '我们替你盯着的事',
        rows: [
          { feature: '记录已知截止日', marks: ['manual', 'yes', 'yes', 'yes'] },
          { feature: '7×24 盯着来源', marks: ['no', 'na', 'na', 'yes'] },
          { feature: 'AI 读懂变化', marks: ['no', 'na', 'na', 'yes'] },
          { feature: '标出受影响客户', marks: ['no', 'na', 'na', 'yes'] },
          { feature: '一键应用新日期', marks: ['no', 'na', 'na', 'yes'] },
          { feature: '每个日期附来源', marks: ['no', 'na', 'na', 'yes'] },
        ],
      },
      {
        label: '管理整个事务所',
        rows: [
          { feature: '事务所与工作流管理', marks: ['no', 'partial', 'yes', 'no'] },
          { feature: '开票与收款', marks: ['no', 'no', 'yes', 'no'] },
          { feature: '文档存储与客户门户', marks: ['no', 'no', 'yes', 'no'] },
          { feature: '装在现有工具之上', marks: ['no', 'no', 'no', 'yes'] },
        ],
      },
    ]
  : [
      {
        label: 'What we watch for you',
        rows: [
          { feature: 'Tracks deadlines you know', marks: ['manual', 'yes', 'yes', 'yes'] },
          { feature: 'Watches sources 24/7', marks: ['no', 'na', 'na', 'yes'] },
          { feature: 'Reads what changed', marks: ['no', 'na', 'na', 'yes'] },
          { feature: 'Flags affected clients', marks: ['no', 'na', 'na', 'yes'] },
          { feature: 'One-click apply', marks: ['no', 'na', 'na', 'yes'] },
          { feature: 'Source on every date', marks: ['no', 'na', 'na', 'yes'] },
        ],
      },
      {
        label: 'Runs your whole practice',
        rows: [
          { feature: 'Practice & workflow management', marks: ['no', 'partial', 'yes', 'no'] },
          { feature: 'Billing & invoicing', marks: ['no', 'no', 'yes', 'no'] },
          { feature: 'Document storage & portal', marks: ['no', 'no', 'yes', 'no'] },
          { feature: 'Layers on what you use', marks: ['no', 'no', 'no', 'yes'] },
        ],
      },
    ]

const t = zh
  ? {
      eyebrow: '横向对比',
      headingPre: '不是又一个全能套件。而是它们都缺的那一',
      headingItal: '层。',
      leadHtml: '全能套件帮你打理事务所。我们盯着<b>截止日什么时候变</b>。',
      partial: '勉强',
      manual: '手动',
      legendYes: '内建',
      legendPartial: '技术上能，但不监测变化',
      footnote: '套件管事务所，我们盯截止日变化——两者并不冲突。',
      disclaimer:
        '依据各厂商公开材料，截至 2026 年 7 月；功能会变。破折号表示对方未公开宣传该能力，并非一定做不到。灾情变更由 DueDateHQ 自动识别并起草、经你审核后一键应用（Pro 套餐，owner/partner/manager 角色）。',
      compareLink: '查看与 File In Time 的完整对比 →',
      ariaSummary:
        '对比 Excel + Outlook、File In Time、TaxDome 与 DueDateHQ。在 7×24 盯官方来源看变化、AI 读懂变化、标出受影响客户、一键应用、为每个日期保留来源这几项上，只有 DueDateHQ 内建；其余产品的公开材料未提及这些能力（不等于一定做不到）。完整的事务所管理、开票、文档存储是套件的强项，DueDateHQ 刻意不做，只装在它们之上。',
    }
  : {
      eyebrow: 'How it compares',
      headingPre: "We're not building another all-in-one. We're the layer they're all ",
      headingItal: 'missing.',
      leadHtml:
        'All-in-ones run your practice. We watch <b>when the deadlines themselves move</b>.',
      partial: 'partial',
      manual: 'manual',
      legendYes: 'Built in',
      legendPartial: 'Technically, but no change monitoring',
      footnote: 'Your suite runs the practice; we watch the deadlines — not in competition.',
      disclaimer:
        'Based on each vendor’s public materials as of July 2026; features change. A dash means the capability isn’t advertised, not that it’s impossible. DueDateHQ detects and drafts disaster changes for your review; one-click apply is on Pro plans for owner/partner/manager roles.',
      compareLink: 'See the full File In Time comparison →',
      ariaSummary:
        'Comparison of Excel + Outlook, File In Time, TaxDome and DueDateHQ. On watching official sources 24/7 for changes, AI-reading what changed, flagging who is affected, one-click apply, and keeping a source on every date, only DueDateHQ has it built in; the other products’ public materials don’t mention these capabilities, which is not the same as being unable to. Full practice management, billing and document storage are the suites’ strength; DueDateHQ deliberately stays out of those and instead layers on top of them.',
    }
// accessible value per mark — the cell's name (svg/dash are decorative); a real
// table announces "<feature>, <product>, <value>" so each cell just needs its word
const markLabel: Record<Mark, string> = zh
  ? { yes: '内建', no: '不支持', partial: '勉强', manual: '手动', na: '未标明' }
  : { yes: 'Yes', no: 'No', partial: 'Partial', manual: 'Manual', na: 'Not advertised' }
---

<section class="m-section compare" aria-labelledby="cmp-h" data-reveal>
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="compare__lead" id="cmp-h" set:html={t.leadHtml} />

  <div class="cmp-scrollwrap">
    <div class="cmp-scroll" data-cmp-scroll>
    <div class="cmp" role="table" aria-label={t.eyebrow}>
      <div class="cmp__r cmp__r--head" role="row">
        <div class="cmp__c cmp__c--head cmp__c--corner" role="columnheader" />
        {
          products.map((p, i) => (
            <div
              class:list={['cmp__c', 'cmp__c--head', i === 3 && 'cmp__c--ddhq cmp__head--ddhq']}
              role="columnheader"
            >
              <span class="cmp__pname">{p.name}</span>
              <span class="cmp__pkind">{p.kind}</span>
            </div>
          ))
        }
      </div>
      {
        groups.map((g) => (
          <>
            <div class="cmp__r cmp__r--group" role="row">
              <div class="cmp__c cmp__c--group" role="cell" aria-colspan="5">
                <span class="cmp__glabel">{g.label}</span>
              </div>
            </div>
            {g.rows.map((r) => (
              <div class="cmp__r" role="row">
                <div class="cmp__c cmp__c--row" role="rowheader">{r.feature}</div>
                {r.marks.map((m, i) => (
                  <div
                    class:list={['cmp__c', 'cmp__c--mark', i === 3 && 'cmp__c--ddhq']}
                    role="cell"
                    aria-label={markLabel[m]}
                  >
                    {m === 'yes' && (
                      <span class="yes" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20 6 9 17l-5-5" />
                        </svg>
                      </span>
                    )}
                    {(m === 'no' || m === 'na') && <span class="no" aria-hidden="true" />}
                    {m === 'partial' && (
                      <span class="cmp__partial" aria-hidden="true">{t.partial}</span>
                    )}
                    {m === 'manual' && <span class="cmp__manual" aria-hidden="true">{t.manual}</span>}
                  </div>
                ))}
              </div>
            ))}
          </>
        ))
      }
    </div>
    </div>
    <span class="cmp-hint" aria-hidden="true"></span>
  </div>

  <p class="compare__foot">{t.footnote}</p>
  <p class="compare__foot compare__foot--fine">{t.disclaimer}</p>
  <p class="compare__cta">
    <a class="compare__link" href={`${base}/compare/file-in-time-alternative`}>{t.compareLink}</a>
  </p>
</section>

<style>
  /* the lead carries the section — a sans-serif deck statement (cleaner +
     more professional than the display serif), emphasis by weight not italic */
  .compare__lead {
    margin-top: 14px;
    max-width: 30ch;
    font-family: var(--m-font-sans);
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--m-ink);
    text-wrap: balance;
  }
  .compare__lead :global(b) {
    font-weight: 600;
    color: var(--m-ink);
  }
  .cmp-scrollwrap {
    position: relative;
    margin-top: clamp(28px, 3.5vw, 44px);
  }
  .cmp-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  /* right-edge fade — a scroll affordance so the off-screen columns (incl. the
     DueDateHQ column, the whole point of the table) read as "more this way" on
     narrow screens. JS clears it once you reach the end so it never veils the
     final column. Only meaningful where the table overflows. */
  .cmp-hint {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 40px;
    pointer-events: none;
    background: linear-gradient(to right, transparent, var(--m-canvas));
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  /* a real ARIA table: each row is its own grid with the SAME fractional template,
     so columns line up pixel-for-pixel across rows (no display:contents needed,
     which keeps the table semantics intact for screen readers). */
  .cmp {
    width: 100%;
    min-width: 720px;
  }
  .cmp__r {
    display: grid;
    grid-template-columns: 2fr repeat(4, minmax(0, 1fr));
  }
  .cmp__c {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--m-hairline-2);
    font-size: var(--m-text-base);
  }
  /* column heads — product name + what kind of tool it is */
  .cmp__c--head {
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 3px;
    min-height: 0;
    padding-block: 16px 14px;
    border-bottom: 1px solid var(--m-hairline);
    text-align: center;
  }
  .cmp__c--corner {
    border-bottom: 1px solid var(--m-hairline);
  }
  .cmp__pname {
    font-size: var(--m-text-sm);
    font-weight: 600;
    color: var(--m-ink);
    white-space: nowrap;
  }
  .cmp__c--ddhq .cmp__pname,
  .cmp__head--ddhq .cmp__pname {
    color: var(--m-accent);
  }
  .cmp__pkind {
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-faint);
    white-space: nowrap;
  }
  .cmp__head--ddhq .cmp__pkind {
    color: var(--m-accent);
    opacity: 0.72;
  }
  /* group divider rows span all columns */
  .cmp__c--group {
    grid-column: 1 / -1;
    min-height: 0;
    padding-block: 22px 10px;
    border-bottom: 1px solid var(--m-hairline);
    font-size: var(--m-text-xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-muted);
  }
  .cmp__c--row {
    color: var(--m-ink);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }
  .cmp__c--mark {
    justify-content: center;
  }
  .cmp__c--ddhq {
    background: var(--m-accent-tint);
  }
  .cmp__head--ddhq {
    background: var(--m-accent-tint);
  }
  .yes {
    display: inline-flex;
    color: var(--m-muted);
  }
  .yes svg {
    width: 17px;
    height: 17px;
  }
  .cmp__c--ddhq .yes {
    color: var(--m-accent);
  }
  .no {
    width: 14px;
    height: 1.5px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .cmp__manual,
  .cmp__partial {
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }
  .compare__foot {
    margin-top: clamp(20px, 2.4vw, 28px);
    max-width: 72ch;
    font-size: var(--m-text-base);
    line-height: 1.6;
    color: var(--m-muted);
  }
  /* dated public-materials disclaimer — small print so it frames the matrix
     without competing with the footnote statement above it */
  .compare__foot--fine {
    margin-top: 8px;
    font-size: var(--m-text-xs);
    color: var(--m-faint);
  }
  .compare__cta {
    margin-top: 12px;
  }
  .compare__link {
    font-size: var(--m-text-base);
    font-weight: 600;
    color: var(--m-accent);
    text-decoration: none;
  }
  .compare__link:hover {
    text-decoration: underline;
  }

  /* ===== mobile: pin the feature column, tighten the matrix =====
     On phones the 2fr feature column ate the viewport and pushed all four
     product columns (most importantly DueDateHQ) off-screen. Here the feature
     names stay pinned on the left while the product columns scroll past them,
     so every row keeps its label and the comparison stays legible. */
  @media (max-width: 640px) {
    .cmp {
      min-width: 512px;
    }
    .cmp__r {
      grid-template-columns: 140px repeat(4, minmax(0, 1fr));
    }
    .cmp__c {
      padding-inline: 13px;
    }
    .cmp__c--corner,
    .cmp__c--row {
      position: sticky;
      left: 0;
      z-index: 2;
      background: var(--m-canvas);
      /* hairline + soft lift so the pinned column reads as floating over the
         cells scrolling beneath it */
      box-shadow: 1px 0 0 var(--m-hairline-2);
    }
    /* keep the group label readable while the matrix scrolls (the cell spans
       the full width, so pin the label text itself, not the cell) */
    .cmp__glabel {
      position: sticky;
      left: 13px;
    }
    /* the DueDateHQ column keeps its tint even where it scrolls under nothing */
    .cmp-hint[data-show] {
      opacity: 1;
    }
  }
</style>

<script>
  // Show the right-edge fade only while the comparison matrix has more to scroll
  // (mobile, where it overflows). Re-inits per View-Transition navigation.
  function initCompareHint(signal: AbortSignal) {
    document.querySelectorAll<HTMLElement>('.cmp-scrollwrap').forEach((wrap) => {
      const scroller = wrap.querySelector<HTMLElement>('[data-cmp-scroll]')
      const hint = wrap.querySelector<HTMLElement>('.cmp-hint')
      if (!scroller || !hint) return
      const sync = () => {
        const more = scroller.scrollWidth - scroller.clientWidth - scroller.scrollLeft > 2
        hint.toggleAttribute('data-show', more)
      }
      scroller.addEventListener('scroll', sync, { passive: true, signal })
      window.addEventListener('resize', sync, { passive: true, signal })
      sync()
    })
  }
  let compareHintCtl: AbortController | undefined
  document.addEventListener('astro:page-load', () => {
    compareHintCtl = new AbortController()
    initCompareHint(compareHintCtl.signal)
  })
  document.addEventListener('astro:before-swap', () => compareHintCtl?.abort())
</script>
