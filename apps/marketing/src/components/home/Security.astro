---
/** Security & privacy — copy + a 2×2 cluster of trust items. */
interface Props { locale?: 'en' | 'zh-CN' }
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      eyebrow: '安全与隐私',
      headingPre: '为你',
      headingItal: '受托',
      headingPost: '保管的数据而生。',
      body: '客户的财务细节是你手中最敏感的东西。DueDateHQ 正是为守护它们而生——同时绝不干扰你的判断。',
      fine: '无需配置客户门户。没有第三方数据中间商。',
      items: [
        { icon: 'lock', t: '加密', d: '传输中和存储时，每一个字节都加密。' },
        { icon: 'shield', t: '只属于你', d: '你的客户名单绝不出售、共享，也绝不在各事务所之间汇集。' },
        { icon: 'eye', t: '只看不报', d: '它读取来源、提出变更建议——绝不替你报税，也绝不动一分钱。' },
        { icon: 'key', t: '没有密码会泄露', d: '采用单点登录(SSO)，我们无密码可看、可存，也没人能钓走。' },
      ],
    }
  : {
      eyebrow: 'Security & privacy',
      headingPre: "Built for the data you're ",
      headingItal: 'trusted',
      headingPost: ' with.',
      body: "Your clients' financial details are the most sensitive thing you hold. DueDateHQ is built to keep them that way — and to stay out of the way of your judgment.",
      fine: 'No client portal to configure. No third-party data brokers.',
      items: [
        { icon: 'lock', t: 'Encrypted', d: 'In transit and at rest, every byte.' },
        { icon: 'shield', t: 'Yours alone', d: 'Your client list is never sold, shared, or pooled across firms.' },
        { icon: 'eye', t: 'Watches, never files', d: 'It reads sources and proposes changes — it never files a return or moves a dollar.' },
        { icon: 'key', t: 'No password to leak', d: 'Single sign-on, so there is no password for us to see, store, or for anyone to phish.' },
      ],
    }
const items = t.items
---

<section class="m-section" id="security" aria-labelledby="sec-h">
  <div class="security">
    <div class="security__copy">
      <p class="m-eyebrow">{t.eyebrow}</p>
      <h2 class="m-h2" id="sec-h">{t.headingPre}<span class="ital">{t.headingItal}</span>{t.headingPost}</h2>
      <p class="security__body">
        {t.body}
      </p>
      <p class="security__fine">{t.fine}</p>
    </div>
    <div class="security__cluster">
      {
        items.map((it) => (
          <div class="secitem">
            <span class="secitem__ico" aria-hidden="true">
              {it.icon === 'lock' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4.5" y="10.5" width="15" height="10" rx="2" />
                  <path d="M8 10.5V7a4 4 0 0 1 8 0v3.5" />
                </svg>
              )}
              {it.icon === 'shield' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3.5l7 2.8v4.7c0 4.3-3 7.2-7 8.5-4-1.3-7-4.2-7-8.5V6.3z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
              {it.icon === 'eye' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              )}
              {it.icon === 'key' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="15" r="4.5" />
                  <path d="M11.5 11.8 20 3.3M16.5 6.8l2.5 2.5M14.3 9l2 2" />
                </svg>
              )}
            </span>
            <p class="secitem__t">{it.t}</p>
            <p class="secitem__d">{it.d}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .security {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(34px, 5vw, 64px);
    align-items: center;
  }
  .security__copy {
    grid-column: span 5;
  }
  .security__cluster {
    grid-column: span 7;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 3vw, 40px);
  }
  .security__body {
    margin-top: 20px;
    max-width: 42ch;
    font-size: clamp(15px, 1.2vw, 16px);
    line-height: 1.6;
    color: var(--m-ink-2);
  }
  .security__fine {
    margin-top: 16px;
    font-size: 13px;
    color: var(--m-faint);
  }
  .secitem__ico {
    display: inline-flex;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    place-items: center;
    justify-content: center;
    align-items: center;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .secitem__ico svg {
    width: 20px;
    height: 20px;
  }
  .secitem__t {
    margin-top: 14px;
    font-size: 15px;
    font-weight: 600;
    color: var(--m-ink);
  }
  .secitem__d {
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.55;
    color: var(--m-muted);
  }
  @media (max-width: 1000px) {
    .security {
      grid-template-columns: 1fr;
    }
    .security__copy,
    .security__cluster {
      grid-column: auto;
    }
  }
  @media (max-width: 460px) {
    .security__cluster {
      grid-template-columns: 1fr;
    }
  }
</style>
