---
/** Why you can trust it — merged trust + security. The glass-box guarantee
 *  (sourced / no auto-apply / reversible) and the data-security cards live in
 *  one block, closing with the honest boundary + a link to the full overview. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      eyebrow: '为什么值得信赖',
      headingPre: '每条变更都有',
      headingItal: '来源',
      headingPost: '，你的数据也只属于你。',
      glassPre: '我们称之为',
      glassWord: '透明可查',
      glassPost: '——每条变更都附带链接、原文引述和经过核验的日期，否则就不会放出。',
      stats: [
        { n: '100%', t: '有来源', b: '没有指向官方原文的引述，就什么都不会显示。' },
        { n: '0', t: '自动应用的变更', b: '任何变更都不会自行改动客户的截止日。是否应用，永远由你决定。' },
        { n: '24h', t: '可撤销', b: '任何应用都能在 24 小时内干净撤销——每一次操作都有记录、可查验。' },
      ],
      dataEyebrow: '你的数据',
      items: [
        { icon: 'lock', t: '加密', d: '传输中和存储时，每一个字节都加密。' },
        { icon: 'shield', t: '只属于你', d: '你的客户名单绝不出售、共享，也绝不在各事务所之间汇集。' },
        { icon: 'eye', t: '只看不报', d: '它读取来源、提出变更建议——绝不替你报税，也绝不动一分钱。' },
        { icon: 'key', t: '没有密码会泄露', d: '采用单点登录(SSO)，我们无密码可看、可存，也没人能钓走。' },
      ],
      link: '查看完整的安全说明',
      boundaryB: '不是税务建议。',
      boundaryRest:
        'DueDateHQ 支持有据可查的复核——它不是税务建议，不是申报系统，也不能替代 CPA、EA 或律师。它告诉你该看哪里、为什么；最终由你来判断。',
    }
  : {
      eyebrow: 'Why you can trust it',
      headingPre: 'Every change is ',
      headingItal: 'sourced',
      headingPost: ', and your data is yours alone.',
      glassPre: 'We call it ',
      glassWord: 'glass-box',
      glassPost: " — a link, the exact quote, and a verified date on every change, or it's held back.",
      stats: [
        { n: '100%', t: 'Sourced', b: 'Nothing is shown without a citation back to the official text.' },
        { n: '0', t: 'Auto-applied changes', b: "Nothing touches a client's deadline on its own. Apply is always your call." },
        { n: '24h', t: 'Reversible', b: 'Any apply undoes cleanly within 24 hours — every action recorded and inspectable.' },
      ],
      dataEyebrow: 'Your data',
      items: [
        { icon: 'lock', t: 'Encrypted', d: 'In transit and at rest, every byte.' },
        { icon: 'shield', t: 'Yours alone', d: 'Your client list is never sold, shared, or pooled across firms.' },
        { icon: 'eye', t: 'Watches, never files', d: 'It reads sources and proposes changes — it never files a return or moves a dollar.' },
        { icon: 'key', t: 'No password to leak', d: 'Single sign-on, so there is no password for us to see, store, or for anyone to phish.' },
      ],
      link: 'Read the full security overview',
      boundaryB: 'Not tax advice.',
      boundaryRest:
        ' DueDateHQ supports evidence-backed review — it is not tax advice, not a filing system, and not a replacement for a CPA, EA, or attorney. It tells you where to look and why; you make the call.',
    }
const stats = t.stats
const items = t.items
const secHref = (zh ? '/zh-CN' : '') + '/security'
---

<section class="m-section trustsec" id="security" aria-labelledby="trustsec-h" data-reveal>
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2" id="trustsec-h">{t.headingPre}<span class="ital">{t.headingItal}</span>{t.headingPost}</h2>
  <p class="m-lead trustsec__lead">
    {t.glassPre}<span class="glass">{t.glassWord}</span>{t.glassPost}
  </p>

  <div class="tstats">
    {
      stats.map((s) => (
        <div class="tstat">
          <div class="tstat__n">{s.n}</div>
          <div class="tstat__t">{s.t}</div>
          <p class="tstat__b">{s.b}</p>
        </div>
      ))
    }
  </div>

  <p class="trustsec__sub m-eyebrow">{t.dataEyebrow}</p>
  <div class="seccards">
    {
      items.map((it) => (
        <div class="secitem">
          <span class="secitem__ico" aria-hidden="true">
            {it.icon === 'lock' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4.5" y="10.5" width="15" height="10" rx="2" />
                <path d="M8 10.5V7a4 4 0 0 1 8 0v3.5" />
              </svg>
            )}
            {it.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3.5l7 2.8v4.7c0 4.3-3 7.2-7 8.5-4-1.3-7-4.2-7-8.5V6.3z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
            {it.icon === 'eye' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {it.icon === 'key' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="15" r="4.5" />
                <path d="M11.5 11.8 20 3.3M16.5 6.8l2.5 2.5M14.3 9l2 2" />
              </svg>
            )}
          </span>
          <p class="secitem__t">{it.t}</p>
          <p class="secitem__d">{it.d}</p>
        </div>
      ))
    }
  </div>

  <div class="boundary">
    <span class="boundary__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" />
      </svg>
    </span>
    <p class="boundary__t"><b>{t.boundaryB}</b>{t.boundaryRest}</p>
    <a class="boundary__link" href={secHref}>{t.link} <span aria-hidden="true">→</span></a>
  </div>
</section>

<style>
  .trustsec__lead {
    margin-top: 16px;
    max-width: 56ch;
  }
  .glass {
    color: var(--m-accent);
    font-weight: 600;
  }
  .tstats {
    margin-top: clamp(26px, 3vw, 40px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2.2vw, 32px);
  }
  .tstat {
    padding-top: 16px;
    /* hairline, never the near-black ink line */
    border-top: 1px solid var(--m-hairline);
  }
  .tstat__n {
    font-family: var(--m-font-mono);
    font-weight: 600;
    font-size: clamp(30px, 3.6vw, 46px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--m-accent);
  }
  .tstat__t {
    margin: 10px 0 5px;
    font-weight: 600;
    font-size: var(--m-text-md);
    color: var(--m-ink);
  }
  .tstat__b {
    font-size: var(--m-text-sm);
    line-height: 1.5;
    color: var(--m-muted);
    max-width: 34ch;
  }
  .trustsec__sub {
    margin-top: clamp(28px, 3.2vw, 42px);
    margin-bottom: 0;
  }
  .seccards {
    margin-top: 14px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .secitem {
    padding: clamp(18px, 1.8vw, 22px);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
  }
  .secitem__ico {
    display: inline-flex;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    place-items: center;
    justify-content: center;
    align-items: center;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .secitem__ico svg {
    width: 20px;
    height: 20px;
  }
  .secitem__t {
    margin-top: 14px;
    font-size: var(--m-text-md);
    font-weight: 600;
    color: var(--m-ink);
  }
  .secitem__d {
    margin-top: 6px;
    font-size: var(--m-text-sm);
    line-height: 1.55;
    color: var(--m-muted);
  }
  .boundary {
    margin-top: clamp(26px, 3vw, 38px);
    padding-top: clamp(20px, 2.4vw, 28px);
    border-top: 1px solid var(--m-hairline);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px 18px;
    align-items: start;
    max-width: 980px;
  }
  .boundary__icon {
    width: 36px;
    height: 36px;
    flex: none;
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: var(--m-muted);
  }
  .boundary__icon svg {
    width: 18px;
    height: 18px;
  }
  .boundary__t {
    font-size: var(--m-text-base);
    line-height: 1.6;
    color: var(--m-muted);
  }
  .boundary__t b {
    color: var(--m-ink);
    font-weight: 600;
  }
  .boundary__link {
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--m-text-base);
    font-weight: 600;
    color: var(--m-accent);
    transition: gap 0.15s ease;
  }
  .boundary__link:hover {
    gap: 9px;
  }
  @media (max-width: 900px) {
    .tstats {
      grid-template-columns: 1fr;
    }
    .seccards {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .seccards {
      grid-template-columns: 1fr;
    }
  }
</style>
