---
/** FAQ — three short answers, rendered with the shared FaqAccordion so the home
 *  FAQ and every subpage FAQ use one identical accordion (this keeps only the
 *  landing's editorial 2-col layout). The Q&A copy lives in lib/home-faq.ts so
 *  the visible accordion and the home FAQPage JSON-LD share one source of truth. */
import FaqAccordion from '../FaqAccordion.astro'
import { homeFaq } from '../../lib/home-faq'
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? { eyebrow: '常见问题', heading: '简短回答。' }
  : { eyebrow: 'Common questions', heading: 'The short answers.' }
const faqs = homeFaq[locale]
---

<section class="m-section" id="faq" aria-labelledby="faq-h" data-reveal>
  <div class="faq__layout">
    <div class="faq__intro">
      <p class="m-eyebrow">{t.eyebrow}</p>
      <h2 class="m-h2" id="faq-h">{t.heading}</h2>
    </div>

    <div class="faq__grid">
      <FaqAccordion items={faqs} />
    </div>
  </div>
</section>

<style>
  /* full-width editorial split — title on the left, the accordion fills the rest */
  .faq__layout {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 4vw, 48px);
    align-items: start;
  }
  .faq__intro {
    grid-column: span 4;
  }
  .faq__grid {
    grid-column: span 8;
  }
  @media (max-width: 860px) {
    .faq__intro,
    .faq__grid {
      grid-column: 1 / -1;
    }
  }
</style>
