---
/** TopNav — floating-pill nav (static for now; glider + scroll-action + nav-on-dark JS in the interactions pass). */
interface Props {
  ctaHref: string
}
const { ctaHref } = Astro.props
const links = [
  { label: 'How it works', href: '#how' },
  { label: 'See it work', href: '#close' },
  { label: 'FAQ', href: '#close' },
]
---

<header class="nav">
  <div class="nav__inner">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22">
          <rect x="2" y="13" width="4" height="9" rx="1" fill="var(--m-accent)" />
          <rect x="8" y="8" width="4" height="14" rx="1" fill="var(--m-accent)" />
          <rect x="14" y="3" width="4" height="19" rx="1" fill="var(--m-ink)" />
          <rect x="20" y="9" width="2.4" height="13" rx="1" fill="var(--m-accent)" />
        </svg>
      </span>
      <span class="brand__name">DueDateHQ</span>
      <span class="brand__beta">Beta</span>
    </a>

    <nav class="nav__pill" aria-label="Sections">
      {links.map((l) => <a class="nav__link" href={l.href}>{l.label}</a>)}
    </nav>

    <a class="nav__cta" href={ctaHref} data-event="marketing.nav.cta">
      Start free <span aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
  }
  .nav__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    height: 70px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }
  .brand {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .brand__mark {
    display: inline-flex;
  }
  .brand__beta {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-accent);
    background: var(--m-accent-tint);
    padding: 3px 7px;
    border-radius: 999px;
    line-height: 1;
  }
  .nav__pill {
    justify-self: center;
    display: flex;
    align-items: center;
    gap: 2px;
    background: color-mix(in srgb, var(--m-section) 70%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    padding: 5px;
  }
  .nav__link {
    padding: 8px 15px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--m-muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .nav__link:hover {
    color: var(--m-ink);
  }
  .nav__cta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    background: var(--m-accent);
    border-radius: 999px;
    padding: 10px 20px;
    transition: background 0.18s ease;
  }
  .nav__cta:hover {
    background: var(--m-accent-strong);
  }
  @media (max-width: 880px) {
    .nav__pill {
      display: none;
    }
  }
</style>
