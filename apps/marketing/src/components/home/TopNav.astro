---
/** TopNav — a centered nav bar that collapses into a floating pill on scroll,
 *  shared site-wide (EN + zh-CN). One solid bg + hairline on every page; the
 *  collapse (.nav--scrolled) and the villain pass (.nav--on-dark) override it.
 *  `current` marks the active destination on every page (orientation) and the
 *  links always point to real section pages. Labels are an inline EN/zh map
 *  (chrome copy, not page content); hrefs are locale-prefixed. */
import { getCtaHref, getAppHref } from '../../lib/app-url'

interface Props {
  ctaHref?: string
  signInHref?: string
  pageMode?: boolean
  current?: 'home' | 'how' | 'coverage' | 'pricing' | 'security'
  locale?: 'en' | 'zh-CN'
}
const { pageMode = false, current, locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const base = zh ? '/zh-CN' : ''
const ctaHref = Astro.props.ctaHref ?? getCtaHref(zh ? 'zh-CN' : undefined)
const signInHref = Astro.props.signInHref ?? getAppHref('/login', zh ? 'zh-CN' : undefined)
const L = zh
  ? { homeNav: '首页', how: '工作原理', coverage: '覆盖范围', pricing: '定价', security: '安全', signIn: '登录', cta: '立即开始', home: 'DueDateHQ 首页', menu: '菜单', menuTitle: '导航菜单', badge: '抢先体验' }
  : { homeNav: 'Home', how: 'How it works', coverage: 'Coverage', pricing: 'Pricing', security: 'Security', signIn: 'Sign in', cta: 'Get started', home: 'DueDateHQ home', menu: 'Menu', menuTitle: 'Navigation menu', badge: 'Early access' }

const links = [
  { key: 'home', label: L.homeNav, href: `${base}/` },
  { key: 'how', label: L.how, href: `${base}/how-it-works` },
  { key: 'coverage', label: L.coverage, href: `${base}/state-coverage` },
  { key: 'pricing', label: L.pricing, href: `${base}/pricing` },
  { key: 'security', label: L.security, href: `${base}/security` },
]
---

<header class:list={['nav', pageMode && 'nav--page']} transition:persist>
  <div class="nav__inner">
    <a class="brand" href={`${base}/`} aria-label={L.home}>
      <span class="brand__lockup">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <rect x="2" y="13" width="4" height="9" rx="1" fill="var(--m-accent)" />
            <rect x="8" y="8" width="4" height="14" rx="1" fill="var(--m-accent)" />
            <rect x="14" y="3" width="4" height="19" rx="1" fill="var(--m-ink)" />
            <rect x="20" y="9" width="2.4" height="13" rx="1" fill="var(--m-accent)" />
          </svg>
        </span>
        <span class="brand__name">DueDateHQ</span>
        <span class="brand__beta">{L.badge}</span>
      </span>
    </a>

    <nav class="nav__pill" aria-label="Primary">
      <span class="nav__glider" aria-hidden="true"></span>
      {
        links.map((l) => (
          <a
            class:list={['nav__link', current === l.key && 'is-active']}
            href={l.href}
            data-key={l.key}
            aria-current={current === l.key ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="nav__right">
      <a class="nav__signin" href={signInHref}>{L.signIn}</a>
      <a class="nav__cta" href={ctaHref} data-event="marketing.nav.cta">
        {L.cta} <span aria-hidden="true">→</span>
      </a>
      <button
        class="nav__burger"
        type="button"
        aria-label={L.menu}
        aria-expanded="false"
        aria-controls="nav-mobile-sheet"
      >
        <span class="nav__burger-box" aria-hidden="true">
          <span class="nav__burger-bar"></span>
          <span class="nav__burger-bar"></span>
          <span class="nav__burger-bar"></span>
        </span>
      </button>
    </div>
  </div>

  <div class="nav__scrim" data-nav-scrim hidden></div>
  <div
    id="nav-mobile-sheet"
    class="nav__sheet"
    role="dialog"
    aria-modal="true"
    aria-label={L.menuTitle}
    hidden
  >
    <nav class="nav__sheet-links" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            class:list={['nav__sheet-link', current === l.key && 'is-active']}
            href={l.href}
            data-key={l.key}
            aria-current={current === l.key ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="nav__sheet-foot">
      <a class="nav__sheet-signin" href={signInHref}>{L.signIn}</a>
      <a class="nav__sheet-cta" href={ctaHref} data-event="marketing.nav.cta">
        {L.cta} <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    /* ONE nav background on every page (home included) — a subtle solid bar with
       a hairline, not a transparent float. The collapse (.nav--scrolled) and the
       villain pass (.nav--on-dark) still override this on scroll. */
    background: var(--m-canvas);
    border-bottom: 1px solid var(--m-hairline);
    transition:
      background 0.25s ease,
      /* match the inner's height transition (0.45s) so the float-gap growth and
         the pill-height shrink stay in lockstep — total header height holds at
         70px through the whole collapse: no bulge, no content shift */
      padding-top 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  /* .nav--page now matches the base (kept as a hook; content pages pass it) */
  .nav__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding: 0 var(--m-gutter);
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    border: 1px solid transparent;
    /* every property the collapse touches is a length/number, so the whole
       morph into the pill interpolates smoothly (no display/grid swap). */
    transition:
      max-width 0.5s cubic-bezier(0.32, 0.72, 0, 1),
      height 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      padding 0.5s cubic-bezier(0.32, 0.72, 0, 1),
      gap 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      margin-top 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      background 0.3s ease,
      border-color 0.3s ease;
  }
  /* scrolled: collapse the whole nav into a centered floating pill */
  .nav--scrolled {
    background: transparent;
    border-bottom-color: transparent;
    /* the floating gap lives here (padding on the sticky nav) — NOT as a margin
       on the inner, which the browser absorbs the moment the nav sticks on scroll */
    padding-top: 14px;
  }
  .nav--scrolled .nav__inner {
    max-width: 700px;
    margin-top: 0;
    /* even inset on all four sides (#19) — the pill reads as one tidy capsule */
    padding: 8px;
    height: 56px;
    gap: 10px;
    background: var(--m-surface);
    border-color: var(--m-hairline);
    border-radius: 999px;
  }
  /* collapse (width + fade) instead of vanish, so the bar converges into the
     pill rather than snapping. */
  .nav--scrolled .brand__name,
  .nav--scrolled .brand__beta,
  .nav--scrolled .nav__signin {
    max-width: 0;
    padding-left: 0;
    padding-right: 0;
    margin: 0;
    opacity: 0;
    /* take the collapsed Sign-in out of the tab order too — not just out of
       reach — so keyboard users never land on an invisible control. Delay the
       flip until the fade finishes (the base rule restores it instantly on
       expand, so it can still fade back in). */
    visibility: hidden;
    pointer-events: none;
    transition:
      max-width 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      padding 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      margin 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.3s ease,
      color 0.18s ease,
      visibility 0s linear 0.45s;
  }
  /* side groups stop growing → logo + pill + CTA pack toward the centre */
  .nav--scrolled .brand {
    flex-grow: 0;
  }
  .nav--scrolled .nav__right {
    flex-grow: 0;
    gap: 0;
  }
  /* drop the lockup's inter-item gap so the lone mark carries no phantom
     trailing space once the wordmark + beta collapse to zero width */
  .nav--scrolled .brand__lockup {
    gap: 0;
  }
  .nav--scrolled .nav__pill {
    background: transparent;
    border: none;
    padding: 0;
  }
  /* collapsed: the CTA joins the pill as a quiet ghost button — the filled
     accent fill stays reserved for the hero / first paint */
  .nav--scrolled .nav__cta {
    background: transparent;
    color: var(--m-accent);
    border: 1px solid color-mix(in srgb, var(--m-accent) 32%, transparent);
    padding: 7px 14px;
  }
  .nav--scrolled .nav__cta:hover {
    background: var(--m-accent-tint);
  }
  /* opaque navy pill on the dark band — we run blur-free, so a translucent fill
     would let the villain content bleed through. A touch lighter than the band
     so it still reads as a floating, elevated pill. */
  .nav--on-dark.nav--scrolled .nav__inner {
    background: color-mix(in srgb, var(--m-accent) 56%, var(--m-ink));
    border-color: rgba(255, 255, 255, 0.22);
  }
  /* ghost CTA on the dark pill — transparent fill (NOT the white fill it would
     otherwise inherit), light white outline + white text */
  .nav--on-dark.nav--scrolled .nav__cta {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.38);
  }
  .nav--on-dark.nav--scrolled .nav__cta:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  /* ===== nav over a dark band (the villain) — white text, accents in
     containers only (no coloured text on dark) ===== */
  .nav--on-dark {
    background: transparent;
    border-bottom-color: transparent;
  }
  .nav--on-dark .brand__name {
    color: #fff;
  }
  .nav--on-dark .brand__mark svg rect {
    fill: #fff;
  }
  .nav--on-dark .brand__beta {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }
  .nav--on-dark .nav__pill {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: none;
  }
  .nav--on-dark .nav__link {
    color: rgba(255, 255, 255, 0.72);
  }
  .nav--on-dark .nav__link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
  }
  .nav--on-dark .nav__link.is-active {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }
  .nav--on-dark .nav__glider {
    background: rgba(255, 255, 255, 0.16);
  }
  .nav--on-dark .nav__signin {
    color: rgba(255, 255, 255, 0.75);
  }
  .nav--on-dark .nav__signin:hover {
    color: #fff;
  }
  .nav--on-dark .nav__cta {
    color: var(--m-accent);
    background: #fff;
  }
  .nav--on-dark .nav__cta:hover {
    background: rgba(255, 255, 255, 0.9);
  }
  .brand {
    flex: 1 1 0;
    justify-content: flex-start;
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    font-size: var(--m-text-xl);
    letter-spacing: -0.01em;
    color: var(--m-ink);
    transition: flex-grow 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  /* the logo lockup shrink-wraps the mark + wordmark so the keyboard focus ring
     hugs the logo — not the full-width flex column the <a> grows into to centre
     the pill. The collapse animates this lockup's gap, not the <a>'s. */
  .brand__lockup {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border-radius: 8px;
    transition: gap 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .brand__mark {
    display: inline-flex;
  }
  .brand__beta {
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-accent);
    background: var(--m-accent-tint);
    padding: 3px 7px;
    border-radius: 999px;
    line-height: 1;
  }
  /* clean floating pill — solid white, hairline, restrained micro-shadow */
  .nav__pill {
    position: relative;
    flex: none;
    display: flex;
    align-items: center;
    gap: 1px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    padding: 4px;
  }
  /* the glider — a single pill that slides under the hovered/active link, so
     moving across the nav reads as one continuous left↔right glide. JS sizes +
     positions it; until then (or without JS) the static .is-active bg shows. */
  .nav__glider {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-radius: 999px;
    background: var(--m-accent-tint);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transition:
      transform 0.32s cubic-bezier(0.32, 0.72, 0, 1),
      width 0.32s cubic-bezier(0.32, 0.72, 0, 1),
      height 0.32s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.2s ease,
      background 0.2s ease;
  }
  .nav__link {
    position: relative;
    z-index: 1;
    padding: 8px 18px;
    border-radius: 999px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-muted);
    white-space: nowrap;
    transition:
      color 0.18s ease,
      background 0.18s ease;
  }
  .nav__link:hover {
    color: var(--m-ink);
    background: var(--m-section);
  }
  .nav__link.is-active {
    color: var(--m-accent);
    background: var(--m-accent-tint);
    font-weight: 600;
  }
  /* once the glider is live it owns the moving background — drop the static ones
     so they don't double up */
  .nav__pill.has-glider .nav__link:hover,
  .nav__pill.has-glider .nav__link.is-active {
    background: transparent;
  }
  .nav__pill.has-glider .nav__link:hover {
    color: var(--m-ink);
  }
  .nav__right {
    flex: 1 1 0;
    justify-content: flex-end;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition:
      flex-grow 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      gap 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  /* secondary, quiet — smaller + muted, the CTA carries the emphasis */
  .nav__signin {
    display: inline-flex;
    align-items: center;
    padding: 7px 8px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-muted);
    transition: color 0.18s ease;
  }
  .nav__signin:hover {
    color: var(--m-ink);
  }
  /* the elements that collapse on scroll — animatable bounds so the fade-out
     and width-collapse are smooth (they are flex items, so max-width applies). */
  .brand__name,
  .brand__beta,
  .nav__signin {
    max-width: 220px;
    overflow: hidden;
    white-space: nowrap;
    transition:
      max-width 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      padding 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      margin 0.45s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.3s ease,
      color 0.18s ease,
      /* restore visibility immediately on expand; the collapsed rule delays the
         hide so the fade-out still plays */
      visibility 0s;
  }
  .nav__cta {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--m-text-sm);
    font-weight: 500;
    white-space: nowrap;
    color: #fff;
    background: var(--m-accent);
    border-radius: 999px;
    padding: 9px 17px;
    transition: background 0.18s ease;
  }
  .nav__cta:hover {
    background: var(--m-accent-strong);
  }
  /* the trailing arrow rides quieter than the label */
  .nav__cta span {
    opacity: 0.6;
  }

  /* ===== keyboard focus — the nav sits OUTSIDE .m-section, so the global
     focus-visible rule never reaches it. One ring for every nav control;
     :focus-visible only (mouse/touch never see it); each outline follows its
     control's own radius. Flips to the cyan delight accent on the dark band,
     where a navy ring would vanish. ===== */
  .nav__link:focus-visible,
  .nav__signin:focus-visible,
  .nav__cta:focus-visible,
  .nav__burger:focus-visible,
  .nav__sheet-link:focus-visible,
  .nav__sheet-signin:focus-visible,
  .nav__sheet-cta:focus-visible {
    outline: var(--m-focus-width) solid var(--m-focus-ring);
    outline-offset: var(--m-focus-offset);
  }
  /* the brand <a> grows to fill its flex column, so ring the inner lockup */
  .brand:focus-visible {
    outline: none;
  }
  .brand:focus-visible .brand__lockup {
    outline: var(--m-focus-width) solid var(--m-focus-ring);
    outline-offset: 3px;
  }
  .nav--on-dark .nav__link:focus-visible,
  .nav--on-dark .nav__signin:focus-visible,
  .nav--on-dark .nav__cta:focus-visible,
  .nav--on-dark .nav__burger:focus-visible,
  .nav--on-dark .brand:focus-visible .brand__lockup {
    outline-color: var(--m-cyan);
  }

  /* ===== hamburger (≤920px only) — hidden on desktop ===== */
  .nav__burger {
    display: none;
    flex: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--m-hairline);
    border-radius: 8px;
    color: var(--m-ink);
    cursor: pointer;
    transition:
      background var(--m-dur-fast) ease,
      border-color var(--m-dur-fast) ease;
  }
  .nav__burger:hover {
    background: var(--m-section);
  }
  .nav__burger-box {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 18px;
    height: 14px;
  }
  .nav__burger-bar {
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform var(--m-dur) var(--m-ease),
      opacity var(--m-dur-fast) ease;
  }
  /* open state morphs the three bars into an X */
  .nav__burger[aria-expanded='true'] .nav__burger-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav__burger[aria-expanded='true'] .nav__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__burger[aria-expanded='true'] .nav__burger-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
  .nav--on-dark .nav__burger {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.24);
  }
  .nav--on-dark .nav__burger:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  /* ===== mobile sheet + scrim ===== */
  .nav__scrim {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: color-mix(in srgb, var(--m-ink) 38%, transparent);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity var(--m-dur) ease;
  }
  .nav__scrim[data-open] {
    opacity: 1;
  }
  .nav__sheet {
    position: fixed;
    top: 12px;
    right: 12px;
    left: 12px;
    z-index: 61;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 12px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transform: translateY(-8px);
    opacity: 0;
    transition:
      transform var(--m-dur) var(--m-ease),
      opacity var(--m-dur) ease;
  }
  .nav__sheet[data-open] {
    transform: translateY(0);
    opacity: 1;
  }
  .nav__sheet-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav__sheet-link {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: var(--m-text-md);
    font-weight: 500;
    color: var(--m-ink);
    transition:
      color var(--m-dur-fast) ease,
      background var(--m-dur-fast) ease;
  }
  .nav__sheet-link:hover {
    background: var(--m-section);
  }
  .nav__sheet-link.is-active {
    color: var(--m-accent);
    background: var(--m-accent-tint);
    font-weight: 600;
  }
  .nav__sheet-foot {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid var(--m-hairline);
  }
  .nav__sheet-signin {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 8px;
    font-size: var(--m-text-base);
    font-weight: 500;
    color: var(--m-ink-2);
    transition:
      color var(--m-dur-fast) ease,
      background var(--m-dur-fast) ease;
  }
  .nav__sheet-signin:hover {
    color: var(--m-ink);
    background: var(--m-section);
  }
  .nav__sheet-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 46px;
    font-size: var(--m-text-md);
    font-weight: 500;
    color: #fff;
    background: var(--m-accent);
    border-radius: 8px;
    transition: background var(--m-dur-fast) ease;
  }
  .nav__sheet-cta:hover {
    background: var(--m-accent-strong);
  }

  @media (max-width: 920px) {
    .nav__pill {
      display: none;
    }
    .nav__burger {
      display: inline-flex;
    }
    /* desktop CTA is redundant once it lives in the sheet → declutter the bar */
    .nav__right .nav__cta {
      display: none;
    }
  }
  @media (max-width: 560px) {
    .nav__signin {
      display: none;
    }
  }
  /* above 920px the sheet never shows even if a stale class lingers */
  @media (min-width: 921px) {
    .nav__scrim,
    .nav__sheet {
      display: none !important;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .nav,
    .nav__inner,
    .brand,
    .brand__lockup,
    .nav__right,
    .brand__name,
    .brand__beta,
    .nav__signin,
    .nav__burger,
    .nav__burger-bar,
    .nav__scrim,
    .nav__sheet {
      transition: none;
    }
  }
</style>

<script>
  // Solidify + slightly shrink on scroll; flip to white when the nav sits over a
  // dark band ([data-nav-dark], e.g. the villain). rAF-throttled scroll handler
  // (IntersectionObserver isn't used so the same logic works headless + live).
  // Re-inits per View-Transition navigation; window listeners drop on swap.
  function initNavScroll(signal: AbortSignal) {
    const nav = document.querySelector<HTMLElement>('.nav')
    if (!nav) return
    const darkSections = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-dark]'))
    let ticking = false
    const update = () => {
      ticking = false
      // hysteresis: collapse past 64px, expand back under 24px — a dead zone so
      // the pill never flickers when the user lingers right at the threshold
      const collapsed = nav.classList.contains('nav--scrolled')
      const y = window.scrollY
      if (!collapsed && y > 64) nav.classList.add('nav--scrolled')
      else if (collapsed && y < 24) nav.classList.remove('nav--scrolled')
      const line = nav.getBoundingClientRect().height * 0.55
      let onDark = false
      for (const s of darkSections) {
        const r = s.getBoundingClientRect()
        if (r.top <= line && r.bottom >= line) {
          onDark = true
          break
        }
      }
      nav.classList.toggle('nav--on-dark', onDark)
    }
    const onScroll = () => {
      if (!ticking) {
        ticking = true
        requestAnimationFrame(update)
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true, signal })
    window.addEventListener('resize', onScroll, { passive: true, signal })
    update()
  }
  let navScrollCtl: AbortController | undefined
  document.addEventListener('astro:page-load', () => {
    navScrollCtl = new AbortController()
    initNavScroll(navScrollCtl.signal)
  })
  document.addEventListener('astro:before-swap', () => navScrollCtl?.abort())
</script>

<script>
  // Nav glider — one pill that rests under the ACTIVE link and slides under the
  // hovered link. The nav is transition:persist'd, so across a page swap the SAME
  // glider slides to the new page's active link instead of the whole nav
  // cross-fading between two positions (which read as a jump). Progressive
  // enhancement: without JS the static .is-active background shows.
  function activeNavKey(path: string): string | null {
    const p = path.replace(/^\/zh-CN/, '') || '/'
    if (p === '/' || p === '') return 'home'
    if (p.startsWith('/how-it-works')) return 'how'
    if (p.startsWith('/state-coverage') || p.startsWith('/states/')) return 'coverage'
    if (p.startsWith('/pricing')) return 'pricing'
    if (p.startsWith('/security')) return 'security'
    return null
  }
  // The persisted nav keeps the previous page's active link, so re-derive it from
  // the URL after each swap (matches the server-rendered `current` logic).
  function syncNavActive() {
    const key = activeNavKey(location.pathname)
    document.querySelectorAll<HTMLElement>('.nav__link, .nav__sheet-link').forEach((l) => {
      const on = l.dataset.key === key
      l.classList.toggle('is-active', on)
      if (on) l.setAttribute('aria-current', 'page')
      else l.removeAttribute('aria-current')
    })
  }

  let navGliderFirst = true
  function initNavGlider(signal: AbortSignal) {
    const pill = document.querySelector<HTMLElement>('.nav__pill')
    const glider = pill?.querySelector<HTMLElement>('.nav__glider')
    const links = pill ? Array.from(pill.querySelectorAll<HTMLElement>('.nav__link')) : []
    if (!pill || !glider || !links.length) return
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    pill.classList.add('has-glider')
    syncNavActive()

    const active = () => pill.querySelector<HTMLElement>('.nav__link.is-active')
    const place = (link: HTMLElement | null, animate = true) => {
      if (!link) {
        glider.style.opacity = '0'
        return
      }
      if (!animate || reduce) glider.style.transition = 'none'
      glider.style.width = `${link.offsetWidth}px`
      glider.style.height = `${link.offsetHeight}px`
      glider.style.transform = `translate(${link.offsetLeft}px, ${link.offsetTop}px)`
      glider.style.opacity = '1'
      if (!animate || reduce) {
        void glider.offsetWidth // flush the no-transition placement
        glider.style.transition = ''
      }
    }
    const rest = (animate = false) => place(active(), animate)

    links.forEach((l) => l.addEventListener('pointerenter', () => place(l, true), { signal }))
    pill.addEventListener('pointerleave', () => rest(true), { signal })
    window.addEventListener('resize', () => rest(false), { passive: true, signal })
    // the nav collapse (pill morph) shifts link positions — re-rest when it ends
    document
      .querySelector('.nav__inner')
      ?.addEventListener('transitionend', () => rest(false), { signal })
    // first paint snaps into place; later page swaps SLIDE to the new active link
    const animate = !navGliderFirst
    navGliderFirst = false
    requestAnimationFrame(() => rest(animate))
    if (!animate) document.fonts?.ready.then(() => rest(false))
  }
  let navGliderCtl: AbortController | undefined
  document.addEventListener('astro:page-load', () => {
    navGliderCtl = new AbortController()
    initNavGlider(navGliderCtl.signal)
  })
  document.addEventListener('astro:before-swap', () => navGliderCtl?.abort())
</script>

<script>
  // Mobile sheet (≤920px): hamburger toggles an accessible dialog with the nav
  // links + Sign in + CTA. Esc closes, focus moves into the sheet and is
  // restored on close, outside-click + link-click + resize-up all dismiss it.
  // Re-inits per View-Transition navigation; every listener drops on the swap.
  function initMobileSheet(signal: AbortSignal) {
    const burger = document.querySelector<HTMLButtonElement>('.nav__burger')
    const sheet = document.querySelector<HTMLElement>('.nav__sheet')
    const scrim = document.querySelector<HTMLElement>('[data-nav-scrim]')
    if (!burger || !sheet || !scrim) return

    let lastFocused: HTMLElement | null = null

    const focusables = () =>
      Array.from(
        sheet.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
      )

    const isOpen = () => burger.getAttribute('aria-expanded') === 'true'

    const open = () => {
      if (isOpen()) return
      lastFocused = document.activeElement as HTMLElement | null
      sheet.hidden = false
      scrim.hidden = false
      // next frame so the entrance transition runs from the hidden state
      requestAnimationFrame(() => {
        sheet.setAttribute('data-open', '')
        scrim.setAttribute('data-open', '')
      })
      burger.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'
      focusables()[0]?.focus()
    }

    const close = (restoreFocus = true) => {
      if (!isOpen()) return
      sheet.removeAttribute('data-open')
      scrim.removeAttribute('data-open')
      burger.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
      const finish = () => {
        sheet.hidden = true
        scrim.hidden = true
      }
      // honour reduced-motion / no-transition by hiding immediately
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (reduce) finish()
      else window.setTimeout(finish, 240)
      if (restoreFocus) (lastFocused ?? burger).focus()
    }

    burger.addEventListener('click', () => (isOpen() ? close() : open()), { signal })
    scrim.addEventListener('click', () => close(), { signal })
    // any link tap navigates → let it close (no focus restore, we're leaving)
    sheet.querySelectorAll('a[href]').forEach((a) =>
      a.addEventListener('click', () => close(false), { signal }),
    )

    document.addEventListener(
      'keydown',
      (e) => {
        if (!isOpen()) return
        if (e.key === 'Escape') {
          e.preventDefault()
          close()
          return
        }
        // simple focus trap inside the sheet
        if (e.key === 'Tab') {
          const items = focusables()
          if (!items.length) return
          const first = items[0]
          const last = items[items.length - 1]
          const active = document.activeElement
          if (e.shiftKey && active === first) {
            e.preventDefault()
            last.focus()
          } else if (!e.shiftKey && active === last) {
            e.preventDefault()
            first.focus()
          }
        }
      },
      { signal },
    )

    // crossing back to desktop width must not leave a hidden-but-open sheet
    const mq = window.matchMedia('(min-width: 921px)')
    mq.addEventListener('change', (e) => e.matches && close(false), { signal })
  }
  let sheetCtl: AbortController | undefined
  document.addEventListener('astro:page-load', () => {
    sheetCtl = new AbortController()
    initMobileSheet(sheetCtl.signal)
  })
  document.addEventListener('astro:before-swap', () => {
    sheetCtl?.abort()
    document.body.style.overflow = ''
  })
</script>
