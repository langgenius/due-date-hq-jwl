---
import { buildLocaleHrefPair } from '../../lib/locale-paths'

/** Footer — wordmark + link columns (EN + zh-CN). The Resources column is the
 *  internal-link on-ramp into the long-tail SEO/AEO/GEO pages. Labels are an
 *  inline EN/zh map (chrome copy); hrefs are locale-prefixed. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const base = zh ? '/zh-CN' : ''
const columns = [
  {
    title: zh ? '产品' : 'Product',
    links: [
      { label: zh ? '工作原理' : 'How it works', href: `${base}/how-it-works` },
      { label: zh ? '覆盖范围' : 'Coverage', href: `${base}/state-coverage` },
      { label: zh ? '定价' : 'Pricing', href: `${base}/pricing` },
      { label: zh ? '安全' : 'Security', href: `${base}/security` },
    ],
  },
  {
    title: zh ? '资源' : 'Resources',
    links: [
      { label: zh ? '全部资源' : 'All resources', href: `${base}/resources` },
      { label: zh ? '规则库' : 'Rule library', href: `${base}/rules` },
      { label: zh ? '证据支持的软件' : 'Evidence-backed software', href: `${base}/guides/evidence-backed-tax-deadline-software` },
      { label: zh ? '对比:File In Time' : 'Compare: File In Time', href: `${base}/compare/file-in-time-alternative` },
      { label: zh ? '每周分诊指南' : 'Weekly triage guide', href: `${base}/guides/weekly-cpa-deadline-triage` },
    ],
  },
  {
    title: zh ? '公司' : 'Company',
    links: [
      { label: zh ? '隐私' : 'Privacy', href: `${base}/privacy` },
      { label: zh ? '条款' : 'Terms', href: `${base}/terms` },
      { label: zh ? '状态' : 'Status', href: `${base}/status` },
    ],
  },
]
const copy = zh
  ? {
      tagline: '为美国 CPA 事务所监控截止日变化 —— 每个日期都附官方来源。',
      audience: '面向美国 CPA 事务所 · 联邦 + 50 州 + DC',
      legal: 'DueDateHQ 支持基于证据的复核;它不是税务建议,也不是报税系统。© 2026 DueDateHQ Inc.',
      note: '你的数据留在你的事务所',
    }
  : {
      tagline: 'Deadline-change monitoring for US CPA practices — with a source on every date.',
      audience: 'For US CPA practices · FED + 50 states + DC',
      legal: 'DueDateHQ supports evidence-backed review; it is not tax advice or a filing system. © 2026 DueDateHQ Inc.',
      note: 'Your data stays in your practice',
    }
const { enHref, zhHref } = buildLocaleHrefPair(Astro.url.pathname)
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <a href={`${base}/`} class="footer__name" aria-label={zh ? 'DueDateHQ 首页' : 'DueDateHQ home'}>
          <svg viewBox="103.768 0 488.021 76.512" fill="currentColor" aria-hidden="true">
