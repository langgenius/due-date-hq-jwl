---
/** Footer — wordmark + link columns. English inline for now; i18n + locale switcher in the localization pass. */
const columns = [
  { title: 'Product', links: ['How it works', 'Sources', 'See it work', 'Security'] },
  { title: 'Resources', links: ['Rule library', 'State coverage', 'Status'] },
  { title: 'Company', links: ['Security', 'Privacy', 'Terms', 'Contact'] },
]
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <span class="footer__name">DueDateHQ</span>
        <p class="footer__tag">Deadline-change monitoring for US CPA practices — with a source on every date.</p>
        <p class="footer__aud">For US CPA practices · FED + 50 states + DC</p>
      </div>
      {
        columns.map((c) => (
          <nav class="footer__col" aria-label={c.title}>
            <p class="footer__coltitle">{c.title}</p>
            {c.links.map((l) => (
              <a href="#" class="footer__link">{l}</a>
            ))}
          </nav>
        ))
      }
    </div>
    <div class="footer__bottom">
      <p class="footer__legal">
        DueDateHQ supports evidence-backed review; it is not tax advice or a filing system. © 2026
        DueDateHQ Inc.
      </p>
      <span class="footer__note">Your data stays in your practice</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline);
  }
  .footer__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(48px, 6vw, 72px);
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: clamp(28px, 4vw, 56px);
  }
  .footer__name {
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .footer__tag {
    margin-top: 14px;
    max-width: 34ch;
    font-size: 14px;
    line-height: 1.5;
    color: var(--m-ink-2);
  }
  .footer__aud {
    margin-top: 14px;
    font-family: var(--m-font-mono);
    font-size: 12px;
    color: var(--m-faint);
  }
  .footer__coltitle {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-faint);
    margin-bottom: 16px;
  }
  .footer__link {
    display: block;
    font-size: 14px;
    color: var(--m-muted);
    padding: 6px 0;
    transition: color 0.15s ease;
  }
  .footer__link:hover {
    color: var(--m-ink);
  }
  .footer__bottom {
    margin-top: clamp(36px, 5vw, 56px);
    padding-top: 22px;
    border-top: 1px solid var(--m-hairline-2);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
  }
  .footer__legal {
    font-size: 12px;
    color: var(--m-muted);
    max-width: 70ch;
  }
  .footer__note {
    font-family: var(--m-font-mono);
    font-size: 12px;
    color: var(--m-muted);
  }
  @media (max-width: 720px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 440px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>
