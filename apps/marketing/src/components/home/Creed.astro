---
/** Creed — a serif "pause" between the proof sections. One large display-serif
 *  positioning line on a faintly-tinted full-bleed band (no card, hairline rules
 *  top + bottom), to break the run of white hairline cards with an editorial beat
 *  and restate the core differentiation: a monitor, not a list you maintain. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const t = zh
  ? { pre: '不是一张要你维护的截止日清单。', ital: '而是日期一变动，就第一时间告诉你的监控。' }
  : { pre: 'Not a deadline list you maintain.', ital: 'A monitor that tells you the moment one moves.' }
---

<section class="creed" aria-label={zh ? '核心定位' : 'What this is'} data-reveal>
  <div class="creed__inner">
    <p class="creed__line">{t.pre} <span class="ital">{t.ital}</span></p>
  </div>
</section>

<style>
  /* full-bleed, faintly navy-tinted band with hairline rules — reads as an
     editorial pause, not a card */
  .creed {
    background: color-mix(in srgb, var(--m-accent) 4%, var(--m-canvas));
    border-block: 1px solid var(--m-hairline);
  }
  .creed__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(64px, 11vw, 132px);
  }
  .creed__line {
    max-width: 22ch;
    font-family: var(--m-font-sans);
    font-weight: 600;
    font-size: clamp(30px, 4.6vw, 58px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--m-ink);
  }
  /* the second clause leans into the display-serif italic the hero opens with */
  .creed__line .ital {
    font-style: italic;
    color: var(--m-ink-2);
  }
</style>
