---
/** Trust — the Glass-Box Guarantee: sourced / no auto-apply / reversible. */
const stats = [
  { n: '100%', t: 'Sourced', b: 'Nothing is shown without a citation back to the official text.' },
  { n: '0', t: 'Auto-applied changes', b: "Nothing touches a client's deadline on its own. Apply is always your call." },
  { n: '24h', t: 'Reversible', b: 'Any apply undoes cleanly within 24 hours — and every apply, undo, and revert is recorded and inspectable.' },
]
---

<section class="m-section trust" id="trust" aria-labelledby="trust-h">
  <p class="m-eyebrow">Why you can trust it</p>
  <h2 class="m-h2" id="trust-h">Every date clicks back to its <span class="ital">source.</span></h2>
  <p class="m-lead trust__lead">
    We call it <span class="glass">glass-box</span> — a link, the exact quote, and a verified date on
    every change, or it's held back.
  </p>

  <div class="trust__grid">
    {
      stats.map((s) => (
        <div class="tstat">
          <div class="tstat__n">{s.n}</div>
          <div class="tstat__t">{s.t}</div>
          <p class="tstat__b">{s.b}</p>
        </div>
      ))
    }
  </div>

  <div class="boundary">
    <span class="boundary__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" />
      </svg>
    </span>
    <p class="boundary__t">
      <b>Not tax advice.</b> DueDateHQ supports evidence-backed review — it is not tax advice, not a
      filing system, and not a replacement for a CPA, EA, or attorney. It tells you where to look and
      why; you make the call.
    </p>
  </div>
</section>

<style>
  .trust__lead {
    margin-top: 16px;
    max-width: 56ch;
  }
  .glass {
    color: var(--m-accent);
    font-weight: 600;
  }
  .trust__grid {
    margin-top: clamp(40px, 5vw, 60px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3vw, 44px);
  }
  .tstat {
    padding-top: 22px;
    border-top: 1px solid var(--m-ink);
  }
  .tstat__n {
    font-family: var(--m-font-mono);
    font-weight: 600;
    font-size: clamp(34px, 4.2vw, 52px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--m-accent);
  }
  .tstat__t {
    margin: 14px 0 7px;
    font-weight: 600;
    font-size: 15px;
    color: var(--m-ink);
  }
  .tstat__b {
    font-size: 13px;
    line-height: 1.55;
    color: var(--m-muted);
    max-width: 32ch;
  }
  .boundary {
    margin-top: clamp(32px, 4vw, 48px);
    padding-top: clamp(26px, 3vw, 34px);
    border-top: 1px solid var(--m-hairline);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: start;
    max-width: 920px;
  }
  .boundary__icon {
    width: 36px;
    height: 36px;
    flex: none;
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: var(--m-muted);
  }
  .boundary__icon svg {
    width: 18px;
    height: 18px;
  }
  .boundary__t {
    font-size: 14px;
    line-height: 1.6;
    color: var(--m-muted);
  }
  .boundary__t b {
    color: var(--m-ink);
    font-weight: 600;
  }
  @media (max-width: 720px) {
    .trust__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
