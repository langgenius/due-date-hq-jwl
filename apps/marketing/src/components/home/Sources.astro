---
/** Sources — coverage proof. One clear, honest message: the whole country is
 *  watched around the clock (IRS + FEMA disaster relief nationwide + the major
 *  state tax agencies, and every one of the 50 + DC in the rule library). A
 *  full-bleed band: a live-scanning US map + a source-monitoring feed. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const agencies = ['IRS', 'CA FTB', 'NY DTF', 'TX Comptroller', 'FL DOR', 'WA DOR', 'MA DOR']

const t = zh
  ? {
      eyebrow: '覆盖范围',
      headingPre: '紧盯官方来源，',
      headingItal: '全天候。',
      leadHtml:
        '我们全天候监控 IRS 和 FEMA 全国灾害救济，并直接盯紧主要州税务机关——<b>50 个州 + DC</b>，没有一个落下。',
      chipsLabel: '实时监控的来源',
      chipMore: '+ FEMA 灾害声明，覆盖全国',
      mapLabel: '美国地图：每一个州都在监控之中，全部 50 个州加 DC',
      legWatched: '全天候监控中',
      mapCap: 'FED + 50 个州 + DC',
      feedLabel: '来源监控动态——示例预览',
      feedTitle: '监控动态',
      feedCap: '实时预览 · 非你的数据',
      statusLabels: { scan: '已扫描', new: '新公告', ok: '已核验' },
      rows: [
        { code: 'IRS', org: 'IRS', body: '已扫描，无变化', when: '2 分钟前', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', body: '新公告', when: '14 分钟前', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', body: '已核验，无变化', when: '31 分钟前', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', body: '已扫描，无变化', when: '52 分钟前', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', body: '灾害声明', when: '1 小时前', dot: 'new', alert: true },
      ],
    }
  : {
      eyebrow: 'Coverage',
      headingPre: 'Eyes on the official sources, ',
      headingItal: 'around the clock.',
      leadHtml:
        'We watch the IRS and FEMA disaster relief nationwide, and the major state tax agencies directly — <b>all 50 states + DC</b>, with nothing left unwatched.',
      chipsLabel: 'Sources monitored live',
      chipMore: '+ FEMA disaster declarations, nationwide',
      mapLabel: 'US map: every state watched, all 50 plus DC',
      legWatched: 'Watched around the clock',
      mapCap: 'FED + 50 states + DC',
      feedLabel: 'Source-monitoring feed — sample preview',
      feedTitle: 'Monitoring feed',
      feedCap: 'live preview · not your data',
      statusLabels: { scan: 'Scanned', new: 'New', ok: 'Verified' },
      rows: [
        { code: 'IRS', org: 'IRS', body: 'scanned, no change', when: '2m ago', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', body: 'new notice', when: '14m ago', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', body: 'verified, no change', when: '31m ago', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', body: 'scanned, no change', when: '52m ago', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', body: 'disaster declaration', when: '1h ago', dot: 'new', alert: true },
      ],
    }
// US tilegram (state, grid-row, grid-column) — every tile is watched
const tiles = [
  { s: 'AK', r: 1, c: 1 }, { s: 'ME', r: 1, c: 11 },
  { s: 'VT', r: 2, c: 10 }, { s: 'NH', r: 2, c: 11 },
  { s: 'WA', r: 3, c: 2 }, { s: 'ID', r: 3, c: 3 }, { s: 'MT', r: 3, c: 4 },
  { s: 'ND', r: 3, c: 5 }, { s: 'MN', r: 3, c: 6 }, { s: 'WI', r: 3, c: 7 },
  { s: 'MI', r: 3, c: 8 }, { s: 'NY', r: 3, c: 10 }, { s: 'MA', r: 3, c: 11 },
  { s: 'OR', r: 4, c: 2 }, { s: 'NV', r: 4, c: 3 }, { s: 'WY', r: 4, c: 4 },
  { s: 'SD', r: 4, c: 5 }, { s: 'IA', r: 4, c: 6 }, { s: 'IL', r: 4, c: 7 },
  { s: 'IN', r: 4, c: 8 }, { s: 'OH', r: 4, c: 9 }, { s: 'PA', r: 4, c: 10 },
  { s: 'NJ', r: 4, c: 11 }, { s: 'CT', r: 4, c: 12 }, { s: 'RI', r: 4, c: 13 },
  { s: 'CA', r: 5, c: 2 }, { s: 'UT', r: 5, c: 3 }, { s: 'CO', r: 5, c: 4 },
  { s: 'NE', r: 5, c: 5 }, { s: 'MO', r: 5, c: 6 }, { s: 'KY', r: 5, c: 7 },
  { s: 'WV', r: 5, c: 8 }, { s: 'VA', r: 5, c: 9 }, { s: 'MD', r: 5, c: 10 },
  { s: 'DE', r: 5, c: 11 }, { s: 'AZ', r: 6, c: 3 }, { s: 'NM', r: 6, c: 4 },
  { s: 'KS', r: 6, c: 5 }, { s: 'AR', r: 6, c: 6 }, { s: 'TN', r: 6, c: 7 },
  { s: 'NC', r: 6, c: 8 }, { s: 'SC', r: 6, c: 9 }, { s: 'DC', r: 6, c: 10 },
  { s: 'HI', r: 7, c: 1 }, { s: 'OK', r: 7, c: 5 }, { s: 'LA', r: 7, c: 6 },
  { s: 'MS', r: 7, c: 7 }, { s: 'AL', r: 7, c: 8 }, { s: 'GA', r: 7, c: 9 },
  { s: 'TX', r: 8, c: 5 }, { s: 'FL', r: 8, c: 9 },
]
---

<section class="sources" id="sources" aria-labelledby="sources-h" data-reveal>
  <div class="sources__inner">
    <p class="m-eyebrow">{t.eyebrow}</p>
    <h2 class="m-h2" id="sources-h">
      {t.headingPre}<span class="ital">{t.headingItal}</span>
    </h2>
    <p class="m-lead sources__lead" set:html={t.leadHtml} />

    <ul class="sources__chips" aria-label={t.chipsLabel}>
      {agencies.map((a) => <li class="chip">{a}</li>)}
      <li class="chip chip--more">{t.chipMore}</li>
    </ul>

    <div class="sources__grid">
      <!-- live-scanning US map — every state watched -->
      <div class="usmap-wrap">
        <div class="usmap" role="img" aria-label={t.mapLabel}>
          {
            tiles.map((tile, i) => (
              <div class="ust" style={`grid-row:${tile.r};grid-column:${tile.c};--i:${i}`}>
                <span class="ust__c">{tile.s}</span>
              </div>
            ))
          }
        </div>
        <div class="usmap__legend">
          <span class="leg"><span class="sw" />{t.legWatched}</span>
          <span class="usmap__cap">{t.mapCap}</span>
        </div>
      </div>

      <!-- source-monitoring feed -->
      <div class="feed" aria-label={t.feedLabel}>
        <div class="feed__bar">
          <span class="feed__title"><span class="live" aria-hidden="true" />{t.feedTitle}</span>
          <span class="feed__cap">{t.feedCap}</span>
        </div>
        {
          t.rows.map((r) => (
            <div class="feed-row">
              <span class="feed-row__badge">{r.code}</span>
              <div class="feed-row__main">
                <span class="feed-row__org">{r.org}</span>
                <span class="feed-row__body">{r.body}</span>
              </div>
              <span class={`feed-row__status feed-row__status--${r.dot}`}>{t.statusLabels[r.dot]}</span>
              <span class={`feed-row__when${r.alert ? ' alert' : ''}`}>{r.when}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* full-bleed band */
  .sources {
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline);
    padding-block: clamp(56px, 8vw, 104px);
  }
  .sources__inner {
    max-width: 1340px;
    margin-inline: auto;
    padding-inline: var(--m-gutter);
  }
  .sources__lead {
    margin-top: 16px;
    max-width: 64ch;
  }
  .sources__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  .sources__chips {
    margin-top: clamp(24px, 3vw, 32px);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
  }
  .chip {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    padding: 6px 14px;
  }
  .chip--more {
    font-weight: 500;
    color: var(--m-muted);
    border-style: dashed;
    background: transparent;
  }

  .sources__grid {
    margin-top: clamp(28px, 4vw, 44px);
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 4vw, 44px);
    align-items: start;
  }
  .usmap-wrap {
    grid-column: span 7;
  }
  .feed {
    grid-column: span 5;
  }

  /* ---- US tilegram — uniform "watched", with a live scan wave ---- */
  .usmap {
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    grid-template-rows: repeat(8, minmax(32px, 1fr));
    gap: 5px;
    min-width: 480px;
  }
  .ust {
    display: grid;
    place-items: center;
    border-radius: 7px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    color: #fff;
    background: var(--m-accent);
    animation: ust-scan 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.11s);
  }
  @keyframes ust-scan {
    0%,
    88%,
    100% {
      background: var(--m-accent);
      box-shadow: none;
    }
    94% {
      background: var(--m-accent-strong);
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--m-cyan) 55%, transparent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ust {
      animation: none;
    }
  }
  .usmap__legend {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    font-size: 12px;
    color: var(--m-muted);
  }
  .leg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .sw {
    width: 12px;
    height: 12px;
    border-radius: 4px;
    flex: none;
    background: var(--m-accent);
  }
  .usmap__cap {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }

  /* ---- feed ---- */
  .live {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-ok);
    flex: none;
  }
  .feed {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .feed__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .feed__title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--m-ink-2);
  }
  .feed__cap {
    font-family: var(--m-font-mono);
    font-size: 10px;
    color: var(--m-faint);
  }
  .feed-row {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 12px 16px;
  }
  .feed-row + .feed-row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .feed-row__badge {
    flex: none;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-family: var(--m-font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .feed-row__main {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .feed-row__org {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink);
  }
  .feed-row__body {
    font-size: 12px;
    color: var(--m-muted);
  }
  .feed-row__status {
    margin-left: auto;
    flex: none;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 999px;
  }
  .feed-row__status--scan {
    color: var(--m-muted);
    background: var(--m-section);
  }
  .feed-row__status--new {
    color: var(--m-urgent);
    background: color-mix(in srgb, var(--m-urgent) 12%, transparent);
  }
  .feed-row__status--ok {
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
  }
  .feed-row__when {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }
  .feed-row__when.alert {
    color: var(--m-urgent);
  }

  @media (max-width: 1000px) {
    .sources__grid {
      grid-template-columns: 1fr;
    }
    .usmap-wrap,
    .feed {
      grid-column: auto;
    }
    .usmap-wrap {
      overflow-x: auto;
    }
  }
</style>
