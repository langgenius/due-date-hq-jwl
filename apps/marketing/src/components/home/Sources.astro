---
/** Sources — coverage proof. One clear, honest message: the whole country is
 *  watched around the clock — IRS + FEMA disaster relief nationwide + every
 *  state tax agency, all 50 states + DC, uniformly live. A full-bleed band:
 *  a live-scanning US map (every tile equally watched) + a source-monitoring
 *  feed styled like the product's Alerts surface (honest beta sample). */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      eyebrow: '覆盖范围',
      headingPre: '紧盯官方来源，',
      headingItal: '全天候。',
      leadHtml:
        '我们全天候监控 IRS、FEMA 全国灾害救济，以及每一个州的税务机关——<b>全部 50 个州 + DC</b>，没有「重点」与「普通」之分，一视同仁地实时盯紧。',
      chipsLabel: '实时监控的来源',
      chipMore: '+ FEMA 灾害声明，覆盖全国',
      mapLabel: '美国地图：每一个州都在 24/7 实时监控之中，全部 50 个州加 DC，一视同仁',
      legWatched: '全部 24/7 实时监控',
      mapStat: '51',
      mapStatLabel: '个辖区实时监控',
      mapCap: 'FED + 50 州 + DC · 24/7',
      feedLabel: '来源监控动态——示例预览',
      feedTitle: '监控动态',
      feedLive: '实时',
      feedCap: '示例预览 · 非你的数据',
      feedFootLeft: '每分钟扫描一次',
      feedFootRight: '示例数据',
      statusLabels: { scan: '已扫描', new: '新公告', ok: '已核验' },
      rows: [
        { code: 'IRS', org: 'IRS', agency: '联邦', body: '已扫描，无变化', when: '2 分钟前', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', agency: '州', body: '检测到新公告', when: '14 分钟前', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', agency: '州', body: '已核验，无变化', when: '31 分钟前', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', agency: '州', body: '已扫描，无变化', when: '52 分钟前', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', agency: '联邦', body: '新灾害声明', when: '1 小时前', dot: 'new', alert: true },
      ],
    }
  : {
      eyebrow: 'Coverage',
      headingPre: 'Eyes on the official sources, ',
      headingItal: 'around the clock.',
      leadHtml:
        'We watch the IRS, FEMA disaster relief nationwide, and every state tax agency — <b>all 50 states + DC</b>, no "priority" states and no afterthoughts. Every jurisdiction is watched live, the same way.',
      chipsLabel: 'Sources monitored live',
      chipMore: '+ FEMA disaster declarations, nationwide',
      mapLabel: 'US map: every state watched live around the clock, all 50 plus DC, uniformly',
      legWatched: 'All watched live, 24/7',
      mapStat: '51',
      mapStatLabel: 'jurisdictions watched live',
      mapCap: 'FED + 50 states + DC · 24/7',
      feedLabel: 'Source-monitoring feed — sample preview',
      feedTitle: 'Monitoring feed',
      feedLive: 'Live',
      feedCap: 'sample preview · not your data',
      feedFootLeft: 'Scanning every minute',
      feedFootRight: 'Sample data',
      statusLabels: { scan: 'Scanned', new: 'New', ok: 'Verified' },
      rows: [
        { code: 'IRS', org: 'IRS', agency: 'Federal', body: 'scanned, no change', when: '2m ago', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', agency: 'State', body: 'new notice detected', when: '14m ago', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', agency: 'State', body: 'verified, no change', when: '31m ago', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', agency: 'State', body: 'scanned, no change', when: '52m ago', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', agency: 'Federal', body: 'new disaster declaration', when: '1h ago', dot: 'new', alert: true },
      ],
    }
// Full state names — drive the "click a state → its sources" panel. Every state
// is watched the same way (IRS + FEMA + its state tax agency), so the panel is
// honest without per-state specifics; the well-known agencies get a real name.
const STATE_NAMES: Record<string, string> = {
  AK: 'Alaska', AL: 'Alabama', AR: 'Arkansas', AZ: 'Arizona', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DC: 'District of Columbia', DE: 'Delaware',
  FL: 'Florida', GA: 'Georgia', HI: 'Hawaii', IA: 'Iowa', ID: 'Idaho',
  IL: 'Illinois', IN: 'Indiana', KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana',
  MA: 'Massachusetts', MD: 'Maryland', ME: 'Maine', MI: 'Michigan', MN: 'Minnesota',
  MO: 'Missouri', MS: 'Mississippi', MT: 'Montana', NC: 'North Carolina',
  ND: 'North Dakota', NE: 'Nebraska', NH: 'New Hampshire', NJ: 'New Jersey',
  NM: 'New Mexico', NV: 'Nevada', NY: 'New York', OH: 'Ohio', OK: 'Oklahoma',
  OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina',
  SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VA: 'Virginia',
  VT: 'Vermont', WA: 'Washington', WI: 'Wisconsin', WV: 'West Virginia', WY: 'Wyoming',
}
// Real agency names for the ones we name elsewhere; the rest use a clean generic.
const STATE_AGENCY: Record<string, string> = {
  CA: 'Franchise Tax Board', NY: 'Dept. of Taxation & Finance',
  TX: 'Comptroller of Public Accounts', FL: 'Dept. of Revenue',
  WA: 'Dept. of Revenue', MA: 'Dept. of Revenue',
}
const panel = zh
  ? { prompt: '点选地图上的任意一州，查看我们为它监控的官方来源。', watched: '实时监控', fed: '联邦', state: '州', sIrs: 'IRS — 联邦报税', sFema: 'FEMA — 全国灾害救济', agencyGeneric: '州税务机关' }
  : { prompt: 'Click any state on the map to see the official sources we watch for it.', watched: 'Watched live', fed: 'Federal', state: 'State', sIrs: 'IRS — federal filing', sFema: 'FEMA — disaster relief, nationwide', agencyGeneric: 'state tax agency' }

// US tilegram (state, grid-row, grid-column) — every tile is watched
const tiles = [
  { s: 'AK', r: 1, c: 1 }, { s: 'ME', r: 1, c: 11 },
  { s: 'VT', r: 2, c: 10 }, { s: 'NH', r: 2, c: 11 },
  { s: 'WA', r: 3, c: 2 }, { s: 'ID', r: 3, c: 3 }, { s: 'MT', r: 3, c: 4 },
  { s: 'ND', r: 3, c: 5 }, { s: 'MN', r: 3, c: 6 }, { s: 'WI', r: 3, c: 7 },
  { s: 'MI', r: 3, c: 8 }, { s: 'NY', r: 3, c: 10 }, { s: 'MA', r: 3, c: 11 },
  { s: 'OR', r: 4, c: 2 }, { s: 'NV', r: 4, c: 3 }, { s: 'WY', r: 4, c: 4 },
  { s: 'SD', r: 4, c: 5 }, { s: 'IA', r: 4, c: 6 }, { s: 'IL', r: 4, c: 7 },
  { s: 'IN', r: 4, c: 8 }, { s: 'OH', r: 4, c: 9 }, { s: 'PA', r: 4, c: 10 },
  { s: 'NJ', r: 4, c: 11 }, { s: 'CT', r: 4, c: 12 }, { s: 'RI', r: 4, c: 13 },
  { s: 'CA', r: 5, c: 2 }, { s: 'UT', r: 5, c: 3 }, { s: 'CO', r: 5, c: 4 },
  { s: 'NE', r: 5, c: 5 }, { s: 'MO', r: 5, c: 6 }, { s: 'KY', r: 5, c: 7 },
  { s: 'WV', r: 5, c: 8 }, { s: 'VA', r: 5, c: 9 }, { s: 'MD', r: 5, c: 10 },
  { s: 'DE', r: 5, c: 11 }, { s: 'AZ', r: 6, c: 3 }, { s: 'NM', r: 6, c: 4 },
  { s: 'KS', r: 6, c: 5 }, { s: 'AR', r: 6, c: 6 }, { s: 'TN', r: 6, c: 7 },
  { s: 'NC', r: 6, c: 8 }, { s: 'SC', r: 6, c: 9 }, { s: 'DC', r: 6, c: 10 },
  { s: 'HI', r: 7, c: 1 }, { s: 'OK', r: 7, c: 5 }, { s: 'LA', r: 7, c: 6 },
  { s: 'MS', r: 7, c: 7 }, { s: 'AL', r: 7, c: 8 }, { s: 'GA', r: 7, c: 9 },
  { s: 'TX', r: 8, c: 5 }, { s: 'FL', r: 8, c: 9 },
]
---

<section class="sources" id="sources" aria-labelledby="sources-h" data-reveal>
  <div class="sources__inner">
    <p class="m-eyebrow">{t.eyebrow}</p>
    <h2 class="m-h2" id="sources-h">
      {t.headingPre}<span class="ital">{t.headingItal}</span>
    </h2>
    <p class="m-lead sources__lead" set:html={t.leadHtml} />

    <div class="sources__grid">
      <!-- live-scanning US map — every state watched, uniformly -->
      <div class="usmap-wrap">
        <div class="usmap" role="group" aria-label={t.mapLabel}>
          {
            tiles.map((tile) => (
              <button
                type="button"
                class="ust"
                data-state={tile.s}
                data-name={STATE_NAMES[tile.s]}
                data-agency={STATE_AGENCY[tile.s] ?? `${STATE_NAMES[tile.s]} ${panel.agencyGeneric}`}
                aria-label={`${STATE_NAMES[tile.s]} — ${panel.watched}`}
                aria-pressed="false"
                style={`grid-row:${tile.r};grid-column:${tile.c}`}
              >
                <span class="ust__c">{tile.s}</span>
              </button>
            ))
          }
        </div>
        <div class="usmap__legend">
          <span class="leg"><span class="sw" aria-hidden="true" />{t.legWatched}</span>
          <span class="usmap__stat">
            <span class="usmap__stat-n">{t.mapStat}</span>
            <span class="usmap__stat-l">{t.mapStatLabel}</span>
          </span>
          <span class="usmap__cap">{t.mapCap}</span>
        </div>
      </div>

      <div class="sources__rightcol">
      <!-- source-monitoring feed — styled like the product's Alerts surface -->
      <div class="feed" aria-label={t.feedLabel}>
        <div class="feed__bar">
          <span class="feed__title">{t.feedTitle}</span>
          <span class="feed__live">
            <span class="feed__live-dot" aria-hidden="true" />
            {t.feedLive}
          </span>
        </div>
        <ul class="feed__rows">
          {
            t.rows.map((r) => (
              <li class={`feed-row${r.alert ? ' is-alert' : ''}`}>
                <span class="feed-row__badge">{r.code}</span>
                <div class="feed-row__main">
                  <span class="feed-row__head">
                    <span class="feed-row__org">{r.org}</span>
                    <span class={`feed-row__agency feed-row__agency--${r.agency === 'Federal' || r.agency === '联邦' ? 'fed' : 'state'}`}>
                      {r.agency}
                    </span>
                  </span>
                  <span class="feed-row__body">{r.body}</span>
                </div>
                <span class="feed-row__meta">
                  <span class={`feed-row__status feed-row__status--${r.dot}`}>
                    <span class="feed-row__status-dot" aria-hidden="true" />
                    {t.statusLabels[r.dot as keyof typeof t.statusLabels]}
                  </span>
                  <span class="feed-row__when">{r.when}</span>
                </span>
              </li>
            ))
          }
        </ul>
        <div class="feed__foot">
          <span class="feed__foot-left">
            <span class="feed__scan" aria-hidden="true" />
            {t.feedFootLeft}
          </span>
          <span class="feed__foot-right">{t.feedCap}</span>
        </div>
      </div>

      <!-- click a state on the map → its sources show here (stacked → no jump) -->
      <div class="statepanel" data-statepanel hidden aria-live="polite">
        <div class="statepanel__head">
          <span class="statepanel__name" data-sp-name></span>
          <span class="statepanel__live"><span class="statepanel__dot" aria-hidden="true" />{panel.watched}</span>
        </div>
        <ul class="statepanel__rows">
          <li class="sp-row">
            <span class="sp-row__badge">IRS</span>
            <span class="sp-row__org">{panel.sIrs}</span>
            <span class="sp-row__tag sp-row__tag--fed">{panel.fed}</span>
          </li>
          <li class="sp-row sp-row--accent">
            <span class="sp-row__badge" data-sp-abbr></span>
            <span class="sp-row__org" data-sp-agency></span>
            <span class="sp-row__tag sp-row__tag--state">{panel.state}</span>
          </li>
          <li class="sp-row">
            <span class="sp-row__badge">FE</span>
            <span class="sp-row__org">{panel.sFema}</span>
            <span class="sp-row__tag sp-row__tag--fed">{panel.fed}</span>
          </li>
        </ul>
      </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Click a state tile → show that state's sources in the side panel (the live
  // feed cross-fades out, the panel in). Stacked in one grid cell = no jump.
  // Re-binds on first load + every View-Transition navigation.
  function initSourcesMap() {
    document.querySelectorAll<HTMLElement>('.sources__grid').forEach((grid) => {
      const tiles = Array.from(grid.querySelectorAll<HTMLButtonElement>('.ust'))
      const panel = grid.querySelector<HTMLElement>('[data-statepanel]')
      const col = grid.querySelector<HTMLElement>('.sources__rightcol')
      if (!panel || !col) return
      const nameEl = panel.querySelector<HTMLElement>('[data-sp-name]')
      const abbrEl = panel.querySelector<HTMLElement>('[data-sp-abbr]')
      const agencyEl = panel.querySelector<HTMLElement>('[data-sp-agency]')
      const select = (tile: HTMLButtonElement) => {
        tiles.forEach((t) => t.setAttribute('aria-pressed', String(t === tile)))
        if (nameEl) nameEl.textContent = tile.dataset.name ?? ''
        if (abbrEl) abbrEl.textContent = tile.dataset.state ?? ''
        if (agencyEl) agencyEl.textContent = tile.dataset.agency ?? ''
        panel.hidden = false
        col.setAttribute('data-showpanel', '')
      }
      // click the active tile again to deselect → the live feed cross-fades back
      // in (otherwise there was no way back to the feed once a state was picked)
      const deselect = () => {
        tiles.forEach((t) => t.setAttribute('aria-pressed', 'false'))
        col.removeAttribute('data-showpanel')
      }
      tiles.forEach((tile) =>
        tile.addEventListener('click', () =>
          tile.getAttribute('aria-pressed') === 'true' ? deselect() : select(tile),
        ),
      )
    })
  }
  document.addEventListener('astro:page-load', initSourcesMap)
</script>

<style>
  /* normal contained band — matches the other sections; no top/bottom border */
  .sources {
    background: var(--m-section);
    padding-block: clamp(56px, 8vw, 112px);
  }
  .sources__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
  }
  .sources__lead {
    margin-top: 18px;
    max-width: var(--m-measure);
  }
  .sources__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  .sources__grid {
    margin-top: clamp(32px, 4vw, 52px);
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 4vw, 56px);
    /* both columns share the taller column's height; the map fills to match */
    align-items: stretch;
  }
  .usmap-wrap {
    grid-column: span 7;
    display: flex;
    flex-direction: column;
  }
  /* right column stacks the live feed + the per-state panel in ONE grid cell, so
     clicking a state cross-fades the panel in with no layout jump (feed keeps its
     height even when faded out). */
  .sources__rightcol {
    grid-column: span 5;
    align-self: stretch;
    display: grid;
  }
  .feed,
  .statepanel {
    grid-area: 1 / 1;
  }
  .feed {
    transition: opacity 0.25s var(--m-ease);
  }
  .sources__rightcol[data-showpanel] .feed {
    opacity: 0;
    visibility: hidden;
  }
  .statepanel {
    align-self: start;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.25s var(--m-ease);
  }
  .sources__rightcol[data-showpanel] .statepanel {
    opacity: 1;
  }
  .statepanel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--m-hairline);
    background: var(--m-section);
  }
  .statepanel__name {
    font-size: var(--m-text-md);
    font-weight: 600;
    color: var(--m-ink);
  }
  .statepanel__live {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
    flex: none;
  }
  .statepanel__dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--m-ok);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-ok) 18%, transparent);
  }
  .statepanel__rows {
    list-style: none;
    margin: 0;
    padding: 8px;
    display: grid;
    gap: 4px;
  }
  .sp-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 12px;
    border-radius: 8px;
  }
  .sp-row--accent {
    background: var(--m-accent-tint);
  }
  .sp-row__badge {
    flex: none;
    display: inline-grid;
    place-items: center;
    min-width: 34px;
    height: 26px;
    padding-inline: 6px;
    border-radius: var(--m-radius-md);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .sp-row__org {
    flex: 1;
    font-size: var(--m-text-sm);
    color: var(--m-ink);
  }
  .sp-row__tag {
    flex: none;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 999px;
  }
  .sp-row__tag--fed {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .sp-row__tag--state {
    color: var(--m-muted);
    background: var(--m-section);
  }
  @media (prefers-reduced-motion: reduce) {
    .feed,
    .statepanel,
    .ust {
      transition: none;
    }
  }

  /* ---- US tilegram — a calm coverage grid: light neutral tiles, every one
     carrying the same quiet "live" cue. No priority tier, no blue block. ---- */
  .usmap {
    flex: 1 1 auto; /* fill the column height so the map matches the feed (#23) */
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    grid-template-rows: repeat(8, minmax(34px, 1fr));
    gap: 6px;
    min-width: 520px;
  }
  .ust {
    appearance: none;
    padding: 0;
    font-family: inherit;
    cursor: pointer;
    position: relative;
    display: grid;
    place-items: center;
    border-radius: var(--m-radius-md);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    line-height: 1;
    color: var(--m-ink-2);
    /* neutral surface on every state — identical, no priority tier */
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
    transition:
      background 0.16s ease,
      border-color 0.16s ease,
      color 0.16s ease;
  }
  .ust:hover {
    background: var(--m-surface);
    border-color: var(--m-accent);
    color: var(--m-ink);
  }
  /* active — a calm cyan fill (no shadow, no size change) */
  .ust[aria-pressed='true'] {
    background: var(--m-cyan);
    border-color: var(--m-cyan);
    color: var(--m-ink);
  }
  .ust:focus-visible {
    outline: 2px solid var(--m-accent);
    outline-offset: 2px;
    z-index: 5;
  }
  .ust__c {
    position: relative;
    z-index: 1;
  }
  /* the map is a clean, calm coverage grid — every tile equally watched. The one
     "live" cue lives in the legend (a single cyan dot), not 51 dots on the map. */
  .usmap__legend {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 22px;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }
  .leg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  /* legend swatch mirrors a map tile: neutral chip + the quiet cyan live-dot */
  .sw {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 4px;
    flex: none;
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
  }
  .sw::after {
    content: '';
    position: absolute;
    top: 2px;
    right: 2px;
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: var(--m-cyan);
  }
  /* "51 jurisdictions watched live" — reinforces uniform, full-country coverage */
  .usmap__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    padding-left: 22px;
    border-left: 1px solid var(--m-hairline);
  }
  .usmap__stat-n {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xl);
    font-weight: 600;
    line-height: 1;
    color: var(--m-ink);
  }
  .usmap__stat-l {
    color: var(--m-muted);
  }
  .usmap__cap {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-faint);
  }

  /* ---- feed — a real product surface (cues from the Alerts monitoring view) ---- */
  .feed {
    display: flex;
    flex-direction: column;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .feed__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    background: var(--m-section);
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .feed__title {
    font-size: var(--m-text-sm);
    font-weight: 600;
    color: var(--m-ink);
  }
  /* live pill — chromatic accent lives in the container, not the text */
  /* a11y: 10px uppercase label uses the darker -ink token for AA on the tint;
     the pulsing dot below keeps the brighter --m-ok hue. */
  .feed__live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-ok-ink);
