---
/** Sources — coverage proof. One clear message: we watch the official sources
 *  live, and cover all 50 + DC. A true 2-tone US map (live-monitored vs covered
 *  — no fictional per-state change counts) + the around-the-clock feed. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const agencies = ['IRS', 'CA FTB', 'NY DTF', 'TX Comptroller', 'FL DOR', 'WA DOR', 'MA DOR']
// states with the deepest live monitoring (the rest of the 50 + DC are covered)
const monitored = new Set(['CA', 'NY', 'TX', 'FL', 'WA', 'MA'])

const t = zh
  ? {
      eyebrow: '覆盖范围',
      headingPre: '紧盯官方来源，',
      headingItal: '全天候。',
      leadHtml:
        '我们实时监控 IRS、主要州税务机关以及 FEMA 灾害救济——并且 <b>50 个州 + DC</b> 中的每一个都已在你的规则库中覆盖。',
      chipsLabel: '实时监控的来源',
      chipMore: '+ FEMA 灾害声明，覆盖全国',
      mapLabel: '美国地图：六个州深度实时监控，全部 50 个州加 DC 已覆盖',
      legMon: '实时监控',
      legCov: '已覆盖 · 规则库',
      mapCap: 'FED + 50 个州 + DC',
      feedLabel: '来源监控动态——示例预览',
      feedTitle: '监控动态',
      feedCap: '实时预览 · 非你的数据',
      rows: [
        { org: 'IRS', body: '已扫描，无变化', when: '2 分钟前', dot: 'scan', alert: false },
        { org: 'TX Comptroller', body: '新公告', when: '14 分钟前', dot: 'new', alert: true },
        { org: 'CA FTB', body: '已核验，无变化', when: '31 分钟前', dot: 'ok', alert: false },
        { org: 'NY DTF', body: '已扫描，无变化', when: '52 分钟前', dot: 'scan', alert: false },
        { org: 'FEMA', body: '灾害声明', when: '1 小时前', dot: 'new', alert: true },
      ],
    }
  : {
      eyebrow: 'Coverage',
      headingPre: 'Eyes on the official sources, ',
      headingItal: 'around the clock.',
      leadHtml:
        'We monitor the IRS, the major state tax agencies, and FEMA disaster relief in real time — and every one of the <b>50 states + DC</b> is covered in your rule library.',
      chipsLabel: 'Sources monitored live',
      chipMore: '+ FEMA disaster declarations, nationwide',
      mapLabel: 'US map: six states deepest live-monitored, all 50 plus DC covered',
      legMon: 'Live-monitored',
      legCov: 'Covered · rule library',
      mapCap: 'FED + 50 states + DC',
      feedLabel: 'Source-monitoring feed — sample preview',
      feedTitle: 'Monitoring feed',
      feedCap: 'live preview · not your data',
      rows: [
        { org: 'IRS', body: 'scanned, no change', when: '2m ago', dot: 'scan', alert: false },
        { org: 'TX Comptroller', body: 'new notice', when: '14m ago', dot: 'new', alert: true },
        { org: 'CA FTB', body: 'verified, no change', when: '31m ago', dot: 'ok', alert: false },
        { org: 'NY DTF', body: 'scanned, no change', when: '52m ago', dot: 'scan', alert: false },
        { org: 'FEMA', body: 'disaster declaration', when: '1h ago', dot: 'new', alert: true },
      ],
    }
// US tilegram (state, grid-row, grid-column)
const tiles = [
  { s: 'AK', r: 1, c: 1 }, { s: 'ME', r: 1, c: 11 },
  { s: 'VT', r: 2, c: 10 }, { s: 'NH', r: 2, c: 11 },
  { s: 'WA', r: 3, c: 2 }, { s: 'ID', r: 3, c: 3 }, { s: 'MT', r: 3, c: 4 },
  { s: 'ND', r: 3, c: 5 }, { s: 'MN', r: 3, c: 6 }, { s: 'WI', r: 3, c: 7 },
  { s: 'MI', r: 3, c: 8 }, { s: 'NY', r: 3, c: 10 }, { s: 'MA', r: 3, c: 11 },
  { s: 'OR', r: 4, c: 2 }, { s: 'NV', r: 4, c: 3 }, { s: 'WY', r: 4, c: 4 },
  { s: 'SD', r: 4, c: 5 }, { s: 'IA', r: 4, c: 6 }, { s: 'IL', r: 4, c: 7 },
  { s: 'IN', r: 4, c: 8 }, { s: 'OH', r: 4, c: 9 }, { s: 'PA', r: 4, c: 10 },
  { s: 'NJ', r: 4, c: 11 }, { s: 'CT', r: 4, c: 12 }, { s: 'RI', r: 4, c: 13 },
  { s: 'CA', r: 5, c: 2 }, { s: 'UT', r: 5, c: 3 }, { s: 'CO', r: 5, c: 4 },
  { s: 'NE', r: 5, c: 5 }, { s: 'MO', r: 5, c: 6 }, { s: 'KY', r: 5, c: 7 },
  { s: 'WV', r: 5, c: 8 }, { s: 'VA', r: 5, c: 9 }, { s: 'MD', r: 5, c: 10 },
  { s: 'DE', r: 5, c: 11 }, { s: 'AZ', r: 6, c: 3 }, { s: 'NM', r: 6, c: 4 },
  { s: 'KS', r: 6, c: 5 }, { s: 'AR', r: 6, c: 6 }, { s: 'TN', r: 6, c: 7 },
  { s: 'NC', r: 6, c: 8 }, { s: 'SC', r: 6, c: 9 }, { s: 'DC', r: 6, c: 10 },
  { s: 'HI', r: 7, c: 1 }, { s: 'OK', r: 7, c: 5 }, { s: 'LA', r: 7, c: 6 },
  { s: 'MS', r: 7, c: 7 }, { s: 'AL', r: 7, c: 8 }, { s: 'GA', r: 7, c: 9 },
  { s: 'TX', r: 8, c: 5 }, { s: 'FL', r: 8, c: 9 },
]
---

<section class="m-section sources" id="sources" aria-labelledby="sources-h">
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2" id="sources-h">
    {t.headingPre}<span class="ital">{t.headingItal}</span>
  </h2>
  <p class="m-lead sources__lead" set:html={t.leadHtml} />

  <ul class="sources__chips" aria-label={t.chipsLabel}>
    {agencies.map((a) => <li class="chip">{a}</li>)}
    <li class="chip chip--more">{t.chipMore}</li>
  </ul>

  <div class="sources__grid">
    <!-- US coverage map (true 2-tone: live-monitored vs covered) -->
    <div class="usmap-wrap">
      <div class="usmap" role="img" aria-label={t.mapLabel}>
        {
          tiles.map((t) => (
            <div
              class:list={['ust', monitored.has(t.s) ? 'ust--mon' : 'ust--cov']}
              style={`grid-row:${t.r};grid-column:${t.c}`}
            >
              <span class="ust__c">{t.s}</span>
            </div>
          ))
        }
      </div>
      <div class="usmap__legend">
        <span class="leg"><span class="sw sw--mon" />{t.legMon}</span>
        <span class="leg"><span class="sw sw--cov" />{t.legCov}</span>
        <span class="usmap__cap">{t.mapCap}</span>
      </div>
    </div>

    <!-- around-the-clock monitoring feed -->
    <div class="feed" aria-label={t.feedLabel}>
      <div class="feed__bar">
        <span class="feed__title"><span class="live" aria-hidden="true" />{t.feedTitle}</span>
        <span class="feed__cap">{t.feedCap}</span>
      </div>
      {
        t.rows.map((r) => (
          <div class="feed-row">
            <span class={`dot ${r.dot}`} />
            <span><b>{r.org}</b> · {r.body}</span>
            <span class={`when${r.alert ? ' alert' : ''}`}>{r.when}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sources {
    background: var(--m-section);
    border-block: 1px solid var(--m-hairline);
  }
  .sources__lead {
    margin-top: 16px;
    max-width: 64ch;
  }
  .sources__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  .sources__chips {
    margin-top: clamp(24px, 3vw, 32px);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
  }
  .chip {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    padding: 6px 14px;
  }
  .chip--more {
    font-weight: 500;
    color: var(--m-muted);
    border-style: dashed;
    background: transparent;
  }

  .sources__grid {
    margin-top: clamp(28px, 4vw, 44px);
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 4vw, 44px);
    align-items: start;
  }
  .usmap-wrap {
    grid-column: span 7;
  }
  .feed {
    grid-column: span 5;
  }

  /* ---- US tilegram (clean 2-tone) ---- */
  .usmap {
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    grid-template-rows: repeat(8, minmax(30px, 1fr));
    gap: 5px;
    min-width: 440px;
  }
  .ust {
    display: grid;
    place-items: center;
    border-radius: 7px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
  }
  .ust--mon {
    color: #fff;
    background: var(--m-accent);
  }
  .ust--cov {
    color: var(--m-faint);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .usmap__legend {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    font-size: 12px;
    color: var(--m-muted);
  }
  .leg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .sw {
    width: 12px;
    height: 12px;
    border-radius: 4px;
    flex: none;
  }
  .sw--mon {
    background: var(--m-accent);
  }
  .sw--cov {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .usmap__cap {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }

  /* ---- feed ---- */
  .live {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-ok);
    flex: none;
  }
  .feed {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .feed__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .feed__title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--m-ink-2);
  }
  .feed__cap {
    font-family: var(--m-font-mono);
    font-size: 10px;
    color: var(--m-faint);
  }
  .feed-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--m-ink-2);
  }
  .feed-row + .feed-row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .feed-row b {
    color: var(--m-ink);
    font-weight: 600;
  }
  .feed-row .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    flex: none;
  }
  .dot.scan {
    background: var(--m-faint);
  }
  .dot.ok {
    background: var(--m-ok);
  }
  .dot.new {
    background: var(--m-urgent);
  }
  .feed-row .when {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }
  .feed-row .when.alert {
    color: var(--m-urgent);
  }

  @media (max-width: 1000px) {
    .sources__grid {
      grid-template-columns: 1fr;
    }
    .usmap-wrap,
    .feed {
      grid-column: auto;
    }
    .usmap-wrap {
      overflow-x: auto;
    }
  }
</style>
