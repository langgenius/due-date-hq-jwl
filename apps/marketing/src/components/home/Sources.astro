---
/** Sources — coverage proof. One clear, honest message: the whole country is
 *  watched around the clock — IRS + FEMA disaster relief nationwide + every
 *  state tax agency, all 50 states + DC, uniformly live. A full-bleed band:
 *  a live-scanning US map (every tile equally watched) + a source-monitoring
 *  feed styled like the product's Alerts surface (honest beta sample). */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const agencies = ['IRS', 'CA FTB', 'NY DTF', 'TX Comptroller', 'FL DOR', 'WA DOR', 'MA DOR']

const t = zh
  ? {
      eyebrow: '覆盖范围',
      headingPre: '紧盯官方来源，',
      headingItal: '全天候。',
      leadHtml:
        '我们全天候监控 IRS、FEMA 全国灾害救济，以及每一个州的税务机关——<b>全部 50 个州 + DC</b>，没有「重点」与「普通」之分，一视同仁地实时盯紧。',
      chipsLabel: '实时监控的来源',
      chipMore: '+ FEMA 灾害声明，覆盖全国',
      mapLabel: '美国地图：每一个州都在 24/7 实时监控之中，全部 50 个州加 DC，一视同仁',
      legWatched: '全部 24/7 实时监控',
      mapStat: '51',
      mapStatLabel: '个辖区实时监控',
      mapCap: 'FED + 50 州 + DC · 24/7',
      feedLabel: '来源监控动态——示例预览',
      feedTitle: '监控动态',
      feedLive: '实时',
      feedCap: '示例预览 · 非你的数据',
      feedFootLeft: '每分钟扫描一次',
      feedFootRight: '示例数据',
      statusLabels: { scan: '已扫描', new: '新公告', ok: '已核验' },
      rows: [
        { code: 'IRS', org: 'IRS', agency: '联邦', body: '已扫描，无变化', when: '2 分钟前', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', agency: '州', body: '检测到新公告', when: '14 分钟前', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', agency: '州', body: '已核验，无变化', when: '31 分钟前', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', agency: '州', body: '已扫描，无变化', when: '52 分钟前', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', agency: '联邦', body: '新灾害声明', when: '1 小时前', dot: 'new', alert: true },
      ],
    }
  : {
      eyebrow: 'Coverage',
      headingPre: 'Eyes on the official sources, ',
      headingItal: 'around the clock.',
      leadHtml:
        'We watch the IRS, FEMA disaster relief nationwide, and every state tax agency — <b>all 50 states + DC</b>, no "priority" states and no afterthoughts. Every jurisdiction is watched live, the same way.',
      chipsLabel: 'Sources monitored live',
      chipMore: '+ FEMA disaster declarations, nationwide',
      mapLabel: 'US map: every state watched live around the clock, all 50 plus DC, uniformly',
      legWatched: 'All watched live, 24/7',
      mapStat: '51',
      mapStatLabel: 'jurisdictions watched live',
      mapCap: 'FED + 50 states + DC · 24/7',
      feedLabel: 'Source-monitoring feed — sample preview',
      feedTitle: 'Monitoring feed',
      feedLive: 'Live',
      feedCap: 'sample preview · not your data',
      feedFootLeft: 'Scanning every minute',
      feedFootRight: 'Sample data',
      statusLabels: { scan: 'Scanned', new: 'New', ok: 'Verified' },
      rows: [
        { code: 'IRS', org: 'IRS', agency: 'Federal', body: 'scanned, no change', when: '2m ago', dot: 'scan', alert: false },
        { code: 'TX', org: 'TX Comptroller', agency: 'State', body: 'new notice detected', when: '14m ago', dot: 'new', alert: true },
        { code: 'CA', org: 'CA FTB', agency: 'State', body: 'verified, no change', when: '31m ago', dot: 'ok', alert: false },
        { code: 'NY', org: 'NY DTF', agency: 'State', body: 'scanned, no change', when: '52m ago', dot: 'scan', alert: false },
        { code: 'FE', org: 'FEMA', agency: 'Federal', body: 'new disaster declaration', when: '1h ago', dot: 'new', alert: true },
      ],
    }
// US tilegram (state, grid-row, grid-column) — every tile is watched
const tiles = [
  { s: 'AK', r: 1, c: 1 }, { s: 'ME', r: 1, c: 11 },
  { s: 'VT', r: 2, c: 10 }, { s: 'NH', r: 2, c: 11 },
  { s: 'WA', r: 3, c: 2 }, { s: 'ID', r: 3, c: 3 }, { s: 'MT', r: 3, c: 4 },
  { s: 'ND', r: 3, c: 5 }, { s: 'MN', r: 3, c: 6 }, { s: 'WI', r: 3, c: 7 },
  { s: 'MI', r: 3, c: 8 }, { s: 'NY', r: 3, c: 10 }, { s: 'MA', r: 3, c: 11 },
  { s: 'OR', r: 4, c: 2 }, { s: 'NV', r: 4, c: 3 }, { s: 'WY', r: 4, c: 4 },
  { s: 'SD', r: 4, c: 5 }, { s: 'IA', r: 4, c: 6 }, { s: 'IL', r: 4, c: 7 },
  { s: 'IN', r: 4, c: 8 }, { s: 'OH', r: 4, c: 9 }, { s: 'PA', r: 4, c: 10 },
  { s: 'NJ', r: 4, c: 11 }, { s: 'CT', r: 4, c: 12 }, { s: 'RI', r: 4, c: 13 },
  { s: 'CA', r: 5, c: 2 }, { s: 'UT', r: 5, c: 3 }, { s: 'CO', r: 5, c: 4 },
  { s: 'NE', r: 5, c: 5 }, { s: 'MO', r: 5, c: 6 }, { s: 'KY', r: 5, c: 7 },
  { s: 'WV', r: 5, c: 8 }, { s: 'VA', r: 5, c: 9 }, { s: 'MD', r: 5, c: 10 },
  { s: 'DE', r: 5, c: 11 }, { s: 'AZ', r: 6, c: 3 }, { s: 'NM', r: 6, c: 4 },
  { s: 'KS', r: 6, c: 5 }, { s: 'AR', r: 6, c: 6 }, { s: 'TN', r: 6, c: 7 },
  { s: 'NC', r: 6, c: 8 }, { s: 'SC', r: 6, c: 9 }, { s: 'DC', r: 6, c: 10 },
  { s: 'HI', r: 7, c: 1 }, { s: 'OK', r: 7, c: 5 }, { s: 'LA', r: 7, c: 6 },
  { s: 'MS', r: 7, c: 7 }, { s: 'AL', r: 7, c: 8 }, { s: 'GA', r: 7, c: 9 },
  { s: 'TX', r: 8, c: 5 }, { s: 'FL', r: 8, c: 9 },
]
---

<section class="sources" id="sources" aria-labelledby="sources-h" data-reveal>
  <div class="sources__inner">
    <p class="m-eyebrow">{t.eyebrow}</p>
    <h2 class="m-h2" id="sources-h">
      {t.headingPre}<span class="ital">{t.headingItal}</span>
    </h2>
    <p class="m-lead sources__lead" set:html={t.leadHtml} />

    <ul class="sources__chips" aria-label={t.chipsLabel}>
      {agencies.map((a) => <li class="chip">{a}</li>)}
      <li class="chip chip--more">{t.chipMore}</li>
    </ul>

    <div class="sources__grid">
      <!-- live-scanning US map — every state watched, uniformly -->
      <div class="usmap-wrap">
        <div class="usmap" role="img" aria-label={t.mapLabel}>
          {
            tiles.map((tile, i) => (
              <div class="ust" style={`grid-row:${tile.r};grid-column:${tile.c};--i:${i}`}>
                <span class="ust__c">{tile.s}</span>
              </div>
            ))
          }
        </div>
        <div class="usmap__legend">
          <span class="leg"><span class="sw" aria-hidden="true" />{t.legWatched}</span>
          <span class="usmap__stat">
            <span class="usmap__stat-n">{t.mapStat}</span>
            <span class="usmap__stat-l">{t.mapStatLabel}</span>
          </span>
          <span class="usmap__cap">{t.mapCap}</span>
        </div>
      </div>

      <!-- source-monitoring feed — styled like the product's Alerts surface -->
      <div class="feed" aria-label={t.feedLabel}>
        <div class="feed__bar">
          <span class="feed__title">{t.feedTitle}</span>
          <span class="feed__live">
            <span class="feed__live-dot" aria-hidden="true" />
            {t.feedLive}
          </span>
        </div>
        <ul class="feed__rows">
          {
            t.rows.map((r) => (
              <li class={`feed-row${r.alert ? ' is-alert' : ''}`}>
                <span class="feed-row__badge">{r.code}</span>
                <div class="feed-row__main">
                  <span class="feed-row__head">
                    <span class="feed-row__org">{r.org}</span>
                    <span class={`feed-row__agency feed-row__agency--${r.agency === 'Federal' || r.agency === '联邦' ? 'fed' : 'state'}`}>
                      {r.agency}
                    </span>
                  </span>
                  <span class="feed-row__body">{r.body}</span>
                </div>
                <span class="feed-row__meta">
                  <span class={`feed-row__status feed-row__status--${r.dot}`}>
                    <span class="feed-row__status-dot" aria-hidden="true" />
                    {t.statusLabels[r.dot]}
                  </span>
                  <span class="feed-row__when">{r.when}</span>
                </span>
              </li>
            ))
          }
        </ul>
        <div class="feed__foot">
          <span class="feed__foot-left">
            <span class="feed__scan" aria-hidden="true" />
            {t.feedFootLeft}
          </span>
          <span class="feed__foot-right">{t.feedCap}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* full-bleed band — genuinely expansive, near edge-to-edge, no bottom border */
  .sources {
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline);
    padding-block: clamp(56px, 8vw, 112px);
  }
  .sources__inner {
    /* nearly full-width: leave only a slim breathing margin so the band reads grand */
    width: min(100% - clamp(28px, 5vw, 96px), 1880px);
    margin-inline: auto;
  }
  .sources__lead {
    margin-top: 18px;
    max-width: 72ch;
  }
  .sources__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  .sources__chips {
    margin-top: clamp(24px, 3vw, 32px);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
  }
  .chip {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
    padding: 6px 14px;
  }
  .chip--more {
    font-weight: 500;
    color: var(--m-muted);
    border-style: dashed;
    background: transparent;
  }

  .sources__grid {
    margin-top: clamp(32px, 4vw, 52px);
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }
  .usmap-wrap {
    grid-column: span 7;
  }
  .feed {
    grid-column: span 5;
    align-self: stretch;
  }

  /* ---- US tilegram — every tile identical: all 50 + DC, uniformly live ---- */
  .usmap {
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    grid-template-rows: repeat(8, minmax(34px, 1fr));
    gap: 6px;
    min-width: 520px;
  }
  .ust {
    position: relative;
    display: grid;
    place-items: center;
    border-radius: 7px;
    overflow: hidden;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    color: #fff;
    /* identical fill on every state — no priority tier */
    background: var(--m-accent);
  }
  .ust__c {
    position: relative;
    z-index: 1;
  }
  /* live scan wave — a cyan flash rippling across the map. Animating an overlay's
     OPACITY (GPU-composited) instead of background + box-shadow on all 51 tiles
     (paint, every frame) keeps the effect cheap. */
  .ust::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--m-cyan);
    opacity: 0;
    animation: ust-scan 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.11s);
    pointer-events: none;
  }
  @keyframes ust-scan {
    0%,
    88%,
    100% {
      opacity: 0;
    }
    94% {
      opacity: 0.42;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ust::after {
      animation: none;
    }
  }
  .usmap__legend {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 22px;
    font-size: 12px;
    color: var(--m-muted);
  }
  .leg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .sw {
    width: 12px;
    height: 12px;
    border-radius: 4px;
    flex: none;
    background: var(--m-accent);
  }
  /* "51 jurisdictions watched live" — reinforces uniform, full-country coverage */
  .usmap__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    padding-left: 22px;
    border-left: 1px solid var(--m-hairline);
  }
  .usmap__stat-n {
    font-family: var(--m-font-mono);
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
    color: var(--m-ink);
  }
  .usmap__stat-l {
    color: var(--m-muted);
  }
  .usmap__cap {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }

  /* ---- feed — a real product surface (cues from the Alerts monitoring view) ---- */
  .feed {
    display: flex;
    flex-direction: column;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
  }
  .feed__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    background: var(--m-section);
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .feed__title {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink);
  }
  /* live pill — chromatic accent lives in the container, not the text */
  /* a11y: 10px uppercase label uses the darker -ink token for AA on the tint;
     the pulsing dot below keeps the brighter --m-ok hue. */
  .feed__live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-ok-ink);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
    border-radius: 999px;
    padding: 3px 9px 3px 8px;
  }
  .feed__live-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    flex: none;
    background: var(--m-ok);
    animation: feed-pulse 2.4s ease-in-out infinite;
  }
  @keyframes feed-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--m-ok) 55%, transparent);
    }
    55% {
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-ok) 0%, transparent);
    }
  }

  .feed__rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .feed-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 16px;
    position: relative;
  }
  .feed-row + .feed-row {
    border-top: 1px solid var(--m-hairline-2);
  }
  /* alert rows get a faint wash — calm, no red-text-on-row */
  .feed-row.is-alert {
    background: color-mix(in srgb, var(--m-urgent) 5%, transparent);
  }
  .feed-row__badge {
    flex: none;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-family: var(--m-font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border: 1px solid color-mix(in srgb, var(--m-accent) 14%, transparent);
  }
  .feed-row__main {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .feed-row__head {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .feed-row__org {
    font-size: 13px;
    font-weight: 600;
    color: var(--m-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  /* agency badge — Federal vs State, sourced provenance */
  .feed-row__agency {
    flex: none;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-muted);
    background: var(--m-section);
    border: 1px solid var(--m-hairline-2);
    border-radius: 4px;
    padding: 1px 6px;
  }
  .feed-row__agency--fed {
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border-color: color-mix(in srgb, var(--m-accent) 16%, transparent);
  }
  .feed-row__body {
    font-size: 12px;
    color: var(--m-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .feed-row__meta {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .feed-row__status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 2px 8px 2px 6px;
    border-radius: 999px;
  }
  .feed-row__status-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    flex: none;
    /* dot keeps the brighter status hue; the LABEL uses the darker -ink token */
    background: var(--dot, currentColor);
  }
  .feed-row__status--scan {
    color: var(--m-muted);
    background: var(--m-section);
  }
  /* a11y: ~10px label text needs the darker -ink token for AA on its own tint;
     the dot stays on the brighter token via --dot (red is still risk only). */
  .feed-row__status--new {
    color: var(--m-urgent-ink);
    background: color-mix(in srgb, var(--m-urgent) 13%, transparent);
    --dot: var(--m-urgent);
  }
  .feed-row__status--ok {
    color: var(--m-ok-ink);
    background: color-mix(in srgb, var(--m-ok) 13%, transparent);
    --dot: var(--m-ok);
  }
  .feed-row__when {
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }

  /* footer strip — cadence + honest "sample data" label */
  .feed__foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline-2);
    font-size: 11px;
    color: var(--m-muted);
  }
  .feed__foot-left {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .feed__scan {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    flex: none;
    background: var(--m-accent);
    box-shadow: 0 0 0 3px var(--m-accent-tint);
  }
  .feed__foot-right {
    font-family: var(--m-font-mono);
    font-size: 10px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--m-faint);
  }

  @media (prefers-reduced-motion: reduce) {
    .feed__live-dot {
      animation: none;
    }
  }

  @media (max-width: 1000px) {
    .sources__grid {
      grid-template-columns: 1fr;
      align-items: stretch;
    }
    .usmap-wrap,
    .feed {
      grid-column: auto;
    }
    .usmap-wrap {
      overflow-x: auto;
    }
  }
</style>
