---
/** Notice — "it reads the official notice". A toggle across change types; each
 *  shows the source doc → extracted fields (source quote · the change · who's
 *  affected), mirroring the product's alert structure. Date/requirement changes
 *  only — no dollar amounts or penalty figures (we don't have that data). */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'

const t = zh
  ? {
      eyebrow: '读懂文件',
      headingPre: '它读取官方公告——并提取出变化内容，以及',
      headingItal: '影响到谁。',
      leadHtml:
        '没有出处，就不呈现——下方每一个字段都附有它的<b>来源原文</b>和一个<b>已核验日期</b>，否则宁可保留不展示，也不去猜。',
      tablistLabel: '示例变化类型',
      switchCue: '换一个示例看看',
      sourceQuote: '来源原文',
      theChange: '变化内容',
      whosAffected: '影响到谁',
      eligible: '符合',
      review: '待复核',
      posted: '发布于',
      examples: [
        {
          tab: '灾害延期',
          doc: {
            org: 'Internal Revenue Service',
            sub: 'IR-2026-31 · 灾害救济',
            posted: 'Mar 2, 2026',
            url: 'irs.gov',
            body: '受影响的纳税人现在可在 <mark>November 3, 2026</mark> 之前提交原定于 April 15 到期的申报并完成缴款。',
          },
          quote: '"…在 November 3, 2026 之前提交申报并完成缴款…"',
          verify: { url: 'irs.gov', date: '已核验 Mar 2' },
          change: { from: 'Apr 15', to: 'Nov 3, 2026', delta: '+202 天' },
          count: '8 个客户',
          affected: [
            { in: 'RO', name: 'Red Oak Partners', meta: '1120-S · TX', tone: 'ok' },
            { in: 'BL', name: 'Brightway Logistics', meta: '1120 · TX', tone: 'ok' },
            { in: 'HC', name: 'Hill Country Partners', meta: '1065 · TX', tone: 'warn' },
          ],
          more: '+ 灾区内另有 5 个',
        },
        {
          tab: '州级延期',
          doc: {
            org: 'California FTB',
            sub: 'Tax News · 预估税',
            posted: 'Sep 4, 2026',
            url: 'ftb.ca.gov',
            body: '对于受影响的县，第三季度预估税截止日在山火声明发布后 <mark>延至 September 29, 2026</mark>。',
          },
          quote: '"…在声明发布后延至 September 29, 2026…"',
          verify: { url: 'ftb.ca.gov', date: '已核验 Sep 4' },
          change: { from: 'Sep 15', to: 'Sep 29, 2026', delta: '+14 天' },
          count: '12 个客户',
          affected: [
            { in: 'CV', name: 'Coastal Ventures', meta: '540-ES · CA', tone: 'ok' },
            { in: 'PM', name: 'Pacific Mills', meta: '100-ES · CA', tone: 'ok' },
            { in: 'NB', name: 'Napa Brands', meta: '540-ES · CA', tone: 'warn' },
          ],
          more: '+ 受影响各县另有 9 个',
        },
        {
          tab: '新增要求',
          doc: {
            org: 'Texas Comptroller',
            sub: 'Tax Policy News · 特许经营税',
            posted: 'Jan 30, 2026',
            url: 'comptroller.texas.gov',
            body: '达到经济关联标准的远程卖家须 <mark>自 January 1, 2026 起开始提交特许经营税报告</mark>。',
          },
          quote: '"…须自 January 1, 2026 起开始提交特许经营税报告…"',
          verify: { url: 'comptroller.texas.gov', date: '已核验 Jan 30' },
          change: { effective: '自 Jan 1, 2026 起生效', badge: '新增义务' },
          count: '5 个客户',
          affected: [
            { in: 'LS', name: 'Lone Star LLC', meta: '05-158 · TX', tone: 'ok' },
            { in: 'BC', name: 'Brazos Co', meta: '05-158 · TX', tone: 'ok' },
            { in: 'RT', name: 'Remote Tech Inc', meta: '05-158 · TX', tone: 'warn' },
          ],
          more: '+ 新纳入范围的另有 2 个',
        },
      ],
    }
  : {
      eyebrow: 'The document, read',
      headingPre: 'It reads the official notice — and pulls out what changed and ',
      headingItal: 'who it hits.',
      leadHtml:
        "No provenance, no render — every field below carries its <b>source quote</b> and a <b>verified date</b>, or it's held back rather than guessed.",
      tablistLabel: 'Example change types',
      switchCue: 'See another example',
      sourceQuote: 'Source quote',
      theChange: 'The change',
      whosAffected: "Who's affected",
      eligible: 'ELIGIBLE',
      review: 'REVIEW',
      posted: 'Posted',
      examples: [
        {
          tab: 'Disaster postponement',
          doc: {
            org: 'Internal Revenue Service',
            sub: 'IR-2026-31 · Disaster relief',
            posted: 'Mar 2, 2026',
            url: 'irs.gov',
            body: 'Affected taxpayers now have until <mark>November 3, 2026</mark> to file the returns and make the payments that were originally due April 15.',
          },
          quote: '"…until November 3, 2026 to file the returns and make the payments…"',
          verify: { url: 'irs.gov', date: 'Verified Mar 2' },
          change: { from: 'Apr 15', to: 'Nov 3, 2026', delta: '+202 days' },
          count: '8 clients',
          affected: [
            { in: 'RO', name: 'Red Oak Partners', meta: '1120-S · TX', tone: 'ok' },
            { in: 'BL', name: 'Brightway Logistics', meta: '1120 · TX', tone: 'ok' },
            { in: 'HC', name: 'Hill Country Partners', meta: '1065 · TX', tone: 'warn' },
          ],
          more: '+ 5 more in the disaster area',
        },
        {
          tab: 'State extension',
          doc: {
            org: 'California FTB',
            sub: 'Tax News · Estimated tax',
            posted: 'Sep 4, 2026',
            url: 'ftb.ca.gov',
            body: 'For affected counties, the third-quarter estimated-tax date is <mark>extended to September 29, 2026</mark> following the wildfire declaration.',
          },
          quote: '"…extended to September 29, 2026 following the declaration…"',
          verify: { url: 'ftb.ca.gov', date: 'Verified Sep 4' },
          change: { from: 'Sep 15', to: 'Sep 29, 2026', delta: '+14 days' },
          count: '12 clients',
          affected: [
            { in: 'CV', name: 'Coastal Ventures', meta: '540-ES · CA', tone: 'ok' },
            { in: 'PM', name: 'Pacific Mills', meta: '100-ES · CA', tone: 'ok' },
            { in: 'NB', name: 'Napa Brands', meta: '540-ES · CA', tone: 'warn' },
          ],
          more: '+ 9 more in the affected counties',
        },
        {
          tab: 'New requirement',
          doc: {
            org: 'Texas Comptroller',
            sub: 'Tax Policy News · Franchise tax',
            posted: 'Jan 30, 2026',
            url: 'comptroller.texas.gov',
            body: 'Remote sellers meeting the economic-nexus standard must <mark>begin filing a franchise tax report on January 1, 2026</mark>.',
          },
          quote: '"…must begin filing a franchise tax report on January 1, 2026…"',
          verify: { url: 'comptroller.texas.gov', date: 'Verified Jan 30' },
          change: { effective: 'Effective Jan 1, 2026', badge: 'new obligation' },
          count: '5 clients',
          affected: [
            { in: 'LS', name: 'Lone Star LLC', meta: '05-158 · TX', tone: 'ok' },
            { in: 'BC', name: 'Brazos Co', meta: '05-158 · TX', tone: 'ok' },
            { in: 'RT', name: 'Remote Tech Inc', meta: '05-158 · TX', tone: 'warn' },
          ],
          more: '+ 2 more newly in scope',
        },
      ],
    }
const examples = t.examples
---

<section class="m-section" id="notice" aria-labelledby="notice-h" data-reveal>
  <p class="m-eyebrow">{t.eyebrow}</p>
  <h2 class="m-h2" id="notice-h">
    {t.headingPre}<span class="ital">{t.headingItal}</span>
  </h2>
  <p class="m-lead notice__lead" set:html={t.leadHtml} />

  <div class="nswitch">
    <div class="ntabs" role="tablist" aria-label={t.tablistLabel}>
      {
        examples.map((e, i) => (
          <button
            class:list={['ntab', i === 0 && 'is-on']}
            id={`ntab-${i}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`npanel-${i}`}
            tabindex={i === 0 ? 0 : -1}
            data-ntab={i}
            type="button"
          >
            <span class="ntab__dot" aria-hidden="true" />
            <span class="ntab__txt">{e.tab}</span>
          </button>
        ))
      }
    </div>
  </div>

  <div class="npanels">
    {
      examples.map((e, i) => (
        <div
          class:list={['extract', i === 0 && 'is-on']}
          id={`npanel-${i}`}
          data-npanel={i}
          role="tabpanel"
          aria-labelledby={`ntab-${i}`}
          tabindex="0"
        >
          <article class="clip" aria-hidden="true">
            <header class="clip__head">
              <span class="clip__seal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </span>
              <div class="clip__org">
                <div class="clip__name">{e.doc.org}</div>
                <div class="clip__sub">{e.doc.sub}</div>
                <div class="clip__posted">
                  {t.posted} <b>{e.doc.posted}</b>
                  <span class="clip__sep" aria-hidden="true">·</span>
                  <span class="clip__url">
                    {e.doc.url}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7M9 7h8v8" />
                    </svg>
                  </span>
                </div>
              </div>
            </header>
            <div class="clip__body">
              <p set:html={e.doc.body} />
            </div>
          </article>

          <div class="beam" aria-hidden="true">
            <span class="beam__conn">
              <span class="beam__dot" />
              <span class="beam__dash" />
              <span class="beam__arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" />
                  <path d="M13 6l6 6-6 6" />
                </svg>
              </span>
            </span>
          </div>

          <div class="extract__out">
            <div class="field">
              <span class="field__label">{t.sourceQuote}</span>
              <p class="field__quote">{e.quote}</p>
              <p class="field__verify">
                {e.verify.url}{' '}
                <span class="field__ok">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {e.verify.date}
                </span>
              </p>
            </div>
            <div class="field">
              <span class="field__label">{t.theChange}</span>
              {e.change.delta ? (
                <p class="field__change">
                  <s>{e.change.from}</s> <span class="arrow">→</span> <b>{e.change.to}</b>
                  <span class="field__delta">{e.change.delta}</span>
                </p>
              ) : (
                <p class="field__change">
                  <b>{e.change.effective}</b> <span class="field__badge">{e.change.badge}</span>
                </p>
              )}
            </div>
            <div class="field">
              <div class="field__head">
                <span class="field__label">{t.whosAffected}</span>
                <span class="field__count">{e.count}</span>
              </div>
              <div class="field__rows">
                {e.affected.map((c) => (
                  <div class="arow">
                    <span class="arow__in">{c.in}</span>
                    <span class="arow__name">{c.name}</span>
                    <span class="arow__meta">{c.meta}</span>
                    <span class={`arow__status arow__status--${c.tone}`}>
                      {c.tone === 'ok' ? t.eligible : t.review}
                    </span>
                  </div>
                ))}
                <p class="field__more">{e.more}</p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .notice__lead {
    margin-top: 16px;
    max-width: 60ch;
  }
  .notice__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  /* ---- example switcher ----
     A row of discrete, bordered pill buttons (each an obvious, clickable choice).
     The selected type fills with the accent tint + accent border + a lit leading
     dot; the rest read as quiet white buttons. */
  .nswitch {
    margin-top: clamp(28px, 3.5vw, 40px);
  }
  .ntabs {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .ntab {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px 8px 13px;
    border-radius: 999px;
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    font-size: var(--m-text-sm);
    font-weight: 500;
    letter-spacing: 0;
    color: var(--m-muted);
    cursor: pointer;
    transition:
      color var(--m-dur-fast) var(--m-ease),
      background var(--m-dur-fast) var(--m-ease),
      border-color var(--m-dur-fast) var(--m-ease);
  }
  /* leading status dot — hollow when idle, fills navy when this type is showing */
  .ntab__dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    flex: none;
    background: transparent;
    box-shadow: inset 0 0 0 1.5px
      color-mix(in srgb, var(--m-muted) 55%, transparent);
    transition:
      background var(--m-dur-fast) var(--m-ease),
      box-shadow var(--m-dur-fast) var(--m-ease);
  }
  .ntab:hover:not(.is-on) {
    color: var(--m-ink-2);
    border-color: var(--m-faint);
  }
  .ntab:hover:not(.is-on) .ntab__dot {
    box-shadow: inset 0 0 0 1.5px
      color-mix(in srgb, var(--m-accent) 55%, transparent);
  }
  .ntab.is-on {
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border-color: var(--m-accent);
    font-weight: 600;
  }
  .ntab.is-on .ntab__dot {
    background: var(--m-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-accent) 18%, transparent);
  }
  .ntab:focus-visible {
    outline: 2px solid var(--m-accent);
    outline-offset: 2px;
  }

  /* panels — ALL stacked in one grid cell so the container height is constant
     (= the tallest example). Switching examples only cross-fades the content;
     the layout never jumps. */
  .npanels {
    margin-top: clamp(24px, 3vw, 36px);
    display: grid;
  }
  .extract {
    grid-area: 1 / 1; /* every panel occupies the same cell → no reflow on swap */
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    align-items: start;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.22s var(--m-ease),
      visibility 0s linear 0.22s;
  }
  .extract.is-on {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 0.22s var(--m-ease),
      visibility 0s;
  }
  @media (prefers-reduced-motion: reduce) {
    .extract {
      transition: none;
    }
  }
  .clip {
    grid-column: span 5;
  }
  .beam {
    grid-column: span 2;
    align-self: center; /* arrow stays centered though columns top-align */
  }
  .extract__out {
    grid-column: span 5;
  }

  /* ---- the document ---- */
  .clip {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    padding: 24px 26px 22px;
  }
  .clip__head {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .clip__seal {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    flex: none;
    display: grid;
    place-items: center;
    color: var(--m-accent);
    border: 1px solid var(--m-hairline);
  }
  .clip__seal svg {
    width: 16px;
    height: 16px;
  }
  .clip__org {
    flex: 1;
  }
  .clip__name {
    font-size: var(--m-text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-ink);
  }
  .clip__sub {
    margin-top: 2px;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }
  /* posted + source now sit beneath the org name as one quiet meta line */
  .clip__posted {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }
  .clip__posted b {
    color: var(--m-ink-2);
    font-weight: 600;
  }
  .clip__sep {
    color: var(--m-faint);
  }
  .clip__url {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-accent);
  }
  .clip__url svg {
    width: 11px;
    height: 11px;
  }
  .clip__body {
    margin-top: 16px;
    display: grid;
    gap: 12px;
    font-size: var(--m-text-base);
    line-height: 1.55;
    color: var(--m-ink-2);
    min-height: 78px;
  }
  .clip__body :global(mark) {
    background: color-mix(in srgb, var(--m-accent) 16%, transparent);
    color: var(--m-ink);
    padding: 0 2px;
    border-radius: var(--m-radius-sm);
  }

  /* ---- connector ---- */
  .beam {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
  }
  .beam__conn {
    display: flex;
    align-items: center;
    width: 100%;
    color: var(--m-accent);
  }
  .beam__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-accent);
    flex: none;
  }
  .beam__dash {
    flex: 1;
    border-top: 1.5px dashed color-mix(in srgb, var(--m-accent) 32%, transparent);
  }
  .beam__arrow svg {
    width: 16px;
    height: 16px;
    flex: none;
  }

  /* ---- extracted fields ---- */
  .extract__out {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .field {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    padding: 14px 18px;
  }
  .field__label {
    display: inline-flex;
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-accent);
  }
  .field__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .field__count {
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border-radius: 999px;
    padding: 2px 9px;
  }
  .field__quote {
    margin-top: 10px;
    font-size: var(--m-text-base);
    line-height: 1.5;
    color: var(--m-ink);
  }
  .field__verify {
    margin-top: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
  }
  .field__ok {
    color: var(--m-ok);
  }
  .field__ok svg {
    width: 12px;
    height: 12px;
    vertical-align: -1px;
  }
  .field__change {
    margin-top: 10px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-md);
    color: var(--m-ink);
  }
  .field__change s {
    color: var(--m-faint);
  }
  .field__change .arrow {
    color: var(--m-muted);
  }
  .field__delta {
    font-family: var(--m-font-sans);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
    border-radius: 999px;
    padding: 1px 8px;
  }
  .field__badge {
    font-family: var(--m-font-sans);
    font-size: var(--m-text-2xs);
    font-weight: 500;
    color: var(--m-muted);
    background: var(--m-section);
    border-radius: 999px;
    padding: 1px 9px;
  }
  .field__rows {
    margin-top: 12px;
    display: grid;
    gap: 2px;
  }
  .arow {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 0;
    border-top: 1px solid var(--m-hairline-2);
  }
  .arow:first-child {
    border-top: none;
  }
  .arow__in {
    width: 22px;
    height: 22px;
    border-radius: var(--m-radius-md);
    flex: none;
    display: grid;
    place-items: center;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .arow__name {
    font-size: var(--m-text-sm);
    color: var(--m-ink);
    white-space: nowrap;
  }
  .arow__meta {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
  }
  .arow__status {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .arow__status--ok {
    color: var(--m-ok);
  }
  .arow__status--warn {
    color: var(--m-urgent);
  }
  .field__more {
    margin-top: 9px;
    font-size: var(--m-text-xs);
    color: var(--m-faint);
  }

  @media (max-width: 1000px) {
    .extract.is-on {
      grid-template-columns: 1fr;
    }
    .clip,
    .beam,
    .extract__out {
      grid-column: auto;
    }
    .beam {
      padding: 14px 0;
    }
    .beam__conn {
      flex-direction: column;
      height: 46px;
      width: auto;
    }
    .beam__dash {
      border-top: 0;
      border-left: 1.5px dashed color-mix(in srgb, var(--m-accent) 32%, transparent);
      width: 0;
    }
    .beam__arrow svg {
      transform: rotate(90deg);
    }
  }
</style>

<script>
  // Change-type examples as a WAI tablist: click + roving tabindex + arrow-key nav.
  // Re-binds on first load + every View-Transition navigation.
  function initNotice() {
    document.querySelectorAll<HTMLElement>('#notice').forEach((section) => {
      const tabs = Array.from(section.querySelectorAll<HTMLElement>('.ntab'))
      const panels = Array.from(section.querySelectorAll<HTMLElement>('.extract'))
      const activate = (idx: number, focus: boolean) => {
        tabs.forEach((t, i) => {
          const on = i === idx
          t.classList.toggle('is-on', on)
          t.setAttribute('aria-selected', String(on))
          t.tabIndex = on ? 0 : -1
          if (on && focus) t.focus()
        })
        panels.forEach((p, i) => p.classList.toggle('is-on', i === idx))
      }
      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activate(i, false))
        tab.addEventListener('keydown', (e) => {
          let next = -1
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % tabs.length
          else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (i - 1 + tabs.length) % tabs.length
          else if (e.key === 'Home') next = 0
          else if (e.key === 'End') next = tabs.length - 1
          if (next >= 0) {
            e.preventDefault()
            activate(next, true)
          }
        })
      })
    })
  }
  document.addEventListener('astro:page-load', initNotice)
</script>
