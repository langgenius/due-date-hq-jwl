---
/** Notice — "it reads the official notice". A toggle across change types; each
 *  shows the source doc → extracted fields (source quote · the change · who's
 *  affected), mirroring the product's alert structure. Date/requirement changes
 *  only — no dollar amounts or penalty figures (we don't have that data). */
const examples = [
  {
    tab: 'Disaster postponement',
    doc: {
      org: 'Internal Revenue Service',
      sub: 'IR-2026-31 · Disaster relief',
      posted: 'Mar 2, 2026',
      url: 'irs.gov',
      body: 'Affected taxpayers now have until <mark>November 3, 2026</mark> to file the returns and make the payments that were originally due April 15.',
    },
    quote: '"…until November 3, 2026 to file the returns and make the payments…"',
    verify: { url: 'irs.gov', date: 'Verified Mar 2' },
    change: { from: 'Apr 15', to: 'Nov 3, 2026', delta: '+202 days' },
    count: '8 clients',
    affected: [
      { in: 'RO', name: 'Red Oak Partners', meta: '1120-S · TX', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'BL', name: 'Brightway Logistics', meta: '1120 · TX', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'HC', name: 'Hill Country Partners', meta: '1065 · TX', status: 'REVIEW', tone: 'warn' },
    ],
    more: '+ 5 more in the disaster area',
  },
  {
    tab: 'State extension',
    doc: {
      org: 'California FTB',
      sub: 'Tax News · Estimated tax',
      posted: 'Sep 4, 2026',
      url: 'ftb.ca.gov',
      body: 'For affected counties, the third-quarter estimated-tax date is <mark>extended to September 29, 2026</mark> following the wildfire declaration.',
    },
    quote: '"…extended to September 29, 2026 following the declaration…"',
    verify: { url: 'ftb.ca.gov', date: 'Verified Sep 4' },
    change: { from: 'Sep 15', to: 'Sep 29, 2026', delta: '+14 days' },
    count: '12 clients',
    affected: [
      { in: 'CV', name: 'Coastal Ventures', meta: '540-ES · CA', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'PM', name: 'Pacific Mills', meta: '100-ES · CA', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'NB', name: 'Napa Brands', meta: '540-ES · CA', status: 'REVIEW', tone: 'warn' },
    ],
    more: '+ 9 more in the affected counties',
  },
  {
    tab: 'New requirement',
    doc: {
      org: 'Texas Comptroller',
      sub: 'Tax Policy News · Franchise tax',
      posted: 'Jan 30, 2026',
      url: 'comptroller.texas.gov',
      body: 'Remote sellers meeting the economic-nexus standard must <mark>begin filing a franchise tax report on January 1, 2026</mark>.',
    },
    quote: '"…must begin filing a franchise tax report on January 1, 2026…"',
    verify: { url: 'comptroller.texas.gov', date: 'Verified Jan 30' },
    change: { effective: 'Effective Jan 1, 2026', badge: 'new obligation' },
    count: '5 clients',
    affected: [
      { in: 'LS', name: 'Lone Star LLC', meta: '05-158 · TX', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'BC', name: 'Brazos Co', meta: '05-158 · TX', status: 'ELIGIBLE', tone: 'ok' },
      { in: 'RT', name: 'Remote Tech Inc', meta: '05-158 · TX', status: 'REVIEW', tone: 'warn' },
    ],
    more: '+ 2 more newly in scope',
  },
]
---

<section class="m-section" id="notice" aria-labelledby="notice-h">
  <p class="m-eyebrow">The document, read</p>
  <h2 class="m-h2" id="notice-h">
    It reads the official notice — and pulls out what changed and <span class="ital">who it hits.</span>
  </h2>
  <p class="m-lead notice__lead">
    No provenance, no render — every field below carries its <b>source quote</b> and a
    <b>verified date</b>, or it's held back rather than guessed.
  </p>

  <div class="ntabs" role="tablist" aria-label="Example change types">
    {
      examples.map((e, i) => (
        <button
          class:list={['ntab', i === 0 && 'is-on']}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-ntab={i}
          type="button"
        >
          {e.tab}
        </button>
      ))
    }
  </div>

  <div class="npanels">
    {
      examples.map((e, i) => (
        <div class:list={['extract', i === 0 && 'is-on']} data-npanel={i} role="tabpanel">
          <article class="clip" aria-hidden="true">
            <header class="clip__head">
              <span class="clip__seal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </span>
              <div class="clip__org">
                <div class="clip__name">{e.doc.org}</div>
                <div class="clip__sub">{e.doc.sub}</div>
              </div>
              <div class="clip__posted">
                Posted <b>{e.doc.posted}</b>
                <div class="clip__url">{e.doc.url}</div>
              </div>
            </header>
            <div class="clip__body">
              <p set:html={e.doc.body} />
            </div>
          </article>

          <div class="beam" aria-hidden="true">
            <span class="beam__conn">
              <span class="beam__dot" />
              <span class="beam__dash" />
              <span class="beam__arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" />
                  <path d="M13 6l6 6-6 6" />
                </svg>
              </span>
            </span>
          </div>

          <div class="extract__out">
            <div class="field">
              <span class="field__label">Source quote</span>
              <p class="field__quote">{e.quote}</p>
              <p class="field__verify">
                {e.verify.url} <span class="field__ok">✓ {e.verify.date}</span>
              </p>
            </div>
            <div class="field">
              <span class="field__label">The change</span>
              {e.change.delta ? (
                <p class="field__change">
                  <s>{e.change.from}</s> <span class="arrow">→</span> <b>{e.change.to}</b>
                  <span class="field__delta">{e.change.delta}</span>
                </p>
              ) : (
                <p class="field__change">
                  <b>{e.change.effective}</b> <span class="field__badge">{e.change.badge}</span>
                </p>
              )}
            </div>
            <div class="field">
              <div class="field__head">
                <span class="field__label">Who's affected</span>
                <span class="field__count">{e.count}</span>
              </div>
              <div class="field__rows">
                {e.affected.map((c) => (
                  <div class="arow">
                    <span class="arow__in">{c.in}</span>
                    <span class="arow__name">{c.name}</span>
                    <span class="arow__meta">{c.meta}</span>
                    <span class={`arow__status arow__status--${c.tone}`}>{c.status}</span>
                  </div>
                ))}
                <p class="field__more">{e.more}</p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .notice__lead {
    margin-top: 16px;
    max-width: 60ch;
  }
  .notice__lead :global(b) {
    color: var(--m-ink);
    font-weight: 600;
  }

  /* toggle */
  .ntabs {
    margin-top: clamp(28px, 3.5vw, 40px);
    display: inline-flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 4px;
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
    border-radius: 999px;
  }
  .ntab {
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    color: var(--m-muted);
    cursor: pointer;
    transition:
      color 0.18s ease,
      background 0.18s ease;
  }
  .ntab:hover {
    color: var(--m-ink);
  }
  .ntab.is-on {
    color: #fff;
    background: var(--m-accent);
  }

  /* panels */
  .npanels {
    margin-top: clamp(24px, 3vw, 36px);
  }
  .extract {
    display: none;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    align-items: center;
  }
  .extract.is-on {
    display: grid;
  }
  .clip {
    grid-column: span 5;
  }
  .beam {
    grid-column: span 2;
  }
  .extract__out {
    grid-column: span 5;
  }

  /* ---- the document ---- */
  .clip {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    padding: 24px 26px 22px;
  }
  .clip__head {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .clip__seal {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    flex: none;
    display: grid;
    place-items: center;
    color: var(--m-accent);
    border: 1px solid var(--m-hairline);
  }
  .clip__seal svg {
    width: 16px;
    height: 16px;
  }
  .clip__org {
    flex: 1;
  }
  .clip__name {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-ink);
  }
  .clip__sub {
    margin-top: 2px;
    font-size: 12px;
    color: var(--m-muted);
  }
  .clip__posted {
    text-align: right;
    font-size: 12px;
    color: var(--m-muted);
    white-space: nowrap;
  }
  .clip__posted b {
    color: var(--m-ink-2);
    font-weight: 600;
  }
  .clip__url {
    margin-top: 2px;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-faint);
  }
  .clip__body {
    margin-top: 16px;
    display: grid;
    gap: 12px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--m-ink-2);
    min-height: 78px;
  }
  .clip__body :global(mark) {
    background: color-mix(in srgb, var(--m-accent) 16%, transparent);
    color: var(--m-ink);
    padding: 0 2px;
    border-radius: 2px;
  }

  /* ---- connector ---- */
  .beam {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
  }
  .beam__conn {
    display: flex;
    align-items: center;
    width: 100%;
    color: var(--m-accent);
  }
  .beam__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-accent);
    flex: none;
  }
  .beam__dash {
    flex: 1;
    border-top: 1.5px dashed color-mix(in srgb, var(--m-accent) 32%, transparent);
  }
  .beam__arrow svg {
    width: 16px;
    height: 16px;
    flex: none;
  }

  /* ---- extracted fields ---- */
  .extract__out {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .field {
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    padding: 16px 18px;
  }
  .field__label {
    display: inline-flex;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: var(--m-accent);
  }
  .field__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .field__count {
    font-size: 11px;
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
    border-radius: 999px;
    padding: 2px 9px;
  }
  .field__quote {
    margin-top: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--m-ink);
  }
  .field__verify {
    margin-top: 8px;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-muted);
  }
  .field__ok {
    color: var(--m-ok);
  }
  .field__change {
    margin-top: 10px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--m-font-mono);
    font-size: 15px;
    color: var(--m-ink);
  }
  .field__change s {
    color: var(--m-faint);
  }
  .field__change .arrow {
    color: var(--m-muted);
  }
  .field__delta {
    font-family: var(--m-font-sans);
    font-size: 11px;
    font-weight: 600;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
    border-radius: 999px;
    padding: 1px 8px;
  }
  .field__badge {
    font-family: var(--m-font-sans);
    font-size: 11px;
    font-weight: 500;
    color: var(--m-muted);
    background: var(--m-section);
    border-radius: 999px;
    padding: 1px 9px;
  }
  .field__rows {
    margin-top: 12px;
    display: grid;
    gap: 2px;
  }
  .arow {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 0;
    border-top: 1px solid var(--m-hairline-2);
  }
  .arow:first-child {
    border-top: none;
  }
  .arow__in {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    flex: none;
    display: grid;
    place-items: center;
    font-size: 9px;
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .arow__name {
    font-size: 13px;
    color: var(--m-ink);
    white-space: nowrap;
  }
  .arow__meta {
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-muted);
  }
  .arow__status {
    margin-left: auto;
    font-family: var(--m-font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .arow__status--ok {
    color: var(--m-ok);
  }
  .arow__status--warn {
    color: var(--m-urgent);
  }
  .field__more {
    margin-top: 9px;
    font-size: 12px;
    color: var(--m-faint);
  }

  @media (max-width: 1000px) {
    .extract.is-on {
      grid-template-columns: 1fr;
    }
    .clip,
    .beam,
    .extract__out {
      grid-column: auto;
    }
    .beam {
      padding: 14px 0;
    }
    .beam__conn {
      flex-direction: column;
      height: 46px;
      width: auto;
    }
    .beam__dash {
      border-top: 0;
      border-left: 1.5px dashed color-mix(in srgb, var(--m-accent) 32%, transparent);
      width: 0;
    }
    .beam__arrow svg {
      transform: rotate(90deg);
    }
  }
</style>

<script>
  // toggle between change-type examples
  document.querySelectorAll<HTMLElement>('#notice').forEach((section) => {
    const tabs = Array.from(section.querySelectorAll<HTMLElement>('.ntab'))
    const panels = Array.from(section.querySelectorAll<HTMLElement>('.extract'))
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const idx = tab.dataset.ntab
        tabs.forEach((t) => {
          const on = t.dataset.ntab === idx
          t.classList.toggle('is-on', on)
          t.setAttribute('aria-selected', String(on))
        })
        panels.forEach((p) => p.classList.toggle('is-on', p.dataset.npanel === idx))
      })
    })
  })
</script>
