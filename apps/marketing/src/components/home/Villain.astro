---
/** Villain — the navy accent band (the pain beat). White text on --m-accent. */
---

<section class="villain" aria-labelledby="villain-h">
  <div class="villain__inner">
    <p class="villain__q">Sound familiar?</p>
    <div class="villain__grid">
      <h2 class="villain__h" id="villain-h">
        It's not missing a deadline that keeps you up. It's <span class="ital">not knowing</span> if
        you did.
      </h2>
      <p class="villain__body">
        Fifty state websites. An inbox you can't keep up with.
        <span class="dim"
          >A rule changed back in March, and you won't hear until your client gets the notice.</span
        > The work was never the hard part — <strong>the not-knowing is.</strong>
      </p>
    </div>
  </div>
</section>

<style>
  .villain {
    background: var(--m-accent);
  }
  .villain__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(56px, 9vw, 110px);
  }
  .villain__q {
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: clamp(20px, 3vw, 32px);
  }
  .villain__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 5vw, 56px);
    align-items: start;
  }
  .villain__h {
    grid-column: span 6;
    font-family: var(--m-font-sans);
    font-weight: 500;
    font-size: clamp(29px, 3.6vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .villain__h .ital {
    font-style: italic;
  }
  .villain__body {
    grid-column: span 6;
    font-size: clamp(18px, 1.5vw, 21px);
    line-height: 1.55;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.82);
  }
  .villain__body .dim {
    color: rgba(255, 255, 255, 0.5);
  }
  .villain__body strong {
    color: #fff;
    font-weight: 600;
  }
  @media (max-width: 1000px) {
    .villain__grid {
      grid-template-columns: 1fr;
    }
    .villain__h,
    .villain__body {
      grid-column: auto;
    }
  }
</style>
