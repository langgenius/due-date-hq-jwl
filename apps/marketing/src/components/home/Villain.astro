---
/** Villain — the navy accent band, now a problem→answer pivot. Left states the
 *  dread (the not-knowing); right turns it with the three things the product
 *  does about it (import · monitor · match) and a link to the full how-it-works
 *  page. White text only (no chromatic text on dark); the answer rows reuse the
 *  pain-row anatomy so the turn feels like one continuous thought, not a new
 *  section. This absorbs the old standalone HowItWorks beat. */
interface Props {
  locale?: 'en' | 'zh-CN'
}
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const howHref = zh ? '/zh-CN/how-it-works' : '/how-it-works'

const t = zh
  ? {
      q: '是不是很熟悉？',
      hBefore: '截止日一变 ——',
      hItal: '等你知道，',
      hAfter: '客户早就知道了。',
      painLine: '五十个州的网站，一个永远清不完的收件箱。没人能靠人工全盯过来。',
      answerEyebrow: '我们怎么让你安心',
      caps: [
        {
          lead: '几分钟就能导入你的客户',
          sub: '粘贴名单，或从你正在用的工具导入。',
        },
        {
          lead: '我们全天候盯着每一个机构',
          sub: 'IRS、全部 50 个州和 FEMA——持续监控。',
        },
        {
          lead: '每条变化，都对应到受影响的客户',
          sub: '一眼看清变化影响哪些客户，并附官方来源。',
        },
      ],
      link: '看它如何运作',
    }
  : {
      q: 'Sound familiar?',
      hBefore: 'A deadline moves —',
      hItal: 'you find out',
      hAfter: 'when your client does.',
      painLine: "Fifty state sites and an inbox that never empties. No one can watch it all by hand.",
      answerEyebrow: 'How we keep you sure',
      caps: [
        {
          lead: 'Bring your clients over in minutes',
          sub: 'Paste a list or import from the tools you already use.',
        },
        {
          lead: 'We watch every agency, around the clock',
          sub: 'The IRS, all fifty states, and FEMA — continuously.',
        },
        {
          lead: 'Every change, matched to who it hits',
          sub: 'See exactly which clients a change affects, with the source.',
        },
      ],
      link: 'See how it works',
    }
const caps = t.caps
---

<section class="villain" data-nav-dark aria-labelledby="villain-h" data-reveal>
  <div class="villain__inner">
    <div class="villain__lead">
      <p class="villain__q">{t.q}</p>
      <h2 class="villain__h" id="villain-h">
        {t.hBefore} <span class="ital">{t.hItal}</span> {t.hAfter}
      </h2>
      <p class="villain__painline">{t.painLine}</p>
    </div>

    <div class="villain__answer">
      <p class="villain__answer-eyebrow">{t.answerEyebrow}</p>
      <ul class="villain__caps" data-reveal-stagger>
        {
          caps.map((c, i) => (
            <li class="vcap">
              <span class="vcap__icon" aria-hidden="true">
                {i === 0 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 15V4M8 8l4-4 4 4" />
                    <path d="M4 14v4a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-4" />
                  </svg>
                )}
                {i === 1 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                    <circle cx="12" cy="12" r="2.7" />
                  </svg>
                )}
                {i === 2 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="8.5" />
                    <circle cx="12" cy="12" r="4.3" />
                    <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none" />
                  </svg>
                )}
              </span>
              <div class="vcap__txt">
                <p class="vcap__lead">{c.lead}</p>
                <p class="vcap__sub">{c.sub}</p>
              </div>
            </li>
          ))
        }
      </ul>
      <a class="villain__link" href={howHref}>
        {t.link} <span class="villain__link-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  /* The dark pivot — a DEEPER, heavier navy: the pressed navy pushed toward ink,
     with a soft top vignette so the band reads somber and recessed (chroma in the
     container, text stays white). */
  .villain {
    position: relative;
    isolation: isolate;
    background: color-mix(in srgb, var(--m-accent-strong) 86%, var(--m-ink));
  }
  .villain::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      130% 100% at 50% 0%,
      transparent 0%,
      color-mix(in srgb, var(--m-ink) 28%, transparent) 100%
    );
    pointer-events: none;
  }
  .villain__inner {
    max-width: var(--m-maxw);
    margin-inline: auto;
    padding-inline: var(--m-gutter);
    padding-block: clamp(56px, 9vw, 104px);
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(36px, 5vw, 56px);
    align-items: center;
  }
  .villain__lead {
    grid-column: span 5;
  }
  .villain__answer {
    grid-column: span 6 / -1;
  }
  .villain__q {
    font-size: var(--m-text-sm);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: clamp(16px, 2.2vw, 24px);
  }
  .villain__h {
    max-width: 18ch;
    font-family: var(--m-font-sans);
    font-weight: 500;
    font-size: clamp(29px, 3.4vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .villain__h .ital {
    font-style: italic;
  }
  .villain__painline {
    margin-top: clamp(22px, 3vw, 32px);
    max-width: 40ch;
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
  }

  /* the turn — a quiet header, then the answer rows (same anatomy as the old
     pains so problem→answer reads as one continuous thought) */
  .villain__answer-eyebrow {
    font-size: var(--m-text-xs);
    font-weight: 600;
    letter-spacing: var(--m-ls-eyebrow);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: clamp(8px, 1.4vw, 14px);
  }
  .villain__caps {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .vcap {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding-block: clamp(16px, 2vw, 22px);
  }
  .vcap + .vcap {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .vcap__icon {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s var(--m-ease, ease);
  }
  .vcap:hover .vcap__icon {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.26);
    transform: translateY(-1px);
  }
  .vcap__icon svg {
    width: 19px;
    height: 19px;
  }
  .vcap__lead {
    font-size: clamp(15px, 1.2vw, 17px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
  }
  .vcap__sub {
    margin-top: 5px;
    font-size: var(--m-text-base);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
  }
  /* a grounded ghost button, not a floating underline */
  .villain__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: clamp(20px, 2.4vw, 28px);
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: #fff;
    transition:
      background 0.18s ease,
      border-color 0.18s ease;
  }
  .villain__link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .villain__link-arrow {
    transition: transform 0.18s ease;
  }
  .villain__link:hover .villain__link-arrow {
    transform: translateX(3px);
  }
  @media (prefers-reduced-motion: reduce) {
    .vcap__icon,
    .villain__link-arrow {
      transition: none;
    }
  }
  @media (max-width: 900px) {
    .villain__inner {
      grid-template-columns: 1fr;
      gap: clamp(28px, 5vw, 40px);
      align-items: start;
    }
    .villain__lead,
    .villain__answer {
      grid-column: auto;
    }
  }
</style>
