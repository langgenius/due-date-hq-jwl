  @media (prefers-reduced-motion: reduce) {
    .mini__variant {
      transition: none;
    }
  }
</style>

<script>
  // Surfaces workbench — jurisdiction tabs swap the lead alert (variants stacked
  // in one cell → no jump). Listeners die with the nodes on View-Transition swap.
  function initSurfaces() {
    document.querySelectorAll<HTMLElement>('.surfaces').forEach((section) => {
      const tabs = Array.from(section.querySelectorAll<HTMLButtonElement>('.bench__tab'))
      const variants = Array.from(section.querySelectorAll<HTMLElement>('.mini__variant'))
      if (!tabs.length) return
      tabs.forEach((tab, idx) => {
        tab.addEventListener('click', () => {
          tabs.forEach((tb, i) => {
            tb.classList.toggle('on', i === idx)
            tb.setAttribute('aria-pressed', String(i === idx))
          })
          variants.forEach((v, i) => v.classList.toggle('is-on', i === idx))
        })
      })
    })
  }
  document.addEventListener('astro:page-load', initSurfaces)
</script>
