---
/** Product surfaces — a Legora "highlights"-style grid: four cards, each with an
 *  embedded product mini-UI fragment on a graph-paper card. The minis reuse the
 *  exact chip vocabulary from the Hero feed and the See-it-work worklist. */
// coverage mini-map tile heat (24 tiles): '' faint · n navy · a urgent · r danger
const tiles = ['', '', 'n', '', 'r', '', '', 'a', '', '', '', 'n', 'r', '', '', 'a', '', '', '', '', 'r', '', '', '']
---

<section class="m-section surfaces" aria-labelledby="surfaces-h">
  <div class="surfaces__head">
    <div>
      <p class="m-eyebrow">The product</p>
      <h2 class="m-h2" id="surfaces-h">Everything in one <span class="ital">workbench.</span></h2>
    </div>
    <p class="surfaces__intro">
      From the first alert to the applied change — four surfaces, one calm place to work.
    </p>
  </div>

  <div class="surfaces__grid">
    <!-- Alerts -->
    <article class="surface">
      <div class="surface__thumb">
        <div class="mini">
          <div class="mini__sevrow">
            <span class="mini__sev">Urgent</span>
            <span class="mini__juris">FED</span>
          </div>
          <p class="mini__title">IRS postpones filing deadlines</p>
          <div class="mini__change"><s>Apr 15</s> → <b>Nov 3</b> <span class="mini__delta">+202d</span></div>
          <p class="mini__affect">Affects <b>8 clients</b></p>
        </div>
      </div>
      <h3 class="surface__t">Alerts</h3>
      <p class="surface__d">The live feed — every change as it lands, sorted by severity.</p>
      <a class="surface__link" href="#how">See it <span aria-hidden="true">→</span></a>
    </article>

    <!-- Coverage -->
    <article class="surface">
      <div class="surface__thumb">
        <div class="mini mini--map" aria-hidden="true">
          {tiles.map((t) => <span class:list={['mini__tile', t]} />)}
        </div>
      </div>
      <h3 class="surface__t">Coverage</h3>
      <p class="surface__d">One map of every jurisdiction — see where changes are landing.</p>
      <a class="surface__link" href="#sources">See it <span aria-hidden="true">→</span></a>
    </article>

    <!-- Worklist -->
    <article class="surface">
      <div class="surface__thumb">
        <div class="mini mini--list">
          <div class="mini__row">
            <span class="mini__bar hi"></span>
            <span class="mini__client">Hill Country Partners</span>
            <span class="mini__status blocked">Blocked</span>
            <span class="mini__due late">2d late</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">Brightway Logistics</span>
            <span class="mini__status review">In review</span>
            <span class="mini__due">in 3d</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">Cedar Park Dental</span>
            <span class="mini__status waiting">Waiting</span>
            <span class="mini__due">in 9d</span>
          </div>
        </div>
      </div>
      <h3 class="surface__t">Worklist</h3>
      <p class="surface__d">Your clients in risk order — who to call first, at a glance.</p>
      <a class="surface__link" href="#work">See it <span aria-hidden="true">→</span></a>
    </article>

    <!-- Apply & audit -->
    <article class="surface">
      <div class="surface__thumb">
        <div class="mini mini--apply">
          <span class="mini__applybtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 9-12h-7z" />
            </svg>
            Apply to 8 clients
          </span>
          <p class="mini__audit">sourced · reversible 24h · logged</p>
        </div>
      </div>
      <h3 class="surface__t">Apply &amp; audit</h3>
      <p class="surface__d">Push a change to everyone it touches — with the full trail behind it.</p>
      <a class="surface__link" href="#trust">See it <span aria-hidden="true">→</span></a>
    </article>
  </div>
</section>

<style>
  .surfaces__head {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 5vw, 72px);
    align-items: start;
  }
  .surfaces__head > :nth-child(1) {
    grid-column: span 7;
  }
  .surfaces__head > :nth-child(2) {
    grid-column: span 5;
  }
  .surfaces__head .m-h2 {
    max-width: 14ch;
  }
  .surfaces__intro {
    max-width: 42ch;
    font-size: 16px;
    line-height: 1.55;
    color: var(--m-muted);
  }
  .surfaces__grid {
    margin-top: clamp(34px, 4vw, 52px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(18px, 2.2vw, 28px);
  }
  .surface {
    display: flex;
    flex-direction: column;
  }
  .surface__thumb {
    position: relative;
    aspect-ratio: 5 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    background-color: var(--m-section);
    background-image:
      linear-gradient(color-mix(in srgb, var(--m-accent) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--m-accent) 6%, transparent) 1px, transparent 1px);
    background-size: 15px 15px;
    overflow: hidden;
  }
  /* embedded product mini-UI fragment — border + bg do the lift, micro-shadow only */
  .mini {
    width: 100%;
    padding: 11px 12px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 10px;
    box-shadow: 0 1px 3px -1px color-mix(in srgb, var(--m-ink) 12%, transparent);
  }
  .mini__sevrow {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }
  .mini__sev {
    padding: 1px 6px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 10%, transparent);
  }
  .mini__juris {
    padding: 1px 5px;
    border-radius: 5px;
    font-family: var(--m-font-mono);
    font-size: 9px;
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-section);
    border: 1px solid var(--m-hairline);
  }
  .mini__title {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--m-ink);
  }
  .mini__change {
    margin-top: 7px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-ink);
  }
  .mini__change s {
    color: var(--m-muted);
  }
  .mini__delta {
    padding: 0 5px;
    border-radius: 999px;
    font-family: var(--m-font-sans);
    font-size: 9px;
    font-weight: 600;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 14%, transparent);
  }
  .mini__affect {
    margin-top: 8px;
    padding-top: 7px;
    border-top: 1px solid var(--m-hairline-2);
    font-size: 11px;
    color: var(--m-ink);
  }
  .mini__affect b {
    color: var(--m-accent);
  }
  /* coverage mini-map */
  .mini--map {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
    padding: 12px;
  }
  .mini__tile {
    aspect-ratio: 1;
    border-radius: 4px;
    background: color-mix(in srgb, var(--m-accent) 8%, var(--m-surface));
  }
  .mini__tile.n {
    background: color-mix(in srgb, var(--m-accent) 30%, var(--m-surface));
  }
  .mini__tile.a {
    background: color-mix(in srgb, var(--m-urgent) 26%, var(--m-surface));
  }
  .mini__tile.r {
    background: color-mix(in srgb, var(--m-danger) 22%, var(--m-surface));
  }
  /* worklist mini */
  .mini--list {
    padding: 6px 8px;
  }
  .mini__row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 2px;
  }
  .mini__row + .mini__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .mini__bar {
    width: 4px;
    height: 18px;
    flex: none;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .mini__bar.hi {
    background: var(--m-urgent);
  }
  .mini__client {
    flex: 1;
    min-width: 0;
    font-size: 11px;
    color: var(--m-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mini__status {
    flex: none;
    padding: 2px 7px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 600;
    line-height: 1.5;
    white-space: nowrap;
  }
  .mini__status.blocked {
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 9%, transparent);
  }
  .mini__status.review {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .mini__status.waiting {
    color: var(--m-muted);
    background: transparent;
    border: 1px solid var(--m-hairline);
  }
  .mini__due {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: 10px;
    color: var(--m-muted);
  }
  .mini__due.late {
    color: var(--m-urgent);
  }
  /* apply mini */
  .mini--apply {
    text-align: center;
  }
  .mini__applybtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    padding: 8px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
    background: var(--m-accent);
  }
  .mini__applybtn svg {
    width: 12px;
    height: 12px;
  }
  .mini__audit {
    margin-top: 9px;
    font-family: var(--m-font-mono);
    font-size: 10px;
    color: var(--m-muted);
  }
  /* card text */
  .surface__t {
    margin-top: 16px;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .surface__d {
    margin-top: 6px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--m-muted);
  }
  .surface__link {
    margin-top: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--m-accent);
    transition: gap 0.15s ease;
  }
  .surface__link:hover {
    gap: 9px;
  }
  @media (max-width: 1000px) {
    .surfaces__head {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .surfaces__head > :nth-child(n) {
      grid-column: auto;
    }
    .surfaces__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .surfaces__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
