---
/** Product surfaces — ONE unified product workbench. A single app-window frame
 *  (titlebar + jurisdiction tabs) holds four connected panels — Alerts, Coverage,
 *  Worklist, Apply & audit — sharing one continuous surface so the product reads as
 *  one strong place to work, not four loose cards. A caption rail below names each
 *  surface, keeping its one-line pitch + a destination-predicting link (per-card
 *  label: "See coverage" → /state-coverage, "See in the tour" → /how-it-works).
 *  The minis reuse the exact chip vocabulary from the Hero feed and the
 *  See-it-work worklist. */
interface Props { locale?: 'en' | 'zh-CN' }
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const base = zh ? '/zh-CN' : ''
// coverage mini-map tile heat (24 tiles): '' faint · n navy · a urgent · r danger
const tiles = ['', '', 'n', '', 'r', '', '', 'a', '', '', '', 'n', 'r', '', '', 'a', '', '', '', '', 'r', '', '', '']

const t = zh
  ? {
      eyebrow: '产品',
      headingPre: '一个',
      headingItal: '工作台，',
      headingPost: '搞定一切。',
      intro: '从第一条提醒到应用变更——四个界面，一个让你安心工作的地方。',
      win: '美国税务截止日 · 实时',
      sevUrgent: '紧急',
      sevInfo: '信息',
      affectPre: '影响 ',
      jurisLabel: '按辖区筛选',
      jurisAlerts: [
        { tab: '联邦', juris: 'FED', sev: 'urgent', title: 'IRS 推迟申报截止日', from: 'Apr 15', to: 'Nov 3', delta: '+202d', affect: '8 家客户' },
        { tab: '德州', juris: 'TX', sev: 'info', title: '德州延长特许经营税申报', from: 'May 15', to: 'Aug 15', delta: '+92d', affect: '5 家客户' },
        { tab: '加州', juris: 'CA', sev: 'info', title: '加州 FTB 延长第三季度预估税', from: 'Sep 15', to: 'Sep 29', delta: '+14d', affect: '12 家客户' },
        { tab: '佛州', juris: 'FL', sev: 'urgent', title: '佛州 DOR 推迟销售税申报', from: 'Oct 20', to: 'Dec 2', delta: '+43d', affect: '6 家客户' },
      ],
      cards: {
        alerts: {
          panel: '提醒动态',
          t: '提醒',
          d: '实时动态——每条变更落地即呈现，按紧急程度排序。',
          see: '在导览中查看',
          recent: [
            { org: 'CA FTB', body: '已核验，无变化', when: '31 分钟前' },
            { org: 'NY DTF', body: '已扫描，无变化', when: '52 分钟前' },
            { org: 'FL DOR', body: '已扫描，无变化', when: '1 小时前' },
            { org: 'WA DOR', body: '已核验，无变化', when: '2 小时前' },
          ],
        },
        coverage: {
          panel: '覆盖',
          t: '覆盖',
          d: '一张地图涵盖所有辖区——看清变更落在何处。',
          see: '查看覆盖范围',
        },
        worklist: {
          rows: [
            { client: 'Hill Country Partners', status: '受阻', due: '逾期 2 天' },
            { client: 'Brightway Logistics', status: '审核中', due: '还剩 3 天' },
            { client: 'Cedar Park Dental', status: '等待中', due: '还剩 9 天' },
          ],
          panel: '工作清单',
          t: '工作清单',
          d: '客户按风险排序——一眼看出先打给谁。',
          see: '在导览中查看',
        },
        apply: {
          panel: '应用与审计',
          btn: '应用到 8 家客户',
          auditLabel: '已记录',
          audit: '已更新 8 家客户的截止日 · 引用 IRS 来源 · 24 小时内可撤销',
          t: '应用与审计',
          d: '把变更推送给每一个受影响的人，背后留有完整记录。',
          see: '在导览中查看',
        },
      },
    }
  : {
      eyebrow: 'The product',
      headingPre: 'Everything in one ',
      headingItal: 'workbench.',
      headingPost: '',
      intro: 'From the first alert to the applied change — four surfaces, one calm place to work.',
      win: 'US tax deadlines · live',
      sevUrgent: 'Urgent',
      sevInfo: 'Info',
      affectPre: 'Affects ',
      jurisLabel: 'Filter by jurisdiction',
      jurisAlerts: [
        { tab: 'Federal', juris: 'FED', sev: 'urgent', title: 'IRS postpones filing deadlines', from: 'Apr 15', to: 'Nov 3', delta: '+202d', affect: '8 clients' },
        { tab: 'Texas', juris: 'TX', sev: 'info', title: 'Texas extends franchise-tax report', from: 'May 15', to: 'Aug 15', delta: '+92d', affect: '5 clients' },
        { tab: 'California', juris: 'CA', sev: 'info', title: 'California FTB extends Q3 estimated tax', from: 'Sep 15', to: 'Sep 29', delta: '+14d', affect: '12 clients' },
        { tab: 'Florida', juris: 'FL', sev: 'urgent', title: 'Florida DOR postpones sales-tax filing', from: 'Oct 20', to: 'Dec 2', delta: '+43d', affect: '6 clients' },
      ],
      cards: {
        alerts: {
          panel: 'Alert feed',
          t: 'Alerts',
          d: 'The live feed — every change as it lands, sorted by severity.',
          see: 'See in the tour',
          recent: [
            { org: 'CA FTB', body: 'verified, no change', when: '31m' },
            { org: 'NY DTF', body: 'scanned, no change', when: '52m' },
            { org: 'FL DOR', body: 'scanned, no change', when: '1h' },
            { org: 'WA DOR', body: 'verified, no change', when: '2h' },
          ],
        },
        coverage: {
          panel: 'Coverage',
          t: 'Coverage',
          d: 'One map of every jurisdiction — see where changes are landing.',
          see: 'See coverage',
        },
        worklist: {
          rows: [
            { client: 'Hill Country Partners', status: 'Blocked', due: '2d late' },
            { client: 'Brightway Logistics', status: 'In review', due: 'in 3d' },
            { client: 'Cedar Park Dental', status: 'Waiting', due: 'in 9d' },
          ],
          panel: 'Worklist',
          t: 'Worklist',
          d: 'Your clients in risk order — who to call first, at a glance.',
          see: 'See in the tour',
        },
        apply: {
          panel: 'Apply & audit',
          btn: 'Apply to 8 clients',
          auditLabel: 'Logged',
          audit: 'Updated 8 client deadlines · IRS source cited · reversible for 24h',
          t: 'Apply & audit',
          d: 'Push a change to everyone it touches — with the full trail behind it.',
          see: 'See in the tour',
        },
      },
    }

const surfaces = [
  { key: 'alerts', href: `${base}/how-it-works#how`, c: t.cards.alerts },
  { key: 'coverage', href: `${base}/state-coverage`, c: t.cards.coverage },
  { key: 'worklist', href: `${base}/how-it-works#work`, c: t.cards.worklist },
  { key: 'apply', href: `${base}/how-it-works`, c: t.cards.apply },
]
---

<section class="m-section surfaces" id="surfaces" aria-labelledby="surfaces-h" data-reveal>
  <div class="surfaces__head">
    <div>
      <p class="m-eyebrow">{t.eyebrow}</p>
      <h2 class="m-h2" id="surfaces-h">{t.headingPre}<span class="ital">{t.headingItal}</span>{t.headingPost}</h2>
    </div>
    <p class="surfaces__intro">
      {t.intro}
    </p>
  </div>

  <!-- One product window: titlebar + jurisdiction tabs + four connected panels.
       Auto-tours each surface (spotlight), follows hover/focus; tabs filter the
       lead alert. -->
  <div class="bench" data-bench>
    <div class="bench__bar">
      <span class="bench__dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="bench__name">{t.win}</span>
      <span class="bench__tabs" role="group" aria-label={t.jurisLabel}>
        {
          t.jurisAlerts.map((j, i) => (
            <button
              class:list={['bench__tab', { on: i === 0 }]}
              type="button"
              aria-pressed={i === 0 ? 'true' : 'false'}
              data-juris-tab={i}
            >
              {j.tab}
            </button>
          ))
        }
      </span>
    </div>

    <div class="bench__grid">
      <!-- Alerts — the lead panel (jurisdiction tabs swap the alert, no jump) -->
      <div class="panel panel--lead" data-surface="alerts">
        <p class="panel__label">{t.cards.alerts.panel}</p>
        <div class="mini mini--alert">
          <div class="mini__alertswap">
            {
              t.jurisAlerts.map((j, i) => (
                <div class:list={['mini__variant', { 'is-on': i === 0 }]} data-juris-panel={i}>
                  <div class="mini__sevrow">
                    <span class:list={['mini__sev', { 'mini__sev--info': j.sev === 'info' }]}>
                      {j.sev === 'urgent' ? t.sevUrgent : t.sevInfo}
                    </span>
                    <span class="mini__juris">{j.juris}</span>
                  </div>
                  <p class="mini__title">{j.title}</p>
                  <div class="mini__change">
                    <s>{j.from}</s> → <b>{j.to}</b> <span class="mini__delta">{j.delta}</span>
                  </div>
                  <p class="mini__affect">{t.cards.alerts.affectPre}<b>{j.affect}</b></p>
                </div>
              ))
            }
          </div>
          <div class="mini__recent">
            {
              t.cards.alerts.recent.map((r) => (
                <div class="mini__recent-row">
                  <span class="mini__recent-org">{r.org}</span>
                  <span class="mini__recent-body">{r.body}</span>
                  <span class="mini__recent-when">{r.when}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Coverage -->
      <div class="panel panel--coverage" data-surface="coverage">
        <p class="panel__label">{t.cards.coverage.panel}</p>
        <div class="mini mini--map" aria-hidden="true">
          {tiles.map((tile) => <span class:list={['mini__tile', tile]} />)}
        </div>
      </div>

      <!-- Worklist -->
      <div class="panel panel--list" data-surface="worklist">
        <p class="panel__label">{t.cards.worklist.panel}</p>
        <div class="mini mini--list">
          <div class="mini__row">
            <span class="mini__bar hi"></span>
            <span class="mini__client">{t.cards.worklist.rows[0].client}</span>
            <span class="mini__status blocked">{t.cards.worklist.rows[0].status}</span>
            <span class="mini__due late">{t.cards.worklist.rows[0].due}</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">{t.cards.worklist.rows[1].client}</span>
            <span class="mini__status review">{t.cards.worklist.rows[1].status}</span>
            <span class="mini__due">{t.cards.worklist.rows[1].due}</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">{t.cards.worklist.rows[2].client}</span>
            <span class="mini__status waiting">{t.cards.worklist.rows[2].status}</span>
            <span class="mini__due">{t.cards.worklist.rows[2].due}</span>
          </div>
        </div>
      </div>

      <!-- Apply & audit -->
      <div class="panel panel--apply" data-surface="apply">
        <p class="panel__label">{t.cards.apply.panel}</p>
        <div class="mini mini--apply">
          <span class="mini__applybtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 9-12h-7z" />
            </svg>
            {t.cards.apply.btn}
          </span>
          <p class="mini__audit">
            <span class="mini__auditmark">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {t.cards.apply.auditLabel}
            </span>
            <span class="mini__audittrail">{t.cards.apply.audit}</span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Caption rail — names each surface, keeps its pitch + link -->
  <ul class="legend" data-reveal-stagger>
    {surfaces.map((s, i) => (
      <li class:list={['legend__item', `legend__item--${s.key}`]} data-surface={s.key}>
        <span class="legend__n" aria-hidden="true">{'0' + (i + 1)}</span>
        <div class="legend__body">
          <h3 class="legend__t">{s.c.t}</h3>
          <p class="legend__d">{s.c.d}</p>
          <a class="legend__link" href={s.href}>{s.c.see} <span aria-hidden="true">→</span></a>
        </div>
      </li>
    ))}
  </ul>
</section>

<style>
  .surfaces__head {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
  }
  .surfaces__head > :nth-child(1) {
    grid-column: span 7;
  }
  .surfaces__head > :nth-child(2) {
    grid-column: span 5;
  }
  .surfaces__head .m-h2 {
    max-width: 14ch;
  }
  .surfaces__intro {
    max-width: 42ch;
    font-size: var(--m-text-lg);
    line-height: 1.55;
    color: var(--m-muted);
  }

  /* ── One product window ─────────────────────────────────────────────────── */
  .bench {
    margin-top: clamp(34px, 4vw, 52px);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    background: var(--m-surface);
    overflow: hidden;
  }
  .bench__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 38px;
    padding: 0 14px;
    border-bottom: 1px solid var(--m-hairline);
    background: var(--m-section);
  }
  .bench__dots {
    display: inline-flex;
    gap: 5px;
    flex: none;
  }
  .bench__dots i {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .bench__name {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    color: var(--m-muted);
    white-space: nowrap;
  }
  .bench__tabs {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }
  .bench__tab {
    appearance: none;
    border: none;
    font-family: inherit;
    cursor: pointer;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 500;
    color: var(--m-muted);
    background: transparent;
    white-space: nowrap;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  .bench__tab:hover:not(.on) {
    color: var(--m-ink-2);
    background: var(--m-hairline-2);
  }
  .bench__tab.on {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .bench__tab:focus-visible {
    outline: 2px solid var(--m-accent);
    outline-offset: 1px;
  }
  /* small screens: scroll the jurisdiction toggles rather than hiding tabs 3–4
     (which made their alert variants permanently unreachable) */
  @media (max-width: 560px) {
    .bench__tabs {
      overflow-x: auto;
      scrollbar-width: none;
    }
    .bench__tabs::-webkit-scrollbar {
      display: none;
    }
  }

  /* Connected panels — one continuous surface, hairline-divided (no boxes).
     Bento: Alerts leads (tall, left), the three supporting panels stack right. */
  .bench__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    grid-template-rows: auto auto;
    /* a clean 2×2 quadrant — the alert feed no longer spans two rows (so it
       isn't forced tall and empty); Apply pairs with the worklist */
    grid-template-areas:
      'lead coverage'
      'list apply';
  }
  .panel {
    display: flex;
    flex-direction: column;
    padding: 14px;
  }
  /* hairline seams between connected panels — drawn with insets, never a box */
  .panel--lead {
    grid-area: lead;
    border-right: 1px solid var(--m-hairline-2);
    border-bottom: 1px solid var(--m-hairline-2);
    background: var(--m-section);
  }
  .panel--coverage {
    grid-area: coverage;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .panel--list {
    grid-area: list;
    border-right: 1px solid var(--m-hairline-2);
  }
  .panel--apply {
    grid-area: apply;
  }
  .panel__label {
    margin-bottom: 8px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--m-faint);
  }

  /* embedded product mini-UI fragments — the surface IS the lift, no inner box */
  .mini {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .mini__sevrow {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }
  /* the lead alert swaps by jurisdiction — variants stacked in one cell so the
     panel height is constant (= tallest variant); no jump on tab click */
  .mini__alertswap {
    display: grid;
  }
  .mini__variant {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s var(--m-ease);
  }
  .mini__variant.is-on {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .mini__sev {
    padding: 1px 6px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 10%, transparent);
  }
  .mini__sev--info {
    color: var(--m-ink-2);
    background: var(--m-section);
  }
  .mini__juris {
    padding: 1px 5px;
    border-radius: var(--m-radius-sm);
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .mini__title {
    font-size: var(--m-text-base);
    font-weight: 500;
    line-height: 1.3;
    color: var(--m-ink);
  }
  .mini__change {
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: var(--m-ink);
  }
  .mini__change s {
    color: var(--m-muted);
  }
  .mini__delta {
    padding: 0 5px;
    border-radius: 999px;
    font-family: var(--m-font-sans);
    font-size: var(--m-text-3xs);
    font-weight: 600;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 14%, transparent);
  }
  .mini__affect {
    margin-top: 9px;
    padding-top: 8px;
    border-top: 1px solid var(--m-hairline-2);
    font-size: var(--m-text-xs);
    color: var(--m-ink);
  }
  /* quiet recent activity below the lead alert — makes the panel a real "feed"
     and fills the tall lead cell instead of leaving it empty */
  .mini__recent {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--m-hairline-2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mini__recent-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: var(--m-text-2xs);
  }
  .mini__recent-org {
    flex: none;
    font-weight: 600;
    color: var(--m-ink-2);
  }
  .mini__recent-body {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--m-muted);
  }
  .mini__recent-when {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    color: var(--m-faint);
  }
  .mini__affect b {
    color: var(--m-accent);
  }
  /* coverage mini-map */
  .mini--map {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 1fr;
    gap: 4px;
  }
  .mini__tile {
    aspect-ratio: 1;
    border-radius: 4px;
    background: color-mix(in srgb, var(--m-accent) 8%, var(--m-surface));
  }
  .mini__tile.n {
    background: color-mix(in srgb, var(--m-accent) 30%, var(--m-surface));
  }
  .mini__tile.a {
    background: color-mix(in srgb, var(--m-urgent) 26%, var(--m-surface));
  }
  .mini__tile.r {
    background: color-mix(in srgb, var(--m-danger) 22%, var(--m-surface));
  }
  /* worklist mini */
  .mini--list {
    justify-content: flex-start;
  }
  .mini__row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }
  .mini__row + .mini__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .mini__bar {
    width: 4px;
    height: 18px;
    flex: none;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .mini__bar.hi {
    background: var(--m-urgent);
  }
  .mini__client {
    flex: 1;
    min-width: 0;
    font-size: var(--m-text-2xs);
    color: var(--m-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mini__status {
    flex: none;
    padding: 2px 7px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    line-height: 1.5;
    white-space: nowrap;
  }
  .mini__status.blocked {
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 9%, transparent);
  }
  .mini__status.review {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .mini__status.waiting {
    color: var(--m-muted);
    background: transparent;
    border: 1px solid var(--m-hairline);
  }
  .mini__due {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-3xs);
    color: var(--m-muted);
  }
  .mini__due.late {
    color: var(--m-urgent);
  }
  /* apply mini — full-width action bar, the resolving move of the workbench */
