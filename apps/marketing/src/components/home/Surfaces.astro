    border-radius: 8px;
    font-size: var(--m-text-xs);
    font-weight: 600;
    color: #fff;
    background: var(--m-accent);
  }
  .mini__applybtn svg {
    width: 13px;
    height: 13px;
  }
  .mini__audit {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mini__auditmark {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 7px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
  }
  .mini__auditmark svg {
    width: 11px;
    height: 11px;
  }
  .mini__audittrail {
