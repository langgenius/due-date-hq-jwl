---
/** Product surfaces — ONE unified product workbench. A single app-window frame
 *  (titlebar + jurisdiction tabs) holds four connected panels — Alerts, Coverage,
 *  Worklist, Apply & audit — sharing one continuous surface so the product reads as
 *  one strong place to work, not four loose cards. A caption rail below names each
 *  surface, keeping its one-line pitch + "See it" link. The minis reuse the exact
 *  chip vocabulary from the Hero feed and the See-it-work worklist. */
interface Props { locale?: 'en' | 'zh-CN' }
const { locale = 'en' } = Astro.props
const zh = locale === 'zh-CN'
const base = zh ? '/zh-CN' : ''
// coverage mini-map tile heat (24 tiles): '' faint · n navy · a urgent · r danger
const tiles = ['', '', 'n', '', 'r', '', '', 'a', '', '', '', 'n', 'r', '', '', 'a', '', '', '', '', 'r', '', '', '']

const t = zh
  ? {
      eyebrow: '产品',
      headingPre: '一个',
      headingItal: '工作台，',
      headingPost: '搞定一切。',
      intro: '从第一条提醒到应用变更——四个界面，一个让你安心工作的地方。',
      win: '美国税务截止日 · 实时',
      tabs: ['联邦', '德州', '加州', '佛州'],
      seeIt: '查看',
      cards: {
        alerts: {
          sev: '紧急',
          title: 'IRS 推迟申报截止日',
          affectPre: '影响 ',
          affectN: '8 家客户',
          panel: '提醒动态',
          t: '提醒',
          d: '实时动态——每条变更落地即呈现，按紧急程度排序。',
        },
        coverage: {
          panel: '覆盖',
          t: '覆盖',
          d: '一张地图涵盖所有辖区——看清变更落在何处。',
        },
        worklist: {
          rows: [
            { client: 'Hill Country Partners', status: '受阻', due: '逾期 2 天' },
            { client: 'Brightway Logistics', status: '审核中', due: '还剩 3 天' },
            { client: 'Cedar Park Dental', status: '等待中', due: '还剩 9 天' },
          ],
          panel: '工作清单',
          t: '工作清单',
          d: '客户按风险排序——一眼看出先打给谁。',
        },
        apply: {
          panel: '应用与审计',
          btn: '应用到 8 家客户',
          audit: '有来源 · 24 小时内可撤销 · 已记录',
          t: '应用与审计',
          d: '把变更推送给每一个受影响的人——背后留有完整记录。',
        },
      },
    }
  : {
      eyebrow: 'The product',
      headingPre: 'Everything in one ',
      headingItal: 'workbench.',
      headingPost: '',
      intro: 'From the first alert to the applied change — four surfaces, one calm place to work.',
      win: 'US tax deadlines · live',
      tabs: ['Federal', 'Texas', 'California', 'Florida'],
      seeIt: 'See it',
      cards: {
        alerts: {
          sev: 'Urgent',
          title: 'IRS postpones filing deadlines',
          affectPre: 'Affects ',
          affectN: '8 clients',
          panel: 'Alert feed',
          t: 'Alerts',
          d: 'The live feed — every change as it lands, sorted by severity.',
        },
        coverage: {
          panel: 'Coverage',
          t: 'Coverage',
          d: 'One map of every jurisdiction — see where changes are landing.',
        },
        worklist: {
          rows: [
            { client: 'Hill Country Partners', status: 'Blocked', due: '2d late' },
            { client: 'Brightway Logistics', status: 'In review', due: 'in 3d' },
            { client: 'Cedar Park Dental', status: 'Waiting', due: 'in 9d' },
          ],
          panel: 'Worklist',
          t: 'Worklist',
          d: 'Your clients in risk order — who to call first, at a glance.',
        },
        apply: {
          panel: 'Apply & audit',
          btn: 'Apply to 8 clients',
          audit: 'sourced · reversible 24h · logged',
          t: 'Apply & audit',
          d: 'Push a change to everyone it touches — with the full trail behind it.',
        },
      },
    }

const surfaces = [
  { key: 'alerts', href: `${base}/how-it-works#how`, c: t.cards.alerts },
  { key: 'coverage', href: `${base}/state-coverage`, c: t.cards.coverage },
  { key: 'worklist', href: `${base}/how-it-works#work`, c: t.cards.worklist },
  { key: 'apply', href: `${base}/security`, c: t.cards.apply },
]
---

<section class="m-section surfaces" aria-labelledby="surfaces-h" data-reveal>
  <div class="surfaces__head">
    <div>
      <p class="m-eyebrow">{t.eyebrow}</p>
      <h2 class="m-h2" id="surfaces-h">{t.headingPre}<span class="ital">{t.headingItal}</span>{t.headingPost}</h2>
    </div>
    <p class="surfaces__intro">
      {t.intro}
    </p>
  </div>

  <!-- One product window: titlebar + jurisdiction tabs + four connected panels -->
  <div class="bench" role="img" aria-label={t.headingPre + t.headingItal + t.headingPost}>
    <div class="bench__bar">
      <span class="bench__dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="bench__name">{t.win}</span>
      <span class="bench__tabs" aria-hidden="true">
        {t.tabs.map((tab, i) => <span class:list={['bench__tab', { on: i === 0 }]}>{tab}</span>)}
      </span>
    </div>

    <div class="bench__grid">
      <!-- Alerts — the lead panel -->
      <div class="panel panel--lead">
        <p class="panel__label">{t.cards.alerts.panel}</p>
        <div class="mini mini--alert">
          <div class="mini__sevrow">
            <span class="mini__sev">{t.cards.alerts.sev}</span>
            <span class="mini__juris">FED</span>
          </div>
          <p class="mini__title">{t.cards.alerts.title}</p>
          <div class="mini__change"><s>Apr 15</s> → <b>Nov 3</b> <span class="mini__delta">+202d</span></div>
          <p class="mini__affect">{t.cards.alerts.affectPre}<b>{t.cards.alerts.affectN}</b></p>
        </div>
      </div>

      <!-- Coverage -->
      <div class="panel panel--coverage">
        <p class="panel__label">{t.cards.coverage.panel}</p>
        <div class="mini mini--map" aria-hidden="true">
          {tiles.map((tile) => <span class:list={['mini__tile', tile]} />)}
        </div>
      </div>

      <!-- Worklist -->
      <div class="panel panel--list">
        <p class="panel__label">{t.cards.worklist.panel}</p>
        <div class="mini mini--list">
          <div class="mini__row">
            <span class="mini__bar hi"></span>
            <span class="mini__client">{t.cards.worklist.rows[0].client}</span>
            <span class="mini__status blocked">{t.cards.worklist.rows[0].status}</span>
            <span class="mini__due late">{t.cards.worklist.rows[0].due}</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">{t.cards.worklist.rows[1].client}</span>
            <span class="mini__status review">{t.cards.worklist.rows[1].status}</span>
            <span class="mini__due">{t.cards.worklist.rows[1].due}</span>
          </div>
          <div class="mini__row">
            <span class="mini__bar"></span>
            <span class="mini__client">{t.cards.worklist.rows[2].client}</span>
            <span class="mini__status waiting">{t.cards.worklist.rows[2].status}</span>
            <span class="mini__due">{t.cards.worklist.rows[2].due}</span>
          </div>
        </div>
      </div>

      <!-- Apply & audit -->
      <div class="panel panel--apply">
        <p class="panel__label">{t.cards.apply.panel}</p>
        <div class="mini mini--apply">
          <span class="mini__applybtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 9-12h-7z" />
            </svg>
            {t.cards.apply.btn}
          </span>
          <p class="mini__audit">{t.cards.apply.audit}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Caption rail — names each surface, keeps its pitch + link -->
  <ul class="legend">
    {surfaces.map((s, i) => (
      <li class="legend__item">
        <span class="legend__n" aria-hidden="true">{'0' + (i + 1)}</span>
        <div class="legend__body">
          <h3 class="legend__t">{s.c.t}</h3>
          <p class="legend__d">{s.c.d}</p>
          <a class="legend__link" href={s.href}>{t.seeIt} <span aria-hidden="true">→</span></a>
        </div>
      </li>
    ))}
  </ul>
</section>

<style>
  .surfaces__head {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--m-col-gap);
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
  }
  .surfaces__head > :nth-child(1) {
    grid-column: span 7;
  }
  .surfaces__head > :nth-child(2) {
    grid-column: span 5;
  }
  .surfaces__head .m-h2 {
    max-width: 14ch;
  }
  .surfaces__intro {
    max-width: 42ch;
    font-size: 16px;
    line-height: 1.55;
    color: var(--m-muted);
  }

  /* ── One product window ─────────────────────────────────────────────────── */
  .bench {
    margin-top: clamp(34px, 4vw, 52px);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    background: var(--m-surface);
    box-shadow: 0 1px 3px -1px color-mix(in srgb, var(--m-ink) 10%, transparent);
    overflow: hidden;
  }
  .bench__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 38px;
    padding: 0 14px;
    border-bottom: 1px solid var(--m-hairline);
    background: var(--m-section);
  }
  .bench__dots {
    display: inline-flex;
    gap: 5px;
    flex: none;
  }
  .bench__dots i {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .bench__name {
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-muted);
    white-space: nowrap;
  }
  .bench__tabs {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }
  .bench__tab {
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 500;
    color: var(--m-muted);
    white-space: nowrap;
  }
  .bench__tab.on {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  @media (max-width: 560px) {
    .bench__tab:nth-child(n + 3) {
      display: none;
    }
  }

  /* Connected panels — one continuous surface, hairline-divided (no boxes).
     Bento: Alerts leads (tall, left), the three supporting panels stack right. */
  .bench__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    grid-template-rows: auto auto;
    grid-template-areas:
      'lead coverage'
      'lead list'
      'apply apply';
  }
  .panel {
    display: flex;
    flex-direction: column;
    padding: clamp(14px, 1.4vw, 18px);
  }
  /* hairline seams between connected panels — drawn with insets, never a box */
  .panel--lead {
    grid-area: lead;
    border-right: 1px solid var(--m-hairline-2);
    border-bottom: 1px solid var(--m-hairline-2);
    background:
      linear-gradient(color-mix(in srgb, var(--m-accent) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--m-accent) 5%, transparent) 1px, transparent 1px);
    background-size: 15px 15px;
  }
  .panel--coverage {
    grid-area: coverage;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .panel--list {
    grid-area: list;
    border-bottom: 1px solid var(--m-hairline-2);
  }
  .panel--apply {
    grid-area: apply;
  }
  .panel__label {
    margin-bottom: 10px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--m-faint);
  }

  /* embedded product mini-UI fragments — the surface IS the lift, no inner box */
  .mini {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .mini--alert {
    justify-content: flex-start;
  }
  .mini__sevrow {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }
  .mini__sev {
    padding: 1px 6px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 10%, transparent);
  }
  .mini__juris {
    padding: 1px 5px;
    border-radius: 5px;
    font-family: var(--m-font-mono);
    font-size: 9px;
    font-weight: 600;
    color: var(--m-ink-2);
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
  }
  .mini__title {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--m-ink);
  }
  .mini__change {
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--m-font-mono);
    font-size: 12px;
    color: var(--m-ink);
  }
  .mini__change s {
    color: var(--m-muted);
  }
  .mini__delta {
    padding: 0 5px;
    border-radius: 999px;
    font-family: var(--m-font-sans);
    font-size: 9px;
    font-weight: 600;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 14%, transparent);
  }
  .mini__affect {
    margin-top: 9px;
    padding-top: 8px;
    border-top: 1px solid var(--m-hairline-2);
    font-size: 12px;
    color: var(--m-ink);
  }
  .mini__affect b {
    color: var(--m-accent);
  }
  /* coverage mini-map */
  .mini--map {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
  }
  .mini__tile {
    aspect-ratio: 1;
    border-radius: 4px;
    background: color-mix(in srgb, var(--m-accent) 8%, var(--m-surface));
  }
  .mini__tile.n {
    background: color-mix(in srgb, var(--m-accent) 30%, var(--m-surface));
  }
  .mini__tile.a {
    background: color-mix(in srgb, var(--m-urgent) 26%, var(--m-surface));
  }
  .mini__tile.r {
    background: color-mix(in srgb, var(--m-danger) 22%, var(--m-surface));
  }
  /* worklist mini */
  .mini--list {
    justify-content: flex-start;
  }
  .mini__row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }
  .mini__row + .mini__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .mini__bar {
    width: 4px;
    height: 18px;
    flex: none;
    border-radius: 999px;
    background: var(--m-hairline);
  }
  .mini__bar.hi {
    background: var(--m-urgent);
  }
  .mini__client {
    flex: 1;
    min-width: 0;
    font-size: 11px;
    color: var(--m-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mini__status {
    flex: none;
    padding: 2px 7px;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 600;
    line-height: 1.5;
    white-space: nowrap;
  }
  .mini__status.blocked {
    color: var(--m-danger);
    background: color-mix(in srgb, var(--m-danger) 9%, transparent);
  }
  .mini__status.review {
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .mini__status.waiting {
    color: var(--m-muted);
    background: transparent;
    border: 1px solid var(--m-hairline);
  }
  .mini__due {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: 10px;
    color: var(--m-muted);
  }
  .mini__due.late {
    color: var(--m-urgent);
  }
  /* apply mini — full-width action bar, the resolving move of the workbench */
  .mini--apply {
    flex-direction: row;
    align-items: center;
    gap: 14px;
  }
  .mini__applybtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex: none;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    background: var(--m-accent);
  }
  .mini__applybtn svg {
    width: 13px;
    height: 13px;
  }
  .mini__audit {
    font-family: var(--m-font-mono);
    font-size: 11px;
    color: var(--m-muted);
  }

  /* ── Caption rail — names each surface ─────────────────────────────────── */
  .legend {
    margin-top: clamp(28px, 3vw, 40px);
    padding-top: clamp(24px, 3vw, 36px);
    border-top: 1px solid var(--m-hairline);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(20px, 2.4vw, 36px);
    list-style: none;
  }
  .legend__item {
    display: flex;
    gap: 12px;
  }
  .legend__n {
    flex: none;
    font-family: var(--m-font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--m-faint);
    padding-top: 1px;
  }
  .legend__t {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .legend__d {
    margin-top: 6px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--m-muted);
  }
  .legend__link {
    margin-top: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--m-accent);
    transition: gap 0.15s ease;
  }
  .legend__link:hover {
    gap: 9px;
  }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 1000px) {
    .surfaces__head {
      grid-template-columns: 1fr;
      gap: 14px;
      align-items: start;
    }
    .surfaces__head > :nth-child(n) {
      grid-column: auto;
    }
    .legend {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 720px) {
    /* the four panels stack into one column — the window stays whole, never clipped */
    .bench__grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        'lead'
        'coverage'
        'list'
        'apply';
    }
    .panel--lead {
      border-right: none;
    }
    .mini--apply {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
    .mini__applybtn {
      width: 100%;
    }
  }
  @media (max-width: 560px) {
    .legend {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
</style>
