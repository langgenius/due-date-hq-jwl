---
import type { SecurityCopy } from '../i18n/types'

interface Props {
  t: SecurityCopy
}

const { t } = Astro.props
---

<section id="security" class="border-b border-border-default bg-bg-canvas">
  <div class="mx-auto flex max-w-[1440px] flex-col items-start gap-x-10 gap-y-5 px-6 py-10 sm:px-10 lg:flex-row lg:items-center lg:px-20">
    <span class="font-mono text-sm tracking-[0.18em] text-text-muted">{t.title}</span>
    <div class="grid flex-1 gap-x-8 gap-y-3 sm:grid-cols-2 lg:flex lg:flex-wrap lg:items-center">
      {t.items.map((item) => (
        <span class="inline-flex items-center gap-2 text-description">
          <span class="block h-1.5 w-1.5 rounded-full bg-status-done"></span>
          <span class="font-medium text-text-primary">{item.pill}</span>
          <span class="text-text-secondary">{item.body}</span>
        </span>
      ))}
    </div>
  </div>
</section>
