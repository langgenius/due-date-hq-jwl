---
/** StateDetailPage — per-state coverage leaf (/states/[state]). Uses the shared
 *  long-tail page kit; 2-col source/faq grids are scoped. */
import type { StatePageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON, type OfficialSourceLink } from '../lib/content-metadata'

interface Props {
  page: StatePageCopy
  coverageHref: string
  locale: 'en' | 'zh-CN'
  officialSources: OfficialSourceLink[]
}

const { page, coverageHref, locale, officialSources } = Astro.props
const labels =
  locale === 'zh-CN'
    ? {
        sourceEyebrow: '来源类型',
        sourceTitle: `${page.name} 的公开来源监控范围。`,
        officialSourcesEyebrow: '官方来源',
        officialSourcesTitle: '公开来源参考。',
        signalsEyebrow: '覆盖信号',
        signalsTitle: '哪些信号可以成为复核工作。',
        limitsEyebrow: '覆盖边界',
        limitsTitle: '覆盖边界。',
        faqEyebrow: 'FAQ',
        faqTitle: `${page.name} 覆盖常见问题。`,
        lastReviewed: '最近复核',
      }
    : {
        sourceEyebrow: 'SOURCE TYPES',
        sourceTitle: `Public sources DueDateHQ monitors for ${page.name}.`,
        officialSourcesEyebrow: 'OFFICIAL SOURCES',
        officialSourcesTitle: 'Public source references.',
        signalsEyebrow: 'COVERED SIGNALS',
        signalsTitle: 'What can become review work.',
        limitsEyebrow: 'LIMITS',
        limitsTitle: 'Coverage boundaries.',
        faqEyebrow: 'FAQ',
        faqTitle: `${page.name} coverage questions.`,
        lastReviewed: 'Last reviewed',
      }
---

<main>
  <section class="m-section m-page-hero" id="hero">
    <a href={coverageHref} class="m-eyebrow std__back">{page.hero.eyebrow}</a>
    <h1 class="m-page-title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {labels.lastReviewed}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  {
    page.keyDeadlines && (
      <section class="m-section m-page-block">
        <p class="m-eyebrow">{page.keyDeadlines.eyebrow}</p>
        <h2 class="m-page-h2">{page.keyDeadlines.title}</h2>
        <dl class="m-page-dl">
          {page.keyDeadlines.rows.map((row) => (
            <div class="m-page-dl__row">
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))}
        </dl>
        <p class="m-page-note">{page.keyDeadlines.note}</p>
        <p class="std__sourcewrap">
          <a class="m-link" href={page.keyDeadlines.sourceHref} rel="noreferrer" target="_blank">
            {page.keyDeadlines.sourceLabel}
          </a>
        </p>
      </section>
    )
  }

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{labels.sourceEyebrow}</p>
        <h2 class="m-page-h2">{labels.sourceTitle}</h2>
      </div>
      <div class="m-page-cards">
        {
          page.sourceTypes.map((item) => (
            <article class="m-card">
              <h3 class="m-card__t">{item.title}</h3>
              <p class="m-card__d">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{labels.officialSourcesEyebrow}</p>
    <h2 class="m-page-h2">{labels.officialSourcesTitle}</h2>
    <ul class="std__grid2">
      {
        officialSources.map((source) => (
          <li class="m-card">
            <a class="m-link m-link--strong" href={source.href} rel="noreferrer" target="_blank">
              {source.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{labels.signalsEyebrow}</p>
        <h2 class="m-page-h2">{labels.signalsTitle}</h2>
      </div>
      <div class="m-page-cards">
        {
          page.coveredSignals.map((item) => (
            <article class="m-card">
              <h3 class="m-card__t">{item.title}</h3>
              <p class="m-card__d">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{labels.limitsEyebrow}</p>
    <h2 class="m-page-h2">{labels.limitsTitle}</h2>
    <ul class="m-page-grid-3">
      {
        page.limitations.map((item) => (
          <li class="m-card">
            <p class="m-card__d std__limit">{item}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{labels.faqEyebrow}</p>
    <h2 class="m-page-h2">{labels.faqTitle}</h2>
    <div class="std__grid2">
      {
        page.faq.map((item) => (
          <section class="m-card">
            <h3 class="m-card__t">{item.question}</h3>
            <p class="m-card__d">{item.answer}</p>
          </section>
        ))
      }
    </div>
  </section>
</main>

<style>
  .std__back {
    transition: color 0.18s ease;
  }
  .std__back:hover {
    color: var(--m-accent);
  }
  .std__sourcewrap {
    margin-top: 14px;
  }
  .m-link {
    font-size: 13px;
    color: var(--m-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .m-link:hover {
    color: var(--m-accent-strong);
  }
  .m-link--strong {
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }
  .std__limit {
    margin-top: 0;
  }
  .std__grid2 {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(14px, 1.6vw, 18px);
  }
  @media (max-width: 720px) {
    .std__grid2 {
      grid-template-columns: 1fr;
    }
  }
</style>
