---
/** StateDetailPage — per-state coverage leaf (/states/[state]). Uses the shared
 *  long-tail page kit; the hero chrome, key-deadline signature module, source/
 *  signal splits, official-source cards, and the cross-link footer are scoped.
 *
 *  Design intent: clearer decision hierarchy for a CPA landing here — lead with
 *  the verified, sourced filing deadline (when we have one), then "what we
 *  watch", the official sources to verify against, what can become review work,
 *  honest limits, FAQ, and a cross-link footer back to the hub + neighbors. */
import type { StatePageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON, type OfficialSourceLink } from '../lib/content-metadata'
import FaqList from './FaqList.astro'

interface Props {
  page: StatePageCopy
  coverageHref: string
  locale: 'en' | 'zh-CN'
  officialSources: OfficialSourceLink[]
}

const { page, coverageHref, locale, officialSources } = Astro.props
const zh = locale === 'zh-CN'
const prefix = zh ? '/zh-CN' : ''

const labels = zh
  ? {
      backToHub: '州覆盖',
      jurisdiction: '辖区',
      watchedLive: '实时监控',
      deadlineSourceLead: '日期出处',
      sourceEyebrow: '来源类型',
      sourceTitle: `我们为 ${page.name} 监控哪些公开来源。`,
      officialSourcesEyebrow: '官方来源',
      officialSourcesTitle: '自行核对的公开来源。',
      officialSourcesBody: '每条变化都链接回它的官方来源。下面是核对来源时优先参考的页面。',
      openSource: '打开来源',
      signalsEyebrow: '覆盖信号',
      signalsTitle: '哪些信号可以成为复核工作。',
      limitsEyebrow: '覆盖边界',
      limitsTitle: '我们承诺什么，不承诺什么。',
      faqEyebrow: 'FAQ',
      faqTitle: `${page.name} 覆盖常见问题。`,
      lastReviewed: '最近复核',
      moreEyebrow: '继续浏览',
      moreTitle: '其他州的覆盖详情。',
      allStates: '查看全部 50 州 + DC',
      ctaTitle: `看看 ${page.name} 的一次变化会如何成为你事务所的工作。`,
      ctaBody: '候选变化带着来源进入复核 —— 由你判断它是否影响你的客户，再决定是否应用。',
      ctaPrimary: '免费开始',
      ctaNote: 'beta 期间免费 · 无需信用卡',
    }
  : {
      backToHub: 'State coverage',
      jurisdiction: 'Jurisdiction',
      watchedLive: 'Watched live',
      deadlineSourceLead: 'Source for this date',
      sourceEyebrow: 'SOURCE TYPES',
      sourceTitle: `Public sources we monitor for ${page.name}.`,
      officialSourcesEyebrow: 'OFFICIAL SOURCES',
      officialSourcesTitle: 'Verify against the public source.',
      officialSourcesBody:
        'Every change links back to its official source. These are the pages we reference first when verifying.',
      openSource: 'Open source',
      signalsEyebrow: 'COVERED SIGNALS',
      signalsTitle: 'What can become review work.',
      limitsEyebrow: 'LIMITS',
      limitsTitle: 'What we promise — and what we don’t.',
      faqEyebrow: 'FAQ',
      faqTitle: `${page.name} coverage questions.`,
      lastReviewed: 'Last reviewed',
      moreEyebrow: 'Keep exploring',
      moreTitle: 'Coverage for other states.',
      allStates: 'See all 50 states + DC',
      ctaTitle: `See how a ${page.name} change becomes work for your firm.`,
      ctaBody:
        'Candidate changes arrive with their source and route through review — you decide whether they touch your clients, then apply.',
      ctaPrimary: 'Start free',
      ctaNote: 'Free during the beta · no card required',
    }

// Published detail pages (the real, linkable leaves). Kept here only to power the
// cross-link footer — content stays in seo-content.ts. Order is curated so the
// most-relevant neighbors (geographic / economic) lead for each state.
const PUBLISHED: { slug: string; name: string; abbr: string }[] = [
  { slug: 'california', name: 'California', abbr: 'CA' },
  { slug: 'new-york', name: 'New York', abbr: 'NY' },
  { slug: 'texas', name: 'Texas', abbr: 'TX' },
  { slug: 'florida', name: 'Florida', abbr: 'FL' },
  { slug: 'washington', name: 'Washington', abbr: 'WA' },
  { slug: 'illinois', name: 'Illinois', abbr: 'IL' },
  { slug: 'new-jersey', name: 'New Jersey', abbr: 'NJ' },
  { slug: 'pennsylvania', name: 'Pennsylvania', abbr: 'PA' },
  { slug: 'georgia', name: 'Georgia', abbr: 'GA' },
  { slug: 'massachusetts', name: 'Massachusetts', abbr: 'MA' },
  { slug: 'north-carolina', name: 'North Carolina', abbr: 'NC' },
  { slug: 'arizona', name: 'Arizona', abbr: 'AZ' },
  { slug: 'colorado', name: 'Colorado', abbr: 'CO' },
  { slug: 'ohio', name: 'Ohio', abbr: 'OH' },
  { slug: 'michigan', name: 'Michigan', abbr: 'MI' },
]
// Other published states (exclude the current one), capped to a tidy row of 6.
const neighbors = PUBLISHED.filter((s) => s.slug !== page.slug).slice(0, 6)
---

<main>
  <section class="m-section m-page-hero std-hero" id="hero">
    <nav class="std-hero__bc" aria-label="Breadcrumb">
      <a href={coverageHref} class="m-page-back">
        <span class="m-page-back__arrow" aria-hidden="true">←</span>{labels.backToHub}
      </a>
      <span class="std-hero__chip">
        <span class="std-hero__chip-abbr">{page.abbreviation}</span>
        <span class="std-hero__chip-live" aria-hidden="true"></span>
        {labels.watchedLive}
      </span>
    </nav>
    <h1 class="m-page-title std-hero__title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {labels.lastReviewed}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  {
    page.keyDeadlines && (
      <section class="m-section m-page-block" aria-labelledby="std-kd-h">
        <p class="m-eyebrow">{page.keyDeadlines.eyebrow}</p>
        <h2 class="m-page-h2" id="std-kd-h">{page.keyDeadlines.title}</h2>
        <div class="std-kd">
          <dl class="std-kd__dl">
            {page.keyDeadlines.rows.map((row) => (
              <div class="std-kd__row">
                <dt>{row.label}</dt>
                <dd>{row.value}</dd>
              </div>
            ))}
          </dl>
          <div class="std-kd__foot">
            <p class="std-kd__note">{page.keyDeadlines.note}</p>
            <a
              class="std-kd__source"
              href={page.keyDeadlines.sourceHref}
              rel="noreferrer"
              target="_blank"
            >
              <span class="std-kd__source-lead">{labels.deadlineSourceLead}</span>
              <span class="std-kd__source-label">
                {page.keyDeadlines.sourceLabel}
                <span class="std-ext" aria-hidden="true">↗</span>
              </span>
            </a>
          </div>
        </div>
      </section>
    )
  }

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{labels.sourceEyebrow}</p>
        <h2 class="m-page-h2">{labels.sourceTitle}</h2>
      </div>
      <div class="m-page-cards">
        {
          page.sourceTypes.map((item) => (
            <article class="m-card">
              <h3 class="m-card__t">{item.title}</h3>
              <p class="m-card__d">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{labels.officialSourcesEyebrow}</p>
        <h2 class="m-page-h2">{labels.officialSourcesTitle}</h2>
        <p class="m-page-body">{labels.officialSourcesBody}</p>
      </div>
      <ul class="std-src__list">
        {
          officialSources.map((source) => (
            <li>
              <a class="std-src" href={source.href} rel="noreferrer" target="_blank">
                <span class="std-src__label">{source.label}</span>
                <span class="std-src__go">
                  {labels.openSource}
                  <span class="std-ext" aria-hidden="true">↗</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{labels.signalsEyebrow}</p>
        <h2 class="m-page-h2">{labels.signalsTitle}</h2>
      </div>
      <div class="m-page-cards">
        {
          page.coveredSignals.map((item) => (
            <article class="m-card">
              <h3 class="m-card__t">{item.title}</h3>
              <p class="m-card__d">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{labels.limitsEyebrow}</p>
    <h2 class="m-page-h2">{labels.limitsTitle}</h2>
    <ul class="std-limits">
      {
        page.limitations.map((item) => (
          <li class="std-limit">
            <span class="std-limit__mark" aria-hidden="true">—</span>
            <p class="std-limit__text">{item}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="m-section m-page-block">
    <FaqList eyebrow={labels.faqEyebrow} title={labels.faqTitle} items={page.faq} />
  </section>

  <!-- Cross-link footer: neighbors + back to the full roster, then a clean CTA -->
  {
    neighbors.length > 0 && (
      <section class="m-section m-page-block">
        <div class="std-more__head">
          <div>
            <p class="m-eyebrow">{labels.moreEyebrow}</p>
            <h2 class="m-page-h2">{labels.moreTitle}</h2>
          </div>
          <a class="std-more__all" href={coverageHref}>
            {labels.allStates} <span aria-hidden="true">→</span>
          </a>
        </div>
        <ul class="std-more__grid">
          {neighbors.map((s) => (
            <li>
              <a class="std-more__card" href={`${prefix}/states/${s.slug}`}>
                <span class="std-more__abbr">{s.abbr}</span>
                <span class="std-more__name">{s.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="m-section m-page-block">
    <div class="m-page-cta">
      <div>
        <h2 class="m-page-cta__title">{labels.ctaTitle}</h2>
        <p class="m-page-cta__body">{labels.ctaBody}</p>
        <p class="std-cta__note">{labels.ctaNote}</p>
      </div>
      <div class="m-page-cta__btns">
        <a class="m-btn m-btn--primary" href={prefix === '' ? '/' : prefix}>{labels.ctaPrimary}</a>
        <a class="m-btn m-btn--secondary" href={coverageHref}>{labels.backToHub}</a>
      </div>
    </div>
  </section>
</main>

<style>
  /* ---- hero chrome: breadcrumb back + jurisdiction chip + serif title ---- */
  .std-hero__bc {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 16px;
    margin-bottom: 18px;
  }
  /* back-link uses the shared .m-page-back kit; only neutralise its bottom
     margin inside the breadcrumb row (the row owns the gap to the title) */
  .std-hero__bc .m-page-back {
    margin-bottom: 0;
  }
  .std-hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 12px 4px 6px;
    border-radius: 999px;
    border: 1px solid var(--m-hairline);
    background: var(--m-surface);
    font-size: var(--m-text-2xs);
    font-weight: 500;
    color: var(--m-muted);
  }
  .std-hero__chip-abbr {
    display: inline-grid;
    place-items: center;
    height: 20px;
    padding-inline: 7px;
    border-radius: 999px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    color: #fff;
    background: var(--m-accent);
  }
  .std-hero__chip-live {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--m-ok);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--m-ok) 18%, transparent);
  }
  .std-hero__title {
    font-family: var(--m-font-display);
    font-weight: 400;
    font-size: var(--m-page-title-size);
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 22ch;
  }

  /* ---- key-deadline signature module: the verified sourced fact ---- */
  .std-kd {
    margin-top: 28px;
    max-width: 880px;
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--m-surface);
  }
  .std-kd__dl {
    margin: 0;
  }
  .std-kd__row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    align-items: baseline;
    padding: 16px 24px;
  }
  .std-kd__row + .std-kd__row {
    border-top: 1px solid var(--m-hairline-2);
  }
  .std-kd__row dt {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-muted);
  }
  .std-kd__row dd {
    margin: 0;
    font-size: var(--m-text-lg);
    font-weight: 500;
    line-height: 1.5;
    color: var(--m-ink);
  }
  .std-kd__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 24px;
    background: var(--m-section);
    border-top: 1px solid var(--m-hairline-2);
  }
  .std-kd__note {
    max-width: 52ch;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-2xs);
    line-height: 1.5;
    color: var(--m-muted);
  }
  .std-kd__source {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    text-align: right;
    margin-left: auto;
  }
  .std-kd__source-lead {
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--m-faint);
  }
  .std-kd__source-label {
    font-size: var(--m-text-sm);
    font-weight: 500;
    color: var(--m-accent);
  }
  .std-kd__source:hover .std-kd__source-label {
    color: var(--m-accent-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .std-ext {
    margin-left: 4px;
    font-family: var(--m-font-mono);
    font-size: 0.85em;
  }

  /* ---- official sources: external-link cards ---- */
  .std-src__list {
    grid-column: span 7;
    display: grid;
    gap: clamp(12px, 1.4vw, 14px);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .std-src {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .std-src:hover {
    border-color: var(--m-accent);
    box-shadow: 0 4px 12px -8px rgba(16, 24, 40, 0.4);
  }
  .std-src__label {
    font-size: var(--m-text-base);
    font-weight: 500;
    line-height: 1.45;
    color: var(--m-ink);
  }
  .std-src__go {
    flex: none;
    display: inline-flex;
    align-items: center;
    font-size: var(--m-text-xs);
    font-weight: 600;
    color: var(--m-accent);
    white-space: nowrap;
  }

  /* ---- limits: calm, restrained list (no boxes) ---- */
  .std-limits {
    margin-top: 28px;
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    max-width: 80ch;
  }
  .std-limit {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 18px 0;
  }
  .std-limit + .std-limit {
    border-top: 1px solid var(--m-hairline-2);
  }
  .std-limit__mark {
    flex: none;
    font-family: var(--m-font-mono);
    color: var(--m-faint);
  }
  .std-limit__text {
    font-size: var(--m-text-md);
    line-height: 1.6;
    color: var(--m-ink-2);
  }


  /* ---- cross-link footer ---- */
  .std-more__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  .std-more__all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--m-text-sm);
    font-weight: 600;
    color: var(--m-accent);
    white-space: nowrap;
  }
  .std-more__all span {
    transition: transform 0.18s ease;
  }
  .std-more__all:hover span {
    transform: translateX(3px);
  }
  .std-more__grid {
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(10px, 1.2vw, 14px);
    list-style: none;
    padding: 0;
  }
  .std-more__card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .std-more__card:hover {
    border-color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .std-more__abbr {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-sm);
    font-weight: 600;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .std-more__card:hover .std-more__abbr {
    color: #fff;
    background: var(--m-accent);
  }
  .std-more__name {
    font-size: var(--m-text-sm);
    font-weight: 500;
    line-height: 1.35;
    color: var(--m-ink);
  }

  .std-cta__note {
    margin-top: 16px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    color: var(--m-muted);
  }

  @media (max-width: 1023px) {
    .std-src__list {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 900px) {
    .std-more__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (max-width: 720px) {
    .std-kd__row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .std-kd__foot {
      flex-direction: column;
      align-items: flex-start;
    }
    .std-kd__source {
      text-align: left;
      margin-left: 0;
    }
  }
  @media (max-width: 560px) {
    .std-more__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .std-src {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>
