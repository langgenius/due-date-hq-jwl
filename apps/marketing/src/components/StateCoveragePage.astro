---
/** StateCoveragePage — the /state-coverage hub. Uses the shared long-tail page
 *  kit; the state-card grid is page-specific (scoped). */
import type { StateCoverageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'

interface Props {
  page: StateCoverageCopy
  locale: 'en' | 'zh-CN'
}

const { page, locale } = Astro.props
const viewCoverageLabel = locale === 'zh-CN' ? '查看覆盖' : 'View coverage'
const lastReviewedLabel = locale === 'zh-CN' ? '最近复核' : 'Last reviewed'
---

<main>
  <section class="m-section m-page-hero" id="hero">
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class="m-page-title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>
    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {lastReviewedLabel}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{page.statesHeader.eyebrow}</p>
    <h2 class="m-page-h2">{page.statesHeader.title}</h2>
    <div class="stcov__grid">
      {
        page.states.map((state) => (
          <a href={state.href} class="stcov__card">
            <div class="stcov__top">
              <span class="stcov__abbr">{state.abbreviation}</span>
              <span class="stcov__status">{state.status}</span>
            </div>
            <h3 class="stcov__name">{state.name}</h3>
            <p class="stcov__body">{state.body}</p>
            <span class="stcov__view">{viewCoverageLabel} <span aria-hidden="true">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-split">
      <div class="m-page-split__lead">
        <p class="m-eyebrow">{page.sourceModel.eyebrow}</p>
        <h2 class="m-page-h2">{page.sourceModel.title}</h2>
        <p class="m-page-body">{page.sourceModel.body}</p>
      </div>
      <div class="m-page-cards">
        {
          page.sourceModel.items.map((item) => (
            <article class="m-card">
              <h3 class="m-card__t">{item.title}</h3>
              <p class="m-card__d">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="m-section m-page-block">
    <p class="m-eyebrow">{page.faqHeader.eyebrow}</p>
    <h2 class="m-page-h2">{page.faqHeader.title}</h2>
    <div class="m-page-grid-3">
      {
        page.faq.map((item) => (
          <section class="m-card">
            <h3 class="m-card__t">{item.question}</h3>
            <p class="m-card__d">{item.answer}</p>
          </section>
        ))
      }
    </div>
  </section>
</main>

<style>
  .stcov__grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(12px, 1.4vw, 16px);
  }
  .stcov__card {
    display: flex;
    flex-direction: column;
    padding: 18px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .stcov__card:hover {
    border-color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .stcov__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .stcov__abbr {
    font-family: var(--m-font-mono);
    font-size: 22px;
    font-weight: 600;
    color: var(--m-ink);
  }
  .stcov__status {
    padding: 2px 7px;
    border-radius: 4px;
    font-family: var(--m-font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--m-accent);
    background: var(--m-accent-tint);
  }
  .stcov__name {
    margin-top: 16px;
    font-size: 15px;
    font-weight: 600;
    color: var(--m-ink);
  }
  .stcov__body {
    margin-top: 8px;
    font-size: 13px;
    line-height: 1.55;
    color: var(--m-muted);
  }
  .stcov__view {
    margin-top: 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--m-accent);
  }
  @media (max-width: 1100px) {
    .stcov__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 700px) {
    .stcov__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 460px) {
    .stcov__grid {
      grid-template-columns: 1fr;
    }
  }
  .stcov__card:hover .stcov__status {
    background: color-mix(in srgb, var(--m-accent) 16%, var(--m-surface));
  }
</style>
