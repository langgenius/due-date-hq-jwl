---
import type { StateCoverageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'

interface Props {
  page: StateCoverageCopy
  locale: 'en' | 'zh-CN'
}

const { page, locale } = Astro.props
const viewCoverageLabel = locale === 'zh-CN' ? '查看覆盖' : 'View coverage'
const lastReviewedLabel = locale === 'zh-CN' ? '最近复核' : 'Last reviewed'
---

<main>
  <section id="hero" class="border-b border-border-default bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-16 md:px-12 lg:px-20 lg:py-20">
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {page.hero.eyebrow}
      </span>
      <h1
        class="mt-5 max-w-[920px] text-display-large font-semibold leading-[1.1] tracking-tight text-text-primary"
      >
        {page.hero.title}
      </h1>
      <p class="mt-5 max-w-[820px] text-[17px] leading-[1.65] text-text-secondary">
        {page.hero.description}
      </p>
      <p class="mt-6 max-w-[780px] font-mono text-[12px] leading-5 text-text-muted">
        {page.hero.note}
      </p>
      <p class="mt-4 font-mono text-[12px] text-text-muted">
        {lastReviewedLabel}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
      </p>
    </div>
  </section>

  <section class="border-b border-border-default bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-14 md:px-12 lg:px-20 lg:py-16">
      <header class="flex flex-col gap-2">
        <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
          {page.statesHeader.eyebrow}
        </span>
        <h2 class="text-[24px] font-semibold leading-[1.25] tracking-tight text-text-primary">
          {page.statesHeader.title}
        </h2>
      </header>
      <div class="mt-8 grid gap-4 lg:grid-cols-5">
        {
          page.states.map((state) => (
            <a
              href={state.href}
              class="group rounded-xl border border-border-default bg-bg-panel p-5 outline-none transition-colors hover:border-accent-default hover:bg-bg-elevated focus-visible:ring-2 focus-visible:ring-state-accent-active-alt"
            >
              <div class="flex items-center justify-between gap-3">
                <span class="font-mono text-[24px] font-semibold text-text-primary">
                  {state.abbreviation}
                </span>
                <span class="rounded-sm bg-accent-tint px-2 py-1 font-mono text-[10px] font-medium tracking-eyebrow text-text-accent">
                  {state.status}
                </span>
              </div>
              <h3 class="mt-5 text-[16px] font-semibold text-text-primary">{state.name}</h3>
              <p class="mt-3 text-[13px] leading-[1.6] text-text-secondary">{state.body}</p>
              <span class="mt-5 inline-flex text-[12px] font-medium text-text-accent">
                {viewCoverageLabel}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-b border-border-default bg-bg-canvas">
    <div class="mx-auto grid max-w-[1440px] gap-10 px-6 py-14 md:px-12 lg:grid-cols-12 lg:px-20 lg:py-16">
      <div class="lg:col-span-5">
        <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
          {page.sourceModel.eyebrow}
        </span>
        <h2 class="mt-4 text-[28px] font-semibold leading-[1.2] tracking-tight text-text-primary">
          {page.sourceModel.title}
        </h2>
        <p class="mt-5 text-[15px] leading-[1.7] text-text-secondary">
          {page.sourceModel.body}
        </p>
      </div>
      <div class="grid gap-4 lg:col-span-7 lg:grid-cols-3">
        {
          page.sourceModel.items.map((item) => (
            <article class="rounded-xl border border-border-default bg-bg-panel p-6">
              <h3 class="text-[15px] font-semibold leading-[1.4] text-text-primary">
                {item.title}
              </h3>
              <p class="mt-3 text-[13px] leading-[1.65] text-text-secondary">
                {item.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-bg-canvas">
    <div class="mx-auto max-w-[1440px] px-6 py-14 md:px-12 lg:px-20 lg:py-16">
      <span class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-accent">
        {page.faqHeader.eyebrow}
      </span>
      <h2 class="mt-4 text-[24px] font-semibold leading-[1.25] tracking-tight text-text-primary">
        {page.faqHeader.title}
      </h2>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {
          page.faq.map((item) => (
            <section class="rounded-xl border border-border-default bg-bg-panel p-6">
              <h3 class="text-[15px] font-semibold leading-[1.4] text-text-primary">
                {item.question}
              </h3>
              <p class="mt-3 text-[13px] leading-[1.65] text-text-secondary">
                {item.answer}
              </p>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</main>
