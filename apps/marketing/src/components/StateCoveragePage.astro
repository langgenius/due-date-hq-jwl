---
/** StateCoveragePage — the /state-coverage hub. Uses the shared long-tail page
 *  kit; the coverage band + state-card grid are page-specific (scoped).
 *
 *  Design intent: this is the "all 50 states + DC, watched the same way" proof
 *  page — the deeper, in-depth counterpart to the landing's Sources band. It must
 *  read comprehensive and honest: a full jurisdiction roster (uniform, no
 *  priority tiers), the states with published detail pages elevated as links,
 *  and a clear path from public signal → reviewed client impact. */
import type { StateCoverageCopy } from '../i18n/types'
import { CONTENT_REVIEWED_ON } from '../lib/content-metadata'
import FaqList from './FaqList.astro'

interface Props {
  page: StateCoverageCopy
  locale: 'en' | 'zh-CN'
}

const { page, locale } = Astro.props
const zh = locale === 'zh-CN'

// Full jurisdiction names — powers the hover tooltip on each roster tile so a
// two-letter abbreviation is never the only label.
const JURISDICTION_NAMES: Record<string, string> = {
  AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas', CA: 'California',
  CO: 'Colorado', CT: 'Connecticut', DC: 'District of Columbia', DE: 'Delaware',
  FL: 'Florida', GA: 'Georgia', HI: 'Hawaii', ID: 'Idaho', IL: 'Illinois',
  IN: 'Indiana', IA: 'Iowa', KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana',
  ME: 'Maine', MD: 'Maryland', MA: 'Massachusetts', MI: 'Michigan', MN: 'Minnesota',
  MS: 'Mississippi', MO: 'Missouri', MT: 'Montana', NE: 'Nebraska', NV: 'Nevada',
  NH: 'New Hampshire', NJ: 'New Jersey', NM: 'New Mexico', NY: 'New York',
  NC: 'North Carolina', ND: 'North Dakota', OH: 'Ohio', OK: 'Oklahoma', OR: 'Oregon',
  PA: 'Pennsylvania', RI: 'Rhode Island', SC: 'South Carolina', SD: 'South Dakota',
  TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VT: 'Vermont', VA: 'Virginia',
  WA: 'Washington', WV: 'West Virginia', WI: 'Wisconsin', WY: 'Wyoming',
}

const l = zh
  ? {
      viewCoverage: '查看覆盖',
      lastReviewed: '最近复核',
      atAGlance: '覆盖速览',
      glanceStats: [
        { n: '51', label: '个辖区实时监控' },
        { n: '50', label: '个州 + 哥伦比亚特区' },
        { n: '24/7', label: '全天候扫描官方来源' },
      ],
      rosterEyebrow: '完整辖区清单',
      rosterTitle: '全部 50 个州 + DC，一视同仁地实时监控。',
      rosterBody:
        '没有「重点州」和「次要州」之分。每一个州税务机关、IRS，以及覆盖全国的 FEMA 灾害救济，都以同样的方式 24/7 盯紧。下方加粗并可点击的，是已经发布独立覆盖详情页的辖区。',
      rosterLegendLive: '全部实时监控',
      rosterLegendPage: '已发布详情页',
      published: '详情页',
      routeNodes: [
        { k: '公开信号', v: '51 个辖区 · IRS · FEMA，7×24 监控' },
        { k: '带源复核', v: '官方链接 + 原文摘录，逐条比对并匹配到你的客户' },
        { k: '已复核的客户影响', v: '由你确认 · 应用并留审计记录' },
      ],
      ctaTitle: '看看某次州级变化会如何成为你事务所的截止日工作。',
      ctaBody:
        '每条候选变化都带着官方来源链接和摘录进入复核 —— 由你判断它是否影响你的客户，再决定是否应用。',
      ctaPrimary: '免费开始',
      ctaSecondary: '看它如何运作',
      ctaSecondaryHref: '/zh-CN/how-it-works',
      ctaNote: 'beta 期间免费 · 无需信用卡',
    }
  : {
      viewCoverage: 'View coverage',
      lastReviewed: 'Last reviewed',
      atAGlance: 'Coverage at a glance',
      glanceStats: [
        { n: '51', label: 'jurisdictions watched live' },
        { n: '50', label: 'states + the District of Columbia' },
        { n: '24/7', label: 'scanning of official sources' },
      ],
      rosterEyebrow: 'Full jurisdiction roster',
      rosterTitle: 'All 50 states + DC, watched live — the same way.',
      rosterBody:
        'No "priority" states and no afterthoughts. Every state tax authority, the IRS, and FEMA disaster relief nationwide are monitored 24/7 the same way. The jurisdictions shown bold and linkable below already have a dedicated coverage detail page.',
      rosterLegendLive: 'All watched live',
      rosterLegendPage: 'Has a detail page',
      published: 'Detail page',
      routeNodes: [
        { k: 'Public signal', v: '51 jurisdictions · IRS · FEMA, watched 24/7' },
        { k: 'Source-backed review', v: 'Official URL + excerpt, diffed and matched to your clients' },
        { k: 'Reviewed client impact', v: 'You approve · applied with an audit trail' },
      ],
      ctaTitle: 'See how a single state change becomes deadline work for your firm.',
      ctaBody:
        'Every candidate change arrives with its official source URL and excerpt and is routed through review — you decide whether it touches your clients, then apply it.',
      ctaPrimary: 'Start free',
      ctaSecondary: 'See how it works',
      ctaSecondaryHref: '/how-it-works',
      ctaNote: 'Free during the beta · no card required',
    }

// Slugs with a published detail page — derived from the live states list so the
// roster's "linkable" set never drifts from what actually exists.
const publishedHref = new Map(page.states.map((s) => [s.abbreviation, s.href]))

// US jurisdiction roster (alphabetical by abbreviation) — every jurisdiction is
// watched uniformly. `live` is true for all; the link is added when a detail
// page exists. This proves comprehensive coverage without faking depth tiers.
const ROSTER = [
  'AL', 'AK', 'AZ', 'AR', 'CA', 'CO', 'CT', 'DC', 'DE', 'FL',
  'GA', 'HI', 'ID', 'IL', 'IN', 'IA', 'KS', 'KY', 'LA', 'ME',
  'MD', 'MA', 'MI', 'MN', 'MS', 'MO', 'MT', 'NE', 'NV', 'NH',
  'NJ', 'NM', 'NY', 'NC', 'ND', 'OH', 'OK', 'OR', 'PA', 'RI',
  'SC', 'SD', 'TN', 'TX', 'UT', 'VT', 'VA', 'WA', 'WV', 'WI', 'WY',
].map((abbr) => ({ abbr, name: JURISDICTION_NAMES[abbr] ?? abbr, href: publishedHref.get(abbr) ?? null }))

const ctaPrimaryHref = zh ? '/zh-CN' : '/'
---

<main>
  <section class="m-section m-page-hero stcov-hero" id="hero">
    <p class="m-eyebrow">{page.hero.eyebrow}</p>
    <h1 class="m-page-title stcov-hero__title">{page.hero.title}</h1>
    <p class="m-page-lead">{page.hero.description}</p>

    <dl class="stcov-glance" aria-label={l.atAGlance}>
      {
        l.glanceStats.map((s) => (
          <div class="stcov-glance__item">
            <dt class="stcov-glance__n">{s.n}</dt>
            <dd class="stcov-glance__l">{s.label}</dd>
          </div>
        ))
      }
    </dl>

    <p class="m-page-note">{page.hero.note}</p>
    <p class="m-page-reviewed">
      {l.lastReviewed}: <time datetime={CONTENT_REVIEWED_ON}>{CONTENT_REVIEWED_ON}</time>
    </p>
  </section>

  <!-- Coverage band: the honest "all 50 + DC, uniformly live" proof -->
  <section class="m-section m-page-block stcov-roster" aria-labelledby="stcov-roster-h">
    <div class="stcov-roster__head">
      <div>
        <p class="m-eyebrow">{l.rosterEyebrow}</p>
        <h2 class="m-page-h2" id="stcov-roster-h">{l.rosterTitle}</h2>
        <p class="m-page-body stcov-roster__body">{l.rosterBody}</p>
      </div>
      <ul class="stcov-roster__legend">
        <li><span class="stcov-roster__sw stcov-roster__sw--live" aria-hidden="true"></span>{l.rosterLegendLive}</li>
        <li><span class="stcov-roster__sw stcov-roster__sw--page" aria-hidden="true"></span>{l.rosterLegendPage}</li>
      </ul>
    </div>

    <ul class="stcov-roster__grid" aria-label={l.rosterTitle}>
      {
        ROSTER.map((j) =>
          j.href ? (
            <li>
              <a class="stcov-tile stcov-tile--page" href={j.href} title={`${j.name} · ${l.viewCoverage}`}>
                <span class="stcov-tile__abbr">{j.abbr}</span>
                <svg class="stcov-tile__go" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 11 11 5M6 5h5v5" />
                </svg>
              </a>
            </li>
          ) : (
            <li>
              <span class="stcov-tile" title={`${j.name} · ${l.rosterLegendLive}`}>
                <span class="stcov-tile__abbr">{j.abbr}</span>
              </span>
            </li>
          ),
        )
      }
    </ul>
  </section>

  <!-- Published detail pages — the richer cards, now clearly secondary to the roster -->
  <section class="m-section m-page-block">
    <p class="m-eyebrow">{page.statesHeader.eyebrow}</p>
    <h2 class="m-page-h2">{page.statesHeader.title}</h2>
    <div class="stcov__grid">
      {
        page.states.map((state) => (
          <a href={state.href} class="stcov__card">
            <div class="stcov__top">
              <span class="stcov__abbr">{state.abbreviation}</span>
              <span class="stcov__status">{state.status}</span>
            </div>
            <h3 class="stcov__name">{state.name}</h3>
            <p class="stcov__body">{state.body}</p>
            <span class="stcov__view">{l.viewCoverage} <span aria-hidden="true">→</span></span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Source model: the technical route only we run — public signal to reviewed
       client impact. Flat (no boxes): a labelled pipeline + the model beneath. -->
  <section class="m-section m-page-block stcov-model">
    <div class="stcov-model__head">
      <p class="m-eyebrow">{page.sourceModel.eyebrow}</p>
      <h2 class="m-page-h2">{page.sourceModel.title}</h2>
      <p class="m-page-body stcov-model__body">{page.sourceModel.body}</p>
    </div>

    <ol class="stcov-route" aria-label={page.sourceModel.title}>
      {
        l.routeNodes.map((n, i) => (
          <>
            {i > 0 && (
              <li class="stcov-route__arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </li>
            )}
            <li class="stcov-route__node">
              <span class="stcov-route__step">{String(i + 1).padStart(2, '0')}</span>
              <span class="stcov-route__k">{n.k}</span>
              <span class="stcov-route__v">{n.v}</span>
            </li>
          </>
        ))
      }
    </ol>

    <div class="stcov-model__rows">
      {
        page.sourceModel.items.map((item) => (
          <div class="stcov-model__row">
            <h3 class="stcov-model__t">{item.title}</h3>
            <p class="stcov-model__d">{item.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="m-section m-page-block">
    <FaqList eyebrow={page.faqHeader.eyebrow} title={page.faqHeader.title} items={page.faq} />
  </section>

  <section class="m-section m-page-block">
    <div class="m-page-cta">
      <div>
        <h2 class="m-page-cta__title">{l.ctaTitle}</h2>
        <p class="m-page-cta__body">{l.ctaBody}</p>
        <p class="stcov-cta__note">{l.ctaNote}</p>
      </div>
      <div class="m-page-cta__btns">
        <a class="m-btn m-btn--primary" href={ctaPrimaryHref}>{l.ctaPrimary}</a>
        <a class="m-btn m-btn--secondary" href={l.ctaSecondaryHref}>{l.ctaSecondary}</a>
      </div>
    </div>
  </section>
</main>

<style>
  /* ---- hero: bolder, display-serif headline + honest at-a-glance stats ---- */
  .stcov-hero__title {
    font-family: var(--m-font-display);
    font-weight: 400;
    font-size: var(--m-page-title-size);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 20ch;
  }
  .stcov-glance {
    margin-top: clamp(28px, 3vw, 36px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 28px);
    max-width: 760px;
    padding: clamp(18px, 2vw, 24px) 0 0;
    border-top: 1px solid var(--m-hairline);
  }
  .stcov-glance__item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .stcov-glance__n {
    font-family: var(--m-font-mono);
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .stcov-glance__l {
    font-size: var(--m-text-sm);
    line-height: 1.45;
    color: var(--m-muted);
  }

  /* ---- coverage roster band: all 50 + DC, uniformly live ---- */
  .stcov-roster__head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(20px, 3vw, 40px);
    align-items: end;
  }
  .stcov-roster__body {
    max-width: 64ch;
  }
  .stcov-roster__legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--m-text-xs);
    color: var(--m-muted);
    white-space: nowrap;
  }
  .stcov-roster__legend li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .stcov-roster__sw {
    width: 12px;
    height: 12px;
    border-radius: 4px;
    flex: none;
  }
  .stcov-roster__sw--live {
    background: color-mix(in srgb, var(--m-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--m-accent) 18%, transparent);
  }
  .stcov-roster__sw--page {
    background: var(--m-accent);
    box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--m-cyan) 70%, transparent);
  }

  .stcov-roster__grid {
    margin-top: clamp(24px, 3vw, 32px);
    display: grid;
    grid-template-columns: repeat(13, minmax(0, 1fr));
    gap: clamp(7px, 0.9vw, 10px);
    list-style: none;
    padding: 0;
  }
  .stcov-roster__grid li {
    display: flex;
  }
  /* base tile = watched live: a light navy tint. The whole grid reads as one
     calm, airy baseline — every jurisdiction monitored the same way. */
  .stcov-tile {
    position: relative;
    flex: 1;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: color-mix(in srgb, var(--m-accent) 8%, transparent);
    color: var(--m-accent);
    border: 1px solid color-mix(in srgb, var(--m-accent) 14%, transparent);
    text-align: center;
    transition:
      background var(--m-dur-fast) var(--m-ease),
      transform var(--m-dur-fast) var(--m-ease),
      box-shadow var(--m-dur-fast) var(--m-ease),
      border-color var(--m-dur-fast) var(--m-ease);
  }
  .stcov-tile__abbr {
    font-family: var(--m-font-mono);
    font-size: clamp(10px, 0.9vw, 12px);
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
  }
  /* a published detail page = the prominent, clickable tile: solid navy so it
     stands out against the light field, a cyan corner mark, and an arrow that
     surfaces on hover — these are the ones you can open. */
  .stcov-tile--page {
    background: var(--m-accent);
    color: #fff;
    border-color: transparent;
    cursor: pointer;
  }
  .stcov-tile--page::after {
    content: '';
    position: absolute;
    top: 5px;
    right: 5px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--m-cyan);
    transition: opacity var(--m-dur-fast) var(--m-ease);
  }
  .stcov-tile__go {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 11px;
    height: 11px;
    opacity: 0;
    color: var(--m-cyan);
    transition: opacity var(--m-dur-fast) var(--m-ease);
  }
  .stcov-tile--page:hover,
  .stcov-tile--page:focus-visible {
    background: var(--m-accent-strong);
    transform: translateY(-2px);
    box-shadow:
      inset 0 0 0 1.5px var(--m-cyan),
      0 6px 14px -8px color-mix(in srgb, var(--m-accent) 75%, transparent);
  }
  .stcov-tile--page:hover::after,
  .stcov-tile--page:focus-visible::after {
    opacity: 0;
  }
  .stcov-tile--page:hover .stcov-tile__go,
  .stcov-tile--page:focus-visible .stcov-tile__go {
    opacity: 1;
  }
  @media (max-width: 900px) {
    .stcov-roster__head {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .stcov-roster__legend {
      flex-direction: row;
      gap: 18px;
    }
    .stcov-roster__grid {
      grid-template-columns: repeat(9, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .stcov-glance {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .stcov-roster__grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }

  /* ---- published detail-page cards (richer; secondary to the roster) ---- */
  .stcov__grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(12px, 1.4vw, 16px);
  }
  .stcov__card {
    display: flex;
    flex-direction: column;
    padding: 18px;
    background: var(--m-surface);
    border: 1px solid var(--m-hairline);
    border-radius: 12px;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease;
  }
  .stcov__card:hover {
    border-color: var(--m-accent);
    background: var(--m-accent-tint);
    box-shadow: 0 4px 12px -8px rgba(16, 24, 40, 0.4);
  }
  .stcov__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .stcov__abbr {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    font-family: var(--m-font-mono);
    font-size: var(--m-text-base);
    font-weight: 600;
    color: #fff;
    background: var(--m-accent);
  }
  .stcov__status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 8px 2px 7px;
    border-radius: 999px;
    font-size: var(--m-text-3xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--m-ok);
    background: color-mix(in srgb, var(--m-ok) 12%, transparent);
  }
  .stcov__status::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--m-ok);
  }
  .stcov__name {
    margin-top: 16px;
    font-size: var(--m-text-md);
    font-weight: 600;
    color: var(--m-ink);
  }
  .stcov__body {
    margin-top: 8px;
    font-size: var(--m-text-sm);
    line-height: 1.55;
    color: var(--m-muted);
  }
  .stcov__view {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--m-hairline-2);
    font-size: var(--m-text-xs);
    font-weight: 600;
    color: var(--m-accent);
  }
  .stcov__view span {
    display: inline-block;
    transition: transform 0.18s ease;
  }
  .stcov__card:hover .stcov__view span {
    transform: translateX(3px);
  }
  @media (max-width: 1100px) {
    .stcov__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 700px) {
    .stcov__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 460px) {
    .stcov__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- source model: the technical route, flat (no boxes) ---- */
  .stcov-model__head {
    max-width: 760px;
  }
  .stcov-model__body {
    max-width: 64ch;
  }
  /* the route made literal: signal → review → impact, on a navy-tinted rail */
  .stcov-route {
    margin-top: clamp(28px, 3.5vw, 40px);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: clamp(8px, 1.2vw, 16px);
    list-style: none;
    padding: clamp(18px, 2vw, 26px);
    border: 1px solid var(--m-hairline);
    border-radius: 16px;
    background:
      radial-gradient(130% 140% at 0% 0%, var(--m-accent-tint), transparent 58%),
      var(--m-surface);
  }
  .stcov-route__node {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 4px 2px;
  }
  .stcov-route__step {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--m-accent);
  }
  .stcov-route__k {
    font-size: var(--m-text-md);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--m-ink);
  }
  .stcov-route__v {
    font-family: var(--m-font-mono);
    font-size: var(--m-text-xs);
    line-height: 1.5;
    color: var(--m-muted);
  }
  .stcov-route__arrow {
    display: grid;
    place-items: center;
    color: var(--m-accent);
    opacity: 0.55;
  }
  .stcov-route__arrow svg {
    width: 20px;
    height: 20px;
  }
  /* the model itself — flat rows divided by hairlines, not cards */
  .stcov-model__rows {
    margin-top: clamp(28px, 3.5vw, 40px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--m-hairline);
  }
  .stcov-model__row {
