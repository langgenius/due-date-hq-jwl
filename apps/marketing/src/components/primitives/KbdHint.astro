---
interface Props {
  keys: string
  label: string
  variant?: 'default' | 'inline'
}

const { keys, label, variant = 'default' } = Astro.props

const wrapperClass =
  variant === 'inline'
    ? 'inline-flex items-center gap-1 text-xs text-text-muted'
    : 'inline-flex items-center gap-2 text-xs text-text-secondary'
const kbdClass =
  'inline-flex h-5 min-w-5 items-center justify-center rounded border border-border-default bg-bg-elevated px-1.5 font-mono text-xs text-text-primary'
---

<span class={wrapperClass}>
  <span class={kbdClass}>{keys}</span>
  <span class="font-medium">{label}</span>
</span>
