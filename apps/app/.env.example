# apps/app — Vite build-time env (VITE_* is inlined into the client bundle).
# Copy to .env.local for local dev, or set in the deploy/build environment.

# Amplitude product analytics. Unset → analytics is a silent no-op (SDK never
# loads). Use the Browser SDK API key for project 827681 (DueDateHQ, US zone).
VITE_AMPLITUDE_API_KEY=

# Optional: stamps every event with `app_version`. Wire to your build's version.
# VITE_APP_VERSION=
